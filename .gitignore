# Admin reference (local only)
ADMIN_ENDPOINTS.md

# Sensitive files (admin tokens, config payloads)
marquee.json
banner.json
update-marquee.ps1

# Backup files (contain user data)
backup_*.json
*leaderboard*.json
lb_*.json

# Temp scripts and data dumps (often contain tokens/PII)
tmp_*
temp*
find_*.js
merge_*.js
fix_*.js
scan_*.js
bulk_*.js
cleanup_*.js
investigate_*.js
check_*.js
reset_*.js
set_force_*.js

# Mod packages (built artifacts, too large for git)
*.ccpmod

# DroneMod contents distributed separately (avatars, sounds, scripts, etc.)
ConditioningControlPanel/DroneMod/*

# ...except the canonical drone-mode.ccpmod package, which is shipped as a
# bundled built-in mod (see ConditioningControlPanel.csproj + ModService.ExtractBundledBuiltInMods).
!ConditioningControlPanel/DroneMod/drone-mode.ccpmod

# ...and the Locked mode resources bundle, likewise shipped as a bundled
# built-in mod (see ConditioningControlPanel.csproj + ModService.ExtractBundledResourceMods).
!ConditioningControlPanel/LockedMod/locked-resources.ccpmod

# MSBuild temp files
*_wpftmp.csproj

# Environment and secrets
*.env
*.env.*
nul

# Avatar-emote production tooling (private generation pipeline — Kling prompts,
# seeds, scratch GIFs). The produced Resources\*_emotes\ assets ARE committed; the
# scripts that make them are not. See tools/avatar-emotes/README.md (local only).
tools/

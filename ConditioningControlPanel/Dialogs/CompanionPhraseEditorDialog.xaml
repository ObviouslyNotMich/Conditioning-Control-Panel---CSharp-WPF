<Window x:Class="ConditioningControlPanel.CompanionPhraseEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        Title="{loc:Str dialog_manage_companion_phrases}"
        Width="820" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <SolidColorBrush x:Key="PinkBrush" Color="{DynamicResource PinkColor}"/>
        <SolidColorBrush x:Key="DarkBg" Color="{DynamicResource DarkerBg}"/>
        <SolidColorBrush x:Key="CardBg" Color="{DynamicResource SurfaceBg}"/>
        <SolidColorBrush x:Key="InputBg" Color="{DynamicResource PanelBg}"/>
        <SolidColorBrush x:Key="BorderColor" Color="#353550"/>
        <SolidColorBrush x:Key="MutedText" Color="#808080"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PinkBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF85C8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#353550"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#454570"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#505070"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{DynamicResource PanelBgBrush}" BorderBrush="#505070"
                                                BorderThickness="1" CornerRadius="4" Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="#E0E0E0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,5,25,5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                                        BorderThickness="1" CornerRadius="4" Margin="0,2,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
                        <Setter Property="Padding" Value="8,5"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentTintedBgBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PinkBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Grouped, virtualized phrase list -->
        <CollectionViewSource x:Key="PhrasesView">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupLabel"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <Style x:Key="PhraseItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PhraseRowTemplate">
            <Border x:Name="RowBorder" Background="#1E1E3A" BorderBrush="#2A2A45" BorderThickness="0,0,0,1"
                    Padding="10,6" Margin="0,0,0,1" Cursor="Hand" MouseLeftButtonDown="RowBorder_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <TextBlock Grid.Column="1" x:Name="BuiltInText" Text="{Binding Text}" FontSize="12"
                               Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Text}"/>
                    <TextBox Grid.Column="1" x:Name="CustomText" Visibility="Collapsed"
                             Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             Background="#252542" Foreground="White" BorderBrush="#404060" BorderThickness="1"
                             Padding="4,2" FontSize="12" VerticalAlignment="Center" LostFocus="TxtCustomPhrase_LostFocus"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <StackPanel x:Name="HasAudioPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock Text="&#x266B; " Foreground="#50C878" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AudioDisplayName}" Foreground="#50C878" FontSize="10"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="90"
                                       ToolTip="{Binding AudioFileName}"/>
                            <Button x:Name="ClearAudioBtn" Content="&#x2716;" Click="BtnClearAudio_Click"
                                    Background="Transparent" Foreground="#FF6B6B" BorderThickness="0" FontSize="10"
                                    Padding="4,0,0,0" Cursor="Hand" VerticalAlignment="Center" ToolTip="Remove audio"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                        <StackPanel x:Name="NoAudioPanel" Orientation="Horizontal">
                            <TextBlock Text="No Audio" Foreground="#606060" FontSize="10" VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <Button x:Name="BrowseBtn" Content="Browse" Click="BtnBrowseAudio_Click" Background="#353550"
                                    Foreground="White" BorderThickness="0" FontSize="10" Padding="6,2" Cursor="Hand"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox Grid.Column="3" x:Name="EnableChk" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              Content="On" Foreground="#50C878" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>

                    <Button Grid.Column="4" Content="&#x2716;" Click="BtnRemovePhrase_Click" Background="Transparent"
                            Foreground="#FF69B4" BorderThickness="0" FontSize="13" Padding="6,0,2,0" Cursor="Hand"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsBuiltIn}" Value="False">
                        <Setter TargetName="BuiltInText" Property="Visibility" Value="Collapsed"/>
                        <Setter TargetName="CustomText" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasAudio}" Value="True">
                        <Setter TargetName="HasAudioPanel" Property="Visibility" Value="Visible"/>
                        <Setter TargetName="NoAudioPanel" Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding CanClearAudio}" Value="True">
                        <Setter TargetName="ClearAudioBtn" Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding CanBrowseAudio}" Value="False">
                        <Setter TargetName="BrowseBtn" Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                        <Setter TargetName="EnableChk" Property="Content" Value="Off"/>
                        <Setter TargetName="EnableChk" Property="Foreground" Value="#808080"/>
                        <Setter TargetName="BuiltInText" Property="Foreground" Value="#606060"/>
                        <Setter TargetName="CustomText" Property="Foreground" Value="#606060"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter TargetName="RowBorder" Property="Background" Value="#2A1E3A"/>
                        <Setter TargetName="RowBorder" Property="BorderBrush" Value="#FF69B4"/>
                        <Setter TargetName="RowBorder" Property="BorderThickness" Value="1,0,0,1"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{loc:Str label_phrase_manager}" Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="{loc:Str label_manage_companion_speech_bubble_phrases_and_co}"
                       Foreground="#808080" FontSize="11" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnSelectAll" Content="{loc:Str btn_select_all}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,6,0" Click="BtnSelectAll_Click"/>
                <Button x:Name="BtnDeselectAll" Content="{loc:Str btn_deselect_all}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,6,0" Click="BtnDeselectAll_Click"/>
                <Button x:Name="BtnEnableSelected" Content="{loc:Str btn_enable_selected}" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,6,0" Click="BtnEnableSelected_Click"/>
                <Button x:Name="BtnDisableSelected" Content="{loc:Str btn_disable_selected}" Style="{StaticResource SecondaryButton}"
                        Click="BtnDisableSelected_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="{DynamicResource PanelBgBrush}" BorderBrush="#505070" BorderThickness="1"
                        CornerRadius="4" Margin="0,0,10,0" Width="190" VerticalAlignment="Center">
                    <Grid>
                        <TextBox x:Name="TxtSearch" Background="Transparent" Foreground="White" BorderThickness="0"
                                 Padding="8,4" FontSize="11" VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_Changed"/>
                        <TextBlock x:Name="TxtSearchPlaceholder" Text="{loc:Str label_search_phrases}"
                                   Foreground="#707070" FontSize="11" IsHitTestVisible="False"
                                   Margin="9,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <TextBlock Text="{loc:Str label_filter}" Foreground="#808080" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CmbCategoryFilter" Width="160" Style="{StaticResource DarkComboBox}"
                          FontSize="11" SelectionChanged="CmbCategoryFilter_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Phrase List (grouped + UI-virtualized: scales to the ~1,500 phrase + bark rows) -->
        <ListBox Grid.Row="2" x:Name="PhraseList"
                 ItemsSource="{Binding Source={StaticResource PhrasesView}}"
                 ItemContainerStyle="{StaticResource PhraseItemStyle}"
                 ItemTemplate="{StaticResource PhraseRowTemplate}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.IsVirtualizingWhenGrouping="True">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#20203C" CornerRadius="6,6,0,0" Padding="10,8" Margin="0,8,0,0">
                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#FF69B4">
                                    <Run Text="{Binding Name, Mode=OneWay}"/><Run Text=" ("/><Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
        </ListBox>

        <!-- Footer Buttons -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnAddPhrase" Content="{loc:Str btn_add_phrase}" Style="{StaticResource ActionButton}"
                        Margin="0,0,8,0" Click="BtnAddPhrase_Click"/>
                <Button x:Name="BtnRemoveSelected" Content="{loc:Str btn_remove_selected}" Style="{StaticResource SecondaryButton}"
                        Foreground="#FF6B6B" Click="BtnRemoveSelected_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtTotalCount" Foreground="#808080" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="{loc:Str btn_close}" Style="{StaticResource SecondaryButton}" Padding="16,6"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

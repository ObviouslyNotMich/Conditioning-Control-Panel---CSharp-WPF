<Window x:Class="ConditioningControlPanel.Lab.GazeMinigame.SubliminalFlashOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subliminal Flash"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        IsHitTestVisible="False">
    <Grid>
        <TextBlock x:Name="TxtSubliminal" Text=""
                   FontSize="240" FontWeight="Bold" Opacity="0"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Effect>
                <DropShadowEffect x:Name="SubliminalShadow" Color="White"
                                  BlurRadius="60" ShadowDepth="0" Opacity="0.9"/>
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>

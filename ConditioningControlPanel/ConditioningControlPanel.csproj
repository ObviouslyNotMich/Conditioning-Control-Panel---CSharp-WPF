<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <WindowsSdkPackageVersion>10.0.26100.84</WindowsSdkPackageVersion>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>ConditioningControlPanel</AssemblyName>
    <RootNamespace>ConditioningControlPanel</RootNamespace>
    <Version>6.1.7</Version>
    <Company>CodeBambi</Company>
    <Product>Conditioning Control Panel</Product>
    <Description>A professional visual conditioning application with gamification features.</Description>
    <Copyright>Copyright © 2024-2026 CodeBambi</Copyright>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    
    <!-- Disable most auto-generated assembly info (we have AssemblyInfo.cs) but enable version -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateAssemblyVersionAttribute>true</GenerateAssemblyVersionAttribute>
    <GenerateAssemblyFileVersionAttribute>true</GenerateAssemblyFileVersionAttribute>
    <GenerateAssemblyInformationalVersionAttribute>true</GenerateAssemblyInformationalVersionAttribute>

    <!-- Custom Main entry point (originally added for Velopack; kept for control over startup) -->
    <StartupObject>ConditioningControlPanel.App</StartupObject>

    <!-- Disable WPF auto-generated entry point so we can use our custom Main -->
    <EnableDefaultApplicationDefinition>false</EnableDefaultApplicationDefinition>
    
    <!-- Trimming disabled - not supported with WPF -->
    <PublishTrimmed>false</PublishTrimmed>
    
    <!-- Ready to Run -->
    <PublishReadyToRun>true</PublishReadyToRun>
    
    <!-- Deterministic builds -->
    <Deterministic>true</Deterministic>

    <!-- Suppress CA1416 platform compatibility warnings — this is a Windows-only WPF app -->
    <NoWarn>$(NoWarn);CA1416</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- UI Framework -->
    <PackageReference Include="Buttplug" Version="3.0.1" />
    <PackageReference Include="Buttplug.Client.Connectors.WebsocketConnector" Version="3.0.1" />
    <PackageReference Include="DiscordRichPresence" Version="1.6.1.70" />
    <PackageReference Include="LibVLCSharp.WPF" Version="3.8.5" />
    <!-- Pin WindowsAppSDK (transitive from LibVLCSharp) and exclude its win10-* runtime assets
         which cause NETSDK1083 on .NET 8.0.400+ SDK with Windows 10 TFM -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.1.1" ExcludeAssets="all" PrivateAssets="all" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
    <PackageReference Include="MahApps.Metro.IconPacks" Version="5.0.0" />
    <!-- GPU-friendly 2D renderer for the new Chaos FX particle/glow layer (ChaosSkiaFxOverlay).
         CPU SKElement path is used for now (reliable on AllowsTransparency layered windows);
         native libSkiaSharp extracts via IncludeNativeLibrariesForSelfExtract for single-file. -->
    <PackageReference Include="SkiaSharp.Views.WPF" Version="2.88.8" />
    
    <!-- MVVM Framework -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    
    <!-- Audio Control -->
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="NAudio.Wasapi" Version="2.2.1" />
    <PackageReference Include="OllamaSharp" Version="5.4.16" />
    
    <!-- Logging -->
    <PackageReference Include="Serilog" Version="3.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="5.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="5.0.0" />
    
    <!-- JSON Settings -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    
    <!-- Security / Encryption -->
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
    
    <!-- System Tray -->
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="1.1.0" />
    
    <!-- Embedded Browser -->
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2535.41" />

    <!-- AI Service -->
    <PackageReference Include="OpenAI-DotNet" Version="8.6.2" />
    
    <!-- SharpDX for Desktop Duplication API (DXGI) -->
    <PackageReference Include="SharpDX" Version="4.2.0" />
    <PackageReference Include="SharpDX.DXGI" Version="4.2.0" />
    <PackageReference Include="SharpDX.Direct3D11" Version="4.2.0" />
    <PackageReference Include="VideoLAN.LibVLC.Windows" Version="3.0.21">
      <IncludeAssets>all</IncludeAssets>
    </PackageReference>

    <!-- GIF Animation Support (also used for Circe avatar emotes — AvatarTubeWindow.CirceEmotes.cs) -->
    <PackageReference Include="XamlAnimatedGif" Version="2.3.0" />

    <!-- QR Code Generation (used by Remote Control tab for mobile pairing) -->
    <PackageReference Include="QRCoder" Version="1.6.0" />

    <!-- Webcam Tracking (Lab) — local-only face/eye detection.
         OpenCvSharp: video capture + image manipulation.
         OnnxRuntime: BlazeFace + FaceMesh + Iris ONNX models, CPU-only x64.
         Privacy contract: frames stay on device, never transmitted, never written to disk.
         See Services/WebcamTrackingService.cs. -->
    <PackageReference Include="OpenCvSharp4" Version="4.9.0.20240103" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.9.0.20240103" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.20.1" />

    <!-- SVG rendering for color emoji (Twemoji) — WPF can't render Segoe UI Emoji
         in color, so we ship the Twemoji SVG set and render via SharpVectors.
         See Helpers/EmojiImage.cs. -->
    <PackageReference Include="SharpVectors" Version="1.8.4.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Localization language files - must be on disk for File.ReadAllText() -->
    <Content Include="Localization\Languages\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <!-- Session files -->
    <Content Include="assets\sessions\*.session.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- AI knowledge base placeholder (read by Services/AIService/Enrichment/KnowledgeService) -->
    <Content Include="assets\knowledge.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Chaos art (bubble sprites etc.), resolved at runtime by Services/Chaos/ChaosArt.cs
         from AppContext.BaseDirectory\Assets\Chaos\{kind}\{id}.png. Staging candidates are
         excluded so only the promoted finals ship. Remove from the default None glob first
         so the no-copy None item doesn't suppress this Content copy. -->
    <None Remove="assets\Chaos\**\*.png;assets\Chaos\**\*.gif;assets\Chaos\**\*.json" />
    <Content Include="assets\Chaos\**\*.png;assets\Chaos\**\*.gif;assets\Chaos\**\*.json" Exclude="assets\Chaos\**\_staging*\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Story (the "half musical" opening): opening.json + bundled scene/character art + songs and
         their baked loudness envelopes. Resolved at runtime by Services/Story/StoryAssets.cs from
         AppContext.BaseDirectory\assets\story\. Remove from the default None glob first so the no-copy
         None item doesn't suppress this Content copy (same gotcha as the Chaos art above). -->
    <None Remove="assets\story\**\*.json;assets\story\**\*.png;assets\story\**\*.mp3;assets\story\**\*.wav;assets\story\**\*.ogg" />
    <Content Include="assets\story\**\*.json;assets\story\**\*.png;assets\story\**\*.mp3;assets\story\**\*.wav;assets\story\**\*.ogg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

  <!-- WebView2Loader.dll must be on disk - the WebView2 SDK loads it outside .NET's single-file extraction -->
  <Target Name="IncludeWebView2LoaderInPublish" AfterTargets="ComputeFilesToPublish">
    <ItemGroup>
      <ResolvedFileToPublish Include="$(NuGetPackageRoot)microsoft.web.webview2\1.0.2535.41\runtimes\win-x64\native\WebView2Loader.dll">
        <RelativePath>WebView2Loader.dll</RelativePath>
        <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
      </ResolvedFileToPublish>
    </ItemGroup>
  </Target>


  <ItemGroup>
    <!-- Rounded display font (Fredoka, OFL) for the Chaos multiplier hero number. Embedded as a
         Resource so the pack:// font URI (/Fonts/#Fredoka) resolves in the single-file build. -->
    <Resource Include="Fonts\Fredoka.ttf" />
  </ItemGroup>

  <ItemGroup>
    <!-- App icon -->
    <Resource Include="Resources\app.ico" />
    <Resource Include="Resources\february.png" />
    <Resource Include="Resources\february_drone.png" />
    <Resource Include="Resources\logo.png" />
    <Resource Include="Resources\logo2.png" />
    <Resource Include="Resources\bubble.png" />
    <Resource Include="Resources\speechbubble1.png" />
    <Resource Include="Resources\speechbubble2.png" />
    <Resource Include="Resources\discord.png" />
    <Resource Include="Resources\lockdown_icon.png" />
    <Resource Include="Resources\spiral.gif" />
    <Resource Include="Resources\Patreon tier1.png" />
    <Resource Include="Resources\Patreon tier2.png" />
    <Resource Include="Resources\Patreon tier3.png" />
    <Resource Include="Resources\Pink filter.webp" />
    <Resource Include="Resources\prime subject.webp" />

    <!-- Content Pack preview images -->
    <Resource Include="Resources\pack1.png" />
    <Resource Include="Resources\pack2.png" />
    
    <!-- Avatar Tube images - MUST be Resource for pack:// URIs to work -->
    <Resource Include="Resources\tube.png" />
    <Resource Include="Resources\tube2.png" />
    
    <!-- Avatar Set 1: Default (Level 1-19) -->
    <Resource Include="Resources\avatar_pose1.png" />
    <Resource Include="Resources\avatar_pose2.png" />
    <Resource Include="Resources\avatar_pose3.png" />
    <Resource Include="Resources\avatar_pose4.png" />
    
    <!-- Avatar Set 2: Level 20+ (Neon/Circuit style) -->
    <Resource Include="Resources\avatar2_pose1.png" />
    <Resource Include="Resources\avatar2_pose2.png" />
    <Resource Include="Resources\avatar2_pose3.png" />
    <Resource Include="Resources\avatar2_pose4.png" />
    
    <!-- Avatar Set 3: Level 50+ (Marionette/Puppet style) -->
    <Resource Include="Resources\avatar3_pose1.png" />
    <Resource Include="Resources\avatar3_pose2.png" />
    <Resource Include="Resources\avatar3_pose3.png" />
    <Resource Include="Resources\avatar3_pose4.png" />
    
    <!-- Avatar Set 4: Level 50-124 (Sunglasses/Glamour style) -->
    <Resource Include="Resources\avatar4_pose1.png" />
    <Resource Include="Resources\avatar4_pose2.png" />
    <Resource Include="Resources\avatar4_pose3.png" />
    <Resource Include="Resources\avatar4_pose4.png" />

    <!-- Avatar Set 5: Level 125-149 (Brainwashed Slavedoll) -->
    <Resource Include="Resources\avatar5_pose1.png" />
    <Resource Include="Resources\avatar5_pose2.png" />
    <Resource Include="Resources\avatar5_pose3.png" />
    <Resource Include="Resources\avatar5_pose4.png" />

    <!-- Avatar Set 6: Level 150+ (Platinum Puppet) -->
    <Resource Include="Resources\avatar6_pose1.png" />
    <Resource Include="Resources\avatar6_pose2.png" />
    <Resource Include="Resources\avatar6_pose3.png" />
    <Resource Include="Resources\avatar6_pose4.png" />

    <!-- Avatar Set 7: Level 75+ (Bambi Cow) -->
    <Resource Include="Resources\avatar7_pose1.png" />
    <Resource Include="Resources\avatar7_pose2.png" />
    <Resource Include="Resources\avatar7_pose3.png" />
    <Resource Include="Resources\avatar7_pose4.png" />

    <!-- Animated Avatars - uncomment when GIF files are added to Resources
    <Resource Include="Resources\animated1_1.gif" />
    <Resource Include="Resources\animated2_1.gif" />
    <Resource Include="Resources\animated3_1.gif" />
    <Resource Include="Resources\animated4_1.gif" />
    -->

    <!-- Animated companion emotes (transparent looping GIF, 15fps) + per-set mapping.
         Rendered via XamlAnimatedGif, wired in AvatarTubeWindow.CirceEmotes.cs (registry-driven).
         To add a pose/mod: drop Resources\<folder>\ (clips + emotes.json), add a line to the
         registry below, and add a <Resource> include here. See tools/avatar-emotes/README.md.
         Embedded as Resource so pack:// URIs resolve in the single-file build (~30 MB / pose). -->
    <Resource Include="Resources\avatar_emotes_registry.json" />
    <Resource Include="Resources\circe_emotes\*.gif" />
    <Resource Include="Resources\circe_emotes\emotes.json" />
    <!-- Circe level emote sets: avatar set 2 = L2 (The Claim/key), 3 = L3 (The Pull/spiral), 4 = L4 (The Bind/chain). -->
    <Resource Include="Resources\circe_emotes_p2\*.gif" />
    <Resource Include="Resources\circe_emotes_p2\emotes.json" Condition="Exists('Resources\circe_emotes_p2\emotes.json')" />
    <Resource Include="Resources\circe_emotes_p3\*.gif" />
    <Resource Include="Resources\circe_emotes_p3\emotes.json" Condition="Exists('Resources\circe_emotes_p3\emotes.json')" />
    <Resource Include="Resources\circe_emotes_p4\*.gif" />
    <Resource Include="Resources\circe_emotes_p4\emotes.json" Condition="Exists('Resources\circe_emotes_p4\emotes.json')" />
    <!-- Avatar-0 (blonde) emote set: shared by BambiSleep + Sissy at avatar set 1. -->
    <Resource Include="Resources\avatar0_emotes\*.gif" />
    <Resource Include="Resources\avatar0_emotes\emotes.json" Condition="Exists('Resources\avatar0_emotes\emotes.json')" />
    <Resource Include="Resources\avatar0_emotes\clip_timing.json" Condition="Exists('Resources\avatar0_emotes\clip_timing.json')" />

    <!-- Achievement images -->
    <Resource Include="Resources\achievements\*.png" />

    <!-- Skill tree images (individual skill files) -->
    <Resource Include="Resources\skills\*.png" />

    <!-- Twemoji SVG set for color-emoji rendering across the UI.
         ~4000 files, ~19 MB on disk, MIT/CC-BY 4.0. Source: github.com/jdecked/twemoji.
         Resolved at runtime via Helpers/EmojiImage.cs (codepoint -> pack:// URI). -->
    <Resource Include="Resources\Twemoji\*.svg" />
  </ItemGroup>

  <ItemGroup>
    <!-- Feature images - embedded as Resource for pack:// URIs to work -->
    <Resource Include="Resources\features\*.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Blink Trainer stage demo assets — SFW abstract gradients shown on the
         dedicated Blink Trainer page when no live preview is running, and to
         non-premium users behind the gate. Regenerate via
         assets\BlinkTrainer\Demo\generate_demos.ps1. -->
    <Resource Include="assets\BlinkTrainer\Demo\*.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Haptics setup guide images -->
    <Resource Include="Resources\haptics_guide\*.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Session completion card images -->
    <Resource Include="Resources\Cards\*.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bespoke per-quest art (one PNG per quest id), bundled in-app so quests
         render without any CDN dependency. Loaded via pack:// by quest id. -->
    <Resource Include="Resources\quests\*.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Sound files - must be copied to output and publish for file system access -->
    <Content Include="Resources\sounds\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Subliminal audio files -->
    <Content Include="Resources\sub_audio\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Awareness Engine preset packs -->
    <Content Include="Resources\AwarenessPresets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Deeper demo enhancements (seeded into user's library on first launch) -->
    <Content Include="Resources\DeeperDemos\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Webcam tracking ONNX models (offline-only, no network calls).
         README.md documents required files; .onnx binaries dropped in by build process. -->
    <Content Include="Resources\Models\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Custom spirals folder -->
    <Content Include="Spirals\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Bundled tutorial video clips (short, low-res, muted loops) played by
         HelpVideoWindow. File-based access via LibVLC requires disk copy. -->
    <Content Include="Resources\tutorial_videos\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <!-- Bundled built-in mod packages. ModService extracts these on first launch
         into %APPDATA%/ConditioningControlPanel/builtin_mods/<id>/ and registers
         them as non-deletable built-in mods (IsBuiltIn=true) so their full asset
         set resolves via InstalledPath instead of the neutral baseline. -->
    <Content Include="DroneMod\drone-mode.ccpmod">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
    <!-- Locked ships a resources-only bundle (no mod.json); its manifest stays in
         code (BuiltInMods.CreateLocked). ModService.ExtractBundledResourceMods()
         extracts it and adopts the folder as InstalledPath for assets only. -->
    <Content Include="LockedMod\locked-resources.ccpmod">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <ExcludeFromSingleFile>true</ExcludeFromSingleFile>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Themes\" />
  </ItemGroup>

  <!-- Ensure all content files are copied during publish -->
  <Target Name="CopyContentAfterPublish" AfterTargets="Publish">
    <ItemGroup>
      <SoundFiles Include="$(ProjectDir)Resources\sounds\**\*" />
      <SubAudioFiles Include="$(ProjectDir)Resources\sub_audio\**\*" />
      <AwarenessPresetFiles Include="$(ProjectDir)Resources\AwarenessPresets\**\*" />
      <DeeperDemoFiles Include="$(ProjectDir)Resources\DeeperDemos\**\*" />
      <SpiralFiles Include="$(ProjectDir)Spirals\**\*" />
      <TutorialVideoFiles Include="$(ProjectDir)Resources\tutorial_videos\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(SoundFiles)" DestinationFolder="$(PublishDir)Resources\sounds\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(SubAudioFiles)" DestinationFolder="$(PublishDir)Resources\sub_audio\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(AwarenessPresetFiles)" DestinationFolder="$(PublishDir)Resources\AwarenessPresets\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(DeeperDemoFiles)" DestinationFolder="$(PublishDir)Resources\DeeperDemos\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(SpiralFiles)" DestinationFolder="$(PublishDir)Spirals\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(TutorialVideoFiles)" DestinationFolder="$(PublishDir)Resources\tutorial_videos\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Message Importance="High" Text="Copied content files to publish folder" />
  </Target>

  <!-- Copy LibVLC native libraries after publish (required for video playback on Windows N/KN) -->
  <Target Name="CopyLibVLCAfterPublish" AfterTargets="Publish">
    <PropertyGroup>
      <LibVLCPath>$(NuGetPackageRoot)videolan.libvlc.windows\3.0.21\build\x64\</LibVLCPath>
    </PropertyGroup>
    <ItemGroup>
      <LibVLCFiles Include="$(LibVLCPath)**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(LibVLCFiles)" DestinationFolder="$(PublishDir)libvlc\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Message Importance="High" Text="Copied LibVLC files from $(LibVLCPath) to $(PublishDir)libvlc\" />
  </Target>

</Project>

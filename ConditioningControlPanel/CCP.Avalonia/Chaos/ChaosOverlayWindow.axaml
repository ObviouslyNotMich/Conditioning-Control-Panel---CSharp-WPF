<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fx="using:Avalonia.Media.Effects"
        xmlns:chaos="clr-namespace:ConditioningControlPanel.Avalonia.Chaos;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Chaos.ChaosOverlayWindow"
        x:DataType="chaos:ChaosOverlayWindow"
        x:CompileBindings="False"
        Title="Down the Rabbit Hole"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI">

    <Grid>
        <Rectangle x:Name="Backdrop" Fill="Black" Opacity="0.72" IsVisible="False"/>

        <Viewbox x:Name="CountdownBox" IsVisible="False" Width="360" Height="360"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="CountdownText" Text="3" Foreground="{DynamicResource TextLightBrush}" FontWeight="Bold" FontSize="200"
                       RenderTransformOrigin="0.5,0.5"/>
        </Viewbox>

        <Border x:Name="DraftPanel" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource PanelBgTransparentBrush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
                CornerRadius="16" Padding="28">
            <StackPanel>
                <TextBlock x:Name="DraftTitle" Text="LOOP CLEARED · CHOOSE A MANTRA"
                           Foreground="{DynamicResource PinkBrush}" FontWeight="Bold" FontSize="18"
                           HorizontalAlignment="Center" Margin="0,0,0,18"/>
                <StackPanel x:Name="BoonCardHost" Orientation="Horizontal" HorizontalAlignment="Center"/>
                <Grid Margin="0,18,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnSkipBoon" Content="SKIP · +1 RESISTANCE" Click="BtnSkipBoon_Click"
                                Padding="12,6" Background="{DynamicResource TransparentWhiteBrush}" Foreground="{DynamicResource TextLightBrush}" BorderThickness="0"
                                ToolTip.Tip="resist the table: take no card, gain one resistance for this descent"/>
                        <Button x:Name="BtnReroll" Content="🎲 tempt fate again" Click="BtnReroll_Click" IsVisible="False"
                                Margin="10,0,0,0" Padding="12,6" Background="{DynamicResource SecondaryBrush}" Foreground="{DynamicResource TextLightBrush}" BorderThickness="0"/>
                    </StackPanel>
                    <TextBlock x:Name="DraftCountdown" Foreground="{DynamicResource TextDimBrush}" FontSize="13"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="ResultsPanel" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource PanelBgTransparentBrush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="3"
                CornerRadius="16" Width="560">
            <StackPanel>
                <Grid Height="190">
                    <Grid.Clip>
                        <RectangleGeometry Rect="0,0,554,300" RadiusX="13" RadiusY="13"/>
                    </Grid.Clip>
                    <Border Background="{DynamicResource AccentGradientBrush}"/>
                    <Image x:Name="ResultsHero" Stretch="UniformToFill"/>
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.30"/>
                                <GradientStop Color="#E0120F22" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel VerticalAlignment="Bottom" Margin="26,0,26,13">
                        <TextBlock Text="YOU SURFACE" Foreground="{DynamicResource TextLightBrush}" FontWeight="Bold" FontSize="30"/>
                        <TextBlock Text="it lets you go. for now." Foreground="{DynamicResource TextLightBrush}"
                                   FontSize="12" FontStyle="Italic" Margin="2,1,0,0"/>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="28,18,28,26">
                    <StackPanel x:Name="ResultsBody"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button x:Name="BtnRunAgain" Content="▸ FALL DEEPER" Click="BtnRunAgain_Click"
                                Padding="18,10" Margin="0,0,12,0" Background="{DynamicResource PinkBrush}" Foreground="{DynamicResource TextLightBrush}" FontWeight="Bold" BorderThickness="0"/>
                        <Button x:Name="BtnClose" Content="wake up" Click="BtnClose_Click"
                                Padding="18,10" Background="{DynamicResource TransparentWhiteBrush}" Foreground="{DynamicResource TextLightBrush}" BorderThickness="0"/>
                        <Button x:Name="BtnDollhouse" Content="the dollhouse" Click="BtnDollhouse_Click" IsVisible="False"
                                Padding="18,10" Margin="12,0,0,0" Background="{DynamicResource SecondaryBrush}" Foreground="{DynamicResource TextLightBrush}" BorderThickness="0"/>
                        <Button x:Name="BtnAdjust" Content="adjust the fall" Click="BtnAdjust_Click" IsVisible="False"
                                Padding="18,10" Margin="12,0,0,0" Background="{DynamicResource TransparentWhiteBrush}" Foreground="{DynamicResource TextLightBrush}" BorderThickness="0"
                                ToolTip.Tip="open run setup — difficulty, length, the whole outfit"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid x:Name="StoryCardPanel" IsVisible="False" Background="#01000000">
            <Image x:Name="StoryBg" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5"/>
            <Border Background="#59000000"/>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0.45"/>
                        <GradientStop Color="#F2080612" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Image x:Name="StoryPortrait" Stretch="Uniform" VerticalAlignment="Bottom"
                   HorizontalAlignment="Left"/>

            <Border x:Name="StoryBox" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Margin="0,0,0,72" MaxWidth="980" Background="{DynamicResource PanelBgTransparentBrush}" BorderBrush="{DynamicResource PinkBrush}"
                    BorderThickness="2" CornerRadius="16" Padding="38,28,38,30" RenderTransformOrigin="0.5,1">
                <StackPanel>
                    <TextBlock x:Name="StoryName" Text="The Madam" Foreground="{DynamicResource PinkBrush}"
                               FontWeight="Bold" FontSize="30" Margin="0,0,0,1"/>
                    <TextBlock x:Name="StoryTitle" Text="" Foreground="{DynamicResource TextDimBrush}"
                               FontSize="16" FontStyle="Italic" Margin="0,0,0,10"/>
                    <TextBlock x:Name="StoryText" Text="" Foreground="{DynamicResource TextLightBrush}" FontSize="24"
                               TextWrapping="Wrap" LineHeight="34"/>
                    <TextBlock x:Name="StoryAdvance" Text="▸" Foreground="{DynamicResource PinkBrush}" FontSize="26"
                               FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0"
                               RenderTransformOrigin="0.5,0.5"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

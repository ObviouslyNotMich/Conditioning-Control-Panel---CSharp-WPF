<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chaos="clr-namespace:ConditioningControlPanel.Avalonia.Chaos"
        x:Class="ConditioningControlPanel.Avalonia.Chaos.ChaosHudWindow"
        x:DataType="chaos:AvaloniaChaosHudViewModel"
        Title="Rabbit Hole HUD"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        Width="300">
    <Window.Resources>
        <SolidColorBrush x:Key="Pink" Color="#FF69B4"/>
        <SolidColorBrush x:Key="StripBg" Color="#E6121026"/>
        <SolidColorBrush x:Key="PanelBg" Color="#F2151226"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#55FF69B4"/>
        <SolidColorBrush x:Key="TextDim" Color="#AAB8B8D0"/>
        <DataTemplate x:Key="BoonTipContent" DataType="chaos:ChaosSidebarBoon">
            <StackPanel MaxWidth="240">
                <TextBlock Text="{Binding TipTitle}" FontWeight="Bold" FontSize="13" Foreground="{Binding AccentBrush}"/>
                <TextBlock Text="{Binding Desc}" Foreground="#DDE0E0F0" FontSize="12" TextWrapping="Wrap"
                           Margin="0,3,0,0" IsVisible="{Binding DescVisibility}"/>
                <TextBlock Text="{Binding Flavor}" IsVisible="{Binding FlavorVisibility}" FontStyle="Italic" FontSize="11"
                           Foreground="#CCB0B0C8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding Extra}" Foreground="#FFD700" FontSize="12" TextWrapping="Wrap"
                           Margin="0,3,0,0" IsVisible="{Binding ExtraVisibility}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="StripBoonTile" DataType="chaos:ChaosSidebarBoon">
            <Grid Width="64" Height="64" Margin="0,0,0,8" HorizontalAlignment="Center" Opacity="{Binding TileOpacity}">
                <ToolTip.Tip>
                    <ToolTip Content="{Binding}" ContentTemplate="{StaticResource BoonTipContent}"/>
                </ToolTip.Tip>
                <Border CornerRadius="13" Background="{Binding TileBackBrush}" BorderThickness="0" ClipToBounds="True">
                    <Grid>
                        <TextBlock Text="{Binding Glyph}" FontSize="30" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                        <Border CornerRadius="13" BorderBrush="{Binding AccentBrush}" BorderThickness="3.5" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <Border Background="#DD121026" CornerRadius="6" Padding="4,0"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"
                        IsVisible="{Binding LevelBadgeVisibility}">
                    <TextBlock Text="{Binding LevelText}" Foreground="{StaticResource Pink}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PocketTile" DataType="chaos:ChaosSidebarBoon">
            <Grid Width="57" Height="57" Margin="0,0,8,6" Opacity="{Binding TileOpacity}"
                  Background="Transparent" Tag="{Binding Id}" PointerPressed="PocketTile_Click">
                <ToolTip.Tip>
                    <ToolTip Content="{Binding}" ContentTemplate="{StaticResource BoonTipContent}"/>
                </ToolTip.Tip>
                <Border CornerRadius="12" Background="{Binding TileBackBrush}" BorderThickness="0">
                    <Grid>
                        <TextBlock Text="{Binding Glyph}" FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                        <Border CornerRadius="12" BorderBrush="{Binding AccentBrush}" BorderThickness="3.5" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <Border Background="#DD121026" CornerRadius="6" Padding="4,0"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"
                        IsVisible="{Binding LevelBadgeVisibility}">
                    <TextBlock Text="{Binding LevelText}" Foreground="{StaticResource Pink}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Border x:Name="Strip" HorizontalAlignment="Left" Width="116"
                Background="{StaticResource StripBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,8,8"
                CornerRadius="0,0,18,0" PointerEntered="Hud_PointerEntered" PointerExited="Strip_PointerExited"
                PointerPressed="Strip_Click">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0" HorizontalAlignment="Center">
                <TextBlock Text="🐇" Foreground="{StaticResource Pink}" FontSize="30" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtStripClock" Text="{Binding ClockText}" Foreground="White" FontFamily="Consolas" FontSize="17"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <Border Margin="0,8,0,0" HorizontalAlignment="Center" Background="#33000000" CornerRadius="9" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="SideLeftBtn" Width="28" Height="19" CornerRadius="8"
                                Background="Transparent" PointerPressed="SideLeft_Click">
                            <TextBlock x:Name="SideLeftGlyph" Text="◀" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SideRightBtn" Width="28" Height="19" CornerRadius="8" Margin="2,0,0,0"
                                Background="Transparent" PointerPressed="SideRight_Click">
                            <TextBlock x:Name="SideRightGlyph" Text="▶" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="TxtStripScore" Text="{Binding ScoreText}" Foreground="White" FontWeight="Bold" FontSize="16"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,14,0,0"/>
                <TextBlock x:Name="TxtStripMult" Text="{Binding TotalMultText}" Foreground="#FFD24DFF" FontWeight="Bold" FontSize="19"
                           FontFamily="{StaticResource FredokaFont}" HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <StackPanel x:Name="StreakBlock" Margin="0,12,0,0" HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                    <TextBlock x:Name="TxtStreakLbl" Text="STREAK" Foreground="{StaticResource TextDim}"
                               FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtStreakNum" Text="x0" Foreground="White" FontWeight="Bold"
                               FontFamily="Consolas" FontSize="24" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel x:Name="FocusStripBlock" Margin="0,14,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="FOCUS" Foreground="#FF9CE8FF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Grid Width="86" Height="8" Margin="0,3,0,0">
                        <ProgressBar x:Name="FocusStripBar" Minimum="0" Maximum="{Binding FocusMax}"
                                     Value="{Binding Focus}"
                                     Foreground="#FF5AC8FA" Background="#33000000" BorderThickness="0"/>
                        <Grid IsHitTestVisible="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="7*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="1.5" HorizontalAlignment="Right" Background="#88FFFFFF"/>
                        </Grid>
                    </Grid>
                    <TextBlock Text="{Binding FocusText}" Foreground="White" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel x:Name="RippleStripBlock" Margin="0,12,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="RIPPLE" Foreground="#FF7AE0FF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="RippleStripText" Text="{Binding RippleText}" FontWeight="Bold" FontFamily="Consolas" FontSize="13"
                               Foreground="{Binding RippleForeground}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding ActiveSidebarToys}" Margin="0,18,0,0" HorizontalAlignment="Center"
                              ItemTemplate="{StaticResource StripBoonTile}"/>
                <Border x:Name="Seam" Height="1" Width="48" Background="{StaticResource PanelBorder}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding ActiveSidebarAccessories}" HorizontalAlignment="Center"
                              ItemTemplate="{StaticResource StripBoonTile}"/>
            </StackPanel>
        </Border>

        <Border x:Name="Panel" HorizontalAlignment="Left" Width="300" IsVisible="False"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,8,8"
                CornerRadius="0,0,18,0" PointerExited="Hud_PointerExited">
            <Grid Margin="20,18,20,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="PortraitHost" Width="44" Height="44" Margin="0,0,10,0" CornerRadius="10" VerticalAlignment="Center"
                                Background="#33FF69B4" BorderThickness="0">
                            <Grid>
                                <Image x:Name="Portrait" Stretch="UniformToFill"/>
                                <Border CornerRadius="10" BorderBrush="{StaticResource PanelBorder}" BorderThickness="3" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐇 THE HOLE" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="22"/>
                                <TextBlock x:Name="TxtActWave" Text="{Binding ActWaveText}" Foreground="White" FontSize="13" VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtRunTime" Text="{Binding RunTimeText}" Foreground="{StaticResource TextDim}" FontSize="13" Margin="0,2,0,0" IsVisible="False"/>
                        </StackPanel>
                    </StackPanel>
                    <Border HorizontalAlignment="Left" Margin="0,6,0,0" Background="#33000000" CornerRadius="9" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="SideLeftBtn2" Width="28" Height="19" CornerRadius="8"
                                    Background="Transparent" PointerPressed="SideLeft_Click">
                                <TextBlock x:Name="SideLeftGlyph2" Text="◀" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="SideRightBtn2" Width="28" Height="19" CornerRadius="8" Margin="2,0,0,0"
                                    Background="Transparent" PointerPressed="SideRight_Click">
                                <TextBlock x:Name="SideRightGlyph2" Text="▶" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ProgressBar x:Name="BarRunProgress" Minimum="0" Maximum="1" Value="{Binding RunProgress}" Height="5" Margin="0,4,0,0"
                                 Foreground="#FF8A7DBD" Background="#33000000" BorderThickness="0" IsVisible="False"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock x:Name="TxtPanelScore" Text="{Binding ScoreText}" Foreground="White" FontWeight="Bold" FontSize="22" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtPanelMult" Text="{Binding TotalMultText}" Foreground="#FFD24DFF" FontWeight="Bold" FontSize="22"
                                   FontFamily="{StaticResource FredokaFont}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,6,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="HdrStack" Text="MULTIPLIER STACK" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                        <Grid x:Name="RowStreak" Margin="0,1"><TextBlock Text="{Binding Combo, StringFormat=streak x{0}}" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding ComboMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                        <Grid x:Name="RowDifficulty" Margin="0,1"><TextBlock Text="difficulty" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding DifficultyMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                        <Grid x:Name="RowLust" Margin="0,1"><TextBlock Text="lust" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding HeatMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                        <Grid x:Name="RowMantras" Margin="0,1"><TextBlock Text="mantras" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding BoonMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                        <ProgressBar x:Name="BarLust" Minimum="0" Maximum="1" Value="{Binding Heat}" Height="5" Margin="0,6,0,0"
                                     Foreground="#FFFF7A3D" Background="#33000000" BorderThickness="0"/>

                        <TextBlock x:Name="HdrResistance" Text="RESISTANCE" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <TextBlock x:Name="TxtShields" Text="{Binding ShieldText}" Foreground="#FFFF6EC7" FontSize="22"
                                   RenderTransformOrigin="0,0.5">
                            <TextBlock.RenderTransform><ScaleTransform/></TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock x:Name="HdrFocus" Text="FOCUS" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <StackPanel x:Name="FocusPanelBlock">
                            <Grid>
                                <TextBlock Text="pops fill it · a hold spends it" Foreground="{StaticResource TextDim}" FontSize="12"/>
                                <TextBlock Text="{Binding FocusText}" Foreground="#FF9CE8FF" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Height="8" Margin="0,4,0,0">
                                <ProgressBar x:Name="FocusPanelBar" Minimum="0" Maximum="{Binding FocusMax}"
                                             Value="{Binding Focus}"
                                             Foreground="#FF5AC8FA" Background="#33000000" BorderThickness="0"/>
                                <Grid IsHitTestVisible="False">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="7*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="1.5" HorizontalAlignment="Right" Background="#88FFFFFF"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <TextBlock x:Name="HdrPockets" Text="TOYS" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <ItemsControl ItemsSource="{Binding ActiveSidebarToys}" ItemTemplate="{StaticResource PocketTile}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <TextBlock x:Name="HdrAccessories" Text="ACCESSORIES" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <ItemsControl ItemsSource="{Binding ActiveSidebarAccessories}" ItemTemplate="{StaticResource PocketTile}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <TextBlock x:Name="HdrConditioning" Text="CONDITIONING" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <ItemsControl ItemsSource="{Binding RunPickTiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="chaos:ChaosSidebarBoon">
                                    <StackPanel Orientation="Horizontal" Margin="0,1">
                                        <ToolTip.Tip>
                                            <ToolTip Content="{Binding}" ContentTemplate="{StaticResource BoonTipContent}"/>
                                        </ToolTip.Tip>
                                        <Border Width="33" Height="33" CornerRadius="8"
                                                Background="{Binding TileBackBrush}" BorderThickness="0">
                                            <Grid>
                                                <TextBlock Text="{Binding Glyph}" FontSize="16" Foreground="{Binding AccentBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                                <Border CornerRadius="8" BorderBrush="{Binding AccentBrush}" BorderThickness="3" IsHitTestVisible="False"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" Foreground="{Binding AccentBrush}" FontSize="13"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="HdrModifiers" Text="MODIFIERS" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <ItemsControl ItemsSource="{Binding RunModifiers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="chaos:ChaosSidebarBoon">
                                    <Border Width="45" Height="45" Margin="0,0,7,7" CornerRadius="10"
                                            Background="{Binding TileBackBrush}" BorderThickness="0">
                                        <ToolTip.Tip>
                                            <ToolTip Content="{Binding}" ContentTemplate="{StaticResource BoonTipContent}"/>
                                        </ToolTip.Tip>
                                        <Grid>
                                            <TextBlock Text="{Binding Glyph}" FontSize="20" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                            <Border CornerRadius="10" BorderBrush="{Binding AccentBrush}" BorderThickness="3" IsHitTestVisible="False"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="HdrFeed" Text="FEED" Foreground="{StaticResource Pink}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Margin="0,12,0,6"/>
                        <ItemsControl ItemsSource="{Binding RecentEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextDim}" FontSize="13" Margin="0,1" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel x:Name="ControlsRow" Grid.Row="2" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnHero" Content="⏸ PAUSE" Click="BtnHero_Click" FontSize="16" FontWeight="Bold"
                                Foreground="White" BorderThickness="0" Padding="0,13" Cursor="Hand"
                                HorizontalAlignment="Stretch">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFE84393" Offset="0"/>
                                    <GradientStop Color="#FF8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button Grid.Column="1" x:Name="BtnCloseMode" Content="✖" Click="BtnCloseMode_Click" FontSize="15" FontWeight="Bold"
                                Width="46" Margin="8,0,0,0" Background="#66FF5050" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip.Tip="leave the rabbit hole" IsVisible="False">
                        </Button>
                    </Grid>
                    <Grid x:Name="PauseChoiceRow" IsVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="▶ continue" Click="BtnResume_Click" FontSize="14" FontWeight="Bold"
                                Padding="0,12" Margin="0,0,5,0" Background="#449CE8A0" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button Grid.Column="1" Content="✖ wake up" Click="BtnExit_Click" FontSize="14" FontWeight="Bold"
                                Padding="0,12" Margin="5,0,0,0" Background="#66FF5050" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock x:Name="TxtPauseHint" Text="⏸ HELD · your panic key again wakes you up"
                               Foreground="{StaticResource TextDim}" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,6,0,0" IsVisible="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

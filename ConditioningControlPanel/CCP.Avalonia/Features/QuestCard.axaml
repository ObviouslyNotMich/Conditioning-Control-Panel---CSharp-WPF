<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.QuestCard"
             x:DataType="{x:Type local:QuestCard}">

  <Border x:Name="RootBorder"
          Background="{DynamicResource PanelBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="12"
          ClipToBounds="True"
          Padding="15">
    <Grid RowDefinitions="Auto,*,Auto">
      <!-- Header -->
      <Grid Grid.Row="0"
            ColumnDefinitions="Auto,*">
        <TextBlock x:Name="TxtGlyph"
                   FontSize="22"
                   Foreground="{DynamicResource TextLightBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
        <TextBlock x:Name="TxtTitle"
                   Grid.Column="1"
                   Text="{loc:Str quest_default_title}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextLightBrush}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </Grid>

      <!-- Body -->
      <Grid Grid.Row="1"
            ColumnDefinitions="*,Auto"
            Margin="0,12,0,0">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">
          <TextBlock x:Name="TxtDescription"
                     Text=""
                     FontSize="12"
                     Foreground="{DynamicResource TextDimBrush}"
                     TextWrapping="Wrap" />

          <ProgressBar x:Name="ProgressBar"
                       Minimum="0"
                       Maximum="1"
                       Height="10"
                       Margin="0,12,0,0"
                       CornerRadius="4" />

          <TextBlock x:Name="TxtProgress"
                     Text="{loc:Str quest_progress_default}"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}"
                     Margin="0,5,0,0" />

          <Border Background="{DynamicResource PanelAccentBrush}"
                  CornerRadius="5"
                  Padding="10,5"
                  Margin="0,10,0,0"
                  HorizontalAlignment="Left">
            <TextBlock x:Name="TxtXp"
                       Text="{loc:Str quest_xp_default}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}" />
          </Border>
        </StackPanel>

        <!-- Quest image -->
        <Border Grid.Column="1"
                Width="150"
                Height="150"
                Background="{DynamicResource DarkerBgBrush}"
                CornerRadius="12"
                ClipToBounds="True">
          <Grid>
            <Image x:Name="ImgQuest"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapInterpolationMode="HighQuality" />

            <Border x:Name="CompletedOverlay"
                    Background="#802D4A2D"
                    IsVisible="False">
              <TextBlock Text="{loc:Str symbol_checkmark}"
                         FontSize="64"
                         FontWeight="Bold"
                         Foreground="#00E676"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </Grid>
        </Border>
      </Grid>

      <!-- Reroll button -->
      <Button x:Name="BtnReroll"
              Grid.Row="2"
              Content="{loc:Str btn_reroll}"
              Theme="{DynamicResource OutlineButton}"
              HorizontalAlignment="Stretch"
              Margin="0,15,0,0" />
    </Grid>
  </Border>
</UserControl>

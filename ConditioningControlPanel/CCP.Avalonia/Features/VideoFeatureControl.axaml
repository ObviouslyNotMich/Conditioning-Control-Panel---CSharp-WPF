<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.VideoFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Master enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str setting_enable_mandatory_videos}"
                     Foreground="White"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_turn_mandatory_videos_on_or_off}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Per hour -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_per_hour}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtPerHour"
                     Text="2"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderPerHour"
                Minimum="1"
                Maximum="20"
                Value="2"
                ValueChanged="SliderPerHour_Changed" />
        <TextBlock Text="{loc:Str msg_videos_per_hour}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Strict lock -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str setting_strict_lock}"
                     Foreground="#FFB347"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_strict_mode_videos_cannot_be_skipped_must_wat}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkStrict"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkStrict_Changed" />
      </Grid>
    </Border>

    <!-- Duration filter -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <TextBlock Text="{loc:Str section_duration_filter}"
                   Foreground="White"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <Grid Margin="0,0,0,4">
          <TextBlock Text="{loc:Str label_min_length}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtVideoMinDur"
                     Text="{loc:Str label_off}"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderVideoMinDur"
                Minimum="0"
                Maximum="600"
                Value="0"
                ValueChanged="SliderVideoMinDur_Changed"
                Margin="0,0,0,10" />

        <Grid Margin="0,0,0,4">
          <TextBlock Text="{loc:Str label_max_length}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtVideoMaxDur"
                     Text="{loc:Str label_off}"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderVideoMaxDur"
                Minimum="0"
                Maximum="1800"
                Value="0"
                ValueChanged="SliderVideoMaxDur_Changed"
                Margin="0,0,0,4" />

        <TextBlock Text="{loc:Str msg_video_duration_filter}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Mini game subsection -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,10">
          <StackPanel Orientation="Horizontal"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_mini_game}"
                       Foreground="#FF69B4"
                       FontSize="14"
                       FontWeight="Bold" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkMiniGame"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkMiniGame_Changed" />
        </Grid>

        <!-- Targets -->
        <Grid Margin="0,0,0,8"
              ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal">
            <TextBlock Text="{loc:Str label_targets}"
                       Foreground="White"
                       FontSize="12" />
            <ToggleSwitch x:Name="ChkRandomize"
                          Margin="8,0,0,0"
                          VerticalAlignment="Center"
                          IsCheckedChanged="ChkRandomize_Changed" />
          </StackPanel>
          <TextBlock x:Name="TxtTargets"
                     Grid.Column="1"
                     Text="3"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderTargets"
                Minimum="1"
                Maximum="10"
                Value="3"
                ValueChanged="SliderTargets_Changed"
                Margin="0,0,0,10" />

        <!-- Duration -->
        <Grid Margin="0,0,0,2">
          <TextBlock Text="{loc:Str setting_duration}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtDuration"
                     Text="5"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderDuration"
                Minimum="1"
                Maximum="15"
                Value="5"
                ValueChanged="SliderDuration_Changed"
                Margin="0,0,0,10" />

        <!-- Target size -->
        <Grid Margin="0,0,0,2">
          <TextBlock Text="{loc:Str setting_size}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtTargetSize"
                     Text="70"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderTargetSize"
                Minimum="30"
                Maximum="150"
                Value="70"
                ValueChanged="SliderTargetSize_Changed"
                Margin="0,0,0,12" />

        <!-- Gaze click -->
        <Grid Margin="0,0,0,12"
              ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_stare_to_click}"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str msg_stare_to_click}"
                       Foreground="#AAAAAA"
                       FontSize="10"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkVideoGazeClick"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkVideoGazeClick_Changed" />
        </Grid>

        <Grid ColumnDefinitions="*,8,*">
          <Button Grid.Column="0"
                  Content="{loc:Str btn_phrases}"
                  Theme="{StaticResource OutlineButton}"
                  Click="BtnManageAttention_Click" />
          <Button Grid.Column="2"
                  Content="{loc:Str btn_style}"
                  Theme="{StaticResource OutlineButton}"
                  Click="BtnAttentionStyle_Click" />
        </Grid>
      </StackPanel>
    </Border>

    <Button Content="{loc:Str btn_test_2}"
            Theme="{StaticResource OutlineButton}"
            Click="BtnTestVideo_Click" />
  </StackPanel>

</UserControl>

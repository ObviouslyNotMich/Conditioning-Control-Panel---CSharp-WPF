<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.LockCardFeatureControl"
             x:Name="Root"
             x:DataType="{x:Type local:LockCardFeatureControl}"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Platform capability badge -->
    <Border Theme="{StaticResource PlatformInfoBadge}"
            IsVisible="{Binding Capabilities.SupportsInputHooks, ElementName=Root, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
      <TextBlock Text="{loc:Str msg_lock_card_platform_unavailable}"
                 Foreground="White"
                 FontSize="11"
                 TextWrapping="Wrap" />
    </Border>

    <!-- Enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_lock_card_enable}"
                     Foreground="White"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str label_lock_card_enable_desc}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Per hour -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_per_hour}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtFreq"
                     Text="2"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFreq"
                Minimum="1"
                Maximum="10"
                Value="2"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderFreq_Changed" />
        <TextBlock Text="{loc:Str label_lock_card_per_hour_desc}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Repeats -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_repeats}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtRepeats"
                     Text="3x"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderRepeats"
                Minimum="1"
                Maximum="10"
                Value="3"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderRepeats_Changed" />
        <TextBlock Text="{loc:Str label_lock_card_repeats_desc}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Strict lock -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_lock_card_strict}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str label_lock_card_strict_desc}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkStrict"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkStrict_Changed"
                      IsEnabled="{Binding Capabilities.SupportsInputHooks, ElementName=Root}"
                      ToolTip.Tip="{loc:Str tooltip_lock_card_strict_desktop_only}" />
      </Grid>
    </Border>

    <!-- Actions -->
    <Grid ColumnDefinitions="*,8,*,8,Auto">
      <Button Grid.Column="0"
              Content="{loc:Str btn_lock_card_manage_phrases}"
              Click="BtnManagePhrases_Click"
              Background="#1A1A2E"
              Foreground="White"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,6" />
      <Button Grid.Column="2"
              Content="{loc:Str btn_test}"
              Click="BtnTest_Click"
              Background="#1A1A2E"
              Foreground="White"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,6" />
      <Button Grid.Column="4"
              Content="{loc:Str btn_lock_card_settings}"
              Width="44"
              Click="BtnColorSettings_Click"
              Background="#1A1A2E"
              Foreground="White"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12,6" />
    </Grid>
  </StackPanel>

</UserControl>

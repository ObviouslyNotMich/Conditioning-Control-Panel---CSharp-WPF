<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.SystemFeatureControl"
             x:Name="Root"
             x:DataType="{x:Type local:SystemFeatureControl}"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Platform capability badge -->
    <Border Theme="{StaticResource PlatformInfoBadge}"
            IsVisible="{Binding Capabilities.SupportsInputHooks, ElementName=Root, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
      <TextBlock Text="{loc:Str msg_panic_key_lockdown_unsupported}"
                 Foreground="White"
                 FontSize="11"
                 TextWrapping="Wrap" />
    </Border>

    <Border Theme="{StaticResource PlatformInfoBadge}"
            IsVisible="{Binding Capabilities.IsWindows, ElementName=Root, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
      <TextBlock Text="{loc:Str msg_win_startup_windows_only}"
                 Foreground="White"
                 FontSize="11"
                 TextWrapping="Wrap" />
    </Border>

    <!-- Toggle grid -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_multi_mon}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_show_content_on_all_connected_monitors_2_3_or}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkMultiMon"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkMultiMon_Changed" />
        </Grid>

        <Grid Margin="16,4,0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_fill_all_monitors_video}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_fill_all_monitors_video}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkFillAllMon"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkFillAllMon_Changed" />
        </Grid>

        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_win_start}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_launch_automatically_when_windows_starts}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkWinStart"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkWinStart_Changed"
                        IsEnabled="{Binding Capabilities.IsWindows, ElementName=Root}"
                        ToolTip.Tip="{loc:Str tooltip_windows_only}" />
        </Grid>

        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_vid_launch}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_play_a_mandatory_video_when_app_opens}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkVidLaunch"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkVidLaunch_Changed" />
        </Grid>

        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_auto_run}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_start_the_engine_automatically_on_launch}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkAutoRun"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkAutoRun_Changed" />
        </Grid>

        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_start_hidden}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_start_minimized_to_system_tray}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkStartHidden"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkStartHidden_Changed"
                        IsEnabled="{Binding Capabilities.SupportsSystemTray, ElementName=Root}"
                        ToolTip.Tip="{loc:Str tooltip_desktop_only}" />
        </Grid>

        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_no_panic}"
                       Foreground="#FF6B6B"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_danger_completely_disables_panic_key_you_won}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkNoPanic"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkNoPanic_Changed"
                        IsEnabled="{Binding Capabilities.SupportsInputHooks, ElementName=Root}"
                        ToolTip.Tip="{loc:Str tooltip_requires_input_hooks}" />
        </Grid>

        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str setting_offline_mode}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_disable_all_network_features_updates_ai_leade}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkOfflineMode"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkOfflineMode_Changed" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Startup video picker -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <StackPanel>
        <TextBlock Text="{loc:Str label_startup_video}"
                   Foreground="White"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6" />
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock x:Name="TxtStartupVideo"
                     Grid.Column="0"
                     Text="{loc:Str label_random}"
                     Foreground="#FF69B4"
                     FontSize="12"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
          <Button Grid.Column="1"
                  Content="📁"
                  Width="36"
                  Theme="{StaticResource OutlineButton}"
                  Padding="6,4"
                  Margin="6,0,0,0"
                  Click="BtnSelectStartupVideo_Click"
                  ToolTip.Tip="{loc:Str tooltip_browse_for_startup_video}" />
          <Button Grid.Column="2"
                  Content="✕"
                  Width="36"
                  Theme="{StaticResource OutlineButton}"
                  Padding="6,4"
                  Margin="4,0,0,0"
                  Click="BtnClearStartupVideo_Click"
                  ToolTip.Tip="{loc:Str tooltip_clear_selection_use_random}" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Assets folder -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,8,*">
        <Button Grid.Column="0"
                Content="{loc:Str btn_pick_folder}"
                Theme="{StaticResource OutlineButton}"
                Click="BtnPickAssets_Click"
                ToolTip.Tip="{loc:Str tooltip_set_custom_assets_folder}" />
        <Button Grid.Column="2"
                Content="{loc:Str btn_assets}"
                Theme="{StaticResource OutlineButton}"
                Click="BtnOpenAssets_Click"
                ToolTip.Tip="{loc:Str tooltip_open_assets_folder_images_videos_sounds}" />
      </Grid>
    </Border>

    <!-- Panic key -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="{loc:Str btn_escape}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_click_to_change_panic_key}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <Button x:Name="BtnPanicKey"
                Grid.Column="1"
                Theme="{StaticResource OutlineButton}"
                Padding="12,6"
                Click="BtnPanicKey_Click"
                ToolTip.Tip="{loc:Str tooltip_panic_key_desktop_only}" />
      </Grid>
    </Border>
  </StackPanel>

</UserControl>

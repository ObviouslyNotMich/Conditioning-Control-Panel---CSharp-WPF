<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.RoadmapNodeCard"
             Width="150"
             Height="220"
             x:DataType="{x:Type local:RoadmapNodeCard}">

  <Border x:Name="RootBorder"
          Background="{DynamicResource PanelBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="12"
          ClipToBounds="True"
          Padding="8">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
      <TextBlock x:Name="TxtStepNumber"
                 Grid.Row="0"
                 Text="{loc:Str roadmap_node_step_default}"
                 FontSize="11"
                 Foreground="{DynamicResource PinkBrush}"
                 HorizontalAlignment="Center" />

      <TextBlock x:Name="TxtTitle"
                 Grid.Row="1"
                 Text="{loc:Str label_title}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextLightBrush}"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 Margin="0,4,0,0" />

      <Border Grid.Row="2"
              Background="{DynamicResource DarkerBgBrush}"
              CornerRadius="10"
              ClipToBounds="True"
              Margin="0,8,0,8">
        <Grid>
          <Border x:Name="ImgIconHost"
                  CornerRadius="10" />
          <TextBlock x:Name="TxtGlyph"
                     FontSize="32"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource PinkBrush}"
                     IsVisible="False" />
        </Grid>
      </Border>

      <StackPanel Grid.Row="3"
                  Spacing="6">
        <TextBlock x:Name="TxtRequirement"
                   Text="{loc:Str roadmap_node_requirement_default}"
                   FontSize="10"
                   Foreground="{DynamicResource TextDimBrush}"
                   TextWrapping="Wrap"
                   TextAlignment="Center" />

        <Button x:Name="BtnStatus"
                Content="{loc:Str btn_start}"
                Theme="{DynamicResource OutlineButton}"
                HorizontalAlignment="Stretch"
                Padding="6,4"
                FontSize="11" />
      </StackPanel>

      <!-- Locked overlay -->
      <Border x:Name="LockedOverlay"
              Grid.RowSpan="4"
              Background="#C0000000"
              CornerRadius="12"
              IsVisible="False">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
          <TextBlock Text="🔒"
                     FontSize="32"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Str label_locked}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextLightBrush}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>

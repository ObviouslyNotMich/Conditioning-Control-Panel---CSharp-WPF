<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.IntensityRampFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{loc:Str btn_enable}"
                   Foreground="White"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <ToggleSwitch x:Name="ChkEnabled"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnabled_Changed" />
      </Grid>
    </Border>

    <!-- Duration -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_duration}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtDuration"
                     Text="60 min"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderDuration"
                Minimum="10"
                Maximum="180"
                Value="60"
                ValueChanged="SliderDuration_Changed" />
      </StackPanel>
    </Border>

    <!-- Multiplier -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_multiplier}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtMultiplier"
                     Text="1.5x"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderMultiplier"
                Minimum="1"
                Maximum="3"
                Value="1.5"
                SmallChange="0.1"
                LargeChange="0.5"
                ValueChanged="SliderMultiplier_Changed" />
      </StackPanel>
    </Border>

    <!-- End at ramp -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{loc:Str label_end_session_on_ramp_complete}"
                   Foreground="White"
                   FontSize="13"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <ToggleSwitch x:Name="ChkEndAt"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEndAt_Changed" />
      </Grid>
    </Border>

    <!-- Ramp links -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14">
      <StackPanel>
        <TextBlock Text="{loc:Str label_link_to_ramp}"
                   Foreground="#FF69B4"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />
        <WrapPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
            <ToggleSwitch x:Name="ChkLinkFlash"
                          IsCheckedChanged="Link_Changed" />
            <TextBlock Text="{loc:Str label_flash}"
                       Foreground="White"
                       FontSize="12"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
            <ToggleSwitch x:Name="ChkLinkSpiral"
                          IsCheckedChanged="Link_Changed" />
            <TextBlock Text="{loc:Str label_spiral}"
                       Foreground="White"
                       FontSize="12"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
            <ToggleSwitch x:Name="ChkLinkPink"
                          IsCheckedChanged="Link_Changed" />
            <TextBlock Text="{loc:Str label_pink}"
                       Foreground="White"
                       FontSize="12"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
            <ToggleSwitch x:Name="ChkLinkMaster"
                          IsCheckedChanged="Link_Changed" />
            <TextBlock Text="{loc:Str setting_master}"
                       Foreground="White"
                       FontSize="12"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <ToggleSwitch x:Name="ChkLinkSub"
                          IsCheckedChanged="Link_Changed" />
            <TextBlock Text="{loc:Str label_sub}"
                       Foreground="White"
                       FontSize="12"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
        </WrapPanel>
      </StackPanel>
    </Border>
  </StackPanel>

</UserControl>

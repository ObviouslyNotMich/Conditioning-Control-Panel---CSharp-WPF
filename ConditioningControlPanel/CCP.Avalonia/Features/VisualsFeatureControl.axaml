<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.VisualsFeatureControl"
             x:Name="Root"
             x:DataType="{x:Type local:VisualsFeatureControl}"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Platform capability badge -->
    <Border Theme="{StaticResource PlatformInfoBadge}"
            IsVisible="{Binding Capabilities.SupportsClickThrough, ElementName=Root, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
      <TextBlock Text="{loc:Str msg_overlay_click_through_degraded}"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="11"
                 TextWrapping="Wrap" />
    </Border>

    <!-- Size -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_size}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtSize"
                     Text="100%"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderSize"
                Minimum="50"
                Maximum="250"
                Value="100"
                ValueChanged="SliderSize_Changed" />
        <TextBlock Text="{loc:Str tooltip_visuals_size}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Opacity -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_opacity}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtOpacity"
                     Text="100%"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderOpacity"
                Minimum="10"
                Maximum="100"
                Value="100"
                ValueChanged="SliderOpacity_Changed" />
        <TextBlock Text="{loc:Str tooltip_visuals_opacity}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Fade -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_fade}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtFade"
                     Text="50%"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFade"
                Minimum="0"
                Maximum="100"
                Value="50"
                ValueChanged="SliderFade_Changed" />
        <TextBlock Text="{loc:Str tooltip_visuals_fade}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Duration -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_duration}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtDuration"
                     Text="5s"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderDuration"
                Minimum="1"
                Maximum="30"
                Value="5"
                ValueChanged="SliderDuration_Changed" />
        <TextBlock Text="{loc:Str tooltip_visuals_duration}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Link to Audio -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_visuals_link_to_audio}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_visuals_link_to_audio}"
                     Foreground="{DynamicResource TextDimBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkAudio"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkAudio_Changed" />
      </Grid>
    </Border>
  </StackPanel>

</UserControl>

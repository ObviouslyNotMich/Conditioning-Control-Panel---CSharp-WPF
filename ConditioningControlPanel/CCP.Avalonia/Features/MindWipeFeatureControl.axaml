<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.MindWipeFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Enable toggle -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{loc:Str label_enable_mind_wipe}"
                   Foreground="White"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Frequency -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_frequency}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtFreq"
                     Text="{loc:Str label_6_h}"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFreq"
                Minimum="1"
                Maximum="180"
                Value="6"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderFreq_Changed" />
        <TextBlock Text="{loc:Str label_mind_wipe_frequency_desc}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Volume -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_volume}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtVolume"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderVolume"
                Minimum="0"
                Maximum="100"
                Value="50"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderVolume_Changed" />
        <TextBlock Text="{loc:Str label_mind_wipe_volume_desc}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Loop in background -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_loop_in_background}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_continuously_loop_a_single_track_instead_of_r}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkLoop"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkLoop_Changed" />
      </Grid>
    </Border>

    <!-- Custom audio clip -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <TextBlock Text="{loc:Str section_custom_audio}"
                   Foreground="White"
                   FontSize="13"
                   FontWeight="SemiBold" />
        <TextBlock Text="{loc:Str label_mind_wipe_custom_audio_desc}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,10" />

        <Border Background="#1A1A2E"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,8">
          <TextBlock x:Name="TxtAudioFile"
                     Text="{loc:Str label_mind_wipe_default_audio}"
                     Foreground="#FF69B4"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis" />
        </Border>

        <Grid ColumnDefinitions="*,Auto">
          <Button Grid.Column="0"
                  x:Name="BtnSelectAudio"
                  Content="{loc:Str btn_select_audio}"
                  Theme="{StaticResource OutlineButton}"
                  Padding="12,8"
                  Margin="0,0,6,0"
                  Click="BtnSelectAudio_Click" />
          <Button Grid.Column="1"
                  x:Name="BtnClearAudio"
                  Content="{loc:Str btn_reset}"
                  Theme="{StaticResource OutlineButton}"
                  Padding="12,8"
                  Click="BtnClearAudio_Click" />
        </Grid>
      </StackPanel>
    </Border>

    <Button Content="{loc:Str btn_mind_wipe_test_now}"
            Theme="{StaticResource OutlineButton}"
            Click="BtnTest_Click" />
  </StackPanel>

</UserControl>

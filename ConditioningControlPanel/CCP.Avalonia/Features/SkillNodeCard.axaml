<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Core.Localization;assembly=CCP.Core"
             x:Class="ConditioningControlPanel.Avalonia.Features.SkillNodeCard"
             Cursor="Hand"
             Width="160"
             Height="200"
             x:DataType="{x:Type local:SkillNodeCard}">

  <Border x:Name="RootBorder"
          Background="{DynamicResource PanelBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="12"
          ClipToBounds="True"
          BoxShadow="0 0 18 0 #00000000">
    <Grid x:Name="ContentRoot">
      <!-- Full-bleed skill image -->
      <Border x:Name="ImgIconHost"
              CornerRadius="10"
              RenderOptions.BitmapInterpolationMode="HighQuality" />

      <!-- Bottom gradient + title overlay -->
      <Border CornerRadius="0,0,10,10"
              VerticalAlignment="Bottom"
              IsHitTestVisible="False">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="Transparent" Offset="0" />
            <GradientStop Color="#90000000" Offset="1" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="8,18,8,8"
              RowDefinitions="Auto,Auto">
          <TextBlock x:Name="TxtTitle"
                     Text=""
                     Grid.Row="0"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="Bold" />
          <TextBlock x:Name="TxtStatus"
                     Text=""
                     Grid.Row="1"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="11"
                     Margin="0,4,0,0" />
        </Grid>
      </Border>

      <!-- Action buttons -->
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="6,6,6,0"
                  Spacing="4"
                  ZIndex="5">
        <Button x:Name="BtnPurchase"
                Padding="6,3"
                FontSize="10"
                FontWeight="Bold"
                Background="#D0FF69B4"
                Foreground="{DynamicResource TextLightBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Content="{Binding [label_skill_purchase], Source={x:Static loc:LocalizationManager.Instance}}" />
        <Button x:Name="BtnDetails"
                Padding="6,3"
                FontSize="10"
                FontWeight="Bold"
                Background="#80000000"
                Foreground="{DynamicResource TextLightBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Content="{Binding [label_skill_details], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>

      <!-- Locked overlay -->
      <Border x:Name="LockedOverlay"
              Background="#C0000000"
              CornerRadius="10"
              IsVisible="False"
              ZIndex="10">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="8">
          <TextBlock Text="🔒"
                     FontSize="28"
                     HorizontalAlignment="Center" />
          <TextBlock x:Name="TxtLockLabel"
                     Text=""
                     Margin="0,4,0,0"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>

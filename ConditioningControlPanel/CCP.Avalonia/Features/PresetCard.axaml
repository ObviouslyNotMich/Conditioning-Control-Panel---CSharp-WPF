<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.PresetCard"
             Cursor="Hand"
             Width="110"
             Height="80"
             x:DataType="{x:Type local:PresetCard}">

  <Border x:Name="RootBorder"
          Background="{DynamicResource PanelBgBrush}"
          BorderBrush="{DynamicResource PanelAccentBrush}"
          BorderThickness="1"
          CornerRadius="8"
          Padding="8"
          Margin="4">

    <Grid x:Name="ContentRoot">

      <!-- Selection ring -->
      <Border x:Name="SelectionBorder"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="2.5"
              CornerRadius="8"
              IsHitTestVisible="False"
              IsVisible="False" />

      <StackPanel VerticalAlignment="Stretch"
                  Spacing="4">

        <!-- Preset name -->
        <TextBlock x:Name="TxtTitle"
                   Text="{loc:Str label_preset}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   MaxHeight="32"
                   LineHeight="14" />

        <!-- DEFAULT / CUSTOM badge -->
        <Border x:Name="BadgeBorder"
                HorizontalAlignment="Left"
                CornerRadius="3"
                Padding="5,2"
                Background="{DynamicResource PanelAccentBrush}">
          <TextBlock x:Name="TxtBadge"
                     Text="{loc:Str preset_badge_default}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="9"
                     FontWeight="Bold" />
        </Border>

        <!-- Compact feature stat glyphs -->
        <ItemsControl x:Name="StatsItems"
                      VerticalAlignment="Bottom"
                      Margin="0,4,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}"
                         FontSize="13"
                         Margin="0,0,3,0"
                         VerticalAlignment="Center" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>

    </Grid>
  </Border>

</UserControl>

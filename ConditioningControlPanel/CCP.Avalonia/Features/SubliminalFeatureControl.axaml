<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.SubliminalFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_enable_subliminals}"
                     Foreground="White"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str desc_enable_subliminals}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Per minute -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_per_minute}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtPerMin"
                     Text="5"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderPerMin"
                Minimum="1"
                Maximum="30"
                Value="5"
                ValueChanged="SliderPerMin_Changed" />
        <TextBlock Text="{loc:Str tooltip_subliminal_per_minute}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Frames -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_frames}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtFrames"
                     Text="2"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFrames"
                Minimum="1"
                Maximum="10"
                Value="2"
                ValueChanged="SliderFrames_Changed" />
        <TextBlock Text="{loc:Str tooltip_display_duration_in_frames_lower_faster_flash}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Opacity -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_opacity}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtOpacity"
                     Text="80%"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderOpacity"
                Minimum="10"
                Maximum="100"
                Value="80"
                ValueChanged="SliderOpacity_Changed" />
        <TextBlock Text="{loc:Str tooltip_text_visibility_lower_more_subtle}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Audio whispers -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_audio_whispers}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str desc_audio_whispers}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkWhispers"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkWhispers_Changed" />
        </Grid>
        <Grid Margin="0,12,0,0">
          <TextBlock Text="{loc:Str setting_volume}"
                     Foreground="#AAAAAA"
                     FontSize="12"
                     VerticalAlignment="Center" />
          <TextBlock x:Name="TxtWhisperVol"
                     Text="50%"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </Grid>
        <Slider x:Name="SliderWhisperVol"
                Minimum="0"
                Maximum="100"
                Value="50"
                ValueChanged="SliderWhisperVol_Changed" />
      </StackPanel>
    </Border>

    <!-- Actions -->
    <Grid ColumnDefinitions="*,Auto,*">
      <Button Grid.Column="0"
              Content="{loc:Str btn_manage_messages}"
              Theme="{StaticResource OutlineButton}"
              Padding="12,8"
              Click="BtnManageMessages_Click" />
      <Button Grid.Column="2"
              Content="{loc:Str btn_advanced}"
              Theme="{StaticResource OutlineButton}"
              Padding="12,8"
              Click="BtnAdvanced_Click" />
    </Grid>
  </StackPanel>

</UserControl>

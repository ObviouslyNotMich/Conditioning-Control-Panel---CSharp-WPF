<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.FeatureCard"
             Cursor="Hand">

  <Border x:Name="RootBorder"
          Background="#1A1A2E"
          BorderBrush="#FF69B4"
          BorderThickness="1"
          CornerRadius="12"
          ClipToBounds="True"
          Margin="6"
          BoxShadow="0 0 18 0 #00000000">
    <Grid x:Name="ContentRoot">
      <!-- Full-bleed background image via ImageBrush (respects parent CornerRadius) -->
      <Border x:Name="ImgIconHost"
              CornerRadius="11"
              RenderOptions.BitmapInterpolationMode="HighQuality" />

      <!-- Glyph fallback (for cards without an image) -->
      <Border x:Name="GlyphHost"
              Width="68"
              Height="68"
              CornerRadius="34"
              Background="#33FF69B4"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsVisible="False">
        <TextBlock x:Name="TxtGlyph"
                   FontSize="32"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="#FF69B4" />
      </Border>

      <!-- Bottom gradient + title overlay -->
      <Border CornerRadius="0,0,11,11"
              VerticalAlignment="Bottom"
              IsHitTestVisible="False">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="Transparent" Offset="0" />
            <GradientStop Color="#60000000" Offset="1" />
          </LinearGradientBrush>
        </Border.Background>
        <TextBlock x:Name="TxtTitle"
                   Text="{loc:Str feature_default_title}"
                   Margin="8,14,8,8"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Foreground="White"
                   FontSize="12"
                   FontWeight="SemiBold" />
      </Border>

      <!-- Active overlay: pink ring when the underlying feature is enabled -->
      <Border x:Name="ActiveBorder"
              BorderBrush="#FF69B4"
              BorderThickness="3.5"
              CornerRadius="12"
              IsHitTestVisible="False"
              IsVisible="False" />

      <!-- Locked overlay -->
      <Border x:Name="LockedOverlay"
              Background="#C0000000"
              CornerRadius="12"
              IsVisible="False">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
          <TextBlock Text="🔒"
                     FontSize="24"
                     HorizontalAlignment="Center" />
          <TextBlock x:Name="TxtLockLabel"
                     Text="{loc:Str feature_card_lock_level_placeholder}"
                     Margin="0,4,0,0"
                     HorizontalAlignment="Center"
                     Foreground="White"
                     FontSize="11"
                     FontWeight="SemiBold" />
        </StackPanel>
      </Border>

      <!-- Help icon overlay (top-right corner) -->
      <Button x:Name="BtnHelp"
              Width="22"
              Height="22"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,8,8,0"
              Background="#33FF69B4"
              Foreground="White"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="11"
              Padding="0"
              FontSize="12"
              FontWeight="Bold"
              Content="{loc:Str label_help_symbol}"
              IsVisible="False"
              IsHitTestVisible="True"
              ToolTip.Tip="{loc:Str btn_help}"
              ZIndex="10" />
    </Grid>
  </Border>
</UserControl>

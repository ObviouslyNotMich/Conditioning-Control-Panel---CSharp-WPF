<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.BouncingTextFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{loc:Str btn_enable}"
                   Foreground="White"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Speed -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_speed}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtSpeed"
                     Text="5"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderSpeed"
                Minimum="1"
                Maximum="10"
                Value="5"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderSpeed_Changed" />
        <TextBlock Text="{loc:Str tooltip_bounce_speed_1_slow_10_fast}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Size -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_size}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtSize"
                     Text="100%"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderSize"
                Minimum="50"
                Maximum="300"
                Value="100"
                TickFrequency="10"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderSize_Changed" />
        <TextBlock Text="{loc:Str tooltip_text_size_50_small_100_normal_300_huge}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Always on top -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str setting_show_over_videos}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_keep_bouncing_text_visible_on_top_of_fullscre}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkAlwaysOnTop"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkAlwaysOnTop_Changed" />
      </Grid>
    </Border>

    <TextBlock Text="{loc:Str label_10_xp_per_bounce}"
               Foreground="#50C878"
               FontSize="12"
               HorizontalAlignment="Center"
               Margin="0,2,0,10" />

    <Button Content="{loc:Str btn_edit_phrases}"
            Click="BtnEditPhrases_Click"
            Background="#1A1A2E"
            Foreground="White"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12,8"
            HorizontalAlignment="Stretch" />
  </StackPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.PremiumGateOverlay"
             x:CompileBindings="False">

  <!-- Full-parent translucent overlay. Shown when IsLocked is true. -->
  <Grid x:Name="RootGrid"
        Background="#B0000000"
        IsVisible="{Binding IsLocked, RelativeSource={RelativeSource AncestorType=UserControl}}">

    <Border VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Background="{DynamicResource SurfaceBgBrush}"
            BorderBrush="#FF69B4"
            BorderThickness="2"
            CornerRadius="16"
            Padding="32,28"
            MaxWidth="420"
            BoxShadow="0 0 28 0 #40000000">

      <StackPanel Spacing="12" HorizontalAlignment="Center">
        <TextBlock Text="🔒"
                   FontSize="48"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center" />

        <TextBlock Text="{Binding Body, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontSize="14"
                   Foreground="#CCCCCC"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center" />

        <Button Content="{Binding ButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Theme="{StaticResource PinkButton}"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Click="BtnUnlock_Click" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

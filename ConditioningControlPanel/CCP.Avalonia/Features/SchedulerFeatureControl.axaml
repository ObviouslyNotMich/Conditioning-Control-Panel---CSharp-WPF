<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.SchedulerFeatureControl"
             Design.DataContext="{x:Null}"
             x:DataType="{x:Type local:SchedulerFeatureControl}">

  <StackPanel>
    <!-- Enable -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{loc:Str setting_scheduler_enable}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <ToggleSwitch x:Name="ChkEnabled"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnabled_Changed" />
      </Grid>
    </Border>

    <!-- Time range -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <TextBlock Text="{loc:Str section_scheduler_time_range}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />
        <Grid ColumnDefinitions="*,Auto,*">
          <TextBox x:Name="TxtStart"
                   Grid.Column="0"
                   Text="16:00"
                   Background="{DynamicResource PanelBgBrush}"
                   Foreground="{DynamicResource TextLightBrush}"
                   BorderBrush="{DynamicResource PinkBrush}"
                   Padding="8,6"
                   FontSize="14"
                   TextAlignment="Center"
                   LostFocus="TxtTime_LostFocus" />
          <TextBlock Grid.Column="1"
                     Text="→"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="16"
                     Margin="10,0"
                     VerticalAlignment="Center" />
          <TextBox x:Name="TxtEnd"
                   Grid.Column="2"
                   Text="22:00"
                   Background="{DynamicResource PanelBgBrush}"
                   Foreground="{DynamicResource TextLightBrush}"
                   BorderBrush="{DynamicResource PinkBrush}"
                   Padding="8,6"
                   FontSize="14"
                   TextAlignment="Center"
                   LostFocus="TxtTime_LostFocus" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Days -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14">
      <StackPanel>
        <TextBlock Text="{loc:Str section_scheduler_active_days}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />
        <WrapPanel HorizontalAlignment="Center">
          <CheckBox x:Name="DayMon"
                    Content="{loc:Str day_mon_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    Margin="0,0,10,0"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
          <CheckBox x:Name="DayTue"
                    Content="{loc:Str day_tue_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    Margin="0,0,10,0"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
          <CheckBox x:Name="DayWed"
                    Content="{loc:Str day_wed_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    Margin="0,0,10,0"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
          <CheckBox x:Name="DayThu"
                    Content="{loc:Str day_thu_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    Margin="0,0,10,0"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
          <CheckBox x:Name="DayFri"
                    Content="{loc:Str day_fri_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    Margin="0,0,10,0"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
          <CheckBox x:Name="DaySat"
                    Content="{loc:Str day_sat_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    Margin="0,0,10,0"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
          <CheckBox x:Name="DaySun"
                    Content="{loc:Str day_sun_short}"
                    Foreground="{DynamicResource TextLightBrush}"
                    IsChecked="True"
                    FontSize="13"
                    IsCheckedChanged="Day_Changed" />
        </WrapPanel>
      </StackPanel>
    </Border>
  </StackPanel>

</UserControl>

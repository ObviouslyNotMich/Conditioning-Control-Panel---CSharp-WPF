<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.BubbleCountFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_enable_bubble_count}"
                     Foreground="White"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str label_bubble_count_description}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Frequency -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_bubble_count_per_hour}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtFreq"
                     Text="2"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFreq"
                Minimum="1"
                Maximum="10"
                Value="2"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderFreq_Changed" />
        <TextBlock Text="{loc:Str tooltip_challenges_per_hour_1_10}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Difficulty -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{loc:Str setting_difficulty}"
                   Foreground="White"
                   FontSize="13"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <ComboBox Grid.Column="1"
                  x:Name="CmbDifficulty"
                  Width="130"
                  SelectionChanged="CmbDifficulty_Changed">
          <ComboBoxItem Content="{loc:Str btn_easy}" Tag="0" />
          <ComboBoxItem Content="{loc:Str btn_medium}" Tag="1" />
          <ComboBoxItem Content="{loc:Str btn_hard}" Tag="2" />
        </ComboBox>
      </Grid>
    </Border>

    <!-- Strict lock -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_bubble_count_strict_lock}"
                     Foreground="White"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_prevent_closing_until_correctly_answered}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkStrict"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkStrict_Changed" />
      </Grid>
    </Border>

    <Button Content="{loc:Str btn_bubble_count_test_now}"
            Click="BtnTest_Click"
            Padding="14,10"
            FontSize="13"
            Background="Transparent"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            Foreground="White"
            CornerRadius="8" />
  </StackPanel>

</UserControl>

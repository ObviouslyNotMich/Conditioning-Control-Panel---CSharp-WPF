<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.SpiralFeatureControl"
             Design.DataContext="{x:Null}"
             x:DataType="{x:Type local:SpiralFeatureControl}">

  <StackPanel>
    <!-- Enable toggle -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str btn_enable}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_show_hypnotic_spiral_overlay}"
                     Foreground="{DynamicResource TextDimBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Opacity slider -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str setting_opacity}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock x:Name="TxtOpacity"
                     Text="15%"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderOpacity"
                Minimum="5"
                Maximum="50"
                Value="15"
                ValueChanged="SliderOpacity_Changed" />
        <TextBlock Text="{loc:Str desc_spiral_opacity_range}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Spiral library -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,10" ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="{loc:Str section_spiral_library}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  x:Name="BtnOpenSpiralFolder"
                  Content="{loc:Str btn_open_spiral_folder}"
                  Theme="{StaticResource OutlineButton}"
                  Padding="10,5"
                  Margin="0,0,6,0"
                  FontSize="11"
                  Click="BtnOpenSpiralFolder_Click" />
          <Button Grid.Column="2"
                  x:Name="BtnRefreshSpirals"
                  Content="{loc:Str btn_refresh_spirals}"
                  Theme="{StaticResource OutlineButton}"
                  Padding="10,5"
                  FontSize="11"
                  Click="BtnRefreshSpirals_Click" />
        </Grid>

        <TextBlock Text="{loc:Str desc_spiral_library}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="10"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="280">
          <WrapPanel x:Name="SpiralLibraryPanel" Orientation="Horizontal" />
        </ScrollViewer>

        <TextBlock x:Name="SpiralEmptyState"
                   IsVisible="False"
                   Text="{loc:Str msg_spiral_library_empty}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0" />
      </StackPanel>
    </Border>

    <!-- Select GIF (browse anywhere) -->
    <Button x:Name="BtnSelectGif"
            Content="{loc:Str btn_select_spiral}"
            Theme="{StaticResource OutlineButton}"
            Padding="12,10"
            Click="BtnSelectGif_Click" />

    <TextBlock Text="{loc:Str msg_display_scaling_warning}"
               Foreground="#FFA500"
               FontSize="10"
               FontStyle="Italic"
               TextWrapping="Wrap"
               Opacity="0.8"
               Margin="0,12,0,0" />
  </StackPanel>

</UserControl>

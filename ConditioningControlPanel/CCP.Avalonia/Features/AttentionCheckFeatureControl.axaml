<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.AttentionCheckFeatureControl"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Master enable -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str feature_attention_checks}"
                     Foreground="White"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str desc_attention_checks}"
                     Foreground="#AAAAAA"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Sliders -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,4">
          <TextBlock Text="{loc:Str label_attention_min_per_hour}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtMin"
                     Text="{loc:Str label_attention_default_min}"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderMin"
                Minimum="0"
                Maximum="20"
                Value="1"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderMin_Changed"
                Margin="0,0,0,10" />

        <Grid Margin="0,0,0,4">
          <TextBlock Text="{loc:Str label_attention_max_per_hour}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtMax"
                     Text="{loc:Str label_attention_default_max}"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderMax"
                Minimum="1"
                Maximum="30"
                Value="5"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderMax_Changed"
                Margin="0,0,0,10" />

        <Grid Margin="0,0,0,4">
          <TextBlock Text="{loc:Str label_attention_grace_window}"
                     Foreground="White"
                     FontSize="12" />
          <TextBlock x:Name="TxtGrace"
                     Text="{loc:Str label_attention_default_grace}"
                     HorizontalAlignment="Right"
                     Foreground="#FF69B4"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderGrace"
                Minimum="1000"
                Maximum="15000"
                Value="4000"
                TickFrequency="500"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderGrace_Changed"
                Margin="0,0,0,10" />
      </StackPanel>
    </Border>

    <!-- Fail mode / scope -->
    <Border Background="#1A1A2E"
            BorderBrush="#FF69B4"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_attention_on_miss}"
                     Foreground="White"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <ComboBox x:Name="CmbFailMode"
                  SelectionChanged="CmbFailMode_Changed"
                  Margin="0,0,0,10">
          <ComboBoxItem Content="{loc:Str label_attention_fail_xp_penalty}" Tag="XpPenalty" />
          <ComboBoxItem Content="{loc:Str label_attention_fail_lock_card}" Tag="LockCard" />
          <ComboBoxItem Content="{loc:Str label_attention_fail_nothing}" Tag="None" />
        </ComboBox>

        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_attention_when}"
                     Foreground="White"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <ComboBox x:Name="CmbScope"
                  SelectionChanged="CmbScope_Changed"
                  Margin="0,0,0,4">
          <ComboBoxItem Content="{loc:Str label_attention_scope_always}" Tag="Always" />
          <ComboBoxItem Content="{loc:Str label_attention_scope_during_sessions_only}" Tag="DuringSessionsOnly" />
        </ComboBox>

        <TextBlock Text="{loc:Str desc_attention_check_rewards}"
                   Foreground="#AAAAAA"
                   FontSize="10"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>

</UserControl>

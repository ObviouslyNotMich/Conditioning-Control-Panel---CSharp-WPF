<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.FlashFeatureControl"
             x:DataType="{x:Type local:FlashFeatureControl}"
             Design.DataContext="{x:Null}">

  <StackPanel>
    <!-- Master enable -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,0,0,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str feature_flash_images}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{loc:Str tooltip_feature_flash_images}"
                     Foreground="{DynamicResource TextDimBrush}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Margin="0,2,0,0" />
        </StackPanel>
        <ToggleSwitch x:Name="ChkEnable"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkEnable_Changed" />
      </Grid>
    </Border>

    <!-- Frequency / per hour -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_per_hour}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtFrequency"
                     Text="10"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFrequency"
                Minimum="1"
                Maximum="180"
                Value="10"
                ValueChanged="SliderFrequency_Changed" />
      </StackPanel>
    </Border>

    <!-- Images per flash -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_images_per_flash}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtImages"
                     Text="5"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderImages"
                Minimum="1"
                Maximum="20"
                Value="5"
                ValueChanged="SliderImages_Changed" />
      </StackPanel>
    </Border>

    <!-- Max on screen -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,14"
            Margin="0,0,0,10">
      <StackPanel>
        <Grid Margin="0,0,0,6">
          <TextBlock Text="{loc:Str label_max_on_screen}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtMaxOnScreen"
                     Text="20"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="13"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderMaxOnScreen"
                Minimum="2"
                Maximum="20"
                Value="20"
                ValueChanged="SliderMaxOnScreen_Changed" />
      </StackPanel>
    </Border>

    <!-- Toggle grid -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12">
      <StackPanel>
        <Grid Margin="0,2" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_click_to_dismiss}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_click_to_dismiss}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkClickable"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkClickable_Changed" />
        </Grid>
        <Grid Margin="0,8" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_hydra_mode}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_hydra_mode}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkCorruption"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkCorruption_Changed" />
        </Grid>
        <Grid Margin="0,2" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_linked_hydra_timing}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_linked_hydra_timing}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkHydraLinked"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkHydraLinked_Changed" />
        </Grid>
        <Grid Margin="0,8,0,2" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_pink_glow}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_pink_glow}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkGlow"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkGlow_Changed" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Gaze interaction toggles (Phase 3) -->
    <Border Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16,12"
            Margin="0,10,0,0">
      <StackPanel>
        <TextBlock Text="{loc:Str section_gaze_interaction}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <Grid Margin="0,2" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_stare_to_pop}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_stare_to_pop}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkFlashGazePop"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkFlashGazePop_Changed" />
        </Grid>

        <Grid Margin="0,8" ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_stare_to_keep}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold" />
            <TextBlock Text="{loc:Str tooltip_stare_to_keep}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
          </StackPanel>
          <ToggleSwitch x:Name="ChkFlashGazeLinger"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsCheckedChanged="ChkFlashGazeLinger_Changed" />
        </Grid>

        <Grid Margin="0,4,0,2">
          <TextBlock Text="{loc:Str label_linger_boost}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="12" />
          <TextBlock x:Name="TxtFlashLingerMs"
                     Text="1500 ms"
                     HorizontalAlignment="Right"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Grid>
        <Slider x:Name="SliderFlashLingerMs"
                Minimum="500"
                Maximum="5000"
                Value="1500"
                TickFrequency="250"
                IsSnapToTickEnabled="True"
                ValueChanged="SliderFlashLingerMs_Changed" />
      </StackPanel>
    </Border>
  </StackPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.ContentPackCard"
             x:Name="Self">

  <Border x:Name="RootBorder"
          Width="192"
          Height="240"
          Background="{DynamicResource SurfaceBgBrush}"
          BorderBrush="{DynamicResource PanelAccentBrush}"
          BorderThickness="1"
          CornerRadius="8"
          ClipToBounds="True">

    <Grid RowDefinitions="72,*">
      <!-- Preview image area -->
      <Border Grid.Row="0"
              Background="{DynamicResource DarkerBgBrush}"
              CornerRadius="8,8,0,0"
              ClipToBounds="True">
        <Grid>
          <Image x:Name="ImgPreview"
                 Stretch="UniformToFill"
                 RenderOptions.BitmapInterpolationMode="HighQuality" />

          <TextBlock x:Name="TxtNoPreview"
                     Text="{loc:Str label_no_preview}"
                     FontSize="14"
                     Foreground="#666666"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsVisible="False" />

          <!-- Size badge -->
          <Border Background="{DynamicResource PinkBrush}"
                  CornerRadius="4"
                  Padding="8,3"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Margin="6">
            <TextBlock x:Name="TxtSize"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="White" />
          </Border>

          <!-- Installed badge -->
          <Border x:Name="InstalledBadge"
                  Background="#4CAF50"
                  CornerRadius="4"
                  Padding="6,2"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="6"
                  IsVisible="False">
            <TextBlock Text="{loc:Str label_installed}"
                       FontSize="8"
                       FontWeight="Bold"
                       Foreground="White" />
          </Border>

          <!-- Manual download badge -->
          <Border x:Name="ManualDownloadBadge"
                  Background="#FFA500"
                  CornerRadius="4"
                  Padding="6,2"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="6"
                  IsVisible="False">
            <TextBlock Text="{loc:Str label_manual_download}"
                       FontSize="8"
                       FontWeight="Bold"
                       Foreground="White" />
          </Border>
        </Grid>
      </Border>

      <!-- Info section -->
      <Grid Grid.Row="1" Margin="6,3,6,3">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtName"
                   Grid.Row="0"
                   Text="{loc:Str label_pack}"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="11"
                   Margin="0,0,0,1" />

        <TextBlock x:Name="TxtDescription"
                   Grid.Row="1"
                   Text=""
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="9"
                   TextWrapping="Wrap"
                   TextTrimming="CharacterEllipsis"
                   MaxHeight="60"
                   VerticalAlignment="Top" />

        <TextBlock x:Name="TxtCounts"
                   Grid.Row="2"
                   Text="{loc:Str label_0_images_0_videos}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="8"
                   Margin="0,1,0,3"
                   FontWeight="SemiBold" />

        <!-- Action buttons -->
        <Grid Grid.Row="3" ColumnDefinitions="*,4,*">
          <Button x:Name="BtnInstall"
                  Grid.Column="0"
                  Content="{loc:Str btn_install}"
                  Theme="{DynamicResource PinkButton}"
                  Padding="4,4"
                  FontSize="10"
                  IsEnabled="{Binding IsDownloading, ElementName=Self, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
          <Button x:Name="BtnActivate"
                  Grid.Column="2"
                  Content="{loc:Str btn_activate}"
                  Theme="{DynamicResource OutlineButton}"
                  Padding="4,4"
                  FontSize="10"
                  IsVisible="{Binding IsDownloaded, ElementName=Self, Mode=OneWay}" />
        </Grid>

        <!-- Progress bar -->
        <ProgressBar x:Name="ProgressBar"
                     Grid.Row="4"
                     Height="4"
                     Margin="0,6,0,0"
                     Minimum="0"
                     Maximum="100"
                     Foreground="{DynamicResource PinkBrush}"
                     Background="{DynamicResource DarkerBgBrush}"
                     IsVisible="{Binding IsDownloading, ElementName=Self, Mode=OneWay}" />

      </Grid>
    </Grid>
  </Border>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:features="using:ConditioningControlPanel.Avalonia.Features"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Features.SchedulerRampFeatureControl"
             Background="{DynamicResource PanelBgBrush}"
             Design.DataContext="{x:Null}"
             x:DataType="{x:Type local:SchedulerRampFeatureControl}">

    <!-- Combined panel: hosts the existing Scheduler and Intensity Ramp
         feature controls back-to-back. Each child keeps its own code-behind
         (load/save), so behaviour is identical to the two separate popups. -->
    <StackPanel>
        <!-- Scheduler section -->
        <TextBlock Text="{loc:Str section_scheduler}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />
        <features:SchedulerFeatureControl />

        <!-- Divider -->
        <Border Height="1"
                Background="{DynamicResource PinkBrush}"
                Margin="0,18,0,18" />

        <!-- Intensity Ramp section -->
        <TextBlock Text="{loc:Str section_intensity_ramp}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />
        <features:IntensityRampFeatureControl />
    </StackPanel>

</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.DisplayNameDialog" x:DataType="x:Object"
        Title="{Binding [dialog_choose_your_display_name], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="240"
        Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False"
        WindowDecorations="None">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <SolidColorBrush x:Key="PinkBrush" Color="{DynamicResource PinkColor}" />
      <SolidColorBrush x:Key="DarkPinkBrush" Color="{DynamicResource DarkPinkColor}" />
      <SolidColorBrush x:Key="WarningBrush" Color="#FFB347" />
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{StaticResource PinkBrush}" BorderThickness="1">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

      <!-- Title -->
      <TextBlock x:Name="TxtTitle"
                 Grid.Row="0"
                 Text="{Binding [label_welcome_choose_your_display_name], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{StaticResource PinkBrush}"
                 FontSize="18"
                 FontWeight="Bold"
                 Margin="0,0,0,10"
                 HorizontalAlignment="Center" />

      <!-- Warning -->
      <Border x:Name="WarningPanel"
              Grid.Row="1"
              Background="#2A2A3E"
              CornerRadius="4"
              Padding="12,8"
              Margin="0,0,0,15">
        <StackPanel x:Name="WarningStack" Orientation="Horizontal" HorizontalAlignment="Center">
          <TextBlock x:Name="TxtWarningLabel"
                     Text="{Binding [label_warning], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{StaticResource WarningBrush}"
                     FontWeight="Bold"
                     FontSize="12"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0" />
          <TextBlock x:Name="TxtWarningText"
                     Text="{Binding [label_this_name_cannot_be_changed_later], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{StaticResource WarningBrush}"
                     FontSize="12"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Prompt -->
      <TextBlock x:Name="TxtPrompt"
                 Grid.Row="2"
                 Text="{Binding [label_enter_the_name_you_d_like_to_be_called], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="13"
                 Margin="0,0,0,8" />

      <!-- Input -->
      <TextBox x:Name="TxtDisplayName"
               Grid.Row="3"
               Background="{DynamicResource PanelBgBrush}"
               Foreground="White"
               BorderBrush="{StaticResource PinkBrush}"
               Padding="12,10"
               FontSize="15"
               MaxLength="20"
               KeyDown="TxtDisplayName_KeyDown" />

      <!-- Character count -->
      <TextBlock x:Name="TxtCharCount"
                 Grid.Row="4"
                 Text="{Binding [label_0_20_characters], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#888888"
                 FontSize="11"
                 Margin="0,5,0,0"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top" />

      <!-- Buttons -->
      <StackPanel Grid.Row="5"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,15,0,0"
                  Spacing="10">
        <Button Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Width="90"
                Padding="10,10"
                Background="{DynamicResource PanelAccentBrush}"
                Foreground="White"
                BorderThickness="0"
                Click="BtnCancel_Click"
                Cursor="Hand"
                FontSize="13" />
        <Button x:Name="BtnConfirm"
                Content="{Binding [btn_confirm], Source={x:Static loc:LocalizationManager.Instance}}"
                Width="90"
                Padding="10,10"
                Background="{StaticResource PinkBrush}"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="13"
                Click="BtnConfirm_Click"
                Cursor="Hand"
                IsEnabled="False" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

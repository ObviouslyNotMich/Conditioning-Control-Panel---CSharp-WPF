<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.WelcomeDialog"
        Title="{Binding [dialog_welcome], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="670"
        Width="520"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="30" RowDefinitions="Auto,Auto,*,Auto">

      <!-- Title Bar with Pink Background -->
      <Border Grid.Row="0"
              Background="{DynamicResource PinkBrush}"
              CornerRadius="8"
              Margin="-10,-10,-10,20"
              Padding="20,15">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <TextBlock Text="💖"
                     FontSize="30"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0" />
          <TextBlock Text="{Binding [app_title], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="White"
                     FontSize="22"
                     FontWeight="Bold"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Welcome Message -->
      <TextBlock x:Name="TxtWelcomeHeading"
                 Grid.Row="1"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="26"
                 FontWeight="Bold"
                 HorizontalAlignment="Center"
                 Margin="0,10,0,20"
                 TextWrapping="Wrap"
                 TextAlignment="Center" />

      <!-- Description -->
      <StackPanel Grid.Row="2" Margin="0,0,0,20" Spacing="0">
        <TextBlock Foreground="#E0E0E0"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="24"
                   TextAlignment="Center"
                   Text="{Binding [label_this_application_is_designed_to_enhance_your], Source={x:Static loc:LocalizationManager.Instance}}" />

        <TextBlock Foreground="#E0E0E0"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="24"
                   TextAlignment="Center"
                   Margin="0,15,0,0"
                   Text="{Binding [label_features_unlock_as_you_level_up_through_use_s], Source={x:Static loc:LocalizationManager.Instance}}" />

        <Border Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Padding="15"
                Margin="0,20,0,0">
          <StackPanel Spacing="4">
            <TextBlock Foreground="#FFB347"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Text="{Binding [label_tips], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBlock Foreground="{DynamicResource PinkBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,8,0,0"
                       FontWeight="SemiBold">
              <Run Text="{Binding [label_click_the], Source={x:Static loc:LocalizationManager.Instance}}" />
              <Run Text=" ? " FontWeight="Bold" Foreground="White" Background="{DynamicResource PinkBrush}" />
              <Run Text="{Binding [label_button_in_the_top_bar_for_a_full_tutorial], Source={x:Static loc:LocalizationManager.Instance}}" />
            </TextBlock>
            <TextBlock Foreground="#B0B0B0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Text="{Binding [label_hover_over_any_setting_to_see_what_it_does], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBlock Foreground="#B0B0B0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Text="{Binding [label_add_videos_to_assets_videos_and_images_to_ass], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBlock Foreground="#B0B0B0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Text="{Binding [label_for_gaming_use_borderless_windowed_mode_for_o], Source={x:Static loc:LocalizationManager.Instance}}" />
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Padding="15"
                Margin="0,20,0,0">
          <StackPanel Spacing="4">
            <TextBlock Foreground="#FFB347"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Text="{Binding [label_performance_warning], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBlock Foreground="#FFB347"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,8,0,0">
              <Run Text="{Binding [label_running_many_features_especially_with_high_fr], Source={x:Static loc:LocalizationManager.Instance}}" />
              <LineBreak />
              <Run Text="{Binding [label_if_you_experience_performance_issues_on_low_e], Source={x:Static loc:LocalizationManager.Instance}}" />
            </TextBlock>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Button -->
      <Button Grid.Row="3"
              Content="{Binding [btn_let_s_begin], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnBegin_Click"
              HorizontalAlignment="Center"
              Theme="{StaticResource ActionButton}"
              FontSize="16"
              Padding="40,16" />
    </Grid>
  </Border>
</Window>

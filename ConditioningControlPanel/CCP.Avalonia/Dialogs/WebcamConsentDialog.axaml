<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        xmlns:docs="using:Avalonia.Controls.Documents"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.WebcamConsentDialog"
        Title="{loc:Str dialog_webcam_consent_webcam_tracking_privacy_consent_title}"
        Width="640"
        Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="32,28,32,24" RowDefinitions="Auto,*,Auto">

    <!-- Step indicator -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,20">
      <Ellipse x:Name="DotStep1" Width="10" Height="10" Fill="{DynamicResource PinkBrush}" />
      <Ellipse x:Name="DotStep2" Width="10" Height="10" Fill="#3A3A52" />
      <Ellipse x:Name="DotStep3" Width="10" Height="10" Fill="#3A3A52" />
      <Ellipse x:Name="DotStep4" Width="10" Height="10" Fill="#3A3A52" />
    </StackPanel>

    <!-- ─── STEP 1 — What this enables ─── -->
    <ScrollViewer x:Name="PanelStep1" Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <TextBlock Text="{loc:Str dialog_webcam_consent_webcam_tracking_lab_feature_text}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold" />
        <TextBlock Text="{loc:Str dialog_webcam_consent_optional_off_by_default_powers_two_text}"
                   Foreground="#B0B0B0"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <TextBlock Foreground="#E8E8E8"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Text="{loc:Str dialog_webcam_consent_optional_feature_uses_webcam_detect_when}" />

        <TextBlock Foreground="{DynamicResource PinkBrush}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="{loc:Str dialog_webcam_consent_what_get}" />

        <TextBlock Margin="14,0,0,0"
                   Foreground="#E8E8E8"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Text="{loc:Str dialog_webcam_consent_webcam_triggers}" />

        <TextBlock Margin="14,0,0,0"
                   Foreground="#E8E8E8"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Text="{loc:Str dialog_webcam_consent_focus_training}" />

        <TextBlock Foreground="#9090A8"
                   FontSize="14"
                   FontStyle="Italic"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Text="{loc:Str dialog_webcam_consent_before_turning_on_next_screen_explains}" />
      </StackPanel>
    </ScrollViewer>

    <!-- ─── STEP 2 — Privacy contract ─── -->
    <ScrollViewer x:Name="PanelStep2" Grid.Row="1" VerticalScrollBarVisibility="Auto" IsVisible="False">
      <StackPanel Spacing="16">
        <TextBlock Text="{loc:Str dialog_webcam_consent_camera_frames_stay_on_computer_text}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold" />
        <TextBlock Text="{loc:Str dialog_webcam_consent_always_read_each_line_text}"
                   Foreground="#B0B0B0"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <Border Padding="20"
                CornerRadius="6"
                Background="#1F1F38"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="0,0,0,3">
          <StackPanel Spacing="12">
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_frames_never_transmitted_not_our_server}" />
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_frames_processed_memory_immediately_discarded_no}" />
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_only_numbers_eyeopen_ratio_gaze_coordinates}" />
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_all_ai_tracking_runs_offline_models}" />
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_audio_never_captured_webcam_microphone_not}" />
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_webcam_light_on_whenever_feature_active}" />
            <TextBlock Foreground="#E8E8E8" FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Text="{loc:Str dialog_webcam_consent_can_disable_instantly_panic_key_inapp}" />
          </StackPanel>
        </Border>

        <StackPanel Spacing="4">
          <TextBlock Foreground="#B8B8C8"
                     FontSize="14"
                     TextWrapping="Wrap"
                     LineHeight="22"
                     Text="{loc:Str dialog_webcam_consent_want_verify_source_code_feature_public_text}" />
          <TextBlock x:Name="LnkSource"
                     Text="{loc:Str dialog_webcam_consent_view_on_github_text}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="14"
                     TextDecorations="Underline"
                     Cursor="Hand"
                     PointerPressed="LnkSource_Click" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <!-- ─── STEP 3 — Explicit consent ─── -->
    <ScrollViewer x:Name="PanelStep3" Grid.Row="1" VerticalScrollBarVisibility="Auto" IsVisible="False">
      <StackPanel Spacing="16">
        <TextBlock Text="{loc:Str dialog_webcam_consent_confirm_consent_text}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold" />
        <TextBlock Text="{loc:Str dialog_webcam_consent_each_box_must_checked_none_prechecked_text}"
                   Foreground="#B0B0B0"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <CheckBox x:Name="ChkConsent1"
                  Margin="0,8,0,0"
                  Foreground="#E8E8E8"
                  FontSize="13"
                  IsCheckedChanged="ConsentCheckChanged">
          <TextBlock TextWrapping="Wrap" Text="{loc:Str dialog_webcam_consent_i_understand_camera_frames_stay_on_text}" />
        </CheckBox>
        <CheckBox x:Name="ChkConsent2"
                  Foreground="#E8E8E8"
                  FontSize="13"
                  IsCheckedChanged="ConsentCheckChanged">
          <TextBlock TextWrapping="Wrap" Text="{loc:Str dialog_webcam_consent_i_understand_frames_processed_memory_never_text}" />
        </CheckBox>
        <CheckBox x:Name="ChkConsent3"
                  Foreground="#E8E8E8"
                  FontSize="13"
                  IsCheckedChanged="ConsentCheckChanged">
          <TextBlock TextWrapping="Wrap" Text="{loc:Str dialog_webcam_consent_i_am_only_person_front_camera_text}" />
        </CheckBox>

        <TextBlock Foreground="#E8E8E8"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,12,0,0"
                   Text="{loc:Str dialog_webcam_consent_type_enable_capitals_confirm}" />
        <TextBox x:Name="TxtConfirm"
                 FontSize="14"
                 Padding="10,8"
                 Background="#1F1F38"
                 Foreground="White"
                 BorderBrush="#3A3A52"
                 BorderThickness="1"
                 CaretBrush="White"
                 TextChanged="TxtConfirm_TextChanged" />

        <TextBlock x:Name="TxtConfirmHint"
                   Foreground="#8888A0"
                   FontSize="14"
                   FontStyle="Italic"
                   TextWrapping="Wrap"
                   Text="{loc:Str dialog_webcam_consent_waiting_3_checkboxes_enable_typed_text}" />
      </StackPanel>
    </ScrollViewer>

    <!-- ─── STEP 4 — Calibration prompt ─── -->
    <ScrollViewer x:Name="PanelStep4" Grid.Row="1" VerticalScrollBarVisibility="Auto" IsVisible="False">
      <StackPanel Spacing="16">
        <TextBlock Text="{loc:Str dialog_webcam_consent_calibration_text}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold" />
        <TextBlock Text="{loc:Str dialog_webcam_consent_quick_onetime_setup_so_camera_knows_text}"
                   Foreground="#B0B0B0"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <TextBlock Foreground="#E8E8E8"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Text="{loc:Str dialog_webcam_consent_two_options_can_switch_later_from}" />

        <Border Padding="18"
                CornerRadius="6"
                Background="#1F1F38">
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_webcam_consent_fast_about_10_seconds_text}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="14"
                       FontWeight="Bold" />
            <TextBlock Text="{loc:Str dialog_webcam_consent_just_left_vs_right_gaze_enough_text}"
                       Foreground="#E8E8E8"
                       FontSize="14"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="18"
                CornerRadius="6"
                Background="#1F1F38">
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_webcam_consent_full_about_45_seconds_text}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="14"
                       FontWeight="Bold" />
            <TextBlock Text="{loc:Str dialog_webcam_consent_twentyfivepoint_precision_55_grid_needed_long_text}"
                       Foreground="#E8E8E8"
                       FontSize="14"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <TextBlock Foreground="#9090A8"
                   FontSize="14"
                   FontStyle="Italic"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   Text="{loc:Str dialog_webcam_consent_can_also_skip_calibrate_later_lab}" />
      </StackPanel>
    </ScrollViewer>

    <!-- Button row -->
    <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="*,Auto,Auto,Auto">
      <Button x:Name="BtnCancel"
              Grid.Column="0"
              HorizontalAlignment="Left"
              Content="{loc:Str dialog_webcam_consent_cancel_content}"
              Click="BtnCancel_Click"
              Theme="{StaticResource SecondaryButton}" />

      <Button x:Name="BtnBack"
              Grid.Column="1"
              Margin="0,0,8,0"
              Content="{loc:Str dialog_webcam_consent_back_content}"
              Click="BtnBack_Click"
              IsVisible="False"
              Theme="{StaticResource SecondaryButton}" />

      <Button x:Name="BtnNext"
              Grid.Column="2"
              Content="{loc:Str dialog_webcam_consent_i_want_know_more_content}"
              Click="BtnNext_Click"
              Theme="{StaticResource ActionButton}" />

      <Button x:Name="BtnEnable"
              Grid.Column="2"
              Content="{loc:Str dialog_webcam_consent_enable_webcam_tracking_content}"
              Click="BtnEnable_Click"
              IsEnabled="False"
              IsVisible="False"
              Theme="{StaticResource ActionButton}" />

      <Button x:Name="BtnSkipCal"
              Grid.Column="2"
              Margin="0,0,8,0"
              Content="{loc:Str dialog_webcam_consent_calibrate_later_content}"
              Click="BtnSkipCal_Click"
              IsVisible="False"
              Theme="{StaticResource SecondaryButton}" />

      <Button x:Name="BtnCalNow"
              Grid.Column="3"
              Content="{loc:Str dialog_webcam_consent_calibrate_now_content}"
              Click="BtnCalNow_Click"
              IsVisible="False"
              Theme="{StaticResource ActionButton}" />
    </Grid>
  </Grid>
</Window>

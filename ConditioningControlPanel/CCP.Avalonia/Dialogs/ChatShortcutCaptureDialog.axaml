<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.ChatShortcutCaptureDialog"
        Title="{Binding [dialog_chat_shortcut_capture_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource DarkerBgBrush}"
        Focusable="True"
        KeyDown="Window_KeyDown">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Padding="20"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="1"
          CornerRadius="8">
    <StackPanel Spacing="12">
      <TextBlock Text="{Binding [dialog_chat_shortcut_capture_prompt], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="White"
                 FontSize="14"
                 TextWrapping="Wrap" />

      <Border Background="{DynamicResource SurfaceBgBrush}"
              CornerRadius="6"
              Padding="12"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1">
        <TextBlock x:Name="TxtCaptured"
                   Text="{Binding [label_chat_shortcut_listening], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />
      </Border>

      <TextBlock Text="{Binding [dialog_chat_shortcut_capture_hint], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="11"
                 TextWrapping="Wrap" />

      <CheckBox x:Name="ChkGlobal"
                Content="{Binding [chat_shortcut_global_checkbox], Source={x:Static loc:LocalizationManager.Instance}}"
                Foreground="White"
                FontSize="12"
                ToolTip.Tip="{Binding [chat_shortcut_global_tooltip], Source={x:Static loc:LocalizationManager.Instance}}" />

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="8">
        <Button x:Name="BtnReset"
                Content="{Binding [btn_reset_to_default], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnReset_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button x:Name="BtnCancel"
                Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnCancel_Click"
                Theme="{StaticResource SecondaryButton}" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>

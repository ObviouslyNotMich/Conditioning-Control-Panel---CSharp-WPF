<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.LockCardColorDialog" x:DataType="x:Object"
        Title="{Binding [dialog_lock_card_colors], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="700"
        Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="{Binding [label_lock_card_colors], Source={x:Static loc:LocalizationManager.Instance}}"
               Foreground="{DynamicResource PinkBrush}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,20" />

    <!-- Color Settings -->
    <StackPanel Grid.Row="1" Margin="0,0,0,20" Spacing="12">

      <!-- Background Color -->
      <Grid ColumnDefinitions="150,*">
        <TextBlock Text="{Binding [label_background], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnBgColor"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnBgColor_Click"
                ToolTip.Tip="{Binding [tooltip_click_to_change_background_color], Source={x:Static loc:LocalizationManager.Instance}}" />
      </Grid>

      <!-- Text Color (Phrase) -->
      <Grid ColumnDefinitions="150,*">
        <TextBlock Text="{Binding [label_phrase_text], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnTextColor"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnTextColor_Click"
                ToolTip.Tip="{Binding [tooltip_click_to_change_phrase_text_color], Source={x:Static loc:LocalizationManager.Instance}}" />
      </Grid>

      <!-- Input Background Color -->
      <Grid ColumnDefinitions="150,*">
        <TextBlock Text="{Binding [label_input_background], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnInputBgColor"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnInputBgColor_Click"
                ToolTip.Tip="{Binding [tooltip_click_to_change_input_field_background], Source={x:Static loc:LocalizationManager.Instance}}" />
      </Grid>

      <!-- Input Text Color -->
      <Grid ColumnDefinitions="150,*">
        <TextBlock Text="{Binding [label_input_text], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnInputTextColor"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnInputTextColor_Click"
                ToolTip.Tip="{Binding [tooltip_click_to_change_input_text_color], Source={x:Static loc:LocalizationManager.Instance}}" />
      </Grid>

      <!-- Accent Color -->
      <Grid ColumnDefinitions="150,*">
        <TextBlock Text="{Binding [label_accent_progress], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnAccentColor"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnAccentColor_Click"
                ToolTip.Tip="{Binding [tooltip_click_to_change_accent_color_progress_bar_bor], Source={x:Static loc:LocalizationManager.Instance}}" />
      </Grid>
    </StackPanel>

    <!-- Preview -->
    <Border Grid.Row="2"
            x:Name="PreviewBorder"
            Background="{DynamicResource DarkerBgBrush}"
            CornerRadius="8"
            Padding="20"
            Margin="0,0,0,20">
      <StackPanel VerticalAlignment="Center" Spacing="15">
        <!-- Title -->
        <TextBlock Text="{Binding [label_type_to_unlock], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="14"
                   HorizontalAlignment="Center" />

        <!-- Phrase to type -->
        <TextBlock x:Name="PreviewPhrase"
                   Text="{Binding [label_good_girls_obey], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <!-- Input field preview -->
        <Border x:Name="PreviewInputBorder"
                Background="{DynamicResource PanelBgBrush}"
                CornerRadius="6"
                Padding="15,10"
                BorderThickness="2">
          <TextBlock x:Name="PreviewInputText"
                     Text="{Binding [label_good_girls_ob], Source={x:Static loc:LocalizationManager.Instance}}"
                     FontSize="16"
                     HorizontalAlignment="Center" />
        </Border>

        <!-- Progress indicator -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
          <TextBlock x:Name="PreviewProgress"
                     Text="1 / 3"
                     FontSize="12" />
          <Border Background="{DynamicResource PanelAccentBrush}"
                  CornerRadius="3"
                  Width="100"
                  Height="6">
            <Border x:Name="PreviewProgressBar"
                    Background="{DynamicResource PinkBrush}"
                    CornerRadius="3"
                    Width="33"
                    HorizontalAlignment="Left" />
          </Border>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Buttons -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto">
      <Button Grid.Column="1"
              Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
              Theme="{StaticResource SecondaryButton}"
              Margin="0,0,10,0"
              Click="BtnCancel_Click" />
      <Button Grid.Column="2"
              Content="{Binding [btn_save], Source={x:Static loc:LocalizationManager.Instance}}"
              Theme="{StaticResource ActionButton}"
              Click="BtnSave_Click" />
    </Grid>
  </Grid>
</Window>

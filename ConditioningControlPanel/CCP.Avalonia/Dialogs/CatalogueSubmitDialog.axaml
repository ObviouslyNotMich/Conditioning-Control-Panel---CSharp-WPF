<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.CatalogueSubmitDialog" x:DataType="x:Object"
        Title="{loc:Str dialog_catalogue_submit_title}"
        SizeToContent="Height"
        MinHeight="420"
        MaxHeight="780"
        Width="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="25" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
        <TextBlock Text="📤"
                   FontSize="30"
                   VerticalAlignment="Center" />
        <TextBlock Text="{loc:Str dialog_catalogue_submit_title}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Subtitle -->
      <TextBlock Grid.Row="1"
                 x:Name="TxtSubtitle"
                 Foreground="#B0B0C0"
                 FontSize="13"
                 Margin="0,0,0,16"
                 TextTrimming="CharacterEllipsis" />

      <!-- Body copy -->
      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    MaxHeight="320">
        <TextBlock Text="{loc:Str dialog_catalogue_submit_body}"
                   Foreground="#E0E0E0"
                   FontSize="14"
                   TextWrapping="Wrap"
                   LineHeight="20"
                   VerticalAlignment="Top" />
      </ScrollViewer>

      <!-- Guidelines hyperlink -->
      <TextBlock Grid.Row="3"
                 Margin="0,14,0,0"
                 FontSize="13"
                 Text="{loc:Str dialog_catalogue_submit_view_guidelines}"
                 Foreground="#B084DC"
                 TextDecorations="Underline"
                 Cursor="Hand"
                 PointerPressed="LinkGuidelines_Click" />

      <!-- Affirmation checkbox -->
      <StackPanel Grid.Row="4"
                  Orientation="Horizontal"
                  Margin="0,20,0,24"
                  Spacing="12">
        <CheckBox x:Name="ChkAffirm"
                  Theme="{StaticResource PinkCheckBox}"
                  VerticalAlignment="Top"
                  IsCheckedChanged="ChkAffirm_IsCheckedChanged" />
        <TextBlock Text="{loc:Str dialog_catalogue_submit_confirm_checkbox}"
                   Foreground="#E0E0E0"
                   FontSize="14"
                   VerticalAlignment="Top"
                   TextWrapping="Wrap"
                   MaxWidth="520" />
      </StackPanel>

      <!-- Spinner -->
      <StackPanel Grid.Row="5"
                  x:Name="PnlSpinner"
                  Orientation="Horizontal"
                  Spacing="8"
                  Margin="0,0,0,12"
                  IsVisible="False">
        <TextBlock Text="⌛" FontSize="14" VerticalAlignment="Center" />
        <TextBlock Text="{loc:Str dialog_catalogue_submit_submitting_text}"
                   Foreground="#B0B0C0"
                   FontSize="13"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Buttons -->
      <Grid Grid.Row="6" ColumnDefinitions="*,*">
        <Button x:Name="BtnCancel"
                Grid.Column="0"
                Content="{loc:Str btn_cancel}"
                Margin="0,0,10,0"
                Click="BtnCancel_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button x:Name="BtnSubmit"
                Grid.Column="1"
                Content="{loc:Str dialog_catalogue_submit_btn}"
                Margin="10,0,0,0"
                Click="BtnSubmit_Click"
                Theme="{StaticResource ActionButton}"
                IsEnabled="False" />
      </Grid>
    </Grid>
  </Border>
</Window>

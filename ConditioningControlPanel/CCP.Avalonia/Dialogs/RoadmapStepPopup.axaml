<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.RoadmapStepPopup"
        Title="{loc:Str dialog_roadmap_step_step_complete_title}"
        Width="400"
        Height="180"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        PointerPressed="Window_PointerPressed">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="#E01A1A2E"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          Margin="10"
          BoxShadow="0 0 20 0 #80FF69B4">
    <Grid Margin="15" ColumnDefinitions="Auto,*">

      <!-- Step Photo/Icon -->
      <Border Grid.Column="0"
              Width="100"
              Height="100"
              Background="{DynamicResource DarkerBgBrush}"
              CornerRadius="50"
              Margin="0,0,15,0"
              ClipToBounds="True">
        <Grid>
          <!-- Photo thumbnail (if available) -->
          <Image x:Name="ImgPhoto"
                 Width="96"
                 Height="96"
                 Stretch="UniformToFill"
                 IsVisible="False" />
          <!-- Default checkmark icon -->
          <TextBlock x:Name="CheckmarkIcon"
                     Text="✓"
                     FontSize="48"
                     FontWeight="Bold"
                     Foreground="#00E676"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- Text Content -->
      <StackPanel Grid.Column="1" VerticalAlignment="Center">
        <!-- Star Icon + "Step Complete" -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <TextBlock Text="✨"
                     FontSize="22"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <TextBlock Text="{loc:Str dialog_roadmap_step_step_complete_text}"
                     Foreground="#FFD700"
                     FontWeight="Bold"
                     FontSize="12"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Step Title -->
        <TextBlock x:Name="TxtStepTitle"
                   Text="{loc:Str dialog_roadmap_step_step_title_text}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontWeight="Bold"
                   FontSize="18"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <!-- Track Name -->
        <TextBlock x:Name="TxtTrackName"
                   Text="{loc:Str dialog_roadmap_step_track_name_text}"
                   Foreground="#AAAAAA"
                   FontSize="12"
                   TextWrapping="Wrap"
                   FontStyle="Italic" />
      </StackPanel>

      <!-- Close Button -->
      <Button Grid.Column="1"
              Content="✕"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Width="24"
              Height="24"
              Margin="0,-5,-5,0"
              Background="Transparent"
              Foreground="#888888"
              BorderThickness="0"
              Click="BtnClose_Click">
        <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="White" />
          </Style>
        </Button.Styles>
      </Button>
    </Grid>
  </Border>
</Window>

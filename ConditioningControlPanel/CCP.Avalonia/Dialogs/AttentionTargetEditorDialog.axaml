<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.AttentionTargetEditorDialog" x:DataType="x:Object"
        Title="{loc:Str dialog_attention_target_editor_attention_target_style_title}"
        Height="520"
        Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="{loc:Str dialog_attention_target_style}"
               Foreground="{DynamicResource PinkBrush}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,15" />

    <!-- Preview Section -->
    <Border Grid.Row="1"
            Background="{DynamicResource PanelBgBrush}"
            CornerRadius="8"
            Padding="20"
            Margin="0,0,0,15">
      <StackPanel>
        <TextBlock Text="{loc:Str section_preview}"
                   Foreground="#808080"
                   FontSize="11"
                   Margin="0,0,0,10" />
        <Border x:Name="PreviewBorder"
                HorizontalAlignment="Center"
                CornerRadius="20"
                Padding="20,10"
                BoxShadow="0 5 15 0 Black"
                Cursor="Hand">
          <Border x:Name="PreviewTextHost" CornerRadius="20">
            <TextBlock x:Name="PreviewText"
                       Text="{loc:Str label_good_girl}"
                       FontSize="40"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Border>
      </StackPanel>
    </Border>

    <!-- Settings -->
    <Border Grid.Row="2"
            Background="{DynamicResource PanelBgBrush}"
            CornerRadius="8"
            Padding="15">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

          <!-- Preset Buttons -->
          <TextBlock Text="{loc:Str label_quick_presets}"
                     Foreground="#808080"
                     FontSize="11"
                     Margin="0,0,0,8" />
          <WrapPanel Margin="0,0,0,15">
            <Button Content="{loc:Str btn_purple_classic}"
                    Theme="{StaticResource SecondaryButton}"
                    Margin="0,0,8,8"
                    Click="PresetPurple_Click" />
            <Button Content="{loc:Str btn_pink_bubbly}"
                    Theme="{StaticResource SecondaryButton}"
                    Margin="0,0,8,8"
                    Click="PresetPink_Click" />
            <Button Content="{loc:Str btn_neon_green}"
                    Theme="{StaticResource SecondaryButton}"
                    Margin="0,0,8,8"
                    Click="PresetGreen_Click" />
            <Button Content="{loc:Str btn_ocean_blue}"
                    Theme="{StaticResource SecondaryButton}"
                    Margin="0,0,8,8"
                    Click="PresetBlue_Click" />
          </WrapPanel>

          <!-- Color 1 -->
          <Grid Margin="0,0,0,12" ColumnDefinitions="120,Auto,*">
            <TextBlock Text="{loc:Str label_primary_color}"
                       Foreground="{DynamicResource TextLightBrush}"
                       VerticalAlignment="Center" />
            <Button x:Name="BtnColor1"
                    Grid.Column="1"
                    Theme="{StaticResource ColorButton}"
                    Click="BtnColor1_Click" />
            <TextBlock x:Name="TxtColor1"
                       Grid.Column="2"
                       Foreground="#808080"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       FontSize="11" />
          </Grid>

          <!-- Color 2 -->
          <Grid Margin="0,0,0,12" ColumnDefinitions="120,Auto,*">
            <TextBlock Text="{loc:Str label_secondary_color}"
                       Foreground="White"
                       VerticalAlignment="Center" />
            <Button x:Name="BtnColor2"
                    Grid.Column="1"
                    Theme="{StaticResource ColorButton}"
                    Click="BtnColor2_Click" />
            <TextBlock x:Name="TxtColor2"
                       Grid.Column="2"
                       Foreground="#808080"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       FontSize="11" />
          </Grid>

          <!-- Text Color -->
          <Grid Margin="0,0,0,12" ColumnDefinitions="120,Auto,*">
            <TextBlock Text="{loc:Str label_text_color}"
                       Foreground="White"
                       VerticalAlignment="Center" />
            <Button x:Name="BtnTextColor"
                    Grid.Column="1"
                    Theme="{StaticResource ColorButton}"
                    Click="BtnTextColor_Click" />
            <TextBlock x:Name="TxtTextColor"
                       Grid.Column="2"
                       Foreground="#808080"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       FontSize="11" />
          </Grid>

          <!-- Floating Text Toggle -->
          <Grid Margin="0,0,0,12" ColumnDefinitions="120,Auto,*">
            <TextBlock Text="{loc:Str label_floating_text}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       ToolTip.Tip="{loc:Str tooltip_remove_background_just_show_text_transparent}" />
            <CheckBox x:Name="ChkFloatingText"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkFloatingText_Changed" />
          </Grid>

          <!-- Border Toggle -->
          <Grid x:Name="BorderToggleRow" Margin="0,0,0,12" ColumnDefinitions="120,Auto,*">
            <TextBlock Text="{loc:Str label_show_border}"
                       Foreground="White"
                       VerticalAlignment="Center" />
            <CheckBox x:Name="ChkShowBorder"
                      Grid.Column="1"
                      VerticalAlignment="Center"
                      IsCheckedChanged="ChkShowBorder_Changed" />
          </Grid>

          <!-- Border Color -->
          <Grid x:Name="BorderColorRow" Margin="0,0,0,12" IsVisible="False" ColumnDefinitions="120,Auto,*">
            <TextBlock Text="{loc:Str label_border_color}"
                       Foreground="White"
                       VerticalAlignment="Center" />
            <Button x:Name="BtnBorderColor"
                    Grid.Column="1"
                    Theme="{StaticResource ColorButton}"
                    Click="BtnBorderColor_Click" />
            <TextBlock x:Name="TxtBorderColor"
                       Grid.Column="2"
                       Foreground="#808080"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       FontSize="11" />
          </Grid>

          <!-- Font -->
          <Grid Margin="0,0,0,8" ColumnDefinitions="120,*">
            <TextBlock Text="{loc:Str label_font}"
                       Foreground="White"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="CmbFont"
                      Grid.Column="1"
                      Background="{DynamicResource SurfaceBgBrush}"
                      Foreground="White"
                      Padding="8,6"
                      SelectionChanged="CmbFont_SelectionChanged">
              <ComboBoxItem Content="{loc:Str btn_segoe_ui}" Tag="Segoe UI" />
              <ComboBoxItem Content="{loc:Str btn_comic_sans_ms}" Tag="Comic Sans MS" />
              <ComboBoxItem Content="{loc:Str btn_impact}" Tag="Impact" />
              <ComboBoxItem Content="{loc:Str btn_arial_black}" Tag="Arial Black" />
              <ComboBoxItem Content="{loc:Str btn_verdana}" Tag="Verdana" />
            </ComboBox>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Footer Buttons -->
    <Grid Grid.Row="3" Margin="0,15,0,0" ColumnDefinitions="Auto,*,Auto">
      <Button Grid.Column="0"
              Content="{loc:Str btn_test_target}"
              Theme="{StaticResource SecondaryButton}"
              Click="BtnTest_Click"
              ToolTip.Tip="{loc:Str tooltip_spawn_a_test_target_to_see_how_it_looks}" />
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
        <Button Content="{loc:Str btn_cancel}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnCancel_Click" />
        <Button Content="{loc:Str btn_save}"
                Theme="{StaticResource ActionButton}"
                Click="BtnSave_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>

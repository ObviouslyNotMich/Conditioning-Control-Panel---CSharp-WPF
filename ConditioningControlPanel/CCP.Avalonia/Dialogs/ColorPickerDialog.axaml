<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.ColorPickerDialog"
        Title="{loc:Str title_pick_color}"
        Width="360"
        Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <Grid RowDefinitions="*,Auto">
    <cp:ColorPicker x:Name="Picker"
                    Margin="15" />

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="15">
      <Button Content="{loc:Str btn_cancel}"
              Click="BtnCancel_Click" />
      <Button Content="{loc:Str btn_ok}"
              Click="BtnOk_Click" />
    </StackPanel>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        xmlns:docs="using:Avalonia.Controls.Documents"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.ExplicitContentAcknowledgementDialog"
        Title="{Binding [explicit_ack_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="560"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="32,28,32,24" RowDefinitions="Auto,Auto,Auto,Auto">
    <StackPanel Grid.Row="0" Spacing="14">
      <TextBlock Text="{Binding [explicit_ack_title], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="20"
                 FontWeight="Bold"
                 TextWrapping="Wrap" />

      <TextBlock Text="{Binding [explicit_ack_body_intro], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#E8E8E8"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="22" />

      <Border Padding="16"
              CornerRadius="6"
              Background="#1F1F38"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="0,0,0,3">
        <StackPanel Spacing="8">
          <TextBlock TextWrapping="Wrap" LineHeight="22">
            <docs:Run FontWeight="Bold" Foreground="{DynamicResource PinkBrush}">•</docs:Run>
            <docs:Run Text="{Binding [explicit_ack_body_age], Source={x:Static loc:LocalizationManager.Instance}}" />
          </TextBlock>
          <TextBlock TextWrapping="Wrap" LineHeight="22">
            <docs:Run FontWeight="Bold" Foreground="{DynamicResource PinkBrush}">•</docs:Run>
            <docs:Run Text="{Binding [explicit_ack_body_policy], Source={x:Static loc:LocalizationManager.Instance}}" />
          </TextBlock>
          <TextBlock TextWrapping="Wrap" LineHeight="22">
            <docs:Run FontWeight="Bold" Foreground="{DynamicResource PinkBrush}">•</docs:Run>
            <docs:Run Text="{Binding [explicit_ack_body_ai], Source={x:Static loc:LocalizationManager.Instance}}" />
          </TextBlock>
        </StackPanel>
      </Border>

      <TextBlock x:Name="LnkPolicy"
                 Text="{Binding [explicit_ack_policy_link], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="22"
                 TextDecorations="Underline"
                 Cursor="Hand"
                 PointerPressed="LnkPolicy_Click" />
    </StackPanel>

    <!-- Required age-confirmation checkbox -->
    <CheckBox x:Name="ChkAgeConfirm"
              Grid.Row="2"
              Margin="0,20,0,0"
              Foreground="#E8E8E8"
              FontSize="13"
              IsCheckedChanged="ChkAgeConfirm_CheckedChanged">
      <TextBlock TextWrapping="Wrap" Text="{Binding [explicit_ack_checkbox], Source={x:Static loc:LocalizationManager.Instance}}" />
    </CheckBox>

    <!-- Button row -->
    <Grid Grid.Row="3" Margin="0,20,0,0" ColumnDefinitions="*,Auto,Auto">
      <Button x:Name="BtnCancel"
              Grid.Column="1"
              Margin="0,0,10,0"
              Content="{Binding [explicit_ack_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnCancel_Click"
              Theme="{StaticResource SecondaryButton}" />

      <Button x:Name="BtnAccept"
              Grid.Column="2"
              IsEnabled="False"
              Content="{Binding [explicit_ack_accept], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnAccept_Click"
              Theme="{StaticResource ActionButton}" />
    </Grid>
  </Grid>
</Window>

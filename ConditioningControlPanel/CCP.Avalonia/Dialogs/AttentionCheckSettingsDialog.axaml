<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        xmlns:features="using:ConditioningControlPanel.Avalonia.Features"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.AttentionCheckSettingsDialog"
        Title="{loc:Str attention_check_settings}"
        Width="460"
        Height="640"
        Background="{DynamicResource DarkerBgBrush}"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="16" RowDefinitions="Auto,*,Auto">
    <TextBlock Grid.Row="0"
               Text="{loc:Str attention_check_settings}"
               Foreground="White"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,12" />

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <features:AttentionCheckFeatureControl />
    </ScrollViewer>

    <Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="Auto,*,Auto">
      <Button Grid.Column="0"
              Content="{loc:Str dialog_attention_check_settings_test_now_content}"
              Padding="14,8"
              Background="#33333A"
              Foreground="White"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              FontWeight="SemiBold"
              Cursor="Hand"
              ToolTip.Tip="{loc:Str dialog_attention_check_settings_fire_a_check_immediately_instead_waiting_tooltip}"
              Click="BtnTestNow_Click" />
      <Button Grid.Column="2"
              Content="{loc:Str btn_close}"
              Padding="20,8"
              Background="{DynamicResource PinkBrush}"
              Foreground="Black"
              BorderThickness="0"
              FontWeight="Bold"
              Cursor="Hand"
              Click="BtnClose_Click" />
    </Grid>
  </Grid>
</Window>

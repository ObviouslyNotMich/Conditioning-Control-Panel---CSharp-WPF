<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.LocalAiSetupWizard"
        Title="{Binding [dialog_local_ai_setup_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="560" Height="540"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <ControlTheme x:Key="WizardButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Template">
          <ControlTemplate>
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}" />
            </Border>
          </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
          <Setter Property="Background" Value="{DynamicResource PanelAccentHoverBrush}" />
        </Style>
        <Style Selector="^:disabled">
          <Setter Property="Opacity" Value="0.4" />
        </Style>
      </ControlTheme>

      <ControlTheme x:Key="WizardPrimaryButton" TargetType="Button" BasedOn="{StaticResource WizardButton}">
        <Setter Property="Background" Value="{StaticResource PinkBrush}" />
        <Style Selector="^:pointerover">
          <Setter Property="Background" Value="#FFFF85C1" />
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Padding="24,18">
      <StackPanel>
        <TextBlock x:Name="TxtStepTitle"
                   Foreground="{StaticResource PinkBrush}"
                   FontSize="20"
                   FontWeight="Bold" />
        <TextBlock x:Name="TxtStepSubtitle"
                   Foreground="#B0B0B0"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0" />
      </StackPanel>
    </Border>

    <!-- Body -->
    <Grid Grid.Row="1" Margin="24,18,24,0">

      <!-- Step: Detecting -->
      <StackPanel x:Name="PanelDetecting" IsVisible="True" VerticalAlignment="Center">
        <TextBlock Foreground="#E0E0E0"
                   FontSize="13"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Text="{Binding [label_local_ai_detecting], Source={x:Static loc:LocalizationManager.Instance}}" />
        <ProgressBar IsIndeterminate="True" Height="6" Margin="0,16,0,0"
                     Background="{DynamicResource PanelBgBrush}"
                     Foreground="{StaticResource PinkBrush}" />
      </StackPanel>

      <!-- Step: Consent -->
      <StackPanel x:Name="PanelConsent" IsVisible="False">
        <TextBlock Foreground="#E0E0E0"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Text="{Binding [label_local_ai_consent_intro], Source={x:Static loc:LocalizationManager.Instance}}" />

        <Border Margin="0,14,0,0" Padding="14,10"
                Background="{DynamicResource PanelBgBrush}" CornerRadius="6">
          <StackPanel>
            <TextBlock Foreground="#E0E0E0"
                       FontSize="13"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Text="{Binding [label_local_ai_consent_will_do], Source={x:Static loc:LocalizationManager.Instance}}" />

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
              <TextBlock Text="•" Foreground="{StaticResource PinkBrush}" FontSize="13" Margin="0,0,8,0" />
              <TextBlock x:Name="TxtConsentLine1"
                         Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                         Text="{Binding [label_local_ai_consent_install_ollama], Source={x:Static loc:LocalizationManager.Instance}}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
              <TextBlock Text="•" Foreground="{StaticResource PinkBrush}" FontSize="13" Margin="0,0,8,0" />
              <TextBlock x:Name="TxtConsentLine2"
                         Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
              <TextBlock Text="•" Foreground="{StaticResource PinkBrush}" FontSize="13" Margin="0,0,8,0" />
              <TextBlock Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                         Text="{Binding [label_local_ai_consent_runs_local], Source={x:Static loc:LocalizationManager.Instance}}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Margin="0,14,0,0"
                   Foreground="#B0B0B0" FontSize="12" TextWrapping="Wrap"
                   Text="{Binding [label_local_ai_consent_disk_note], Source={x:Static loc:LocalizationManager.Instance}}" />

        <CheckBox x:Name="ChkAdvanced" Margin="0,14,0,0"
                  Foreground="#B0B0B0"
                  Content="{Binding [label_local_ai_advanced_use_different_model], Source={x:Static loc:LocalizationManager.Instance}}"
                  IsCheckedChanged="ChkAdvanced_Changed" />
        <Grid x:Name="AdvancedPanel" IsVisible="False" Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                     VerticalAlignment="Center" Margin="0,0,8,0"
                     Text="{Binding [label_local_ai_advanced_model_label], Source={x:Static loc:LocalizationManager.Instance}}" />
          <TextBox Grid.Column="1" x:Name="TxtAdvancedModel"
                   Background="{DynamicResource PanelBgBrush}" Foreground="#E0E0E0"
                   BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                   Padding="6,4" FontSize="13" />
        </Grid>

        <TextBlock Margin="0,14,0,0"
                   Foreground="#B084DC"
                   FontSize="13"
                   TextDecorations="Underline"
                   Cursor="Hand"
                   PointerPressed="LinkManualInstall_Click"
                   Text="{Binding [link_local_ai_manual_install], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>

      <!-- Step: Downloading installer -->
      <StackPanel x:Name="PanelDownloadInstaller" IsVisible="False">
        <TextBlock Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                   Text="{Binding [label_local_ai_downloading_installer], Source={x:Static loc:LocalizationManager.Instance}}" />
        <Border Margin="0,12,0,0" Background="{DynamicResource PanelBgBrush}"
                CornerRadius="4" Height="20" Padding="2">
          <Grid>
            <Border x:Name="DownloadProgressFill"
                    Background="{StaticResource PinkBrush}"
                    CornerRadius="3" HorizontalAlignment="Left" Width="0" />
          </Grid>
        </Border>
        <TextBlock x:Name="TxtDownloadProgress"
                   Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                   Margin="0,8,0,0" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Step: Installing -->
      <StackPanel x:Name="PanelInstalling" IsVisible="False" VerticalAlignment="Center">
        <TextBlock Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"
                   Text="{Binding [label_local_ai_installing], Source={x:Static loc:LocalizationManager.Instance}}" />
        <ProgressBar IsIndeterminate="True" Height="6" Margin="0,16,0,0"
                     Background="{DynamicResource PanelBgBrush}"
                     Foreground="{StaticResource PinkBrush}" />
        <TextBlock Foreground="#B0B0B0" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"
                   Margin="0,12,0,0"
                   Text="{Binding [label_local_ai_installing_hint], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>

      <!-- Step: Pulling model -->
      <StackPanel x:Name="PanelPullModel" IsVisible="False">
        <TextBlock x:Name="TxtPullHeader"
                   Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                   Text="{Binding [label_local_ai_pulling_model], Source={x:Static loc:LocalizationManager.Instance}}" />
        <Border Margin="0,12,0,0" Background="{DynamicResource PanelBgBrush}"
                CornerRadius="4" Height="20" Padding="2">
          <Grid>
            <Border x:Name="PullProgressFill"
                    Background="{StaticResource PinkBrush}"
                    CornerRadius="3" HorizontalAlignment="Left" Width="0" />
          </Grid>
        </Border>
        <TextBlock x:Name="TxtPullStatus"
                   Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                   Margin="0,8,0,0" HorizontalAlignment="Center" />
        <TextBlock x:Name="TxtPullDetail"
                   Foreground="#B0B0B0" FontSize="12" TextWrapping="Wrap"
                   Margin="0,4,0,0" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Step: Smoke test -->
      <StackPanel x:Name="PanelSmokeTest" IsVisible="False" VerticalAlignment="Center">
        <TextBlock Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"
                   Text="{Binding [label_local_ai_smoke_test], Source={x:Static loc:LocalizationManager.Instance}}" />
        <ProgressBar IsIndeterminate="True" Height="6" Margin="0,16,0,0"
                     Background="{DynamicResource PanelBgBrush}"
                     Foreground="{StaticResource PinkBrush}" />
        <TextBlock Foreground="#B0B0B0" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"
                   Margin="0,12,0,0"
                   Text="{Binding [label_local_ai_smoke_test_hint], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>

      <!-- Step: Done -->
      <StackPanel x:Name="PanelDone" IsVisible="False" VerticalAlignment="Center">
        <TextBlock Foreground="{StaticResource PinkBrush}" FontSize="36"
                   HorizontalAlignment="Center" Text="✓" FontWeight="Bold" />
        <TextBlock Foreground="#E0E0E0" FontSize="15" FontWeight="SemiBold"
                   TextWrapping="Wrap" HorizontalAlignment="Center"
                   Margin="0,12,0,0"
                   Text="{Binding [label_local_ai_done], Source={x:Static loc:LocalizationManager.Instance}}" />
        <TextBlock x:Name="TxtDoneDetail"
                   Foreground="#B0B0B0" FontSize="12" TextWrapping="Wrap"
                   Margin="0,8,0,0" HorizontalAlignment="Center"
                   TextAlignment="Center" />
      </StackPanel>

      <!-- Step: Error -->
      <StackPanel x:Name="PanelError" IsVisible="False">
        <TextBlock Foreground="#FF6B6B" FontSize="32" HorizontalAlignment="Center"
                   Text="!" FontWeight="Bold" />
        <TextBlock Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="0,8,0,0" FontWeight="SemiBold"
                   Text="{Binding [label_local_ai_error_heading], Source={x:Static loc:LocalizationManager.Instance}}" />
        <TextBox x:Name="TxtErrorDetail" Margin="0,12,0,0" MaxHeight="180"
                 Background="{DynamicResource PanelBgBrush}" Foreground="#E0E0E0"
                 BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                 Padding="8" FontFamily="Consolas" FontSize="11"
                 IsReadOnly="True" TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
        <TextBlock Margin="0,12,0,0"
                   Foreground="#B084DC" FontSize="13"
                   TextDecorations="Underline"
                   Cursor="Hand"
                   PointerPressed="LinkManualInstall_Click"
                   Text="{Binding [link_local_ai_manual_install], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>
    </Grid>

    <!-- Footer -->
    <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" Padding="20,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="1" x:Name="BtnSecondary" Theme="{StaticResource WizardButton}"
                Margin="0,0,10,0" Click="BtnSecondary_Click"
                Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}" />
        <Button Grid.Column="2" x:Name="BtnPrimary" Theme="{StaticResource WizardPrimaryButton}"
                Click="BtnPrimary_Click"
                Content="{Binding [btn_continue], Source={x:Static loc:LocalizationManager.Instance}}" />
      </Grid>
    </Border>
  </Grid>
</Window>

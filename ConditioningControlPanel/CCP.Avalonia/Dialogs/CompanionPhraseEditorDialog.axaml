<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        xmlns:models="using:ConditioningControlPanel.Core.Models"
        xmlns:dialogs="using:ConditioningControlPanel.Avalonia.Dialogs"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.CompanionPhraseEditorDialog"
        Title="{loc:Str dialog_manage_companion_phrases}"
        Width="840"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="True">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <dialogs:BoolInverterConverter x:Key="BoolInverter" />
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="15" RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,10" Spacing="3">
      <TextBlock Text="{loc:Str label_phrase_manager}"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="18"
                 FontWeight="Bold" />
      <TextBlock Text="{loc:Str label_manage_companion_speech_bubble_phrases_and_co}"
                 Foreground="#808080"
                 FontSize="11" />
    </StackPanel>

    <!-- Toolbar -->
    <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="*,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
        <Button x:Name="BtnSelectAll"
                Content="{loc:Str btn_select_all}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnSelectAll_Click" />
        <Button x:Name="BtnDeselectAll"
                Content="{loc:Str btn_deselect_all}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnDeselectAll_Click" />
        <Button x:Name="BtnEnableSelected"
                Content="{loc:Str btn_enable_selected}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnEnableSelected_Click" />
        <Button x:Name="BtnDisableSelected"
                Content="{loc:Str btn_disable_selected}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnDisableSelected_Click" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Border Background="{DynamicResource PanelBgBrush}"
                BorderBrush="#505070"
                BorderThickness="1"
                CornerRadius="4"
                Width="190"
                VerticalAlignment="Center">
          <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="TxtSearch"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     Padding="8,4"
                     FontSize="11"
                     VerticalContentAlignment="Center"
                     TextChanged="TxtSearch_Changed" />
            <TextBlock x:Name="TxtSearchPlaceholder"
                       Grid.Column="1"
                       Text="{loc:Str label_search_phrases}"
                       Foreground="#707070"
                       FontSize="11"
                       IsHitTestVisible="False"
                       Margin="0,0,9,0"
                       VerticalAlignment="Center" />
          </Grid>
        </Border>
        <TextBlock Text="{loc:Str label_filter}"
                   Foreground="#808080"
                   FontSize="11"
                   VerticalAlignment="Center" />
        <ComboBox x:Name="CmbCategoryFilter"
                  Width="160"
                  FontSize="11"
                  SelectionChanged="CmbCategoryFilter_SelectionChanged" />
      </StackPanel>
    </Grid>

    <!-- Phrase List -->
    <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="5">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="PhraseList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:CompanionPhrase">
              <Border x:Name="RowBorder"
                      Background="#1E1E3A"
                      BorderBrush="#2A2A45"
                      BorderThickness="0,0,0,1"
                      Padding="10,6"
                      Margin="0,0,0,1">
                <Grid ColumnDefinitions="Auto,*,150,Auto,Auto">
                  <CheckBox Grid.Column="0"
                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />

                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding Text}"
                               FontSize="12"
                               Foreground="White"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Text}" />
                    <TextBlock Text="{Binding Category}"
                               FontSize="10"
                               Foreground="#707070" />
                  </StackPanel>

                  <StackPanel Grid.Column="2"
                              Orientation="Horizontal"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Spacing="4">
                    <StackPanel x:Name="HasAudioPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                IsVisible="{Binding HasAudio}">
                      <TextBlock Text="♫ "
                                 Foreground="#50C878"
                                 FontSize="12"
                                 VerticalAlignment="Center" />
                      <TextBlock Text="{Binding AudioDisplayName}"
                                 Foreground="#50C878"
                                 FontSize="10"
                                 VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis"
                                 MaxWidth="90"
                                 ToolTip.Tip="{Binding AudioFileName}" />
                      <Button x:Name="ClearAudioBtn"
                              Content="✖"
                              Background="Transparent"
                              Foreground="#FF6B6B"
                              BorderThickness="0"
                              FontSize="10"
                              Padding="4,0,0,0"
                              VerticalAlignment="Center"
                              ToolTip.Tip="{loc:Str dialog_companion_phrase_editor_remove_audio_tooltip}"
                              IsVisible="{Binding CanClearAudio}"
                              Click="BtnClearAudio_Click"
                              Tag="{Binding}" />
                    </StackPanel>
                    <StackPanel x:Name="NoAudioPanel"
                                Orientation="Horizontal"
                                Spacing="4"
                                IsVisible="{Binding HasAudio, Converter={StaticResource BoolInverter}}">
                      <TextBlock Text="{loc:Str dialog_companion_phrase_editor_no_audio_text}"
                                 Foreground="#606060"
                                 FontSize="10"
                                 VerticalAlignment="Center" />
                      <Button x:Name="BrowseBtn"
                              Content="{loc:Str dialog_companion_phrase_editor_browse_content}"
                              Background="#353550"
                              Foreground="White"
                              BorderThickness="0"
                              FontSize="10"
                              Padding="6,2"
                              VerticalAlignment="Center"
                              Click="BtnBrowseAudio_Click"
                              Tag="{Binding}"
                              IsVisible="{Binding CanBrowseAudio}" />
                    </StackPanel>
                  </StackPanel>

                  <CheckBox Grid.Column="3"
                            IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                            Content="{loc:Str dialog_companion_phrase_editor_on_content}"
                            Foreground="#50C878"
                            FontSize="10"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0" />

                  <Button Grid.Column="4"
                          Content="✖"
                          Background="Transparent"
                          Foreground="#FF69B4"
                          BorderThickness="0"
                          FontSize="13"
                          Padding="6,0,2,0"
                          VerticalAlignment="Center"
                          Click="BtnRemovePhrase_Click"
                          Tag="{Binding}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- Footer Buttons -->
    <Grid Grid.Row="3" Margin="0,10,0,0" ColumnDefinitions="Auto,*,Auto">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
        <Button x:Name="BtnAddPhrase"
                Content="{loc:Str btn_add_phrase}"
                Theme="{StaticResource ActionButton}"
                Click="BtnAddPhrase_Click" />
        <Button x:Name="BtnRemoveSelected"
                Content="{loc:Str btn_remove_selected}"
                Theme="{StaticResource DangerButton}"
                Click="BtnRemoveSelected_Click" />
      </StackPanel>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
        <TextBlock x:Name="TxtTotalCount"
                   Foreground="#808080"
                   FontSize="11"
                   VerticalAlignment="Center" />
        <Button Content="{loc:Str btn_close}"
                Theme="{StaticResource SecondaryButton}"
                Padding="16,6"
                Click="BtnClose_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.KnowledgeLinkEditorDialog"
        Title="{Binding [dialog_add_knowledge_link], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="12"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">

      <!-- URL -->
      <StackPanel Grid.Row="0" Margin="0,0,0,15" Spacing="5">
        <TextBlock Text="{Binding [label_url_2], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontWeight="Bold" />
        <TextBox x:Name="TxtUrl"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PanelAccentBrush}"
                 BorderThickness="1"
                 Padding="8"
                 FontSize="12" />
      </StackPanel>

      <!-- Title -->
      <StackPanel Grid.Row="1" Margin="0,0,0,15" Spacing="5">
        <TextBlock Text="{Binding [label_title], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontWeight="Bold" />
        <TextBox x:Name="TxtTitle"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PanelAccentBrush}"
                 BorderThickness="1"
                 Padding="8"
                 FontSize="12" />
      </StackPanel>

      <!-- Description -->
      <StackPanel Grid.Row="2" Margin="0,0,0,15" Spacing="5">
        <TextBlock Text="{Binding [label_description_optional], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontWeight="Bold" />
        <TextBox x:Name="TxtDescription"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PanelAccentBrush}"
                 BorderThickness="1"
                 Padding="8"
                 FontSize="12"
                 Height="60"
                 TextWrapping="Wrap"
                 AcceptsReturn="True" />
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Grid.Row="4"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="10">
        <Button Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Width="80"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnCancel_Click" />
        <Button Content="{Binding [btn_add], Source={x:Static loc:LocalizationManager.Instance}}"
                Width="80"
                Theme="{StaticResource ActionButton}"
                Click="BtnAdd_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

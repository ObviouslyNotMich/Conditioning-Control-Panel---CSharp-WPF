<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        xmlns:models="using:ConditioningControlPanel.Models"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.CataloguePickerDialog"
        Title="{Binding [dialog_catalogue_picker_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="620"
        Width="640"
        MinHeight="420"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        KeyDown="Window_KeyDown">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="25" RowDefinitions="Auto,Auto,*,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0"
                  Orientation="Horizontal"
                  Spacing="12"
                  Margin="0,0,0,6">
        <TextBlock Text="{Binding [dialog_catalogue_picker_title_icon], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="28"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding [dialog_catalogue_picker_title], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Subtitle -->
      <TextBlock Grid.Row="1"
                 x:Name="TxtSubtitle"
                 Foreground="#B0B0C0"
                 FontSize="13"
                 Margin="0,0,0,14"
                 TextTrimming="CharacterEllipsis" />

      <!-- Entries list -->
      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Focusable="False">
        <ItemsControl x:Name="EntriesList" Focusable="False">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="8" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:CatalogueEntry">
              <Border Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="12,10"
                      Cursor="Hand"
                      Focusable="True"
                      PointerPressed="EntryRow_Click">
                <Grid ColumnDefinitions="Auto,*">
                  <!-- Thumbnail placeholder -->
                  <Border Width="80"
                          Height="50"
                          CornerRadius="4"
                          Background="{DynamicResource DarkerBgBrush}"
                          BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
                          BorderThickness="1"
                          VerticalAlignment="Center"
                          ClipToBounds="True">
                    <TextBlock Text="{Binding [dialog_catalogue_picker_play_icon], Source={x:Static loc:LocalizationManager.Instance}}"
                               FontSize="22"
                               Foreground="#606080"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>

                  <StackPanel Grid.Column="1"
                              Margin="12,0,0,0"
                              Spacing="2">
                    <TextBlock Text="{Binding DisplayTitle}"
                               Foreground="{DynamicResource TextLightBrush}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding BylineText}"
                               Foreground="#B0B0C0"
                               FontSize="12" />
                    <TextBlock Text="{Binding Description}"
                               Foreground="#E0E0E0"
                               FontSize="13"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="38"
                               IsVisible="{Binding HasDescription}" />

                    <ItemsControl ItemsSource="{Binding Tags}"
                                  Margin="0,6,0,0"
                                  IsVisible="{Binding HasTags}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                          <Border Background="{DynamicResource DeeperAccentTransparent20Brush}"
                                  CornerRadius="10"
                                  Padding="8,2"
                                  Margin="0,0,6,4">
                            <TextBlock Text="{Binding }"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextLightBrush}" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="14">
                      <TextBlock Text="{Binding ViewCountText}"
                                 FontSize="11"
                                 Foreground="#9090A8" />
                      <TextBlock Text="{Binding LicenseText}"
                                 FontSize="11"
                                 Foreground="#9090A8" />
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Footer -->
      <Grid Grid.Row="3" Margin="0,14,0,0" ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Text="{Binding [dialog_catalogue_picker_browse_web], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#B084DC"
                   TextDecorations="Underline"
                   Cursor="Hand"
                   PointerPressed="LinkBrowseWeb_Click" />

        <Button Grid.Column="1"
                x:Name="BtnClose"
                Content="{Binding [dialog_catalogue_picker_close], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnClose_Click"
                MinWidth="110"
                Theme="{StaticResource SecondaryButton}" />
      </Grid>
    </Grid>
  </Border>
</Window>

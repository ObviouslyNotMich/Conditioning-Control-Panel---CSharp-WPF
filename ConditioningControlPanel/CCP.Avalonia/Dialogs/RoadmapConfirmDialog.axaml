<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.RoadmapConfirmDialog"
        Title="{Binding [dialog_confirm_photo], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="450"
        Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="12"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="25" RowDefinitions="Auto,*,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
        <TextBlock Text="{Binding [dialog_icon_camera], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="24"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding [dialog_confirm_photo], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Message Content -->
      <StackPanel Grid.Row="1">
        <TextBlock Text="{Binding [label_does_this_photo_show_you_completing], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#E0E0E0"
                   FontSize="14"
                   Margin="0,0,0,10" />
        <TextBlock x:Name="TxtStepTitle"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="16"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15" />
        <Border Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Padding="12">
          <TextBlock x:Name="TxtRequirement"
                     Foreground="#AAAAAA"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </Border>
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,20,0,0"
                  Spacing="10">
        <Button Content="{Binding [btn_no_choose_another], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnNo_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button Content="{Binding [btn_yes_submit], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnYes_Click"
                Theme="{StaticResource ActionButton}" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.ContentPolicyWarningDialog" x:DataType="x:Object"
        Title="{Binding [policy_warning_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="32,28,32,24" RowDefinitions="Auto,Auto">
    <StackPanel Grid.Row="0" Spacing="14">
      <TextBlock Text="{Binding [policy_warning_title], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#E5C76B"
                 FontSize="20"
                 FontWeight="Bold"
                 TextWrapping="Wrap" />

      <TextBlock x:Name="TxtBodyCount"
                 Foreground="#E8E8E8"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="22" />

      <TextBlock Text="{Binding [policy_warning_body_explain], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#E8E8E8"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="22" />

      <TextBlock Text="{Binding [policy_warning_body_link], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#E8E8E8"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="22" />

      <TextBlock x:Name="LnkPolicy"
                 Text="{Binding [moderation_policy_link], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#E5C76B"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="22"
                 TextDecorations="Underline"
                 Cursor="Hand"
                 PointerPressed="LnkPolicy_Click" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,24,0,0" ColumnDefinitions="*,Auto">
      <Button x:Name="BtnOk"
              Grid.Column="1"
              Content="{Binding [policy_warning_ok], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnOk_Click"
              Theme="{StaticResource ActionButton}"
              IsDefault="True" />
    </Grid>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.UsernamePickerDialog"
        Title="{Binding [dialog_choose_your_display_name], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="350"
        Width="450"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2" CornerRadius="10" PointerPressed="Root_PointerPressed">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

      <!-- Title -->
      <TextBlock Grid.Row="0"
                 Text="{Binding [dialog_choose_your_display_name], Source={x:Static loc:LocalizationManager.Instance}}"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="{DynamicResource PinkBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,10" />

      <!-- Subtitle for new users -->
      <TextBlock x:Name="TxtSubtitle"
                 Grid.Row="1"
                 Text="{Binding [label_this_name_will_be_shown_on_the_leaderboard_an], Source={x:Static loc:LocalizationManager.Instance}}"
                 FontSize="12"
                 Foreground="#B0B0B0"
                 TextWrapping="Wrap"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,15" />

      <!-- OG Welcome message (hidden by default) -->
      <Border x:Name="OgWelcomePanel"
              Grid.Row="2"
              IsVisible="False"
              Background="#30FFD700"
              BorderBrush="#FFD700"
              BorderThickness="1"
              CornerRadius="5"
              Padding="10"
              Margin="0,0,0,15">
        <StackPanel>
          <TextBlock Text="{Binding [label_welcome_back_pioneer], Source={x:Static loc:LocalizationManager.Instance}}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="#FFD700"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{Binding [label_you_ve_been_recognized_as_a_season_0_og_your], Source={x:Static loc:LocalizationManager.Instance}}"
                     FontSize="11"
                     Foreground="White"
                     TextWrapping="Wrap"
                     HorizontalAlignment="Center"
                     Margin="0,5,0,0" />
        </StackPanel>
      </Border>

      <!-- Username input -->
      <StackPanel Grid.Row="3" Margin="0,0,0,10">
        <TextBlock Text="{Binding [label_display_name], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="White"
                   FontSize="14"
                   Margin="0,0,0,5" />
        <TextBox x:Name="TxtUsername"
                 FontSize="18"
                 Padding="10,8"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PinkBrush}"
                 MaxLength="30"
                 TextChanged="TxtUsername_TextChanged" />
        <TextBlock x:Name="TxtAvailability"
                   FontSize="11"
                   Margin="0,5,0,0"
                   Foreground="#B0B0B0"
                   Text="{Binding [label_enter_a_unique_display_name_3_30_characters], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>

      <!-- Suggested name (from legacy data or provider) -->
      <StackPanel x:Name="SuggestionPanel"
                  Grid.Row="4"
                  IsVisible="False"
                  Margin="0,0,0,10">
        <TextBlock Text="{Binding [label_suggested_name_from_your_previous_account], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#B0B0B0"
                   FontSize="11" />
        <Button x:Name="BtnUseSuggestion"
                Content=""
                Padding="10,5"
                Background="{DynamicResource AccentTintedBgBrush}"
                Foreground="{DynamicResource PinkBrush}"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnUseSuggestion_Click"
                Margin="0,3,0,0"
                HorizontalAlignment="Left" />
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Grid.Row="5"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,10,0,0"
                  Spacing="10">
        <Button x:Name="BtnCancel"
                Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Padding="20,10"
                Background="{DynamicResource AccentTintedBgBrush}"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnCancel_Click" />
        <Button x:Name="BtnConfirm"
                Content="{Binding [btn_confirm], Source={x:Static loc:LocalizationManager.Instance}}"
                Padding="20,10"
                Background="{DynamicResource PinkBrush}"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="BtnConfirm_Click"
                IsEnabled="False" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

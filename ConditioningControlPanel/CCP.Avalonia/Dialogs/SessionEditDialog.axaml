<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.SessionEditDialog"
        Title="{loc:Str dialog_session_edit_session_editor_title}"
        Height="560"
        Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto">

    <!-- Header -->
    <TextBlock x:Name="TxtTitle"
               Grid.Row="0"
               Text="{loc:Str dialog_session_edit_edit_session_text}"
               Foreground="{DynamicResource PinkBrush}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,15" />

    <!-- Fields -->
    <Border Grid.Row="1"
            Background="{DynamicResource PanelBgBrush}"
            CornerRadius="8"
            Padding="15">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12">

          <!-- Name -->
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_session_edit_name_text}"
                       Foreground="White"
                       FontSize="13" />
            <TextBox x:Name="TxtName"
                     Background="{DynamicResource SurfaceBgBrush}"
                     Foreground="White"
                     BorderBrush="{DynamicResource PinkBrush}"
                     BorderThickness="1"
                     Padding="10,8"
                     FontSize="14" />
          </StackPanel>

          <!-- Icon -->
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_session_edit_icon_text}"
                       Foreground="White"
                       FontSize="13" />
            <TextBox x:Name="TxtIcon"
                     Background="{DynamicResource SurfaceBgBrush}"
                     Foreground="White"
                     BorderBrush="{DynamicResource PinkBrush}"
                     BorderThickness="1"
                     Padding="10,8"
                     FontSize="14" />
          </StackPanel>

          <!-- Duration -->
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_session_edit_duration_minutes_text}"
                       Foreground="White"
                       FontSize="13" />
            <NumericUpDown x:Name="NumDuration"
                           Minimum="1"
                           Maximum="1440"
                           Increment="1"
                           FormatString="0"
                           Background="{DynamicResource SurfaceBgBrush}"
                           Foreground="White"
                           BorderBrush="{DynamicResource PinkBrush}"
                           BorderThickness="1"
                           Padding="10,8"
                           FontSize="14"
                           Width="160"
                           HorizontalAlignment="Left" />
          </StackPanel>

          <!-- Difficulty -->
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_session_edit_difficulty_text}"
                       Foreground="White"
                       FontSize="13" />
            <ComboBox x:Name="CmbDifficulty"
                      Background="{DynamicResource SurfaceBgBrush}"
                      Foreground="White"
                      BorderBrush="{DynamicResource PinkBrush}"
                      BorderThickness="1"
                      Padding="10,8"
                      FontSize="14"
                      Width="160"
                      HorizontalAlignment="Left" />
          </StackPanel>

          <!-- Bonus XP -->
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_session_edit_bonus_xp_text}"
                       Foreground="White"
                       FontSize="13" />
            <NumericUpDown x:Name="NumBonusXP"
                           Minimum="0"
                           Maximum="10000"
                           Increment="50"
                           FormatString="0"
                           Background="{DynamicResource SurfaceBgBrush}"
                           Foreground="White"
                           BorderBrush="{DynamicResource PinkBrush}"
                           BorderThickness="1"
                           Padding="10,8"
                           FontSize="14"
                           Width="160"
                           HorizontalAlignment="Left" />
          </StackPanel>

          <!-- Available -->
          <CheckBox x:Name="ChkAvailable"
                    Content="{loc:Str dialog_session_edit_available_content}"
                    Foreground="White"
                    FontSize="13" />

          <!-- Description -->
          <StackPanel Spacing="4">
            <TextBlock Text="{loc:Str dialog_session_edit_description_text}"
                       Foreground="White"
                       FontSize="13" />
            <TextBox x:Name="TxtDescription"
                     Background="{DynamicResource SurfaceBgBrush}"
                     Foreground="White"
                     BorderBrush="{DynamicResource PinkBrush}"
                     BorderThickness="1"
                     Padding="10,8"
                     FontSize="14"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="100" />
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- Validation error -->
    <TextBlock x:Name="TxtError"
               Grid.Row="2"
               Text=""
               Foreground="{DynamicResource DangerBrush}"
               FontSize="13"
               TextWrapping="Wrap"
               Margin="0,10,0,0"
               IsVisible="False" />

    <!-- Footer Buttons -->
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,15,0,0">
      <Button Content="{loc:Str dialog_session_edit_cancel_content}"
              Theme="{StaticResource SecondaryButton}"
              Click="BtnCancel_Click" />
      <Button Content="{loc:Str dialog_session_edit_save_content}"
              Theme="{StaticResource ActionButton}"
              Click="BtnSave_Click" />
    </StackPanel>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.OpenAiCompatibleSamplerSettingsDialog" x:DataType="x:Object"
        Title="{Binding [dialog_openai_sampler_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="440"
        Height="540"
        Background="{DynamicResource DarkerBgBrush}"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="20,16" RowDefinitions="Auto,Auto,*,Auto,Auto">
    <TextBlock Grid.Row="0"
               Text="{Binding [dialog_openai_sampler_title], Source={x:Static loc:LocalizationManager.Instance}}"
               Foreground="{DynamicResource TextLightBrush}"
               FontSize="16"
               FontWeight="Bold"
               Margin="0,0,0,8" />

    <TextBlock Grid.Row="1"
               Text="{Binding [hint_sampler_settings], Source={x:Static loc:LocalizationManager.Instance}}"
               Foreground="{DynamicResource TextLightBrush}"
               FontSize="12"
               TextWrapping="Wrap"
               Margin="0,0,0,12" />

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <CheckBox x:Name="ChkUseCustomSamplers"
                  Foreground="White"
                  FontSize="13"
                  Content="{Binding [label_sampler_use_custom_settings], Source={x:Static loc:LocalizationManager.Instance}}"
                  IsCheckedChanged="ChkUseCustomSamplers_Changed" />

        <Grid x:Name="InputsPanel" IsEnabled="False" ColumnDefinitions="*,12,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">

          <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_temperature], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtTemperature" />
          </StackPanel>

          <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_top_p], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtTopP" />
          </StackPanel>

          <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_top_k], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtTopK" />
          </StackPanel>

          <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_min_p], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtMinP" />
          </StackPanel>

          <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_frequency_penalty], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtFrequencyPenalty" />
          </StackPanel>

          <StackPanel Grid.Row="2" Grid.Column="2" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_presence_penalty], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtPresencePenalty" />
          </StackPanel>

          <StackPanel Grid.Row="3" Grid.Column="0" Spacing="4">
            <TextBlock Foreground="{DynamicResource TextLightBrush}" FontSize="12"
                       Text="{Binding [label_sampler_repetition_penalty], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtRepetitionPenalty" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>

    <TextBlock x:Name="TxtError"
               Grid.Row="3"
               Foreground="{DynamicResource DangerBrush}"
               FontSize="11"
               TextWrapping="Wrap"
               Margin="0,8,0,0"
               IsVisible="False" />

    <Grid Grid.Row="4" Margin="0,16,0,0" ColumnDefinitions="Auto,*,Auto,Auto">
      <Button Grid.Column="0"
              Content="{Binding [label_sampler_reset_defaults], Source={x:Static loc:LocalizationManager.Instance}}"
              Background="Transparent"
              Foreground="{DynamicResource TextLightBrush}"
              BorderBrush="#505050"
              BorderThickness="1"
              Padding="14,6"
              Click="BtnReset_Click" />

      <Button Grid.Column="2"
              Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
              Margin="0,0,10,0"
              Theme="{StaticResource SecondaryButton}"
              Click="BtnCancel_Click" />

      <Button Grid.Column="3"
              Content="{Binding [btn_ok], Source={x:Static loc:LocalizationManager.Instance}}"
              Theme="{StaticResource ActionButton}"
              Click="BtnOk_Click" />
    </Grid>
  </Grid>
</Window>

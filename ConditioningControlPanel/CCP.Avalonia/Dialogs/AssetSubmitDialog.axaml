<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.AssetSubmitDialog" x:DataType="x:Object"
        Title="{Binding [dialog_catalogue_submit_title], Source={x:Static loc:LocalizationManager.Instance}}"
        SizeToContent="Height"
        MinHeight="480"
        MaxHeight="820"
        Width="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="25" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
        <TextBlock Text="{Binding [dialog_icon_upload], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="30"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding [dialog_catalogue_submit_title], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="22"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Subtitle -->
      <TextBlock Grid.Row="1"
                 x:Name="TxtSubtitle"
                 Foreground="#B0B0C0"
                 FontSize="13"
                 Margin="0,0,0,16"
                 TextTrimming="CharacterEllipsis" />

      <!-- Body copy -->
      <TextBlock Grid.Row="2"
                 Text="{Binding [dialog_catalogue_submit_asset_body], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#E0E0E0"
                 FontSize="14"
                 TextWrapping="Wrap"
                 LineHeight="20"
                 VerticalAlignment="Top"
                 Margin="0,0,0,6" />

      <!-- Creator name -->
      <StackPanel Grid.Row="3" Margin="0,12,0,0" Spacing="4">
        <TextBlock Text="{Binding [dialog_catalogue_submit_creator_label], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#B0B0C0"
                   FontSize="12"
                   FontWeight="SemiBold" />
        <TextBox x:Name="TxtCreator"
                 MaxLength="100"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="#E0E0E0"
                 BorderBrush="{DynamicResource PanelAccentBrush}"
                 BorderThickness="1"
                 Padding="8,6"
                 FontSize="14"
                 CaretBrush="{DynamicResource PinkBrush}"
                 TextChanged="TxtCreator_TextChanged" />
      </StackPanel>

      <!-- Tags -->
      <StackPanel Grid.Row="4" Margin="0,12,0,0" Spacing="4">
        <TextBlock Text="{Binding [dialog_catalogue_submit_tags_label], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#B0B0C0"
                   FontSize="12"
                   FontWeight="SemiBold" />
        <TextBox x:Name="TxtTags"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="#E0E0E0"
                 BorderBrush="{DynamicResource PanelAccentBrush}"
                 BorderThickness="1"
                 Padding="8,6"
                 FontSize="14"
                 CaretBrush="{DynamicResource PinkBrush}" />
        <TextBlock Text="{Binding [dialog_catalogue_submit_tags_hint], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#808090"
                   FontSize="11"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Guidelines + affirmation -->
      <StackPanel Grid.Row="5" Margin="0,14,0,0" Spacing="16">
        <TextBlock FontSize="13"
                   Text="{Binding [dialog_catalogue_submit_view_guidelines], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#B084DC"
                   TextDecorations="Underline"
                   Cursor="Hand"
                   PointerPressed="LinkGuidelines_Click" />

        <StackPanel Orientation="Horizontal" Spacing="12">
          <CheckBox x:Name="ChkAffirm"
                    Theme="{StaticResource PinkCheckBox}"
                    VerticalAlignment="Top"
                    IsCheckedChanged="ChkAffirm_IsCheckedChanged" />
          <TextBlock Text="{Binding [dialog_catalogue_submit_confirm_checkbox], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="#E0E0E0"
                     FontSize="14"
                     VerticalAlignment="Top"
                     TextWrapping="Wrap"
                     MaxWidth="520" />
        </StackPanel>
      </StackPanel>

      <!-- Spinner -->
      <StackPanel Grid.Row="6"
                  x:Name="PnlSpinner"
                  Orientation="Horizontal"
                  Spacing="8"
                  Margin="0,16,0,12"
                  IsVisible="False">
        <TextBlock Text="⌛" FontSize="14" VerticalAlignment="Center" />
        <TextBlock Text="{Binding [dialog_catalogue_submit_spinner], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#B0B0C0"
                   FontSize="13"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Buttons -->
      <Grid Grid.Row="7" Margin="0,20,0,0" ColumnDefinitions="*,*">
        <Button x:Name="BtnCancel"
                Grid.Column="0"
                Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Margin="0,0,10,0"
                Click="BtnCancel_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button x:Name="BtnSubmit"
                Grid.Column="1"
                Content="{Binding [dialog_catalogue_submit_btn], Source={x:Static loc:LocalizationManager.Instance}}"
                Margin="10,0,0,0"
                Click="BtnSubmit_Click"
                Theme="{StaticResource ActionButton}"
                IsEnabled="False" />
      </Grid>
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        xmlns:dialogs="using:ConditioningControlPanel.Avalonia.Dialogs"
        xmlns:models="using:ConditioningControlPanel.Models"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.CompanionPromptEditorDialog"
        Title="{loc:Str dialog_customize_ai_companion}"
        Width="720"
        Height="780"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="True">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <dialogs:NullOrEmptyToVisibilityCollapsedConverter x:Key="NullToCollapsedConverter" />

      <ControlTheme x:Key="ResetButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Template">
          <ControlTemplate>
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}" />
            </Border>
          </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
          <Setter Property="Background" Value="{DynamicResource PanelAccentHoverBrush}" />
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Padding="20,15">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{loc:Str label_customize_your_ai_companion}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
            <Border Background="{DynamicResource DangerBrush}" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
              <TextBlock Text="{loc:Str label_beta}" Foreground="White" FontSize="10" FontWeight="Bold" />
            </Border>
          </StackPanel>

          <!-- Active Prompt Badge -->
          <Border x:Name="ActivePromptBadge"
                  Grid.Column="1"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Background="{DynamicResource DarkerBgBrush}"
                  CornerRadius="12"
                  Padding="12,6">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="{loc:Str label_active}"
                         Foreground="#707070"
                         FontSize="11"
                         VerticalAlignment="Center" />
              <TextBlock x:Name="TxtActivePromptName"
                         Text="{loc:Str label_default}"
                         Foreground="#9370DB"
                         FontSize="11"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>

        <TextBlock Text="{loc:Str label_edit_the_prompts_that_control_how_your_compan}"
                   Foreground="#808080"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" Spacing="10">
          <CheckBox x:Name="ChkUseCustom"
                    Content="{loc:Str btn_enable_custom_prompts}"
                    Foreground="White"
                    VerticalContentAlignment="Center"
                    IsCheckedChanged="ChkUseCustom_Changed" />
          <TextBlock Text="{loc:Str label_uncheck_to_use_default_prompts}"
                     Foreground="#606060"
                     FontSize="11"
                     VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Scrollable Content -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
      <StackPanel x:Name="ContentPanel">

        <!-- Validator banner -->
        <Border x:Name="ValidatorBanner"
                IsVisible="False"
                Margin="0,0,0,12"
                Padding="10,8"
                CornerRadius="4"
                Background="#3D3520"
                BorderBrush="#E5C76B"
                BorderThickness="1">
          <TextBlock x:Name="TxtValidatorBanner"
                     Foreground="#F0E2A6"
                     FontSize="12"
                     TextWrapping="Wrap" />
        </Border>

        <!-- Policy banner full -->
        <Border x:Name="PolicyBannerFull"
                Margin="0,0,0,16"
                Padding="12"
                CornerRadius="4"
                Background="#3D3520"
                BorderBrush="#A98E3A"
                BorderThickness="1">
          <StackPanel Spacing="6">
            <Grid ColumnDefinitions="Auto,*">
              <TextBlock Text="⚠"
                         FontSize="16"
                         Foreground="#E5C76B"
                         VerticalAlignment="Top"
                         Margin="0,0,8,0" />
              <TextBlock Grid.Column="1"
                         Text="{loc:Str prompt_editor_policy_full}"
                         Foreground="#F0E2A6"
                         FontSize="12"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
              <Button x:Name="BtnPolicyReadFull"
                      Content="{loc:Str prompt_editor_policy_read}"
                      Background="Transparent"
                      Foreground="#E5C76B"
                      BorderThickness="0"
                      FontSize="11"
                      Padding="8,4"
                      Click="BtnPolicyRead_Click" />
              <Button x:Name="BtnPolicyGotIt"
                      Content="{loc:Str prompt_editor_policy_got_it}"
                      Background="#A98E3A"
                      Foreground="White"
                      BorderThickness="0"
                      FontSize="11"
                      Padding="12,4"
                      Click="BtnPolicyGotIt_Click" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Policy banner slim -->
        <Border x:Name="PolicyBannerSlim"
                IsVisible="False"
                Margin="0,0,0,12"
                Padding="10,6"
                CornerRadius="4"
                Background="#2A2520"
                BorderBrush="#A98E3A"
                BorderThickness="0,0,0,2">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <TextBlock Text="⚠"
                       FontSize="13"
                       Foreground="#E5C76B"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <Button x:Name="BtnPolicyReadSlim"
                    Grid.Column="2"
                    Content="{loc:Str prompt_editor_policy_read}"
                    Background="Transparent"
                    Foreground="#E5C76B"
                    BorderThickness="0"
                    FontSize="11"
                    Padding="4,0"
                    VerticalAlignment="Center"
                    Click="BtnPolicyRead_Click" />
            <TextBlock Grid.Column="1"
                       Text="{loc:Str prompt_editor_policy_slim}"
                       Foreground="#C8B47A"
                       FontSize="11"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
          </Grid>
        </Border>

        <!-- Section 1: Personality -->
        <Expander IsExpanded="True" Margin="0,0,0,15">
          <Expander.Header>
            <TextBlock Text="{loc:Str setting_personality_normal_mode}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="16"
                       FontWeight="Bold" />
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_define_who_companion_their_vibe_tone_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="TxtPersonality"
                       Height="120"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource PanelBgBrush}"
                       Foreground="#E0E0E0"
                       BorderBrush="{DynamicResource PanelAccentBrush}"
                       BorderThickness="1"
                       Padding="8"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextChanged="OnTextChanged" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_reset}"
                      Theme="{StaticResource ResetButton}"
                      VerticalAlignment="Top"
                      Margin="5,0,0,0"
                      Click="ResetPersonality_Click" />
            </Grid>
          </StackPanel>
        </Expander>

        <!-- Section 2: Explicit Reaction -->
        <Expander IsExpanded="False" Margin="0,0,0,15">
          <Expander.Header>
            <TextBlock Text="{loc:Str setting_explicit_topic_handling}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="16"
                       FontWeight="Bold" />
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_how_should_companion_react_when_mention_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="TxtExplicitReaction"
                       Height="100"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource PanelBgBrush}"
                       Foreground="#E0E0E0"
                       BorderBrush="{DynamicResource PanelAccentBrush}"
                       BorderThickness="1"
                       Padding="8"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextChanged="OnTextChanged" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_reset}"
                      Theme="{StaticResource ResetButton}"
                      VerticalAlignment="Top"
                      Margin="5,0,0,0"
                      Click="ResetExplicitReaction_Click" />
            </Grid>
          </StackPanel>
        </Expander>

        <!-- Section 3: Slut Mode -->
        <Expander IsExpanded="False" Margin="0,0,0,15">
          <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{loc:Str setting_slut_mode_personality}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="16"
                         FontWeight="Bold" />
              <TextBlock Text="{loc:Str label_patreon}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="11"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_define_companions_personality_when_slut_mode_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="TxtSlutMode"
                       Height="140"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource PanelBgBrush}"
                       Foreground="#E0E0E0"
                       BorderBrush="{DynamicResource PanelAccentBrush}"
                       BorderThickness="1"
                       Padding="8"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextChanged="OnTextChanged" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_reset}"
                      Theme="{StaticResource ResetButton}"
                      VerticalAlignment="Top"
                      Margin="5,0,0,0"
                      Click="ResetSlutMode_Click" />
            </Grid>
          </StackPanel>
        </Expander>

        <!-- Section 4: Knowledge Base -->
        <Expander IsExpanded="False" Margin="0,0,0,15">
          <Expander.Header>
            <TextBlock Text="{loc:Str setting_knowledge_base}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="16"
                       FontWeight="Bold" />
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_files_videos_resources_companion_knows_about_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="TxtKnowledgeBase"
                       Height="140"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource PanelBgBrush}"
                       Foreground="#E0E0E0"
                       BorderBrush="{DynamicResource PanelAccentBrush}"
                       BorderThickness="1"
                       Padding="8"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextChanged="OnTextChanged" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_reset}"
                      Theme="{StaticResource ResetButton}"
                      VerticalAlignment="Top"
                      Margin="5,0,0,0"
                      Click="ResetKnowledgeBase_Click" />
            </Grid>
          </StackPanel>
        </Expander>

        <!-- Section 5: Context Reactions -->
        <Expander IsExpanded="False" Margin="0,0,0,15">
          <Expander.Header>
            <TextBlock Text="{loc:Str setting_screen_awareness_reactions}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="16"
                       FontWeight="Bold" />
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_how_companion_reacts_different_apps_websites_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="TxtContextReactions"
                       Height="180"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource PanelBgBrush}"
                       Foreground="#E0E0E0"
                       BorderBrush="{DynamicResource PanelAccentBrush}"
                       BorderThickness="1"
                       Padding="8"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextChanged="OnTextChanged" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_reset}"
                      Theme="{StaticResource ResetButton}"
                      VerticalAlignment="Top"
                      Margin="5,0,0,0"
                      Click="ResetContextReactions_Click" />
            </Grid>
          </StackPanel>
        </Expander>

        <!-- Section 6: Output Rules -->
        <Expander IsExpanded="False" Margin="0,0,0,15">
          <Expander.Header>
            <TextBlock Text="{loc:Str setting_output_rules}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="16"
                       FontWeight="Bold" />
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_control_how_long_responses_emoji_usage_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox x:Name="TxtOutputRules"
                       Height="100"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource PanelBgBrush}"
                       Foreground="#E0E0E0"
                       BorderBrush="{DynamicResource PanelAccentBrush}"
                       BorderThickness="1"
                       Padding="8"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextChanged="OnTextChanged" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_reset}"
                      Theme="{StaticResource ResetButton}"
                      VerticalAlignment="Top"
                      Margin="5,0,0,0"
                      Click="ResetOutputRules_Click" />
            </Grid>
          </StackPanel>
        </Expander>

        <!-- Section 7: Global Knowledge Base Links -->
        <Expander IsExpanded="False" Margin="0,0,0,15">
          <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{loc:Str setting_global_knowledge_base_links}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="16"
                         FontWeight="Bold" />
              <TextBlock Text="{loc:Str label_all_personalities}"
                         Foreground="#50C878"
                         FontSize="11"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Expander.Header>
          <StackPanel Margin="0,10,0,0" Spacing="8">
            <TextBlock Text="{loc:Str dialog_companion_prompt_editor_add_urls_hypno_content_companion_knows_text}"
                         Foreground="#808080"
                         FontSize="11"
                         TextWrapping="Wrap" />

            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
              <ListBox x:Name="LstKnowledgeLinks"
                       Height="120"
                       Background="Transparent"
                       BorderThickness="0"
                       Foreground="White"
                       FontSize="11"
                       SelectionMode="Single">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:KnowledgeBaseLink">
                    <StackPanel Margin="0,2">
                      <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding Url}" Foreground="#707070" FontSize="10" />
                      <TextBlock Text="{Binding Description}"
                                 Foreground="#A0A0A0"
                                 FontSize="10"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding Description, Converter={StaticResource NullToCollapsedConverter}}" />
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{loc:Str btn_add_link}"
                      Theme="{StaticResource ResetButton}"
                      Padding="12,6"
                      Click="AddKnowledgeLink_Click" />
              <Button Content="{loc:Str btn_remove_selected}"
                      Theme="{StaticResource ResetButton}"
                      Padding="12,6"
                      Click="RemoveKnowledgeLink_Click" />
            </StackPanel>
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" Padding="20,15">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <Button x:Name="BtnResetAll"
                Grid.Column="0"
                Content="{loc:Str btn_reset_all_to_defaults}"
                Theme="{StaticResource ResetButton}"
                HorizontalAlignment="Left"
                Click="ResetAll_Click" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,0,10,0">
          <Button x:Name="BtnCancel"
                  Content="{loc:Str btn_cancel}"
                  Theme="{StaticResource SecondaryButton}"
                  Width="80"
                  Click="BtnCancel_Click" />
          <Button x:Name="BtnSave"
                  Content="{loc:Str btn_save}"
                  Theme="{StaticResource ActionButton}"
                  Width="80"
                  Click="BtnSave_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>

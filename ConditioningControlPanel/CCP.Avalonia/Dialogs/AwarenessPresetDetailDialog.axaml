<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.AwarenessPresetDetailDialog"
        Title="{loc:Str dialog_awareness_preset_detail_preset_title}"
        Height="720" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False"
        WindowDecorations="None"
        Topmost="True"
        ShowInTaskbar="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" CornerRadius="0">
    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">

      <!-- Policy banner -->
      <StackPanel Grid.Row="0" Margin="0,0,0,12">
        <Border x:Name="PolicyBannerFull" Padding="12" CornerRadius="4"
                Background="#3D3520" BorderBrush="#A98E3A" BorderThickness="1">
          <StackPanel>
            <DockPanel Margin="0,0,0,6">
              <TextBlock Text="&#9888;" FontSize="16" Foreground="#E5C76B"
                         VerticalAlignment="Top" Margin="0,0,8,0"
                         DockPanel.Dock="Left"/>
              <TextBlock Text="{loc:Str dialog_awareness_preset_detail_do_not_use_prompt_editor_generate_text}"
                         Foreground="#F0E2A6" FontSize="12" TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
            </DockPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
              <Button x:Name="BtnPolicyReadFull"
                      Content="{loc:Str dialog_awareness_preset_detail_read_policy_content}"
                      Background="Transparent" Foreground="#E5C76B"
                      BorderThickness="0" FontSize="11" Cursor="Hand"
                      Padding="8,4" Margin="0,0,8,0"
                      Click="BtnPolicyRead_Click"/>
              <Button x:Name="BtnPolicyGotIt"
                      Content="{loc:Str dialog_awareness_preset_detail_got_content}"
                      Background="#A98E3A" Foreground="White"
                      BorderThickness="0" FontSize="11" Cursor="Hand"
                      Padding="12,4"
                      Click="BtnPolicyGotIt_Click"/>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border x:Name="PolicyBannerSlim" IsVisible="False"
                Padding="10,6" CornerRadius="4" Background="#2A2520"
                BorderBrush="#A98E3A" BorderThickness="0,0,0,2">
          <DockPanel>
            <TextBlock Text="&#9888;" FontSize="13" Foreground="#E5C76B"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       DockPanel.Dock="Left"/>
            <Button x:Name="BtnPolicyReadSlim"
                    Content="{loc:Str dialog_awareness_preset_detail_read_policy_content}"
                    Background="Transparent" Foreground="#E5C76B"
                    BorderThickness="0" FontSize="11" Cursor="Hand"
                    Padding="4,0" VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Click="BtnPolicyRead_Click"/>
            <TextBlock Text="{loc:Str dialog_awareness_preset_detail_content_policy_applies_all_prompts_text}"
                       Foreground="#C8B47A" FontSize="11" TextWrapping="Wrap"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
          </DockPanel>
        </Border>
      </StackPanel>

      <!-- Header -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
        <TextBlock x:Name="TxtIcon" FontSize="36" VerticalAlignment="Center" Margin="0,0,14,0"/>
        <StackPanel x:Name="NameReadPanel" VerticalAlignment="Center">
          <TextBlock x:Name="TxtName" Foreground="White" FontSize="22" FontWeight="Bold"/>
          <TextBlock x:Name="TxtAuthor" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
        </StackPanel>

        <TextBox x:Name="TxtIconEdit" FontSize="28"
                 Width="60" Height="52" MaxLength="4"
                 Background="#1E1E32" Foreground="White"
                 BorderBrush="#3A3A5A" BorderThickness="1"
                 VerticalAlignment="Center" HorizontalContentAlignment="Center"
                 VerticalContentAlignment="Center"
                 Margin="0,0,14,0" IsVisible="False"
                 ToolTip.Tip="{loc:Str dialog_awareness_preset_detail_emoji_short_label_card_eg_tooltip}"/>
        <StackPanel x:Name="NameEditPanel" VerticalAlignment="Center" IsVisible="False">
          <TextBox x:Name="TxtNameEdit" Foreground="White" FontSize="22" FontWeight="Bold"
                   Background="#1E1E32" BorderBrush="#3A3A5A" BorderThickness="1"
                   Padding="4,2" MinWidth="300"
                   ToolTip.Tip="{loc:Str dialog_awareness_preset_detail_preset_name_shown_on_card_tooltip}"/>
          <TextBlock Text="{loc:Str dialog_awareness_preset_detail_custom_preset_text}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- Description read-only -->
      <TextBlock Grid.Row="2" x:Name="TxtDescription"
                 Foreground="#C8C8D6" FontSize="13"
                 TextWrapping="Wrap" Margin="0,0,0,10"/>

      <!-- Description editable -->
      <TextBox Grid.Row="2" x:Name="TxtDescriptionEdit"
               Foreground="White" FontSize="12"
               Background="#1E1E32" BorderBrush="#3A3A5A" BorderThickness="1"
               Padding="6,4" TextWrapping="Wrap" AcceptsReturn="True"
               MinHeight="44" MaxHeight="80"
               Margin="0,0,0,10" IsVisible="False"
               ToolTip.Tip="{loc:Str dialog_awareness_preset_detail_short_description_shown_on_card_tooltip}"/>

      <!-- AI badge -->
      <Border Grid.Row="3" x:Name="BrdAiBadge" IsVisible="False"
              Background="#2A1A3E" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
              CornerRadius="6" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,12">
        <TextBlock Text="{loc:Str dialog_awareness_preset_detail_ai_required_best_experience_falls_back_text}"
                   Foreground="{DynamicResource PinkBrush}" FontSize="10" FontWeight="SemiBold"/>
      </Border>

      <!-- Triggers label -->
      <TextBlock Grid.Row="4" Text="{loc:Str dialog_awareness_preset_detail_triggers_text}" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                 Margin="0,0,0,8"/>

      <!-- Trigger list -->
      <Border Grid.Row="5" Background="#1A1A2E" BorderBrush="#2E2E48" BorderThickness="1" CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="TriggerStack" Margin="10"/>
        </ScrollViewer>
      </Border>

      <!-- Footer note -->
      <TextBlock Grid.Row="6" x:Name="TxtFooterNote"
                 Text="{loc:Str dialog_awareness_preset_detail_changes_save_automatically_text}"
                 Foreground="#8A8AA0" FontSize="10" FontStyle="Italic"
                 Margin="0,8,0,0" IsVisible="False"/>

      <!-- Buttons -->
      <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
        <Button x:Name="BtnDeletePreset" Content="{loc:Str dialog_awareness_preset_detail_delete_preset_content}" Padding="12,8" Margin="0,0,8,0"
                Background="#5A3030" Foreground="White" BorderThickness="0" Cursor="Hand"
                IsVisible="False"
                Click="BtnDeletePreset_Click"/>
        <Button x:Name="BtnClone" Content="{loc:Str dialog_awareness_preset_detail_copy_custom_content}" Padding="12,8" Margin="0,0,8,0"
                Background="#2A2A44" Foreground="White" BorderThickness="0" Cursor="Hand"
                Click="BtnClone_Click"/>
        <Button x:Name="BtnClose" Content="{loc:Str dialog_awareness_preset_detail_close_content}" Padding="12,8" Margin="0,0,8,0"
                Background="#2A2A44" Foreground="White" BorderThickness="0" Cursor="Hand"
                Click="BtnClose_Click"/>
        <Button x:Name="BtnInstall" Content="{loc:Str dialog_awareness_preset_detail_activate_content}" Padding="16,8"
                Background="{DynamicResource PinkBrush}" Foreground="White"
                BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                Click="BtnInstall_Click"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>

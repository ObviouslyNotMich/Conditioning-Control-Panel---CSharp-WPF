<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        xmlns:dialogs="using:ConditioningControlPanel.Avalonia.Dialogs"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.TextEditorDialog"
        Title="{loc:Str dialog_text_editor_text_manager_title}"
        Height="500"
        Width="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="True">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <dialogs:BoolToBrushConverter x:Key="SelectedBackgroundConverter">
        <dialogs:BoolToBrushConverter.TrueBrush>
          <SolidColorBrush Color="#3A2A5A" />
        </dialogs:BoolToBrushConverter.TrueBrush>
        <dialogs:BoolToBrushConverter.FalseBrush>
          <SolidColorBrush Color="{DynamicResource SurfaceBg}" />
        </dialogs:BoolToBrushConverter.FalseBrush>
      </dialogs:BoolToBrushConverter>

      <dialogs:BoolToBrushConverter x:Key="SelectedBorderConverter">
        <dialogs:BoolToBrushConverter.TrueBrush>
          <SolidColorBrush Color="{DynamicResource PinkColor}" />
        </dialogs:BoolToBrushConverter.TrueBrush>
        <dialogs:BoolToBrushConverter.FalseBrush>
          <SolidColorBrush Color="Transparent" />
        </dialogs:BoolToBrushConverter.FalseBrush>
      </dialogs:BoolToBrushConverter>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="15" RowDefinitions="Auto,Auto,*,Auto">

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,15" ColumnDefinitions="*,Auto">
      <TextBlock x:Name="TxtTitle"
                 Text="{loc:Str dialog_text_editor_text_manager_title}"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="18"
                 FontWeight="Bold"
                 VerticalAlignment="Center" />
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="{loc:Str btn_sort_a_z}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnSort_Click" />
        <Button Content="{loc:Str btn_toggle_all}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnToggleAll_Click" />
      </StackPanel>
    </Grid>

    <!-- Add New Item -->
    <Grid Grid.Row="1" Margin="0,0,0,10" ColumnDefinitions="*,Auto">
      <TextBox x:Name="TxtNewItem"
               Grid.Column="0"
               Background="{DynamicResource SurfaceBgBrush}"
               Foreground="{DynamicResource TextLightBrush}"
               BorderBrush="{DynamicResource PinkBrush}"
               BorderThickness="1"
               Padding="10,8"
               FontSize="13"
               VerticalContentAlignment="Center"
               KeyDown="TxtNewItem_KeyDown" />
      <Button Grid.Column="1"
              Content="{loc:Str btn_add_2}"
              Theme="{StaticResource ActionButton}"
              Margin="8,0,0,0"
              Click="BtnAdd_Click" />
    </Grid>

    <!-- Item List -->
    <Border Grid.Row="2"
            Background="{DynamicResource PanelBgBrush}"
            CornerRadius="8">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
        <ItemsControl x:Name="ItemList">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="dialogs:TextItem">
              <Border Background="{Binding IsSelected, Converter={StaticResource SelectedBackgroundConverter}}"
                      BorderBrush="{Binding IsSelected, Converter={StaticResource SelectedBorderConverter}}"
                      BorderThickness="1"
                      CornerRadius="5"
                      Margin="3"
                      Padding="10,8"
                      Cursor="Hand"
                      PointerPressed="Item_Click">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <ToggleSwitch Grid.Column="0"
                                IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                IsCheckedChanged="Toggle_Changed"
                                OnContent=""
                                OffContent=""
                                Margin="0,0,10,0" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Text}"
                             Foreground="White"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="✕"
                             Foreground="#808080"
                             FontSize="14"
                             VerticalAlignment="Center"
                             Cursor="Hand"
                             PointerPressed="BtnRemove_Click"
                             ToolTip.Tip="{loc:Str tooltip_remove_item}">
                    <TextBlock.Styles>
                      <Style Selector="TextBlock:pointerover">
                        <Setter Property="Foreground" Value="#FFFF4757" />
                      </Style>
                    </TextBlock.Styles>
                  </TextBlock>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- Footer Buttons -->
    <Grid Grid.Row="3" Margin="0,15,0,0" ColumnDefinitions="Auto,*,Auto">
      <Button Grid.Column="0"
              Content="{loc:Str btn_remove_selected_2}"
              Theme="{StaticResource DangerButton}"
              Click="BtnRemoveSelected_Click" />
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Content="{loc:Str btn_cancel}"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnCancel_Click" />
        <Button Content="{loc:Str btn_save}"
                Theme="{StaticResource ActionButton}"
                Click="BtnSave_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.InputDialog"
        Title="{loc:Str dialog_input}"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False"
        WindowDecorations="None"
        Topmost="True">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2" CornerRadius="0">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">

      <!-- Title -->
      <TextBlock x:Name="TxtTitle"
                 Grid.Row="0"
                 Text="{loc:Str label_title}"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="18"
                 FontWeight="Bold"
                 Margin="0,0,0,12" />

      <!-- Prompt -->
      <TextBlock x:Name="TxtPrompt"
                 Grid.Row="1"
                 Text="{loc:Str label_enter_value}"
                 Foreground="White"
                 FontSize="13"
                 Margin="0,0,0,10" />

      <!-- Input -->
      <TextBox x:Name="TxtInput"
               Grid.Row="2"
               Background="{DynamicResource PanelBgBrush}"
               Foreground="White"
               BorderBrush="{DynamicResource PinkBrush}"
               BorderThickness="1"
               Padding="10,8"
               FontSize="14"
               KeyDown="TxtInput_KeyDown" />

      <!-- Buttons -->
      <StackPanel Grid.Row="4"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Spacing="10"
                  Margin="0,15,0,0">
        <Button Content="{loc:Str btn_cancel}"
                Width="90"
                Theme="{StaticResource SecondaryButton}"
                Click="BtnCancel_Click" />
        <Button Content="{loc:Str dialog_input_ok_content}"
                Width="90"
                Theme="{StaticResource ActionButton}"
                Click="BtnOK_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

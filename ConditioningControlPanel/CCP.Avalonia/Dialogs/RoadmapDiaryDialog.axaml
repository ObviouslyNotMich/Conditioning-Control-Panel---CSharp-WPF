<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.RoadmapDiaryDialog"
        Title="{loc:Str dialog_transformation_diary}"
        Width="500"
        Height="700"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False"
        Topmost="True">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="15">
    <Grid Margin="25" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

      <!-- Header with Close Button -->
      <Grid Grid.Row="0" Margin="0,0,0,15" ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock x:Name="TxtStepNumber"
                     Text="{loc:Str label_step_1_2}"
                     Foreground="#888888"
                     FontSize="12" />
          <TextBlock x:Name="TxtStepTitle"
                     Text="{loc:Str label_the_blank_slate}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="20"
                     FontWeight="Bold" />
        </StackPanel>
        <Button Content="{loc:Str dialog_roadmap_diary_x_content}"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                Foreground="#888888"
                BorderThickness="0"
                FontSize="16"
                FontWeight="Bold"
                Padding="5"
                Click="BtnClose_Click">
          <Button.Styles>
            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Foreground" Value="{DynamicResource PinkBrush}" />
            </Style>
          </Button.Styles>
        </Button>
      </Grid>

      <!-- Full Resolution Photo -->
      <Border Grid.Row="1"
              CornerRadius="12"
              Background="{DynamicResource PanelBgBrush}"
              Margin="0,0,0,15"
              Height="280"
              ClipToBounds="True">
        <Grid>
          <Image x:Name="ImgFullPhoto"
                 Stretch="Uniform" />
          <TextBlock x:Name="TxtNoPhoto"
                     Text="{loc:Str label_no_photo_available}"
                     Foreground="#666666"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsVisible="False" />
        </Grid>
      </Border>

      <!-- Objective/Requirement -->
      <Border Grid.Row="2"
              Background="{DynamicResource PanelBgBrush}"
              CornerRadius="10"
              Padding="15"
              Margin="0,0,0,15">
        <StackPanel>
          <TextBlock Text="{loc:Str label_objective}"
                     Foreground="#888888"
                     FontSize="11"
                     Margin="0,0,0,4" />
          <TextBlock x:Name="TxtObjective"
                     Foreground="White"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Completion Stats -->
      <Border Grid.Row="3"
              Background="{DynamicResource PanelBgBrush}"
              CornerRadius="10"
              Padding="15"
              Margin="0,0,0,15">
        <Grid ColumnDefinitions="*,*">
          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="{loc:Str label_completed}"
                       Foreground="#888888"
                       FontSize="11"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="TxtCompletedDate"
                       Text="{loc:Str label_jan_15_2024}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
            <TextBlock x:Name="TxtCompletedTime"
                       Text="{loc:Str label_3_45_pm}"
                       Foreground="#888888"
                       FontSize="11"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <StackPanel Grid.Column="1" HorizontalAlignment="Center">
            <TextBlock Text="{loc:Str label_time_taken}"
                       Foreground="#888888"
                       FontSize="11"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="TxtTimeTaken"
                       Text="{loc:Str label_45_minutes}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- User Note -->
      <Border Grid.Row="4"
              Background="{DynamicResource PanelBgBrush}"
              CornerRadius="10"
              Padding="15">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0"
                     Text="{loc:Str label_personal_note}"
                     Foreground="#888888"
                     FontSize="11"
                     Margin="0,0,0,8" />
          <TextBox x:Name="TxtUserNote"
                   Grid.Row="1"
                   Background="Transparent"
                   Foreground="White"
                   BorderThickness="0"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   FontSize="13"
                   Padding="0"
                   CaretBrush="{DynamicResource PinkBrush}" />
        </Grid>
      </Border>

      <!-- Buttons -->
      <StackPanel Grid.Row="5"
                  Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Margin="0,15,0,0"
                  Spacing="10">
        <Button Content="{loc:Str btn_save_note}"
                Theme="{StaticResource ActionButton}"
                Padding="20,10"
                Click="BtnSaveNote_Click" />
        <Button Content="{loc:Str btn_close}"
                Theme="{StaticResource SecondaryButton}"
                Padding="20,10"
                Click="BtnClose_Click" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

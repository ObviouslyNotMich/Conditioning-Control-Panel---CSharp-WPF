<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.WarningDialog" x:DataType="x:Object"
        Title="{loc:Str dialog_warning_warning_title}"
        Height="340"
        MinHeight="340"
        MaxHeight="800"
        Width="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="25" RowDefinitions="Auto,*,Auto,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
        <TextBlock x:Name="TxtIcon"
                   Text="⚠"
                   FontSize="32"
                   VerticalAlignment="Center"
                   Margin="0,0,14,0" />
        <TextBlock x:Name="TxtTitle"
                   Text="{loc:Str dialog_warning_warning_title}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Message -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    MaxHeight="500">
        <TextBlock x:Name="TxtMessage"
                   Text="{loc:Str dialog_warning_sure_want_enable_text}"
                   Foreground="#E0E0E0"
                   FontSize="15"
                   TextWrapping="Wrap"
                   LineHeight="22"
                   VerticalAlignment="Top" />
      </ScrollViewer>

      <!-- Confirmation Toggle -->
      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  Margin="0,20,0,24">
        <ToggleSwitch x:Name="ChkConfirm"
                      IsCheckedChanged="ChkConfirm_Changed"
                      OnContent=""
                      OffContent=""
                      VerticalAlignment="Center" />
        <TextBlock x:Name="TxtConfirmLabel"
                   Text="{loc:Str dialog_warning_i_understand_risks_text}"
                   Foreground="#FFB347"
                   FontSize="14"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Buttons -->
      <Grid Grid.Row="3" ColumnDefinitions="*,*">
        <Button x:Name="BtnCancel"
                Grid.Column="0"
                Content="{loc:Str btn_cancel}"
                Margin="0,0,10,0"
                Click="BtnCancel_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button x:Name="BtnConfirm"
                Grid.Column="1"
                Content="{loc:Str btn_enable_anyway}"
                Margin="10,0,0,0"
                Click="BtnConfirm_Click"
                Theme="{StaticResource DangerButton}"
                IsEnabled="False" />
      </Grid>
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        xmlns:models="using:ConditioningControlPanel.Core.Models"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.ModManagerDialog"
        Title="{loc:Str dialog_mod_manager}"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          BoxShadow="0 8 24 0 #80000000">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Title Bar -->
      <Border Grid.Row="0"
              Background="{DynamicResource PanelBgBrush}"
              CornerRadius="12,12,0,0"
              Padding="20,12"
              PointerPressed="TitleBar_PointerPressed">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="{loc:Str dialog_mod_manager}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="18"
                     FontWeight="Bold"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Content="{loc:Str dialog_mod_manager_x_content}"
                  Click="BtnClose_Click"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Background="Transparent"
                  Foreground="#B0B0B0"
                  FontSize="16"
                  FontWeight="Bold"
                  BorderThickness="0"
                  Cursor="Hand"
                  Padding="8,2"
                  Width="30"
                  Height="30" />
        </Grid>
      </Border>

      <!-- Main Content -->
      <Grid Grid.Row="1" Margin="15" ColumnDefinitions="200,*">

        <!-- Mod List -->
        <Border Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Margin="0,0,10,0"
                Padding="5">
          <Grid>
            <ListBox x:Name="ModList"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectionChanged="ModList_SelectionChanged"
                     Foreground="White"
                     FontSize="13">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:ModPackage">
                  <TextBlock Text="{Binding Name}"
                             Foreground="White"
                             Padding="10,8" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock x:Name="TxtNoMods"
                       Text="{loc:Str dialog_mod_manager_no_mods_available_text}"
                       Foreground="#808080"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsVisible="True" />
          </Grid>
        </Border>

        <!-- Details Panel -->
        <Border Grid.Column="1"
                Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Padding="20">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="DetailsPanel" IsVisible="False" Spacing="8">
              <TextBlock x:Name="TxtModName"
                         FontSize="20"
                         FontWeight="Bold"
                         Foreground="White" />
              <TextBlock x:Name="TxtModAuthor"
                         FontSize="12"
                         Foreground="#808080" />
              <TextBlock x:Name="TxtModVersion"
                         FontSize="12"
                         Foreground="#808080" />
              <TextBlock x:Name="TxtModDescription"
                         FontSize="13"
                         Foreground="#C0C0C0"
                         TextWrapping="Wrap" />

              <!-- Theme Color Preview -->
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{loc:Str label_theme}"
                           Foreground="#808080"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <Border x:Name="ThemeColorPreview"
                        Width="20"
                        Height="20"
                        CornerRadius="4" />
                <TextBlock x:Name="TxtThemeColor"
                           FontSize="12"
                           Foreground="#A0A0A0"
                           VerticalAlignment="Center" />
              </StackPanel>

              <!-- Companion Info -->
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{loc:Str label_companion}"
                           Foreground="#808080"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="TxtCompanion"
                           FontSize="12"
                           Foreground="#A0A0A0"
                           VerticalAlignment="Center" />
              </StackPanel>

              <!-- Active Indicator -->
              <TextBlock x:Name="TxtActiveIndicator"
                         Text="{loc:Str label_currently_active}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="#4CAF50"
                         IsVisible="False" />

              <!-- Action Buttons -->
              <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                <Button x:Name="BtnActivate"
                        Content="{loc:Str btn_activate}"
                        Theme="{StaticResource ActionButton}"
                        Click="BtnActivate_Click" />
                <Button x:Name="BtnUninstall"
                        Content="{loc:Str btn_uninstall}"
                        Background="{DynamicResource PanelAccentBrush}"
                        Foreground="#FF6B6B"
                        FontWeight="SemiBold"
                        Padding="16,8"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnUninstall_Click" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>

      <!-- Bottom Bar -->
      <Border Grid.Row="2"
              Background="{DynamicResource PanelBgBrush}"
              CornerRadius="0,0,12,12"
              Padding="15,10">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10">
          <Button x:Name="BtnInstall"
                  Content="{loc:Str btn_install_from_file}"
                  Theme="{StaticResource SecondaryButton}"
                  Click="BtnInstall_Click" />
          <Button x:Name="BtnExport"
                  Content="{loc:Str btn_export_current}"
                  Theme="{StaticResource SecondaryButton}"
                  Click="BtnExport_Click" />
          <Button x:Name="BtnCreate"
                  Content="{loc:Str btn_create_new_2}"
                  Theme="{StaticResource ActionButton}"
                  Click="BtnCreate_Click" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.RoadmapStartDialog"
        Title="{Binding [dialog_start_step], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="480"
        Height="340"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="12"
          BoxShadow="0 8 24 0 #80000000">
    <Grid Margin="25" RowDefinitions="Auto,*,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0" Margin="0,0,0,15">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
          <TextBlock x:Name="TxtStepIcon"
                     Text="📷"
                     FontSize="24"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding [label_ready_to_complete], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="20"
                     FontWeight="Bold"
                     Margin="10,0,0,0"
                     VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock x:Name="TxtStepTitle"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,5,0,0" />
      </StackPanel>

      <!-- Content -->
      <StackPanel Grid.Row="1" Spacing="15">
        <!-- Objective -->
        <TextBlock Text="{Binding [label_objective_2], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#888888"
                   FontSize="12" />
        <Border Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Padding="12">
          <TextBlock x:Name="TxtObjective"
                     Foreground="#E0E0E0"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </Border>

        <!-- Photo Requirement -->
        <TextBlock Text="{Binding [label_photo_required], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#888888"
                   FontSize="12" />
        <Border Background="{DynamicResource PanelBgBrush}"
                CornerRadius="8"
                Padding="12">
          <TextBlock x:Name="TxtPhotoRequirement"
                     Foreground="#AAAAAA"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </Border>
      </StackPanel>

      <!-- Buttons -->
      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,20,0,0"
                  Spacing="10">
        <Button Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnCancel_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button Content="{Binding [btn_select_photo], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnStart_Click"
                Theme="{StaticResource ActionButton}" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

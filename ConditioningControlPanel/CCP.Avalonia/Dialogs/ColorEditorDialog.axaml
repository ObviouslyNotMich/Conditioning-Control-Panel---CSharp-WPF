<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.ColorEditorDialog"
        Title="{loc:Str dialog_color_editor_color_editor_title}"
        Height="480"
        Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="20" RowDefinitions="Auto,*,Auto,Auto">

    <!-- Header -->
    <TextBlock Grid.Row="0"
               Text="{loc:Str label_subliminal_colors}"
               Foreground="{DynamicResource PinkBrush}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,20" />

    <!-- Color Settings -->
    <StackPanel Grid.Row="1" Margin="0,0,0,20">

      <!-- Background Color -->
      <Grid Margin="0,0,0,15" ColumnDefinitions="*,Auto,Auto">
        <TextBlock Text="{loc:Str label_background}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnBgColor"
                Grid.Column="1"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnBgColor_Click"
                ToolTip.Tip="{loc:Str tooltip_click_to_change}" />
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Margin="15,0,0,0"
                    VerticalAlignment="Center">
          <TextBlock Text="{loc:Str label_transparent}"
                     Foreground="#808080"
                     FontSize="11"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <CheckBox x:Name="ChkBgTransparent"
                    IsCheckedChanged="ChkBgTransparent_Changed" />
        </StackPanel>
      </Grid>

      <!-- Text Color -->
      <Grid Margin="0,0,0,15" ColumnDefinitions="*,Auto,Auto">
        <TextBlock Text="{loc:Str label_text_5}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnTextColor"
                Grid.Column="1"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnTextColor_Click"
                ToolTip.Tip="{loc:Str tooltip_click_to_change}" />
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Margin="15,0,0,0"
                    VerticalAlignment="Center"
                    IsVisible="False">
          <TextBlock Text="{loc:Str label_transparent}"
                     Foreground="#808080"
                     FontSize="11"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0" />
          <CheckBox x:Name="ChkTextTransparent" />
        </StackPanel>
      </Grid>

      <!-- Border Color -->
      <Grid Margin="0,0,0,15" ColumnDefinitions="*,Auto">
        <TextBlock Text="{loc:Str label_border_outline}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   VerticalAlignment="Center" />
        <Button x:Name="BtnBorderColor"
                Grid.Column="1"
                Theme="{StaticResource ColorButtonLarge}"
                Click="BtnBorderColor_Click"
                ToolTip.Tip="{loc:Str tooltip_click_to_change}" />
      </Grid>

      <!-- Steal Focus Toggle -->
      <Grid Margin="0,10,0,0" ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="{loc:Str label_steal_keyboard_focus}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="14" />
          <TextBlock Text="{loc:Str label_forces_attention_by_stealing_keyboard_focus_w}"
                     Foreground="#808080"
                     FontSize="10"
                     Margin="0,2,0,0" />
        </StackPanel>
        <CheckBox x:Name="ChkStealsFocus"
                  Grid.Column="1"
                  IsCheckedChanged="ChkStealsFocus_Changed"
                  VerticalAlignment="Center" />
      </Grid>
    </StackPanel>

    <!-- Preview -->
    <Border Grid.Row="2"
            x:Name="PreviewBorder"
            Background="Black"
            CornerRadius="8"
            Height="80"
            Margin="0,0,0,20">
      <Border x:Name="PreviewTextHost" CornerRadius="8">
        <TextBlock x:Name="PreviewText"
                   Text="{loc:Str label_good_girl}"
                   FontSize="28"
                   FontWeight="Bold"
                   FontFamily="Arial"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>
    </Border>

    <!-- Buttons -->
    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto">
      <Button Grid.Column="1"
              Content="{loc:Str btn_cancel}"
              Theme="{StaticResource SecondaryButton}"
              Margin="0,0,10,0"
              Click="BtnCancel_Click" />
      <Button Grid.Column="2"
              Content="{loc:Str btn_save}"
              Theme="{StaticResource ActionButton}"
              Click="BtnSave_Click" />
    </Grid>
  </Grid>
</Window>

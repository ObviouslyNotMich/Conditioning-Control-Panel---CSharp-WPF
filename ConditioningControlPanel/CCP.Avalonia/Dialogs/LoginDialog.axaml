<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Dialogs.LoginDialog" x:DataType="x:Object"
        Title="{loc:Str btn_login}"
        Height="560"
        Width="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2" CornerRadius="10" PointerPressed="Root_PointerPressed">
    <Grid Margin="25" RowDefinitions="Auto,*,Auto">

      <!-- Title -->
      <StackPanel Grid.Row="0" Margin="0,0,0,20">
        <TextBlock Text="{loc:Str login_welcome}"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PinkBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str login_choose_method}"
                   FontSize="13"
                   Foreground="#B0B0B0"
                   HorizontalAlignment="Center"
                   Margin="0,5,0,0" />
      </StackPanel>

      <!-- Provider Selection (Initial State) -->
      <StackPanel x:Name="ProviderPanel" Grid.Row="1" VerticalAlignment="Center" Spacing="15">
        <Button x:Name="BtnLoginDiscord"
                Padding="20,15"
                Background="#5865F2"
                Foreground="{DynamicResource TextLightBrush}"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="16"
                Cursor="Hand"
                Click="BtnLoginDiscord_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{loc:Str label_text_6}"
                       FontSize="20"
                       Margin="0,0,10,0" />
            <TextBlock Text="{loc:Str login_discord}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button x:Name="BtnLoginPatreon"
                Padding="20,15"
                Background="#FF424D"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="16"
                Cursor="Hand"
                Click="BtnLoginPatreon_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{loc:Str label_text_7}"
                       FontSize="20"
                       Margin="0,0,10,0" />
            <TextBlock Text="{loc:Str login_patreon}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button x:Name="BtnLoginSubscribeStar"
                Padding="20,15"
                Background="#009E8F"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="16"
                Cursor="Hand"
                Click="BtnLoginSubscribeStar_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="★" FontSize="20" Margin="0,0,10,0" />
            <TextBlock Text="{loc:Str dialog_login_login_subscribestar_text}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button x:Name="BtnLoginAccount"
                Padding="20,15"
                Background="{DynamicResource AccentTintedBgBrush}"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="16"
                Cursor="Hand"
                Click="BtnLoginAccount_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{loc:Str label_text_3}"
                       FontSize="20"
                       Margin="0,0,10,0" />
            <TextBlock Text="{loc:Str login_anonymous}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button x:Name="BtnLoginDeviceCode"
                Padding="20,15"
                Background="#9333EA"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="16"
                Cursor="Hand"
                Click="BtnLoginDeviceCode_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{loc:Str dialog_login_sign_via_web_text}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Account Login/Register Panel -->
      <StackPanel x:Name="AccountPanel" Grid.Row="1" IsVisible="False" VerticalAlignment="Center" Spacing="8">
        <TextBlock x:Name="TxtAccountTitle"
                   Text="{loc:Str btn_login}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15" />

        <TextBlock x:Name="LblInviteCodeHint"
                   Text="{loc:Str label_for_an_invite_code_please_ask_a_discord_mod_a}"
                   FontSize="11"
                   Foreground="#808080"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"
                   IsVisible="False" />
        <TextBlock x:Name="LblInviteCode"
                   Text="{loc:Str login_invite_code}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   Margin="0,0,0,4"
                   IsVisible="False" />
        <TextBox x:Name="TxtInviteCode"
                 FontSize="14"
                 Padding="10,8"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PinkBrush}"
                 MaxLength="8"
                 HorizontalAlignment="Stretch"
                 IsVisible="False"
                 TextChanged="TxtInviteCode_TextChanged" />

        <TextBlock x:Name="LblDisplayName"
                   Text="{loc:Str login_display_name}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   Margin="0,0,0,4"
                   IsVisible="False" />
        <TextBox x:Name="TxtLoginDisplayName"
                 FontSize="14"
                 Padding="10,8"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PinkBrush}"
                 MaxLength="30"
                 HorizontalAlignment="Stretch"
                 IsVisible="False" />

        <TextBlock x:Name="LblPassword"
                   Text="{loc:Str login_password}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   Margin="0,10,0,4" />
        <TextBox PasswordChar="●" x:Name="TxtPassword"
                     FontSize="14"
                     Padding="10,8"
                     Background="{DynamicResource PanelBgBrush}"
                     Foreground="White"
                     BorderBrush="{DynamicResource PinkBrush}"
                     MaxLength="128" />

        <TextBlock x:Name="LblPasswordConfirm"
                   Text="{loc:Str login_confirm_password}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   Margin="0,10,0,4"
                   IsVisible="False" />
        <TextBox PasswordChar="●" x:Name="TxtPasswordConfirm"
                     FontSize="14"
                     Padding="10,8"
                     Background="{DynamicResource PanelBgBrush}"
                     Foreground="White"
                     BorderBrush="{DynamicResource PinkBrush}"
                     MaxLength="128"
                     IsVisible="False" />

        <TextBlock x:Name="TxtAccountError"
                   FontSize="11"
                   Margin="0,8,0,0"
                   Foreground="Orange"
                   Text=""
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />

        <Button x:Name="BtnAccountSubmit"
                Content="{loc:Str btn_login}"
                Padding="30,12"
                Margin="0,15,0,0"
                Background="{DynamicResource PinkBrush}"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="14"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Click="BtnAccountSubmit_Click" />

        <TextBlock x:Name="TxtAccountToggle"
                   Margin="0,12,0,0"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   HorizontalAlignment="Center"
                   Cursor="Hand"
                   PointerPressed="TxtAccountToggle_Click" />

        <TextBlock Text="{loc:Str btn_back}"
                   Margin="0,10,0,0"
                   FontSize="12"
                   Foreground="#808080"
                   HorizontalAlignment="Center"
                   Cursor="Hand"
                   PointerPressed="BtnAccountBack_Click" />
      </StackPanel>

      <!-- Username Entry Panel (for new accounts) -->
      <StackPanel x:Name="UsernamePanel" Grid.Row="1" IsVisible="False" VerticalAlignment="Center" Spacing="8">
        <TextBlock x:Name="TxtUsernameTitle"
                   Text="{loc:Str label_choose_your_display_name}"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5" />
        <TextBlock x:Name="TxtUsernameSubtitle"
                   Text="{loc:Str label_this_will_be_shown_on_the_leaderboard}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15" />

        <TextBox x:Name="TxtUsername"
                 FontSize="18"
                 Padding="12,10"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource PinkBrush}"
                 MaxLength="30"
                 TextChanged="TxtUsername_TextChanged"
                 HorizontalAlignment="Stretch" />

        <TextBlock x:Name="TxtAvailability"
                   FontSize="11"
                   Margin="0,8,0,0"
                   Foreground="#B0B0B0"
                   Text="{loc:Str label_enter_a_unique_name_3_30_characters}"
                   HorizontalAlignment="Center" />

        <Button x:Name="BtnConfirmUsername"
                Content="{loc:Str btn_confirm}"
                Padding="30,12"
                Margin="0,20,0,0"
                Background="{DynamicResource PinkBrush}"
                Foreground="White"
                BorderThickness="0"
                FontWeight="Bold"
                FontSize="14"
                Cursor="Hand"
                IsEnabled="False"
                HorizontalAlignment="Center"
                Click="BtnConfirmUsername_Click" />
      </StackPanel>

      <!-- Loading Panel -->
      <StackPanel x:Name="LoadingPanel" Grid.Row="1" IsVisible="False"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
        <TextBlock x:Name="TxtLoadingMessage"
                   Text="{loc:Str login_connecting}"
                   FontSize="16"
                   Foreground="White"
                   HorizontalAlignment="Center" />
        <ProgressBar IsIndeterminate="True"
                     Width="200"
                     Height="4"
                     Foreground="{DynamicResource PinkBrush}"
                     Background="{DynamicResource AccentTintedBgBrush}" />
      </StackPanel>

      <!-- Device-Code Panel -->
      <StackPanel x:Name="DeviceCodePanel" Grid.Row="1" IsVisible="False" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="{loc:Str dialog_login_sign_via_web_text}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8" />
        <TextBlock Text="{loc:Str dialog_login_weve_opened_browser_finish_signin_complete_text}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"
                   TextAlignment="Center" />

        <TextBlock Text="{loc:Str dialog_login_code_text}"
                   FontSize="11"
                   Foreground="#808080"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4" />
        <Border BorderBrush="#9333EA" BorderThickness="2" CornerRadius="6"
                Background="{DynamicResource PanelBgBrush}" Padding="20,12"
                HorizontalAlignment="Center" Margin="0,0,0,12">
          <TextBlock x:Name="TxtDeviceCode"
                     Text="------"
                     FontSize="32"
                     FontWeight="Bold"
                     Foreground="White"
                     FontFamily="Consolas"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
        </Border>

        <TextBlock Text="{loc:Str dialog_login_open_url_manually_text}"
                   FontSize="11"
                   Foreground="#808080"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4" />
        <TextBox x:Name="TxtVerificationUrl"
                 IsReadOnly="True"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="#B0B0B0"
                 FontSize="12"
                 FontFamily="Consolas"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,12"
                 Cursor="IBeam" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,15">
          <Button x:Name="BtnDeviceCodeCopy"
                  Content="{loc:Str dialog_login_copy_code_content}"
                  Padding="14,6"
                  Background="{DynamicResource AccentTintedBgBrush}"
                  Foreground="White"
                  BorderThickness="0"
                  FontSize="12"
                  Cursor="Hand"
                  Click="BtnDeviceCodeCopy_Click" />
          <Button x:Name="BtnDeviceCodeOpenBrowser"
                  Content="{loc:Str dialog_login_open_browser_again_content}"
                  Padding="14,6"
                  Background="{DynamicResource AccentTintedBgBrush}"
                  Foreground="White"
                  BorderThickness="0"
                  FontSize="12"
                  Cursor="Hand"
                  Click="BtnDeviceCodeOpenBrowser_Click" />
        </StackPanel>

        <TextBlock x:Name="TxtDeviceStatus"
                   Text="{loc:Str dialog_login_waiting_browser_confirmation_text}"
                   FontSize="12"
                   Foreground="#B0B0B0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
        <ProgressBar x:Name="DeviceProgressBar"
                     IsIndeterminate="True"
                     Width="200"
                     Height="3"
                     Margin="0,0,0,15"
                     Foreground="#9333EA"
                     Background="{DynamicResource AccentTintedBgBrush}" />

        <TextBlock Text="{loc:Str dialog_login_cancel_text}"
                   FontSize="12"
                   Foreground="#808080"
                   HorizontalAlignment="Center"
                   Cursor="Hand"
                   PointerPressed="BtnDeviceCodeCancel_Click" />
      </StackPanel>

      <!-- Cancel Button -->
      <Button x:Name="BtnCancel" Grid.Row="2"
              Content="{loc:Str btn_cancel}"
              Padding="20,8"
              HorizontalAlignment="Right"
              Background="Transparent"
              Foreground="#808080"
              BorderThickness="0"
              Cursor="Hand"
              Click="BtnCancel_Click" />
    </Grid>
  </Border>
</Window>

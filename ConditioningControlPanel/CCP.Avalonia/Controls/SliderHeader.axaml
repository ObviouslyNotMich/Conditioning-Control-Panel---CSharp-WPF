<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ConditioningControlPanel.Avalonia.Controls;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Controls.SliderHeader">
  <Grid ColumnDefinitions="*,Auto">
    <TextBlock Grid.Column="0"
               Text="{Binding Label, RelativeSource={RelativeSource AncestorType=controls:SliderHeader}}"
               Foreground="White" FontSize="10"
               VerticalAlignment="Center" />
    <TextBlock Grid.Column="1"
               Text="{Binding ValueText, RelativeSource={RelativeSource AncestorType=controls:SliderHeader}}"
               Foreground="{DynamicResource PinkBrush}" FontSize="10"
               VerticalAlignment="Center" />
  </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.RemoteControlTabView"
             x:Name="Root"
             x:DataType="vm:RemoteControlTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:conv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base">

  <Design.DataContext>
    <vm:RemoteControlTabViewModel />
  </Design.DataContext>

  <Grid>
    <ScrollViewer IsVisible="{Binding !IsPremiumLocked}">
      <Grid HorizontalAlignment="Stretch">
        <StackPanel Spacing="14" Margin="16" MaxWidth="900" HorizontalAlignment="Center">

        <!-- Hero banner -->
        <Border CornerRadius="12"
                ClipToBounds="True"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                Height="220"
                VerticalAlignment="Top">
          <Image Source="avares://CCP.Avalonia/Assets/features/remote_control.png"
                 Stretch="UniformToFill"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center" />
        </Border>

        <!-- Header row -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="🎮"
                     FontSize="32"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0" />
          <TextBlock Grid.Column="1"
                     Text="{loc:Str tab_remote_control}"
                     FontSize="20"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}"
                     VerticalAlignment="Center" />
          <Button Grid.Column="2"
                  Content="{loc:Str btn_help}"
                  Theme="{StaticResource OutlineButton}"
                  Command="{Binding ShowHelpCommand}"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0" />
          <StackPanel Grid.Column="3"
                      Orientation="Horizontal"
                      Spacing="8"
                      VerticalAlignment="Center">
            <TextBlock Text="{loc:Str tab_remote_control_enable_remote_control_content}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <ToggleSwitch VerticalAlignment="Center"
                          IsChecked="{Binding IsRemoteEnabled, Mode=TwoWay}" />
          </StackPanel>
        </Grid>

        <!-- Description card -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20,18">
          <Grid ColumnDefinitions="Auto,18,*">
            <Border Grid.Column="0"
                    Width="64"
                    Height="64"
                    CornerRadius="32"
                    Background="{DynamicResource TransparentPinkBrush}"
                    VerticalAlignment="Top">
              <TextBlock Text="🎮"
                         FontSize="32"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
              <TextBlock Text="{loc:Str label_what_is_this}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="11"
                         FontWeight="Bold"
                         Margin="0,0,0,4" />
              <TextBlock Text="{loc:Str desc_remote_control}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="15"
                         TextWrapping="Wrap"
                         Margin="0,0,0,12"
                         LineHeight="22" />
              <TextBlock Text="{loc:Str desc_remote_control_bullets}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="13"
                         TextWrapping="Wrap"
                         LineHeight="20" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Tier comparison cards -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Str tab_remote_control_tier_text}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*,*"
                  RowDefinitions="Auto"
                  ColumnSpacing="10">
              <!-- Light -->
              <Border Grid.Column="0"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      BorderBrush="{DynamicResource SurfaceBgBrush}"
                      BorderThickness="2"
                      CornerRadius="10"
                      Padding="14,12"
                      Classes.selected="{Binding IsLightSelected}"
                      PointerPressed="OnTierCardPointerPressed"
                      Tag="light">
                <StackPanel Spacing="6">
                  <TextBlock Text="{loc:Str label_remote_tier_light}"
                             Foreground="{DynamicResource PinkBrush}"
                             FontSize="14"
                             FontWeight="Bold" />
                  <TextBlock Text="{loc:Str tab_remote_control_tier_summary_light}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{loc:Str tab_remote_control_tier_bullets_light}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             LineHeight="16" />
                </StackPanel>
              </Border>
              <!-- Standard -->
              <Border Grid.Column="1"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      BorderBrush="{DynamicResource SurfaceBgBrush}"
                      BorderThickness="2"
                      CornerRadius="10"
                      Padding="14,12"
                      Classes.selected="{Binding IsStandardSelected}"
                      PointerPressed="OnTierCardPointerPressed"
                      Tag="standard">
                <StackPanel Spacing="6">
                  <TextBlock Text="{loc:Str label_remote_tier_standard}"
                             Foreground="{DynamicResource PinkBrush}"
                             FontSize="14"
                             FontWeight="Bold" />
                  <TextBlock Text="{loc:Str tab_remote_control_tier_summary_standard}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{loc:Str tab_remote_control_tier_bullets_standard}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             LineHeight="16" />
                </StackPanel>
              </Border>
              <!-- Full -->
              <Border Grid.Column="2"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      BorderBrush="{DynamicResource SurfaceBgBrush}"
                      BorderThickness="2"
                      CornerRadius="10"
                      Padding="14,12"
                      Classes.selected="{Binding IsFullSelected}"
                      PointerPressed="OnTierCardPointerPressed"
                      Tag="full">
                <StackPanel Spacing="6">
                  <TextBlock Text="{loc:Str label_remote_tier_full}"
                             Foreground="{DynamicResource PinkBrush}"
                             FontSize="14"
                             FontWeight="Bold" />
                  <TextBlock Text="{loc:Str tab_remote_control_tier_summary_full}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{loc:Str tab_remote_control_tier_bullets_full}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             LineHeight="16" />
                </StackPanel>
              </Border>
            </Grid>
          </StackPanel>
          <Border.Styles>
            <Style Selector="Border.selected">
              <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}" />
            </Style>
          </Border.Styles>
        </Border>

        <!-- Pairing panel -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
          <Grid ColumnDefinitions="*,Auto"
                RowDefinitions="Auto,Auto,Auto,Auto"
                ColumnSpacing="20">
            <StackPanel Grid.Column="0" Grid.RowSpan="4" Spacing="12">
              <TextBlock Text="{loc:Str tab_remote_control_session_code_text}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="11"
                         FontWeight="Bold" />
              <TextBlock Text="{Binding SessionCode}"
                         FontSize="36"
                         FontWeight="Bold"
                         Foreground="{DynamicResource PinkBrush}"
                         FontFamily="Consolas, Monospace" />
              <TextBlock Text="{loc:Str tab_remote_control_pin_label}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="11"
                         FontWeight="Bold" />
              <TextBlock Text="{Binding ConnectPin}"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontFamily="Consolas, Monospace" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{loc:Str tab_remote_control_copy_code}"
                        Command="{Binding CopySessionCodeCommand}"
                        Theme="{StaticResource PinkButton}" />
                <Button Content="{loc:Str tab_remote_control_copy_link}"
                        Command="{Binding CopyPairingUrlCommand}"
                        Theme="{StaticResource OutlineButton}" />
              </StackPanel>
              <TextBlock Text="{Binding DirectoryStatusText}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="12" />
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="4" Spacing="6">
              <TextBlock Text="{loc:Str label_remote_pairing}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="11"
                         FontWeight="Bold"
                         HorizontalAlignment="Center" />
              <Border Width="130"
                      Height="130"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      BorderBrush="{DynamicResource PinkBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      ClipToBounds="True">
                <Grid>
                  <Image Source="{Binding PairingQrImage}"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsVisible="{Binding PairingQrImage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
                  <TextBlock Text="{loc:Str tab_remote_control_qr_placeholder}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="12"
                             TextWrapping="Wrap"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsVisible="{Binding PairingQrImage, Converter={x:Static conv:ObjectConverters.IsNull}}" />
                </Grid>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Directory opt-in panel -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
          <StackPanel Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{loc:Str tab_remote_control_directory_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <TextBlock Text="{loc:Str desc_optin_directory_consent}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding IsDirectoryOptedIn, Mode=OneWay}"
                            Command="{Binding OptInCommand}" />
            </Grid>

            <StackPanel Spacing="6" IsVisible="{Binding IsDirectoryOptedIn}">
              <TextBlock Text="{loc:Str label_optin_tags}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="10"
                         FontWeight="Bold" />
              <ItemsControl ItemsSource="{Binding OptInTags}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:RemoteControlTabViewModel+OptInTagItem">
                    <ToggleButton Content="{Binding Label}"
                                  IsChecked="{Binding IsSelected, Mode=OneWay}"
                                  Command="{Binding #Root.DataContext.ToggleTagCommand}"
                                  CommandParameter="{Binding}"
                                  Margin="0,0,8,8"
                                  Padding="10,5"
                                  CornerRadius="9999"
                                  FontSize="11"
                                  FontWeight="SemiBold">
                      <ToggleButton.Styles>
                        <Style Selector="ToggleButton:checked">
                          <Setter Property="Background" Value="{DynamicResource PinkBrush}" />
                          <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
                        </Style>
                        <Style Selector="ToggleButton:not(:checked)">
                          <Setter Property="Background" Value="{DynamicResource ElevatedSurfaceBrush}" />
                          <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                        </Style>
                      </ToggleButton.Styles>
                    </ToggleButton>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="{loc:Str label_optin_status}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="10"
                         FontWeight="Bold"
                         Margin="0,8,0,0" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding OptInStatusText, Mode=TwoWay}"
                         Watermark="{loc:Str tab_remote_control_status_placeholder}"
                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding OptInStatusCharacterCount}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
              </Grid>

              <CheckBox Content="{loc:Str chk_remember_optin_details}"
                        IsChecked="{Binding RememberOptInDetails, Mode=TwoWay}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Status + command log -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
          <StackPanel Spacing="12">
            <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                    CornerRadius="8"
                    Padding="12,10">
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Str label_remote_controller_info}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13" />
              </StackPanel>
            </Border>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Str label_remote_command_log}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="11"
                         FontWeight="Bold" />
              <ListBox ItemsSource="{Binding CommandLog}"
                       Background="Transparent"
                       MaxHeight="200"
                       IsVisible="{Binding HasCommands}" />
              <TextBlock Text="{loc:Str label_remote_no_commands}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="12"
                         FontStyle="Italic"
                         IsVisible="{Binding !HasCommands}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Emote picker -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Str label_remote_emotes}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Content="💖"
                      Command="{Binding SendEmoteCommand}"
                      CommandParameter="💖"
                      Width="44"
                      Height="44"
                      CornerRadius="22"
                      FontSize="20"
                      Padding="0"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      Foreground="{DynamicResource TextLightBrush}" />
              <Button Content="😊"
                      Command="{Binding SendEmoteCommand}"
                      CommandParameter="😊"
                      Width="44"
                      Height="44"
                      CornerRadius="22"
                      FontSize="20"
                      Padding="0"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      Foreground="{DynamicResource TextLightBrush}" />
              <Button Content="👍"
                      Command="{Binding SendEmoteCommand}"
                      CommandParameter="👍"
                      Width="44"
                      Height="44"
                      CornerRadius="22"
                      FontSize="20"
                      Padding="0"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      Foreground="{DynamicResource TextLightBrush}" />
              <Button Content="🥰"
                      Command="{Binding SendEmoteCommand}"
                      CommandParameter="🥰"
                      Width="44"
                      Height="44"
                      CornerRadius="22"
                      FontSize="20"
                      Padding="0"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      Foreground="{DynamicResource TextLightBrush}" />
              <Button Content="😵‍💫"
                      Command="{Binding SendEmoteCommand}"
                      CommandParameter="😵‍💫"
                      Width="44"
                      Height="44"
                      CornerRadius="22"
                      FontSize="20"
                      Padding="0"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      Foreground="{DynamicResource TextLightBrush}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0"
                       Text="{Binding CustomEmoteText, Mode=TwoWay}"
                       Watermark="{loc:Str watermark_emote_custom}"
                       VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_emote_send}"
                      Command="{Binding SendCustomEmoteCommand}"
                      Theme="{StaticResource PinkButton}"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Privacy toggles -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
          <StackPanel Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{loc:Str label_remote_stop_on_disconnect}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{loc:Str desc_remote_stop_on_disconnect}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding StopEffectsOnDisconnect, Mode=TwoWay}" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{loc:Str label_remote_share_avatar}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{loc:Str desc_remote_share_avatar}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding ShareAvatar, Mode=TwoWay}" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
      </Grid>
    </ScrollViewer>

    <!-- Premium gate overlay -->
    <features:PremiumGateOverlay IsLocked="{Binding IsPremiumLocked}"
                                  UnlockCommand="{Binding UnlockCommand}" />
  </Grid>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.HapticsTabView"
             x:DataType="vm:HapticsTabViewModel">

  <Design.DataContext>
    <vm:HapticsTabViewModel />
  </Design.DataContext>

  <Grid>
    <ScrollViewer>
      <StackPanel Spacing="14" Margin="16">

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Grid.Column="0"
                     Text="💜"
                     FontSize="32"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0" />
          <TextBlock Grid.Column="1"
                     Text="{loc:Str tab_haptics}"
                     FontSize="20"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}"
                     VerticalAlignment="Center" />
        </Grid>

        <!-- Hero description card -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24,20"
                BoxShadow="0 0 20 0 #80FF69B4">
          <Grid ColumnDefinitions="Auto,22,*">
            <Border Grid.Column="0"
                    Width="160"
                    Height="160"
                    CornerRadius="12"
                    ClipToBounds="True"
                    BorderBrush="{DynamicResource PinkBrush}"
                    BorderThickness="2"
                    VerticalAlignment="Top">
              <Image Source="avares://CCP.Avalonia/Assets/features/vibe.png"
                     Stretch="UniformToFill" />
            </Border>
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
              <TextBlock Text="{loc:Str label_what_is_this}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="11"
                         FontWeight="Bold"
                         Margin="0,0,0,4" />
              <TextBlock Text="{loc:Str desc_haptics}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="15"
                         TextWrapping="Wrap"
                         Margin="0,0,0,12"
                         LineHeight="22" />
              <TextBlock Text="{loc:Str desc_haptics_bullets}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="13"
                         TextWrapping="Wrap"
                         LineHeight="20" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Connection card -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,18"
                BoxShadow="0 0 20 0 #80FF69B4">
          <StackPanel Spacing="14">

            <!-- Header: icon + title + help + master toggle -->
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          Spacing="10">
                <TextBlock Text="🔌"
                           FontSize="22"
                           VerticalAlignment="Center" />
                <TextBlock Text="{loc:Str label_haptic_connection}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="15"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <Button Content="{loc:Str label_help_symbol}"
                        Theme="{StaticResource OutlineButton}"
                        Command="{Binding ShowHelpCommand}"
                        ToolTip.Tip="{loc:Str haptics_help_title}"
                        Padding="0"
                        Width="22"
                        Height="22"
                        CornerRadius="11"
                        FontSize="12"
                        VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Text="{loc:Str btn_enable}"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <ToggleSwitch VerticalAlignment="Center"
                              IsChecked="{Binding HapticsEnabled, Mode=TwoWay}" />
              </StackPanel>
            </Grid>

            <!-- Provider + URL + Connect -->
            <Grid ColumnDefinitions="Auto,200,12,*,12,Auto">
              <TextBlock Grid.Column="0"
                         Text="{loc:Str label_provider}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="13"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0" />
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding ProviderOptions}"
                        SelectedIndex="{Binding SelectedProviderIndex, Mode=TwoWay}"
                        VerticalAlignment="Center" />
              <TextBox Grid.Column="3"
                       Text="{Binding ProviderUrl, Mode=TwoWay}"
                       Watermark="{loc:Str watermark_provider_url}"
                       VerticalAlignment="Center" />
              <Button Grid.Column="5"
                      Content="{Binding ConnectButtonText}"
                      Command="{Binding ConnectCommand}"
                      Theme="{StaticResource PinkButton}"
                      Padding="18,8"
                      FontSize="13"
                      VerticalAlignment="Center" />
            </Grid>

            <!-- Hint + auto-connect -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0"
                         Text="{Binding ProviderHint}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="12"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
              <CheckBox Grid.Column="1"
                        Content="{loc:Str label_auto_connect}"
                        IsChecked="{Binding AutoConnect, Mode=TwoWay}"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Status + intensity + test inset -->
            <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                    CornerRadius="8"
                    Padding="16,12">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0"
                              Orientation="Horizontal"
                              Spacing="8">
                    <Ellipse Width="10"
                             Height="10"
                             Fill="{Binding StatusColor}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Str label_status}"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{Binding StatusColor}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Grid.Column="1"
                             Text="{Binding DevicesText}"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontSize="12"
                             VerticalAlignment="Center" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{loc:Str label_intensity}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="13"
                             FontWeight="Bold"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0" />
                  <Slider Grid.Column="1"
                          Minimum="0"
                          Maximum="100"
                          Value="{Binding GlobalIntensity, Mode=TwoWay}"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"
                          VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="{Binding GlobalIntensity, StringFormat='{}{0}%'}"
                             Foreground="{DynamicResource PinkBrush}"
                             FontSize="13"
                             FontWeight="Bold"
                             VerticalAlignment="Center"
                             Margin="12,0,0,0" />
                  <Button Grid.Column="3"
                          Content="{loc:Str btn_test_vibration}"
                          Command="{Binding TestCommand}"
                          Theme="{StaticResource OutlineButton}"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- Help link -->
            <Button Content="{loc:Str btn_need_help_setting_up}"
                    Command="{Binding ShowHelpCommand}"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Foreground="{DynamicResource PinkBrush}"
                    BorderThickness="0"
                    FontSize="12"
                    Padding="0">
              <Button.Styles>
                <Style Selector="Button">
                  <Setter Property="Template">
                    <ControlTemplate>
                      <TextBlock Text="{TemplateBinding Content}"
                                 Foreground="{TemplateBinding Foreground}"
                                 FontSize="{TemplateBinding FontSize}"
                                 TextDecorations="Underline" />
                    </ControlTemplate>
                  </Setter>
                </Style>
              </Button.Styles>
            </Button>
          </StackPanel>
        </Border>

        <!-- Video Haptic Sync featured card -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1,2,1,1"
                CornerRadius="8">
          <Grid RowDefinitions="Auto,Auto,Auto">

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ElevatedSurfaceBrush}"
                    CornerRadius="8,8,0,0"
                    Padding="12,10">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🎵"
                               FontSize="16"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Str label_video_haptic_sync}"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Text="{loc:Str label_syncs_haptics_to_video_audio_in_real_time}"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontSize="10" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{loc:Str label_help_symbol}"
                        Theme="{StaticResource OutlineButton}"
                        Command="{Binding ShowVideoSyncHelpCommand}"
                        Padding="0"
                        Width="22"
                        Height="22"
                        CornerRadius="11"
                        FontSize="12"
                        Margin="0,0,10,0" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8">
                  <TextBlock Text="{loc:Str btn_enable}"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontSize="10"
                             VerticalAlignment="Center" />
                  <ToggleSwitch VerticalAlignment="Center"
                                IsChecked="{Binding AudioSyncEnabled, Mode=TwoWay}" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Algorithm cards + image -->
            <Grid Grid.Row="1"
                  Margin="12,8"
                  ColumnDefinitions="*,10,Auto">
              <StackPanel Grid.Column="0"
                          Spacing="3"
                          VerticalAlignment="Center">
                <TextBlock Text="{loc:Str label_sync_algorithm}"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="10"
                           Margin="0,0,0,5" />

                <!-- Audio Reactive (selected) -->
                <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                        CornerRadius="4"
                        Padding="8,5"
                        BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="2">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{loc:Str label_audio_reactive}"
                               Foreground="{DynamicResource TextLightBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Ellipse Grid.Column="1"
                             Width="6"
                             Height="6"
                             Fill="{DynamicResource PinkBrush}"
                             VerticalAlignment="Center"
                             Margin="8,0,0,0" />
                  </Grid>
                </Border>

                <!-- Beat Detection (coming soon) -->
                <Grid>
                  <Border Background="{DynamicResource PanelBgBrush}"
                          CornerRadius="4"
                          Padding="8,5"
                          Opacity="0.5">
                    <TextBlock Text="{loc:Str label_beat_detection}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="10"
                               FontWeight="SemiBold" />
                  </Border>
                  <Border Background="{DynamicResource PanelBgBrush}"
                          CornerRadius="4"
                          Opacity="0.8">
                    <TextBlock Text="{loc:Str label_coming_soon}"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="8"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                </Grid>

                <!-- AI Enhanced (coming soon) -->
                <Grid>
                  <Border Background="{DynamicResource PanelBgBrush}"
                          CornerRadius="4"
                          Padding="8,5"
                          Opacity="0.5">
                    <TextBlock Text="{loc:Str label_ai_enhanced}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="10"
                               FontWeight="SemiBold" />
                  </Border>
                  <Border Background="{DynamicResource PanelBgBrush}"
                          CornerRadius="4"
                          Opacity="0.8">
                    <TextBlock Text="{loc:Str label_coming_soon}"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="8"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                </Grid>
              </StackPanel>

              <Border Grid.Column="2"
                      Width="130"
                      Height="130"
                      CornerRadius="6"
                      ClipToBounds="True"
                      BorderBrush="{DynamicResource PinkBrush}"
                      BorderThickness="1">
                <Image Source="avares://CCP.Avalonia/Assets/features/vibe.png"
                       Stretch="UniformToFill" />
              </Border>
            </Grid>

            <!-- Delay + Power sliders -->
            <Border Grid.Row="2"
                    IsVisible="{Binding AudioSyncEnabled}"
                    Padding="12,8,12,12">
              <Grid ColumnDefinitions="*,12,*">
                <StackPanel Grid.Column="0" Spacing="4">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{loc:Str label_delay_2}"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="10" />
                    <TextBlock Text="{Binding AudioSyncLatencyFormatted}"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="10"
                               HorizontalAlignment="Right" />
                  </Grid>
                  <Slider Minimum="-600"
                          Maximum="600"
                          Value="{Binding AudioSyncLatency, Mode=TwoWay}"
                          TickFrequency="10"
                          IsSnapToTickEnabled="True"
                          ToolTip.Tip="{loc:Str tooltip_adjust_haptic_timing_positive_earlier_negativ}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{loc:Str label_power_2}"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="10" />
                    <TextBlock Text="{Binding AudioSyncIntensity, StringFormat='{}{0}%'}"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="10"
                               HorizontalAlignment="Right" />
                  </Grid>
                  <Slider Minimum="0"
                          Maximum="100"
                          Value="{Binding AudioSyncIntensity, Mode=TwoWay}"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"
                          ToolTip.Tip="{loc:Str tooltip_live_intensity_control_reduce_if_vibration_is}" />
                </StackPanel>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <!-- Global intensity -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="6">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{loc:Str label_global_intensity}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <TextBlock Grid.Column="1"
                         Text="{Binding GlobalIntensity, StringFormat='{}{0}%'}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="13"
                         FontWeight="SemiBold" />
            </Grid>
            <Slider Minimum="0"
                    Maximum="100"
                    Value="{Binding GlobalIntensity, Mode=TwoWay}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True" />
          </StackPanel>
        </Border>

        <!-- Per-event intensities -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="✨"
                         FontSize="22"
                         VerticalAlignment="Center" />
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{loc:Str label_event_intensities}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PinkBrush}" />
                <TextBlock Text="{loc:Str label_adjust_vibration_strength_per_feature}"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="11" />
              </StackPanel>
            </StackPanel>

            <UniformGrid Columns="2">
              <!-- Each event row: label | enabled | slider | mode -->
              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="0,0,8,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_haptics_bubble_pop}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding BubbleEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding BubbleIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding BubbleModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="8,0,0,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_flash_display}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding FlashDisplayEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding FlashDisplayIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding FlashDisplayModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="0,0,8,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_flash_click}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding FlashClickEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding FlashClickIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding FlashClickModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="8,0,0,10">
                <TextBlock Grid.Column="0" Text="{loc:Str setting_video}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding VideoEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding VideoIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding VideoModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="0,0,8,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_target_hit}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding TargetHitEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding TargetHitIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding TargetHitModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="8,0,0,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_allow_subliminal}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding SubliminalEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding SubliminalIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding SubliminalModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="0,0,8,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_level_up}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding LevelUpEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding LevelUpIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding LevelUpModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="8,0,0,10">
                <TextBlock Grid.Column="0" Text="{loc:Str label_haptics_achievement}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding AchievementEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding AchievementIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding AchievementModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>

              <Grid ColumnDefinitions="Auto,*,Auto,120" Margin="0,0,8,0">
                <TextBlock Grid.Column="0" Text="{loc:Str feature_bouncing_text}" VerticalAlignment="Center" Width="110" />
                <CheckBox Grid.Column="1" Content="{loc:Str setting_enabled}" IsChecked="{Binding BouncingTextEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <Slider Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding BouncingTextIntensity, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True" Width="120" Margin="8,0" />
                <ComboBox Grid.Column="3" ItemsSource="{Binding ModeOptions}" SelectedIndex="{Binding BouncingTextModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" />
              </Grid>
            </UniformGrid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Premium gate overlay -->
    <features:PremiumGateOverlay IsLocked="{Binding IsPremiumLocked}"
                                  UnlockCommand="{Binding UnlockCommand}" />
  </Grid>
</UserControl>

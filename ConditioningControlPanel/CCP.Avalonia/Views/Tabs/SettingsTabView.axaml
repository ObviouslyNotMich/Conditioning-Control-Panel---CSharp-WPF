<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:controls="clr-namespace:ConditioningControlPanel.Avalonia.Controls;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.SettingsTabView"
             x:DataType="vm:SettingsTabViewModel">

  <Design.DataContext>
    <vm:SettingsTabViewModel />
  </Design.DataContext>

  <Grid>
    <ScrollViewer IsVisible="{Binding !IsHelpOverlayVisible}"
                  Margin="16"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid RowDefinitions="*,Auto,Auto">

        <!-- Velvet mosaic dashboard: 4x4 feature cards on the left, browser/audio/quick-links on the right -->
        <Grid Grid.Row="0" ColumnDefinitions="640,*">

        <!-- Feature card grid -->
        <Grid Grid.Column="0"
              Margin="5"
              ColumnDefinitions="*,*,*,*"
              RowDefinitions="*,*,*,*">

          <!-- Row 1 -->
          <features:FeatureCard Grid.Row="0" Grid.Column="0"
                                Title="{loc:Str feature_title_flash_images}"
                                IconUri="pack://application:,,,/Resources/features/flash.png"
                                HelpSectionId="FlashImages"
                                IsActive="{Binding FlashEnabled}"
                                Click="CardFlash_Click" />
          <features:FeatureCard Grid.Row="0" Grid.Column="1"
                                Title="{loc:Str feature_title_visuals}"
                                Glyph="◎"
                                HelpSectionId="Visuals"
                                Click="CardVisuals_Click" />
          <features:FeatureCard Grid.Row="0" Grid.Column="2"
                                Title="{loc:Str feature_title_mandatory_video}"
                                IconUri="pack://application:,,,/Resources/features/mandatory_videos.png"
                                HelpSectionId="Video"
                                IsActive="{Binding VideoEnabled}"
                                CanTest="True"
                                Click="CardVideo_Click" />
          <features:FeatureCard Grid.Row="0" Grid.Column="3"
                                Title="{loc:Str feature_title_subliminals}"
                                IconUri="pack://application:,,,/Resources/features/subliminal.png"
                                HelpSectionId="Subliminals"
                                IsActive="{Binding SubliminalEnabled}"
                                Click="CardSubliminal_Click" />

          <!-- Row 2 -->
          <features:FeatureCard Grid.Row="1" Grid.Column="0"
                                Title="{loc:Str feature_title_spiral_overlay}"
                                IconUri="pack://application:,,,/Resources/features/spiral_overlay.png"
                                HelpSectionId="SpiralOverlay"
                                IsActive="{Binding SpiralEnabled}"
                                Click="CardSpiral_Click" />

          <!-- Center logo (2x2) -->
          <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2"
                  Background="#01000000" Margin="6"
                  Cursor="Hand"
                  PointerPressed="ImgLogo_PointerPressed"
                  ToolTip.Tip="{loc:Str tooltip_click_me_rapidly}">
            <Border CornerRadius="12" ClipToBounds="True">
              <Image x:Name="ImgLogo"
                     Stretch="Uniform"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     RenderOptions.BitmapInterpolationMode="HighQuality" />
            </Border>
          </Border>

          <features:FeatureCard Grid.Row="1" Grid.Column="3"
                                Title="{loc:Str feature_title_lock_card}"
                                IconUri="pack://application:,,,/Resources/features/Phrase_Lock.png"
                                HelpSectionId="LockCard"
                                IsActive="{Binding LockCardEnabled}"
                                Click="CardLockCard_Click" />

          <!-- Row 3 -->
          <features:FeatureCard Grid.Row="2" Grid.Column="0"
                                Title="{loc:Str feature_title_pink_filter}"
                                IconUri="pack://application:,,,/Resources/features/Pink_filter.png"
                                HelpSectionId="PinkFilter"
                                IsActive="{Binding PinkFilterEnabled}"
                                Click="CardPinkFilter_Click" />
          <features:FeatureCard Grid.Row="2" Grid.Column="3"
                                Title="{loc:Str feature_title_mind_wipe}"
                                IconUri="pack://application:,,,/Resources/features/Mind_Wipers.png"
                                HelpSectionId="MindWipe"
                                IsActive="{Binding MindWipeEnabled}"
                                Click="CardMindWipe_Click" />

          <!-- Row 4 -->
          <features:FeatureCard Grid.Row="3" Grid.Column="0"
                                Title="{loc:Str feature_title_bubble_pop}"
                                IconUri="pack://application:,,,/Resources/features/Bubble_pop.png"
                                HelpSectionId="BubblePop"
                                IsActive="{Binding BubblesEnabled}"
                                Click="CardBubblePop_Click" />
          <features:FeatureCard Grid.Row="3" Grid.Column="1"
                                Title="{loc:Str feature_title_bouncing_text}"
                                IconUri="pack://application:,,,/Resources/features/bouncing_text.png"
                                HelpSectionId="BouncingText"
                                IsActive="{Binding BouncingTextEnabled}"
                                Click="CardBouncingText_Click" />
          <features:FeatureCard Grid.Row="3" Grid.Column="2"
                                Title="{loc:Str feature_title_system}"
                                Glyph="⚙"
                                HelpSectionId="System"
                                Click="CardSystem_Click" />
          <features:FeatureCard Grid.Row="3" Grid.Column="3"
                                Title="{loc:Str feature_title_bubble_count}"
                                IconUri="pack://application:,,,/Resources/features/Bubble_count.png"
                                HelpSectionId="BubbleCount"
                                IsActive="{Binding BubbleCountEnabled}"
                                Click="CardBubbleCount_Click" />
        </Grid>

        <!-- Right half: browser / audio / quick links / media path -->
        <Grid Grid.Column="1" Margin="5" RowDefinitions="*,Auto,Auto">

          <!-- Browser -->
          <Border Grid.Row="0" CornerRadius="12" Padding="9" Margin="0,0,0,5"
                  Background="{DynamicResource ElevatedSurfaceBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
            <StackPanel>
              <Grid Margin="0,0,0,4" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="{loc:Str label_browser}"
                             Foreground="{DynamicResource TextLightBrush}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                  <Button Content="{loc:Str label_help_symbol}"
                          Command="{Binding ShowHelpSectionCommand}" CommandParameter="Browser"
                          Background="{DynamicResource TransparentPinkBrush}"
                          Foreground="{DynamicResource TextLightBrush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                          CornerRadius="11" Padding="0" Width="22" Height="22" Margin="8,0,0,0"
                          HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                          FontSize="11" FontWeight="Bold"
                          ToolTip.Tip="{loc:Str btn_help}" />
                </StackPanel>

                <!-- Site toggle -->
                <Border Grid.Column="1" Background="{DynamicResource PanelAccentBrush}" CornerRadius="10" Padding="2" Margin="10,0,0,0" VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal">
                    <RadioButton Content="{loc:Str btn_bambicloud}"
                                 GroupName="BrowserSite"
                                 IsChecked="{Binding IsBambiCloudSelected, Mode=TwoWay}"
                                 Command="{Binding OpenBrowserCommand}"
                                 CommandParameter="bambicloud"
                                 Foreground="{DynamicResource TextLightBrush}" FontSize="10" Padding="8,3" />
                    <RadioButton Content="{loc:Str btn_hypnotube}"
                                 GroupName="BrowserSite"
                                 IsChecked="{Binding !IsBambiCloudSelected, Mode=TwoWay}"
                                 Command="{Binding OpenBrowserCommand}"
                                 CommandParameter="hypnotube"
                                 Foreground="{DynamicResource TextLightBrush}" FontSize="10" Padding="8,3" />
                  </StackPanel>
                </Border>

                <Button Grid.Column="2" Content="{loc:Str btn_reload}" Padding="6,3" Margin="8,0,0,0"
                        Command="{Binding OpenBrowserCommand}"
                        CommandParameter="{Binding IsBambiCloudSelected, Converter={StaticResource BoolToBrowserSiteConverter}}"
                        ToolTip.Tip="{loc:Str tooltip_browser_reload}" />

                <TextBlock Grid.Column="3" Text="{Binding BrowserStatusText}"
                           Foreground="{DynamicResource PinkBrush}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,8,0" />

                <!-- Deeper auto-bind badge -->
                <Border Grid.Column="3"
                        IsVisible="{Binding DeeperBrowserBadgeVisible}"
                        Background="{DynamicResource DeeperAccentTransparent20Brush}"
                        BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                        CornerRadius="3" Padding="6,1" Margin="0,0,8,0"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        ToolTip.Tip="{Binding DeeperBrowserBadgeToolTip}">
                  <TextBlock Text="{Binding DeeperBrowserBadgeText}"
                             Foreground="{DynamicResource DeeperAccentBrush}"
                             FontSize="9" FontWeight="SemiBold" />
                </Border>

                <Button Grid.Column="4" Content="{loc:Str btn_browser_webcam_tracking_off}"
                        Click="BrowserWebcamTracking_Click"
                        Padding="6,3" Margin="0,0,6,0" VerticalAlignment="Center"
                        ToolTip.Tip="{loc:Str tooltip_browser_webcam_tracking_off}" />

                <Button Grid.Column="5" Content="{loc:Str btn_pop_out_plain}" Padding="6,3"
                        Command="{Binding PopOutBrowserCommand}"
                        ToolTip.Tip="{loc:Str tooltip_pop_out_browser_to_resizable_window}" />
              </Grid>

              <!-- Browser container -->
              <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" ClipToBounds="True" Height="340">
                <Grid RowDefinitions="Auto,Auto,*">
                  <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Padding="8,4">
                    <Grid ColumnDefinitions="Auto,*">
                      <CheckBox Grid.Column="0" Content="{loc:Str browser_enhance_label}"
                                IsChecked="{Binding BrowserEnhanceIfPossible, Mode=TwoWay}"
                                Foreground="{DynamicResource TextLightBrush}" FontSize="11" VerticalAlignment="Center"
                                ToolTip.Tip="{loc:Str browser_enhance_tooltip}" />
                      <TextBlock Grid.Column="1" Text="{Binding EnhanceMatchStatusText}"
                                 Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                 VerticalAlignment="Center" Margin="12,0,0,0" />
                    </Grid>
                  </Border>

                  <!-- Haptic Audio Sync latency/intensity panel -->
                  <Border Grid.Row="1" Background="{DynamicResource PanelBgBrush}" Padding="6,3"
                          IsVisible="{Binding AudioSyncLatencyPanelVisible}">
                    <Grid ColumnDefinitions="*,8,*">
                      <Grid Grid.Column="0" ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{loc:Str label_delay}" Foreground="{DynamicResource TextDimBrush}" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <Slider Grid.Column="1" Minimum="-600" Maximum="600"
                                Value="{Binding LegacyAudioSyncLatency, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{loc:Str tooltip_adjust_haptic_timing_positive_earlier_negativ}" />
                        <TextBlock Grid.Column="2" Text="{Binding LegacyAudioSyncLatencyText}"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                      </Grid>
                      <Grid Grid.Column="2" ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="{loc:Str label_power}" Foreground="{DynamicResource TextDimBrush}" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding LegacyAudioSyncIntensity, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{loc:Str tooltip_live_intensity_control_reduce_if_vibration_is}" />
                        <TextBlock Grid.Column="2" Text="{Binding LegacyAudioSyncIntensityText}"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="9"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                      </Grid>
                    </Grid>
                  </Border>

                  <Border Grid.Row="2" x:Name="BrowserContainer">
                    <TextBlock Text="{loc:Str label_click_to_load_browser}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Cursor="Hand"
                               PointerPressed="BrowserLoadingText_PointerPressed" />
                  </Border>
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <!-- Audio + Quick Links -->
          <Grid Grid.Row="1" ColumnDefinitions="*,5,*">
            <!-- Audio -->
            <Border Grid.Column="0" CornerRadius="12" Padding="9" Margin="0,5,0,6"
                    Background="{DynamicResource ElevatedSurfaceBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
              <StackPanel>
                <Grid Margin="0,0,0,6">
                  <TextBlock Text="{loc:Str label_audio}"
                             Foreground="{DynamicResource TextLightBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{loc:Str label_help_symbol}"
                            Command="{Binding ShowHelpSectionCommand}" CommandParameter="Audio"
                            Background="{DynamicResource TransparentPinkBrush}"
                            Foreground="{DynamicResource TextLightBrush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                            CornerRadius="11" Padding="0" Width="22" Height="22" Margin="0,0,8,0"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            FontSize="11" FontWeight="Bold"
                            ToolTip.Tip="{loc:Str btn_help}" />
                    <TextBlock Text="{loc:Str label_duck}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ToggleSwitch IsChecked="{Binding AudioDuckEnabled, Mode=TwoWay}" />
                  </StackPanel>
                </Grid>

                <controls:SliderHeader Label="{loc:Str setting_master}" ValueText="{Binding MasterVolumeText}" />
                <Slider Value="{Binding MasterVolume, Mode=TwoWay}" Minimum="0" Maximum="100" Margin="0,0,0,6" />

                <controls:SliderHeader Label="{loc:Str setting_video}" ValueText="{Binding VideoVolumeText}" />
                <Slider Value="{Binding VideoVolume, Mode=TwoWay}" Minimum="0" Maximum="100" Margin="0,0,0,6" />

                <controls:SliderHeader Label="{loc:Str label_duck}" ValueText="{Binding DuckVolumeText}" />
                <Slider Value="{Binding DuckVolume, Mode=TwoWay}" Minimum="0" Maximum="100" Margin="0,0,0,6" />

                <!-- Audio output device picker -->
                <Grid Margin="0,6,0,0" ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Text="{loc:Str setting_output}"
                             Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                             VerticalAlignment="Center" Margin="0,0,4,0"
                             ToolTip.Tip="{loc:Str tooltip_audio_output_device}" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding AudioOutputDevices}"
                            SelectedItem="{Binding SelectedAudioOutputDevice, Mode=TwoWay}"
                            DisplayMemberBinding="{Binding Name}"
                            Margin="4,0,4,0"
                            ToolTip.Tip="{loc:Str tooltip_audio_output_device}" />
                  <Button Grid.Column="2" Content="↻"
                          Command="{Binding RefreshAudioOutputDevicesCommand}"
                          ToolTip.Tip="Re-scan playback devices."
                          Padding="8,2" Background="#33FF69B4" Foreground="{DynamicResource TextLightBrush}" FontSize="10"
                          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" />
                </Grid>

                <!-- Don't-duck-browser toggle + Audio Test -->
                <Grid Margin="0,4,0,0" ColumnDefinitions="*,Auto">
                  <CheckBox Content="{loc:Str setting_don_t_duck_browser}"
                            IsChecked="{Binding ExcludeBrowserDucking, Mode=TwoWay}"
                            Foreground="{DynamicResource PinkBrush}" FontSize="9" />
                  <Button Grid.Column="1" Content="Test Audio"
                          Command="{Binding TestAudioCommand}"
                          ToolTip.Tip="Play a test sound and show audio diagnostics. Use this if audio isn't working."
                          Background="#33FF69B4" Foreground="{DynamicResource TextLightBrush}" FontSize="9" Padding="8,3"
                          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                          VerticalAlignment="Center" />
                </Grid>
              </StackPanel>
            </Border>

            <!-- Quick Links -->
            <Border Grid.Column="2" CornerRadius="12" Padding="9" Margin="0,5,0,6"
                    Background="{DynamicResource ElevatedSurfaceBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
              <StackPanel>
                <Grid Margin="0,0,0,6">
                  <TextBlock Text="{loc:Str label_quick_links}"
                             Foreground="{DynamicResource TextLightBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                  <Button Content="{loc:Str label_help_symbol}"
                          Command="{Binding ShowHelpSectionCommand}" CommandParameter="QuickLinks"
                          Background="{DynamicResource TransparentPinkBrush}"
                          Foreground="{DynamicResource TextLightBrush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                          CornerRadius="11" Padding="0" Width="22" Height="22"
                          HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                          FontSize="11" FontWeight="Bold"
                          ToolTip.Tip="{loc:Str btn_help}" />
                </Grid>

                <Button Content="{loc:Str btn_login}"
                        Command="{Binding UnifiedLoginCommand}"
                        IsVisible="{Binding IsNotLoggedIn}"
                        Padding="8,12" Margin="0,0,0,6"
                        ToolTip.Tip="{loc:Str tooltip_login_with_discord_or_patreon}" />

                <Border IsVisible="{Binding IsLoggedIn}"
                        Background="{DynamicResource PanelBgBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel>
                      <TextBlock Text="{loc:Str label_logged_in_as}"
                                 Foreground="{DynamicResource TextMutedBrush}" FontSize="10" />
                      <TextBlock Text="{Binding LoggedInDisplayName}"
                                 Foreground="{DynamicResource TextLightBrush}" FontWeight="Bold" FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="{loc:Str btn_logout}"
                            Command="{Binding LogoutCommand}"
                            Padding="10,5" Background="{DynamicResource AccentTintedBgBrush}" Foreground="{DynamicResource PinkBrush}"
                            BorderThickness="0" FontSize="10" />
                  </Grid>
                </Border>

                <Button Content="{loc:Str label_join_discord}"
                        Command="{Binding OpenDiscordCommand}"
                        Padding="8,10" Margin="0,0,0,6"
                        Background="{DynamicResource DiscordBlueBrush}"
                        Foreground="{DynamicResource TextLightBrush}"
                        FontWeight="Bold"
                        HorizontalAlignment="Stretch" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <ToggleSwitch IsChecked="{Binding DiscordRichPresenceEnabled, Mode=TwoWay}" />
                  <TextBlock Text="{loc:Str label_rp}" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Media assets path -->
          <Border Grid.Row="2" CornerRadius="12" Padding="9" Margin="0,0,0,6"
                  Background="{DynamicResource ElevatedSurfaceBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                         Text="Media folder"
                         Foreground="{DynamicResource TextLightBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
              <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding CustomAssetsPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                       Watermark="Select or type the folder containing images, videos, wallpapers..."
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="10"
                       Margin="0,4,8,0"
                       VerticalAlignment="Center" />
              <Button Grid.Row="1" Grid.Column="2"
                      Content="Browse..."
                      Command="{Binding BrowseCustomAssetsPathCommand}"
                      Padding="10,5"
                      Background="{DynamicResource TransparentPinkBrush}"
                      Foreground="{DynamicResource TextLightBrush}"
                      BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <!-- Helper button row -->
      <Grid Grid.Row="1" Margin="5,12,5,0" ColumnDefinitions="*,10,*,10,*,10,*">
        <Button Grid.Column="0" Click="VelvetBtnWebcam_Click">
          <TextBlock><Run Text="📷"/><Run Text="{loc:Str btn_webcam}"/></TextBlock>
        </Button>
        <Button Grid.Column="2" Click="VelvetBtnAppInfo_Click">
          <TextBlock><Run Text="ℹ️"/><Run Text="{loc:Str btn_app_info}"/></TextBlock>
        </Button>
        <Button Grid.Column="4" Click="VelvetBtnSchedulerRamp_Click">
          <TextBlock><Run Text="📅"/><Run Text="{loc:Str btn_scheduler_intensity_ramp}"/></TextBlock>
        </Button>
        <Button Grid.Column="6" Click="VelvetBtnCatalogue_Click">
          <TextBlock><Run Text="📁"/><Run Text="{loc:Str btn_ccp_catalogue}"/></TextBlock>
        </Button>
      </Grid>

      <!-- Marquee banner -->
      <Border Grid.Row="2" Background="#1A0A1A" BorderBrush="{DynamicResource DarkPinkBrush}" BorderThickness="2"
              CornerRadius="8" Height="48" Margin="5,5,5,0" ClipToBounds="True"
              BoxShadow="0 0 15 0 #80FF1493">
        <Canvas x:Name="MarqueeCanvas">
          <StackPanel x:Name="MarqueeContent" Orientation="Horizontal" Canvas.Top="8">
            <TextBlock x:Name="MarqueeText1"
                       Text="{loc:Str label_marquee_v5_2_1}"
                       FontFamily="Impact" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}" />
            <TextBlock x:Name="MarqueeText2"
                       Text="{loc:Str label_marquee_v5_2_1}"
                       FontFamily="Impact" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       Margin="40,0,0,0" />
          </StackPanel>
        </Canvas>
      </Border>
    </Grid>
    </ScrollViewer>

    <Border Background="{DynamicResource PanelBgBrush}"
            CornerRadius="10"
            Padding="24"
            IsVisible="{Binding IsHelpOverlayVisible}">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0"
                   Text="{Binding HelpOverlayTitle}"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextLightBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12" />
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="12" HorizontalAlignment="Stretch" MaxWidth="720">
            <TextBlock Text="{Binding HelpOverlayWhatItDoes}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextLightBrush}" />

            <StackPanel IsVisible="{Binding HelpOverlayHasTips}" Spacing="6">
              <TextBlock Text="Tips" FontWeight="Bold" Foreground="{DynamicResource PinkBrush}" />
              <ItemsControl ItemsSource="{Binding HelpOverlayTips}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="•" Foreground="{DynamicResource PinkBrush}" VerticalAlignment="Top" />
                      <TextBlock Text="{Binding}" Foreground="{DynamicResource TextLightBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel IsVisible="{Binding HelpOverlayHasHowItWorks}" Spacing="6">
              <TextBlock Text="How it works" FontWeight="Bold" Foreground="{DynamicResource PinkBrush}" />
              <TextBlock Text="{Binding HelpOverlayHowItWorks}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource TextLightBrush}" />
            </StackPanel>

            <Button Content="{loc:Str btn_close}"
                    Command="{Binding HideHelpOverlayCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0" />
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:models="using:ConditioningControlPanel.Models"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.PresetIOTabView"
             x:DataType="vm:PresetIOTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:PresetIOTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <Grid RowDefinitions="Auto,*,Auto" Margin="24" MaxWidth="900" HorizontalAlignment="Stretch">

      <!-- Banner -->
      <Border Grid.Row="0"
              Height="140"
              CornerRadius="12"
              ClipToBounds="True"
              Margin="0,0,0,16">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#1A1A2E" />
            <GradientStop Offset="1" Color="#4A2C6A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="White"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_preset_i_o_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="{loc:Str tab_preset_i_o_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Preset list -->
      <Border Grid.Row="1"
              Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0"
                     Text="{loc:Str tab_preset_i_o_presets_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White"
                     Margin="0,0,0,12" />
          <ListBox Grid.Row="1"
                   x:Name="PresetsListBox"
                   ItemsSource="{Binding Presets}"
                   SelectedItem="{Binding SelectedPreset}"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type models:Preset}">
                <Border Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Name}"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Actions & drop zone -->
      <StackPanel Grid.Row="2"
                  Spacing="12"
                  Margin="0,16,0,0">
        <Border x:Name="DropZone"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="2"
                CornerRadius="12"
                Padding="24"
                IsVisible="{Binding IsDropZoneActive}">
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="📥"
                       FontSize="32"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding DropZoneStatus}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Button Content="{loc:Str tab_preset_i_o_export_content}"
                      Command="{Binding ExportPresetCommand}"
                      CommandParameter="{Binding SelectedPreset}" />
              <Button Content="{loc:Str tab_preset_i_o_import_content}"
                      Command="{Binding ImportPresetCommand}" />
              <Button Content="{loc:Str tab_preset_i_o_share_content}"
                      Command="{Binding SharePresetCommand}"
                      CommandParameter="{Binding SelectedPreset}" />
            </StackPanel>

            <TextBlock Text="{loc:Str tab_preset_i_o_drag_drop_a_presetjson_file_here_text}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>
  </ScrollViewer>

</UserControl>

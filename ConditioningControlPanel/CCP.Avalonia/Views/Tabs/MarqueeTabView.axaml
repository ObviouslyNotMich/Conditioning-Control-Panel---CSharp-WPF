<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.MarqueeTabView"
             x:DataType="vm:MarqueeTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:MarqueeTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="{DynamicResource PanelBg}" />
            <GradientStop Offset="1" Color="#4A2C6A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="{DynamicResource TextLightBrush}"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_marquee_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{loc:Str tab_marquee_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_marquee_message_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}" />
          <TextBox Text="{Binding MarqueeMessage, Mode=TwoWay}"
                   PlaceholderText="{loc:Str tab_marquee_marquee_message_placeholder}" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str tab_marquee_refresh_from_server_content}"
                    Command="{Binding RefreshFromServerCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str tab_marquee_check_update_banner_content}"
                    Command="{Binding CheckUpdateBannerCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str tab_marquee_check_announcement_content}"
                    Command="{Binding CheckAnnouncementCommand}"
                    IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_marquee_welcome_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}" />
          <TextBlock Text="{Binding WelcomeText}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap" />
          <Button Content="{loc:Str tab_marquee_update_welcome_message_content}"
                  Command="{Binding UpdateWelcomeMessageCommand}"
                  IsEnabled="{Binding !IsBusy}" />
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_marquee_update_banner_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}" />
          <TextBlock Text="{Binding UpdateBannerText}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     TextWrapping="Wrap" />
          <Button Content="{loc:Str tab_marquee_open_update_url_content}"
                  Command="{Binding OpenUpdateUrlCommand}"
                  IsEnabled="{Binding !IsBusy}" />
        </StackPanel>
      </Border>

      <ProgressBar IsIndeterminate="True"
                   IsVisible="{Binding IsBusy}"
                   HorizontalAlignment="Stretch" />
    </StackPanel>
  </ScrollViewer>

</UserControl>

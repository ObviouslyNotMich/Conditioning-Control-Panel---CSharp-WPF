<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.MarqueeTabView"
             x:DataType="vm:MarqueeTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:MarqueeTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{loc:Str tab_marquee_marquee_text}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="White" />

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str tab_marquee_message_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <TextBox Text="{Binding MarqueeMessage, Mode=TwoWay}"
                   PlaceholderText="{loc:Str tab_marquee_marquee_message_placeholder}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Str tab_marquee_refresh_from_server_content}"
                    Command="{Binding RefreshFromServerCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str tab_marquee_check_update_banner_content}"
                    Command="{Binding CheckUpdateBannerCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str tab_marquee_check_announcement_content}"
                    Command="{Binding CheckAnnouncementCommand}"
                    IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str tab_marquee_welcome_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <TextBlock Text="{Binding WelcomeText}"
                     TextWrapping="Wrap" />
          <Button Content="{loc:Str tab_marquee_update_welcome_message_content}"
                  Command="{Binding UpdateWelcomeMessageCommand}"
                  IsEnabled="{Binding !IsBusy}" />
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str tab_marquee_update_banner_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <TextBlock Text="{Binding UpdateBannerText}"
                     TextWrapping="Wrap" />
          <Button Content="{loc:Str tab_marquee_open_update_url_content}"
                  Command="{Binding OpenUpdateUrlCommand}"
                  IsEnabled="{Binding !IsBusy}" />
        </StackPanel>
      </Border>

      <ProgressBar IsIndeterminate="True"
                   IsVisible="{Binding IsBusy}"
                   HorizontalAlignment="Stretch" />
    </StackPanel>
  </ScrollViewer>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.CompanionHubTabView"
             x:DataType="vm:CompanionHubTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:CompanionHubTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{loc:Str tab_companion_hub_companion_hub_text}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="White" />

      <Border Theme="{StaticResource PlatformInfoBadge}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="ℹ️"
                     FontSize="16"
                     VerticalAlignment="Center" />
          <TextBlock Text="{loc:Str tab_companion_hub_full_avatar_tube_integration_not_yet_text}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding AvatarStatusText}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <TextBlock Text="{Binding AvatarVisible, StringFormat='Visible: {0}'}"
                     Opacity="0.8" />
          <TextBlock Text="{Binding AvatarDetached, StringFormat='Detached: {0}'}"
                     Opacity="0.8" />
          <WrapPanel Orientation="Horizontal">
            <Button Content="{loc:Str tab_companion_hub_initialize_content}"
                    Command="{Binding InitializeAvatarCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_show_content}"
                    Command="{Binding ShowAvatarCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_hide_content}"
                    Command="{Binding HideAvatarCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_wake_bambi_content}"
                    Command="{Binding WakeBambiCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_toggle_detach_content}"
                    Command="{Binding ToggleDetachCommand}"
                    Margin="0,0,8,8" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str tab_companion_hub_pose_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <NumericUpDown Value="{Binding CurrentPose}"
                           Minimum="1"
                           Maximum="10"
                           Width="120" />
            <Button Content="{loc:Str tab_companion_hub_set_pose_content}"
                    Command="{Binding SetPoseCommand}"
                    CommandParameter="{Binding CurrentPose}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str tab_companion_hub_audio_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ToggleButton x:Name="MuteToggle"
                          Content="{loc:Str tab_companion_hub_mute_avatar_content}"
                          Click="MuteToggle_Click" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Button Content="{loc:Str tab_companion_hub_avatar_settings_content}"
              Command="{Binding OpenAvatarSettingsCommand}"
              HorizontalAlignment="Left" />
    </StackPanel>
  </ScrollViewer>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.CompanionHubTabView"
             x:DataType="vm:CompanionHubTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:CompanionHubTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#2A0E2E" />
            <GradientStop Offset="1" Color="#6B2C91" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="White"
                  Width="280"
                  Height="280"
                  CornerRadius="140"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_companion_hub_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="{loc:Str tab_companion_hub_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Theme="{StaticResource PlatformInfoBadge}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="ℹ️"
                     FontSize="16"
                     VerticalAlignment="Center" />
          <TextBlock Text="{loc:Str tab_companion_hub_full_avatar_tube_integration_not_yet_text}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>

      <!-- Avatar status & actions -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="14">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="🤖"
                       FontSize="32"
                       VerticalAlignment="Center" />
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding AvatarStatusText}"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="{DynamicResource PinkBrush}" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Background="{DynamicResource TransparentPinkBrush}"
                        CornerRadius="4"
                        Padding="6,2">
                  <TextBlock Text="{Binding AvatarVisible, StringFormat='Visible: {0}'}"
                             FontSize="11"
                             Foreground="{DynamicResource PinkBrush}" />
                </Border>
                <Border Background="{DynamicResource TransparentPinkBrush}"
                        CornerRadius="4"
                        Padding="6,2">
                  <TextBlock Text="{Binding AvatarDetached, StringFormat='Detached: {0}'}"
                             FontSize="11"
                             Foreground="{DynamicResource PinkBrush}" />
                </Border>
              </StackPanel>
            </StackPanel>
          </StackPanel>

          <WrapPanel Orientation="Horizontal">
            <Button Content="{loc:Str tab_companion_hub_initialize_content}"
                    Command="{Binding InitializeAvatarCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_show_content}"
                    Command="{Binding ShowAvatarCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_hide_content}"
                    Command="{Binding HideAvatarCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_wake_bambi_content}"
                    Command="{Binding WakeBambiCommand}"
                    Margin="0,0,8,8" />
            <Button Content="{loc:Str tab_companion_hub_toggle_detach_content}"
                    Command="{Binding ToggleDetachCommand}"
                    Margin="0,0,8,8" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- Pose -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_companion_hub_pose_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <NumericUpDown Value="{Binding CurrentPose}"
                           Minimum="1"
                           Maximum="10"
                           Width="120" />
            <Button Content="{loc:Str tab_companion_hub_set_pose_content}"
                    Command="{Binding SetPoseCommand}"
                    CommandParameter="{Binding CurrentPose}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Audio -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_companion_hub_audio_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <ToggleButton x:Name="MuteToggle"
                        Content="{loc:Str tab_companion_hub_mute_avatar_content}"
                        Click="MuteToggle_Click" />
        </StackPanel>
      </Border>

      <Button Content="{loc:Str tab_companion_hub_avatar_settings_content}"
              Command="{Binding OpenAvatarSettingsCommand}"
              HorizontalAlignment="Left" />
    </StackPanel>
  </ScrollViewer>

</UserControl>

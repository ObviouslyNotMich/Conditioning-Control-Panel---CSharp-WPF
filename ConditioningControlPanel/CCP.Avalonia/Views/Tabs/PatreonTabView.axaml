<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.PatreonTabView"
             x:DataType="vm:PatreonTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:PatreonTabViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <SolidColorBrush x:Key="SubscribeStarGreenBrush" Color="#FF009E8F" />
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="#FF00C853" />
  </UserControl.Resources>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="20">

      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="2">
          <Border BoxShadow="0 0 20 0 #80FF69B4">
            <TextBlock Text="{loc:Str label_patreon_exclusives}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
          </Border>
          <TextBlock Text="{loc:Str label_premium_features_for_supporters}"
                     FontSize="14"
                     Opacity="0.8"
                     Foreground="{DynamicResource TextLightBrush}" />
        </StackPanel>
        <Button Grid.Column="1"
                Content="{loc:Str label_help_symbol}"
                VerticalAlignment="Top"
                Command="{Binding ShowHelpCommand}"
                ToolTip.Tip="{loc:Str title_help}" />
      </Grid>

      <!-- Premium Status -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <StackPanel Spacing="4">
          <TextBlock Text="{loc:Str tab_patreon_account_status_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PinkBrush}" />
          <TextBlock Text="{loc:Str tab_patreon_premium_active_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource SuccessGreenBrush}"
                     IsVisible="{Binding IsPremium}" />
          <TextBlock Text="{loc:Str tab_patreon_free_user_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextMutedBrush}"
                     IsVisible="{Binding !IsPremium}" />
        </StackPanel>
      </Border>

      <!-- Account login cards -->
      <Grid ColumnDefinitions="* * *"
            HorizontalAlignment="Stretch">
        <!-- Patreon -->
        <Border Grid.Column="0"
                Background="{DynamicResource PatreonLightPurpleBrush}"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,8,0">
          <StackPanel Spacing="8">
            <TextBlock Text="⭐"
                       FontSize="28"
                       HorizontalAlignment="Left" />
            <TextBlock Text="{loc:Str tab_patreon_patreon_text}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{Binding PatreonStatusText}"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{Binding PatreonTierText}"
                       Foreground="{DynamicResource TextLightBrush}"
                       Opacity="0.8" />
            <TextBlock Text="{Binding PatreonExpiryText}"
                       Foreground="{DynamicResource TextLightBrush}"
                       Opacity="0.7"
                       IsVisible="{Binding PatreonExpiryText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{Binding PatreonButtonText}"
                      Command="{Binding PatreonLoginCommand}" />
              <Button Content="{loc:Str tab_patreon_visit_patreon_content}"
                      Command="{Binding VisitPatreonCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- SubscribeStar -->
        <Border Grid.Column="1"
                Background="{DynamicResource SubscribeStarGreenBrush}"
                CornerRadius="12"
                Padding="16"
                Margin="4,0,4,0">
          <StackPanel Spacing="8">
            <TextBlock Text="💚"
                       FontSize="28"
                       HorizontalAlignment="Left" />
            <TextBlock Text="{loc:Str tab_patreon_subscribestar_text}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{Binding SubscribeStarStatusText}"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{Binding SubscribeStarTierText}"
                       Foreground="{DynamicResource TextLightBrush}"
                       Opacity="0.8" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{Binding SubscribeStarButtonText}"
                      Command="{Binding SubscribeStarLoginCommand}" />
              <Button Content="{loc:Str tab_patreon_visit_subscribestar_content}"
                      Command="{Binding VisitSubscribeStarCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Discord -->
        <Border Grid.Column="2"
                Background="{DynamicResource DiscordBlueBrush}"
                CornerRadius="12"
                Padding="16"
                Margin="8,0,0,0">
          <StackPanel Spacing="8">
            <TextBlock Text="💬"
                       FontSize="28"
                       HorizontalAlignment="Left" />
            <TextBlock Text="{loc:Str tab_patreon_discord_text}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{Binding DiscordStatusText}"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{Binding DiscordInfoText}"
                       Foreground="{DynamicResource TextLightBrush}"
                       Opacity="0.8" />
            <Button Content="{Binding DiscordButtonText}"
                    Command="{Binding DiscordLoginCommand}" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Account Linking -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16"
              IsVisible="{Binding ShowLinkingSection}">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str label_link_accounts}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PinkBrush}" />
          <TextBlock Text="{loc:Str label_link_both_providers_to_access_your_account_fr}"
                     Opacity="0.8"
                     TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Str btn_link_patreon}"
                    Command="{Binding LinkPatreonCommand}"
                    IsVisible="{Binding ShowLinkPatreonButton}" />
            <Button Content="{loc:Str btn_link_discord}"
                    Command="{Binding LinkDiscordCommand}"
                    IsVisible="{Binding ShowLinkDiscordButton}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Cloud Backup -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16"
              IsVisible="{Binding ShowCloudBackupSection}">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str label_cloud_settings_backup}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PinkBrush}" />
          <TextBlock Text="{Binding BackupStatusText}"
                     Opacity="0.8" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Str btn_backup_now}"
                    Command="{Binding BackupNowCommand}" />
            <Button Content="{loc:Str btn_restore_from_cloud}"
                    Command="{Binding RestoreFromCloudCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Data & Privacy -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16"
              IsVisible="{Binding ShowDataPrivacySection}">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str label_data_privacy}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PinkBrush}" />
          <TextBlock Text="{loc:Str label_export_your_cloud_data_or_view_our_privacy_po}"
                     Opacity="0.8"
                     TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Str btn_export_my_data}"
                    Command="{Binding ExportDataCommand}" />
            <Button Content="{loc:Str btn_privacy_policy}"
                    Command="{Binding OpenPrivacyPolicyCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Premium Benefits / Support Development -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <Grid ColumnDefinitions="Auto,*">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="16"
                      VerticalAlignment="Center"
                      Margin="0,0,20,0">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <Image Source="avares://CCP.Avalonia/Assets/patreon/Patreon tier1.png"
                     Width="72"
                     Height="72"
                     Stretch="Uniform" />
              <TextBlock Text="{loc:Str patreon_tier_badge_level1}"
                         FontSize="12"
                         HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <Image Source="avares://CCP.Avalonia/Assets/patreon/Patreon tier2.png"
                     Width="72"
                     Height="72"
                     Stretch="Uniform" />
              <TextBlock Text="{loc:Str patreon_tier_badge_level2}"
                         FontSize="12"
                         HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <Image Source="avares://CCP.Avalonia/Assets/patreon/Patreon tier3.png"
                     Width="72"
                     Height="72"
                     Stretch="Uniform" />
              <TextBlock Text="{loc:Str patreon_tier_badge_level3}"
                         FontSize="12"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="8">
            <Border BoxShadow="0 0 20 0 #80FF69B4">
              <TextBlock Text="{loc:Str section_support_development}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource PinkBrush}" />
            </Border>
            <TextBlock Text="{loc:Str patreon_support_card_body}"
                       TextWrapping="Wrap"
                       Opacity="0.9" />
            <TextBlock Text="{loc:Str section_patreon_unlocks}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PinkBrush}" />
            <TextBlock Text="{loc:Str tab_patreon_exclusive_achievements_rewards_text}"
                       Opacity="0.9" />
            <TextBlock Text="{loc:Str tab_patreon_cloud_backup_settings_progress_text}"
                       Opacity="0.9" />
            <TextBlock Text="{loc:Str tab_patreon_early_access_new_features_experiments_text}"
                       Opacity="0.9" />
            <TextBlock Text="{loc:Str tab_patreon_advanced_discord_integration_rich_presence_text}"
                       Opacity="0.9" />
            <Button Content="{loc:Str btn_visit_patreon}"
                    Command="{Binding VisitPatreonCommand}"
                    HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Discord Settings -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str tab_patreon_discord_settings_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource PinkBrush}" />
          <ToggleSwitch Content="{loc:Str tab_patreon_share_achievements_content}"
                        IsChecked="{Binding DiscordShareAchievements, Mode=TwoWay}" />
          <ToggleSwitch Content="{loc:Str tab_patreon_share_level_ups_content}"
                        IsChecked="{Binding DiscordShareLevelUps, Mode=TwoWay}" />
          <ToggleSwitch Content="{loc:Str tab_patreon_show_level_presence_content}"
                        IsChecked="{Binding DiscordShowLevelInPresence, Mode=TwoWay}" />
          <ToggleSwitch Content="{loc:Str tab_patreon_allow_discord_dms_content}"
                        IsChecked="{Binding AllowDiscordDm, Mode=TwoWay}" />
          <ToggleSwitch Content="{loc:Str tab_patreon_share_profile_picture_content}"
                        IsChecked="{Binding ShareProfilePicture, Mode=TwoWay}" />
          <ToggleSwitch Content="{loc:Str tab_patreon_show_online_status_content}"
                        IsChecked="{Binding ShowOnlineStatus, Mode=TwoWay}" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

</UserControl>

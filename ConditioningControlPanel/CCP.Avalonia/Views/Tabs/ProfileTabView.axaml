<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.ProfileTabView"
             x:DataType="vm:ProfileTabViewModel">

  <Design.DataContext>
    <vm:ProfileTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#2A0E2E" />
            <GradientStop Offset="1" Color="#5865F2" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="White"
                  Width="300"
                  Height="300"
                  CornerRadius="150"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-80" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_profile_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="{loc:Str tab_profile_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="480"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Identity card with avatar -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="#5865F2"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="12">
          <!-- Avatar -->
          <Grid Grid.RowSpan="2" VerticalAlignment="Center" Margin="0,0,16,0">
            <Ellipse Width="72"
                     Height="72"
                     Fill="{DynamicResource PinkBrush}" />
            <TextBlock Text="{Binding AvatarInitials}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Grid>

          <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{Binding LoginStatusText}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13" />
            <TextBlock Text="{Binding DisplayName}"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       IsVisible="{Binding IsLoggedIn}" />
            <TextBlock Text="{Binding UnifiedId}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12"
                       IsVisible="{Binding IsLoggedIn}" />
            <TextBlock Text="{Binding LoginPrompt}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       IsVisible="{Binding !IsLoggedIn}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Grid.Row="1"
                  Content="{Binding LogoutText}"
                  Command="{Binding LogoutCommand}"
                  IsVisible="{Binding IsLoggedIn}"
                  HorizontalAlignment="Left"
                  Background="#E84A6B"
                  Foreground="White"
                  Padding="16,8"
                  CornerRadius="8" />
        </Grid>
      </Border>

      <!-- Stats -->
      <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding PlayerLevel}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Str tab_profile_stats_level}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding PlayerXpText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Str tab_profile_stats_xp}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2"
                Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding TotalHoursText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Str tab_profile_stats_total_hours}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
        <Border Grid.Column="3"
                Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding PeakRankText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Str tab_profile_stats_peak_rank}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Badges -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="#5865F2"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_profile_badges_title}"
                     Foreground="White"
                     FontSize="16"
                     FontWeight="Bold" />
          <ItemsControl ItemsSource="{Binding Badges}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource TransparentPinkBrush}"
                        CornerRadius="16"
                        Padding="12,6"
                        Margin="0,0,8,8">
                  <TextBlock Text="{Binding}"
                             Foreground="{DynamicResource PinkBrush}"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Linked providers -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="#5865F2"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{Binding LinkedAccountsTitle}"
                     Foreground="White"
                     FontSize="16"
                     FontWeight="Bold" />

          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{DynamicResource TransparentPinkBrush}"
                    CornerRadius="6"
                    Padding="10,6"
                    IsVisible="{Binding HasLinkedPatreon}">
              <TextBlock Text="{loc:Str label_linked_patreon}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontWeight="SemiBold" />
            </Border>
            <Border Background="{DynamicResource TransparentPinkBrush}"
                    CornerRadius="6"
                    Padding="10,6"
                    IsVisible="{Binding HasLinkedDiscord}">
              <TextBlock Text="{loc:Str label_linked_discord}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontWeight="SemiBold" />
            </Border>
          </StackPanel>

          <TextBlock Text="{Binding CommunitySettingsTitle}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Gallery placeholder -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_profile_gallery_title}"
                     Foreground="White"
                     FontSize="16"
                     FontWeight="Bold" />
          <TextBlock Text="{loc:Str tab_profile_gallery_placeholder}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>

</UserControl>

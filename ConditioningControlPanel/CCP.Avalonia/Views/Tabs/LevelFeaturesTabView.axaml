<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="using:ConditioningControlPanel.Core.Localization"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.LevelFeaturesTabView"
             x:DataType="vm:LevelFeaturesTabViewModel">

  <Design.DataContext>
    <vm:LevelFeaturesTabViewModel PlayerLevel="65"
                                  BubbleCountEnabled="True"
                                  BubbleCountFrequency="4"
                                  BubbleCountDifficulty="60"
                                  BouncingTextEnabled="False"
                                  BouncingTextSpeed="55"
                                  BouncingTextSize="60"
                                  MindWipeEnabled="True"
                                  MindWipeFrequency="3"
                                  MindWipeVolume="70"
                                  BrainDrainEnabled="False"
                                  BrainDrainIntensity="40" />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{Binding [tab_level_features], Source={x:Static loc:LocalizationManager.Instance}}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextLightBrush}" />

      <!-- 2×2 FeatureCard dashboard -->
      <Grid ColumnDefinitions="*,*" RowDefinitions="*,*">
        <features:FeatureCard Grid.Row="0" Grid.Column="0"
                              Title="{Binding [feature_bubble_count], Source={x:Static loc:LocalizationManager.Instance}}"
                              IconUri="pack://application:,,,/Resources/features/Bubble_count.png"
                              HelpSectionId="BubbleCount"
                              IsActive="{Binding BubbleCountEnabled}"
                              IsLocked="{Binding IsBubbleCountLocked}"
                              LockLevel="{Binding BubbleCountLockLevel}"
                              Tag="BubbleCount"
                              Click="FeatureCard_Click"
                              ToggleRequested="FeatureCard_ToggleRequested" />
        <features:FeatureCard Grid.Row="0" Grid.Column="1"
                              Title="{Binding [feature_bouncing_text], Source={x:Static loc:LocalizationManager.Instance}}"
                              IconUri="pack://application:,,,/Resources/features/bouncing_text.png"
                              HelpSectionId="BouncingText"
                              IsActive="{Binding BouncingTextEnabled}"
                              IsLocked="{Binding IsBouncingTextLocked}"
                              LockLevel="{Binding BouncingTextLockLevel}"
                              Tag="BouncingText"
                              Click="FeatureCard_Click"
                              ToggleRequested="FeatureCard_ToggleRequested" />
        <features:FeatureCard Grid.Row="1" Grid.Column="0"
                              Title="{Binding [feature_brain_drain], Source={x:Static loc:LocalizationManager.Instance}}"
                              IconUri="pack://application:,,,/Resources/features/brain_drain.png"
                              HelpSectionId="BrainDrain"
                              IsActive="{Binding BrainDrainEnabled}"
                              IsLocked="{Binding IsBrainDrainLocked}"
                              LockLevel="{Binding BrainDrainLockLevel}"
                              Tag="BrainDrain"
                              Click="FeatureCard_Click"
                              ToggleRequested="FeatureCard_ToggleRequested" />
        <features:FeatureCard Grid.Row="1" Grid.Column="1"
                              Title="{Binding [feature_mind_wipe], Source={x:Static loc:LocalizationManager.Instance}}"
                              IconUri="pack://application:,,,/Resources/features/Mind_Wipers.png"
                              HelpSectionId="MindWipe"
                              IsActive="{Binding MindWipeEnabled}"
                              IsLocked="{Binding IsMindWipeLocked}"
                              LockLevel="{Binding MindWipeLockLevel}"
                              Tag="MindWipe"
                              Click="FeatureCard_Click"
                              ToggleRequested="FeatureCard_ToggleRequested" />
      </Grid>

      <!-- Bubble Count -->
      <Border Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid ColumnDefinitions="160,*">
          <features:FeatureCard Grid.Column="0"
                                Title=""
                                IconUri="pack://application:,,,/Resources/features/Bubble_count.png"
                                HelpSectionId="BubbleCount"
                                IsActive="{Binding BubbleCountEnabled}"
                                IsLocked="{Binding IsBubbleCountLocked}"
                                LockLevel="{Binding BubbleCountLockLevel}"
                                Tag="BubbleCount"
                                Click="FeatureCard_Click"
                                ToggleRequested="FeatureCard_ToggleRequested" />
          <StackPanel Grid.Column="1" Spacing="10" Margin="16,0,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding [feature_bubble_count], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextLightBrush}" />
              <TextBlock Text="{Binding BubbleCountUnlockText}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <ToggleSwitch Content="{Binding [setting_enabled], Source={x:Static loc:LocalizationManager.Instance}}"
                          IsChecked="{Binding BubbleCountEnabled, Mode=TwoWay}" />

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_frequency], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BubbleCountFrequency}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="1"
                      Maximum="10"
                      Value="{Binding BubbleCountFrequency, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_difficulty], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BubbleCountDifficulty}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="10"
                      Maximum="100"
                      Value="{Binding BubbleCountDifficulty, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <CheckBox Content="{Binding [setting_strict_lock], Source={x:Static loc:LocalizationManager.Instance}}"
                      IsChecked="{Binding BubbleCountStrictLock, Mode=TwoWay}" />

            <Button Content="{Binding [setting_strict_lock_warning], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding ToggleBubbleCountStrictCommand}"
                    Theme="{DynamicResource OutlineButton}"
                    IsVisible="{Binding BubbleCountStrictLock}"
                    IsEnabled="{Binding BubbleCountStrictLock}" />

            <Button Content="{Binding [btn_test], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding TestBubbleCountCommand}"
                    Theme="{DynamicResource OutlineButton}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Bouncing Text -->
      <Border Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid ColumnDefinitions="160,*">
          <features:FeatureCard Grid.Column="0"
                                Title=""
                                IconUri="pack://application:,,,/Resources/features/bouncing_text.png"
                                HelpSectionId="BouncingText"
                                IsActive="{Binding BouncingTextEnabled}"
                                IsLocked="{Binding IsBouncingTextLocked}"
                                LockLevel="{Binding BouncingTextLockLevel}"
                                Tag="BouncingText"
                                Click="FeatureCard_Click"
                                ToggleRequested="FeatureCard_ToggleRequested" />
          <StackPanel Grid.Column="1" Spacing="10" Margin="16,0,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding [feature_bouncing_text], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextLightBrush}" />
              <TextBlock Text="{Binding BouncingTextUnlockText}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <ToggleSwitch Content="{Binding [setting_enabled], Source={x:Static loc:LocalizationManager.Instance}}"
                          IsChecked="{Binding BouncingTextEnabled, Mode=TwoWay}" />

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_speed], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BouncingTextSpeed}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="1"
                      Maximum="100"
                      Value="{Binding BouncingTextSpeed, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_size], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BouncingTextSize}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="10"
                      Maximum="200"
                      Value="{Binding BouncingTextSize, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <CheckBox Content="{Binding [setting_always_on_top], Source={x:Static loc:LocalizationManager.Instance}}"
                      IsChecked="{Binding BouncingTextAlwaysOnTop, Mode=TwoWay}" />

            <Button Content="{Binding [btn_edit_phrases], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding EditBouncingTextPhrasesCommand}"
                    Theme="{DynamicResource OutlineButton}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Mind Wipe -->
      <Border Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid ColumnDefinitions="160,*">
          <features:FeatureCard Grid.Column="0"
                                Title=""
                                IconUri="pack://application:,,,/Resources/features/Mind_Wipers.png"
                                HelpSectionId="MindWipe"
                                IsActive="{Binding MindWipeEnabled}"
                                IsLocked="{Binding IsMindWipeLocked}"
                                LockLevel="{Binding MindWipeLockLevel}"
                                Tag="MindWipe"
                                Click="FeatureCard_Click"
                                ToggleRequested="FeatureCard_ToggleRequested" />
          <StackPanel Grid.Column="1" Spacing="10" Margin="16,0,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding [feature_mind_wipe], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextLightBrush}" />
              <TextBlock Text="{Binding MindWipeUnlockText}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <ToggleSwitch Content="{Binding [setting_enabled], Source={x:Static loc:LocalizationManager.Instance}}"
                          IsChecked="{Binding MindWipeEnabled, Mode=TwoWay}" />

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_frequency], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding MindWipeFrequency}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="1"
                      Maximum="10"
                      Value="{Binding MindWipeFrequency, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_volume], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding MindWipeVolume}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="100"
                      Value="{Binding MindWipeVolume, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <CheckBox Content="{Binding [setting_loop], Source={x:Static loc:LocalizationManager.Instance}}"
                      IsChecked="{Binding MindWipeLoop, Mode=TwoWay}" />

            <Button Content="{Binding [btn_test], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding TestMindWipeCommand}"
                    Theme="{DynamicResource OutlineButton}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Brain Drain -->
      <Border Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid ColumnDefinitions="160,*">
          <features:FeatureCard Grid.Column="0"
                                Title=""
                                IconUri="pack://application:,,,/Resources/features/brain_drain.png"
                                HelpSectionId="BrainDrain"
                                IsActive="{Binding BrainDrainEnabled}"
                                IsLocked="{Binding IsBrainDrainLocked}"
                                LockLevel="{Binding BrainDrainLockLevel}"
                                Tag="BrainDrain"
                                Click="FeatureCard_Click"
                                ToggleRequested="FeatureCard_ToggleRequested" />
          <StackPanel Grid.Column="1" Spacing="10" Margin="16,0,0,0">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding [feature_brain_drain], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextLightBrush}" />
              <TextBlock Text="{Binding BrainDrainUnlockText}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>

            <ToggleSwitch Content="{Binding [setting_enabled], Source={x:Static loc:LocalizationManager.Instance}}"
                          IsChecked="{Binding BrainDrainEnabled, Mode=TwoWay}" />

            <StackPanel>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [setting_intensity], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextLightBrush}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BrainDrainIntensity}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="100"
                      Value="{Binding BrainDrainIntensity, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <CheckBox Content="{Binding [setting_high_refresh], Source={x:Static loc:LocalizationManager.Instance}}"
                      IsChecked="{Binding BrainDrainHighRefresh, Mode=TwoWay}" />
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

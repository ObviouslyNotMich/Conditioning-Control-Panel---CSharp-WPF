<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:system="using:System"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.AnimationsTabView"
             x:DataType="vm:AnimationsTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:AnimationsTabViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <system:Boolean x:Key="TrueBool">True</system:Boolean>
    <system:Boolean x:Key="FalseBool">False</system:Boolean>
  </UserControl.Resources>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#1A1A2E" />
            <GradientStop Offset="1" Color="#5A3A1A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="White"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_animations_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="{loc:Str tab_animations_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_animations_season_title_shimmer_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str tab_animations_start_content}"
                    Command="{Binding StartSeasonTitleShimmerCommand}" />
            <Button Content="{loc:Str tab_animations_stop_content}"
                    Command="{Binding StopSeasonTitleShimmerCommand}" />
          </StackPanel>
          <TextBlock Text="{loc:Str tab_animations_active_text}"
                     IsVisible="{Binding IsSeasonTitleShimmerActive}"
                     Foreground="{DynamicResource PinkBrush}" />
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_animations_lockdown_pulse_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str tab_animations_start_content}"
                    Command="{Binding StartLockdownPulseCommand}" />
            <Button Content="{loc:Str tab_animations_stop_content}"
                    Command="{Binding StopLockdownPulseCommand}" />
          </StackPanel>
          <TextBlock Text="{loc:Str tab_animations_active_text}"
                     IsVisible="{Binding IsLockdownPulseActive}"
                     Foreground="{DynamicResource PinkBrush}" />
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_animations_skill_tree_animations_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str tab_animations_start_content}"
                    Command="{Binding StartSkillTreeAnimationsCommand}" />
            <Button Content="{loc:Str tab_animations_stop_content}"
                    Command="{Binding StopSkillTreeAnimationsCommand}" />
          </StackPanel>
          <TextBlock Text="{loc:Str tab_animations_active_text}"
                     IsVisible="{Binding AreSkillTreeAnimationsActive}"
                     Foreground="{DynamicResource PinkBrush}" />
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_animations_expandable_icon_labels_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str tab_animations_show_labels_content}"
                    Command="{Binding ShowExpandableIconLabelCommand}"
                    CommandParameter="{StaticResource TrueBool}" />
            <Button Content="{loc:Str tab_animations_hide_labels_content}"
                    Command="{Binding ShowExpandableIconLabelCommand}"
                    CommandParameter="{StaticResource FalseBool}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Button Content="{loc:Str tab_animations_show_og_welcome_popup_content}"
              Command="{Binding ShowOgWelcomePopupCommand}"
              HorizontalAlignment="Left" />
    </StackPanel>
  </ScrollViewer>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.BambiTakeoverTabView"
             x:DataType="vm:BambiTakeoverTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:BambiTakeoverTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="22"
                Margin="36,28"
                MaxWidth="1180"
                HorizontalAlignment="Center">

      <!-- Header -->
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0"
                   Text="🤖"
                   FontSize="44"
                   VerticalAlignment="Center"
                   Margin="0,0,16,0" />
        <TextBlock Grid.Column="1"
                   Text="{loc:Str tab_takeover}"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center" />
      </Grid>

      <!-- Description card -->
      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="12"
              Padding="24,20">
        <Grid ColumnDefinitions="Auto,22,*">
          <Border Grid.Column="0"
                  Width="160"
                  Height="160"
                  CornerRadius="12"
                  ClipToBounds="True"
                  BorderBrush="#FF69B4"
                  BorderThickness="2"
                  VerticalAlignment="Top">
            <Image Source="avares://CCP.Avalonia/Assets/features/bambi takeover.png"
                   Stretch="UniformToFill" />
          </Border>
          <StackPanel Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str label_what_is_this}"
                       Foreground="#FF69B4"
                       FontSize="11"
                       FontWeight="Bold"
                       Margin="0,0,0,4" />
            <TextBlock Text="{loc:Str desc_takeover}"
                       Foreground="White"
                       FontSize="15"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       LineHeight="22" />
            <TextBlock Text="{loc:Str desc_takeover_bullets}"
                       Foreground="#AAAAAA"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="20" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Controls + guide -->
      <Grid ColumnDefinitions="2*,22,*">

        <!-- Controls column with gating overlay -->
        <Grid Grid.Column="0">
          <StackPanel Spacing="14">

            <!-- Autonomy toggle -->
            <Border Background="#1A1A2E"
                    BorderBrush="#FF69B4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str tab_bambi_takeover_autonomy_mode_text}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{loc:Str tab_bambi_takeover_let_companion_trigger_effects_on_own_text}"
                               Foreground="#AAAAAA"
                               FontSize="11"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1"
                                VerticalAlignment="Center"
                                IsChecked="{Binding AutonomyEnabled, Mode=TwoWay}" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Content="{loc:Str tab_bambi_takeover_toggle_autonomy_content}"
                          Command="{Binding ToggleAutonomyCommand}" />
                  <Button Content="{loc:Str tab_bambi_takeover_test_content}"
                          Command="{Binding TestAutonomyCommand}" />
                  <Button Content="{loc:Str tab_bambi_takeover_force_start_content}"
                          Command="{Binding ForceStartAutonomyCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Cadence sliders -->
            <Border Background="#1A1A2E"
                    BorderBrush="#FF69B4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <StackPanel Spacing="14">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{loc:Str tab_bambi_takeover_intensity_text}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AutonomyIntensity, StringFormat='{}{0}%'}"
                               Foreground="#FF69B4"
                               FontSize="13"
                               FontWeight="SemiBold" />
                  </Grid>
                  <Slider Minimum="0"
                          Maximum="100"
                          Value="{Binding AutonomyIntensity, Mode=TwoWay}"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{loc:Str tab_bambi_takeover_cooldown_text}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AutonomyCooldown, StringFormat='{}{0}s'}"
                               Foreground="#FF69B4"
                               FontSize="13"
                               FontWeight="SemiBold" />
                  </Grid>
                  <Slider Minimum="10"
                          Maximum="300"
                          Value="{Binding AutonomyCooldown, Mode=TwoWay}"
                          TickFrequency="5"
                          IsSnapToTickEnabled="True" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{loc:Str tab_bambi_takeover_random_interval_text}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AutonomyInterval, StringFormat='{}{0}s'}"
                               Foreground="#FF69B4"
                               FontSize="13"
                               FontWeight="SemiBold" />
                  </Grid>
                  <Slider Minimum="60"
                          Maximum="600"
                          Value="{Binding AutonomyInterval, Mode=TwoWay}"
                          TickFrequency="10"
                          IsSnapToTickEnabled="True" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Trigger conditions -->
            <Border Background="#1A1A2E"
                    BorderBrush="#FF69B4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <StackPanel Spacing="10">
                <TextBlock Text="{loc:Str tab_bambi_takeover_trigger_conditions_text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FF69B4" />
                <WrapPanel Orientation="Horizontal">
                  <CheckBox Content="{loc:Str tab_bambi_takeover_idle_trigger_content}"
                            IsChecked="{Binding AutonomyIdleTrigger, Mode=TwoWay}"
                            Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_random_trigger_content}"
                            IsChecked="{Binding AutonomyRandomTrigger, Mode=TwoWay}"
                            Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_time_aware_content}"
                            IsChecked="{Binding AutonomyTimeAware, Mode=TwoWay}"
                            Margin="0,0,16,8" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Allowed behaviours -->
            <Border Background="#1A1A2E"
                    BorderBrush="#FF69B4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <StackPanel Spacing="10">
                <TextBlock Text="{loc:Str tab_bambi_takeover_allowed_behaviours_text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FF69B4" />
                <WrapPanel Orientation="Horizontal">
                  <CheckBox Content="{loc:Str tab_bambi_takeover_flash_content}" IsChecked="{Binding CanTriggerFlash, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_video_content}" IsChecked="{Binding CanTriggerVideo, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_web_video_content}" IsChecked="{Binding CanTriggerWebVideo, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_subliminal_content}" IsChecked="{Binding CanTriggerSubliminal, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_bubbles_content}" IsChecked="{Binding CanTriggerBubbles, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_comments_content}" IsChecked="{Binding CanComment, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_mind_wipe_content}" IsChecked="{Binding CanTriggerMindWipe, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_lock_card_content}" IsChecked="{Binding CanTriggerLockCard, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_spiral_content}" IsChecked="{Binding CanTriggerSpiral, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_pink_filter_content}" IsChecked="{Binding CanTriggerPinkFilter, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_bouncing_text_content}" IsChecked="{Binding CanTriggerBouncingText, Mode=TwoWay}" Margin="0,0,16,8" />
                  <CheckBox Content="{loc:Str tab_bambi_takeover_bubble_count_content}" IsChecked="{Binding CanTriggerBubbleCount, Mode=TwoWay}" Margin="0,0,16,8" />
                </WrapPanel>
              </StackPanel>
            </Border>

            <!-- Announcement chance -->
            <Border Background="#1A1A2E"
                    BorderBrush="#FF69B4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{loc:Str tab_bambi_takeover_announcement_chance_text}"
                             Foreground="White"
                             FontSize="13"
                             FontWeight="SemiBold" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding AnnouncementChance, StringFormat='{}{0}%'}"
                             Foreground="#FF69B4"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Grid>
                <Slider Minimum="0"
                        Maximum="100"
                        Value="{Binding AnnouncementChance, Mode=TwoWay}"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True" />
              </StackPanel>
            </Border>

            <!-- Start / Stop / Test controls -->
            <Border Background="#1A1A2E"
                    BorderBrush="#FF69B4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <Grid ColumnDefinitions="*,12,Auto">
                <Button Grid.Column="0"
                        Content="{Binding StartStopButtonText}"
                        Command="{Binding StartStopCommand}"
                        Background="#2A1A3A"
                        Foreground="{Binding StartStopButtonForeground}"
                        FontWeight="Bold"
                        FontSize="14"
                        Padding="14,8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center">
                  <ToolTip.Tip>
                    <ToolTip Content="{loc:Str tooltip_start_stop_takeover}" />
                  </ToolTip.Tip>
                </Button>
                <Button Grid.Column="2"
                        Content="{loc:Str btn_test}"
                        Command="{Binding TestAutonomyCommand}"
                        Background="#FF69B4"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        Padding="14,8">
                  <ToolTip.Tip>
                    <ToolTip Content="{loc:Str tooltip_test_action}" />
                  </ToolTip.Tip>
                </Button>
              </Grid>
            </Border>
          </StackPanel>

          <!-- Premium gate overlay -->
          <Border IsVisible="{Binding IsPremiumLocked}"
                  Background="#99000010"
                  BorderBrush="#FF69B4"
                  BorderThickness="2"
                  CornerRadius="10"
                  IsHitTestVisible="True"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10">
              <TextBlock Text="🔒"
                         FontSize="52"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{loc:Str gate_premium_locked}"
                         FontSize="22"
                         FontWeight="Bold"
                         Foreground="White"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{loc:Str gate_premium_subtitle}"
                         Foreground="#CCCCCC"
                         FontSize="14"
                         HorizontalAlignment="Center" />
              <Button Content="{loc:Str gate_unlock_with_patreon}"
                      Command="{Binding UnlockCommand}"
                      Padding="20,8"
                      Background="#FF69B4"
                      Foreground="White"
                      FontWeight="Bold"
                      HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>

        <!-- Guide sidebar -->
        <Border Grid.Column="2"
                VerticalAlignment="Top"
                Background="#1A1A2E"
                BorderBrush="#FF69B4"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,16">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <TextBlock Text="💡"
                         FontSize="18"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0" />
              <TextBlock Text="{loc:Str guide_takeover_title}"
                         Foreground="#FF69B4"
                         FontSize="15"
                         FontWeight="Bold"
                         VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Text="{loc:Str guide_takeover_step1_title}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Bold"
                       Margin="0,0,0,2" />
            <TextBlock Text="{loc:Str guide_takeover_step1_body}"
                       Foreground="#AAAAAA"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="17"
                       Margin="0,0,0,12" />

            <TextBlock Text="{loc:Str guide_takeover_step2_title}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Bold"
                       Margin="0,0,0,2" />
            <TextBlock Text="{loc:Str guide_takeover_step2_body}"
                       Foreground="#AAAAAA"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="17"
                       Margin="0,0,0,12" />

            <TextBlock Text="{loc:Str guide_takeover_step3_title}"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Bold"
                       Margin="0,0,0,2" />
            <TextBlock Text="{loc:Str guide_takeover_step3_body}"
                       Foreground="#AAAAAA"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="17"
                       Margin="0,0,0,4" />

            <Border Height="1" Background="#2E2E48" Margin="0,8,0,12" />

            <TextBlock Text="{loc:Str guide_takeover_settings_title}"
                       Foreground="#FF69B4"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,0,0,6" />
            <TextBlock Text="{loc:Str guide_takeover_settings_body}"
                       Foreground="#AAAAAA"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="18"
                       Margin="0,0,0,12" />

            <Border Background="#22FF69B4"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,0,0,10">
              <TextBlock Text="{loc:Str guide_takeover_tip}"
                         Foreground="#FF69B4"
                         FontSize="12"
                         TextWrapping="Wrap"
                         LineHeight="17" />
            </Border>

            <TextBlock Text="{loc:Str guide_takeover_patreon}"
                       Foreground="#AAAAAA"
                       FontSize="11"
                       TextWrapping="Wrap"
                       LineHeight="16"
                       FontStyle="Italic" />
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>

</UserControl>

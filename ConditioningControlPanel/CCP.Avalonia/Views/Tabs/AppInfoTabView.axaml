<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.AppInfoTabView"
             x:DataType="vm:AppInfoTabViewModel">

  <Design.DataContext>
    <vm:AppInfoTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#1A1A2E" />
            <GradientStop Offset="1" Color="#2A4A6A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="White"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_app_info_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="{loc:Str tab_app_info_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Version + main actions -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="2"
              CornerRadius="12"
              Padding="24">
        <StackPanel HorizontalAlignment="Center" Spacing="10">
          <TextBlock Text="ℹ️"
                     FontSize="48"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{loc:Str label_app_info}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="22"
                     FontWeight="Bold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{Binding VersionText}"
                     Foreground="White"
                     FontSize="16"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Conditioning Control Panel"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="12"
                     HorizontalAlignment="Center" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="12"
                      Margin="0,8,0,0">
            <Button Content="{loc:Str btn_check_updates}"
                    Command="{Binding CheckUpdatesCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str btn_report_bug}"
                    Command="{Binding OpenBugReportCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Account -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str section_account}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{Binding PatreonButtonText}"
                    Command="{Binding QuickPatreonLoginCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{Binding DiscordButtonText}"
                    Command="{Binding QuickDiscordLoginCommand}"
                    IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str btn_discord_server}"
                    Command="{Binding OpenDiscordInviteCommand}" />
            <ToggleButton Content="{loc:Str label_rich_presence}"
                          IsChecked="{Binding IsRichPresenceEnabled}"
                          Command="{Binding ToggleRichPresenceCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Language -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str label_language}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <ComboBox ItemsSource="{Binding LanguageOptions}"
                    SelectedItem="{Binding SelectedLanguage}"
                    Width="240">
            <ComboBox.ItemTemplate>
              <DataTemplate DataType="vm:LanguageOption">
                <TextBlock Text="{Binding DisplayName}"
                           ToolTip.Tip="{Binding ToolTip}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
      </Border>

      <!-- Cloud backup -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str section_cloud_backup}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <TextBlock Text="{Binding BackupStatusText}"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextMutedBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str btn_back_up_now}"
                    Command="{Binding BackupSettingsCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str btn_restore_from_cloud_appinfo}"
                    Command="{Binding RestoreSettingsCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str btn_export_my_data_appinfo}"
                    Command="{Binding ExportDataCommand}"
                    IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Legal & support -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str section_legal_and_support}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <Button Content="{loc:Str btn_privacy_policy}"
                  Command="{Binding OpenPrivacyPolicyCommand}" />
        </StackPanel>
      </Border>

      <!-- Smoke tests -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str section_smoke_tests}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="{loc:Str btn_test_audio}"
                    Command="{Binding SmokeTestAudioCommand}"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str btn_test_video}"
                    Command="{Binding SmokeTestVideoCommand}"
                    IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

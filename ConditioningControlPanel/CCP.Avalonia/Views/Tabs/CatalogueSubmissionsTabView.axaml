<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.CatalogueSubmissionsTabView"
             x:DataType="vm:CatalogueSubmissionsTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:CatalogueSubmissionsTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{loc:Str tab_catalogue_submissions_catalogue_submissions_text}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="White" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{loc:Str tab_catalogue_submissions_refresh_content}"
                Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsBusy}" />
        <Button Content="{loc:Str tab_catalogue_submissions_check_preset_statuses_content}"
                Command="{Binding CheckPresetStatusesCommand}"
                IsEnabled="{Binding !IsBusy}" />
        <Button Content="{loc:Str tab_catalogue_submissions_check_session_statuses_content}"
                Command="{Binding CheckSessionStatusesCommand}"
                IsEnabled="{Binding !IsBusy}" />
      </StackPanel>

      <TextBlock Text="{Binding LastCheckedText}"
                 Opacity="0.7" />

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="{loc:Str tab_catalogue_submissions_preset_submissions_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <ListBox ItemsSource="{Binding PresetSubmissions}"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CatalogueSubmissionRowViewModel">
                <Border Background="#252540"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,4">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding CatalogueId}"
                               Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding StatusGlyph}" />
                      <TextBlock Text="{Binding StatusLabel}"
                                 Foreground="#FF69B4" />
                    </StackPanel>
                    <TextBlock Text="{Binding SubmittedUtc}"
                               FontSize="11"
                               Opacity="0.6" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="{loc:Str tab_catalogue_submissions_session_submissions_text}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <ListBox ItemsSource="{Binding SessionSubmissions}"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CatalogueSubmissionRowViewModel">
                <Border Background="#252540"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,4">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="{Binding CatalogueId}"
                               Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding StatusGlyph}" />
                      <TextBlock Text="{Binding StatusLabel}"
                                 Foreground="#FF69B4" />
                    </StackPanel>
                    <TextBlock Text="{Binding SubmittedUtc}"
                               FontSize="11"
                               Opacity="0.6" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

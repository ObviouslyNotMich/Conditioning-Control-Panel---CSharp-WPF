<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.CatalogueSubmissionsTabView"
             x:DataType="vm:CatalogueSubmissionsTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:CatalogueSubmissionsTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="{DynamicResource PanelBg}" />
            <GradientStop Offset="1" Color="#2A4A6A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="{DynamicResource TextLightBrush}"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_catalogue_submissions_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{loc:Str tab_catalogue_submissions_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="{loc:Str tab_catalogue_submissions_refresh_content}"
                Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsBusy}" />
        <Button Content="{loc:Str tab_catalogue_submissions_check_preset_statuses_content}"
                Command="{Binding CheckPresetStatusesCommand}"
                IsEnabled="{Binding !IsBusy}" />
        <Button Content="{loc:Str tab_catalogue_submissions_check_session_statuses_content}"
                Command="{Binding CheckSessionStatusesCommand}"
                IsEnabled="{Binding !IsBusy}" />
      </StackPanel>

      <TextBlock Text="{Binding LastCheckedText}"
                 Foreground="{DynamicResource TextMutedBrush}" />

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_catalogue_submissions_preset_submissions_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}" />
          <ListBox ItemsSource="{Binding PresetSubmissions}"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CatalogueSubmissionRowViewModel">
                <Border Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,8">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLightBrush}" />
                    <TextBlock Text="{Binding CatalogueId}"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding StatusGlyph}"
                                 Foreground="{DynamicResource PinkBrush}" />
                      <TextBlock Text="{Binding StatusLabel}"
                                 Foreground="{DynamicResource PinkBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding SubmittedUtc}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str tab_catalogue_submissions_session_submissions_text}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}" />
          <ListBox ItemsSource="{Binding SessionSubmissions}"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:CatalogueSubmissionRowViewModel">
                <Border Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,8">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Key}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLightBrush}" />
                    <TextBlock Text="{Binding CatalogueId}"
                               Foreground="{DynamicResource TextMutedBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding StatusGlyph}"
                                 Foreground="{DynamicResource PinkBrush}" />
                      <TextBlock Text="{Binding StatusLabel}"
                                 Foreground="{DynamicResource PinkBrush}" />
                    </StackPanel>
                    <TextBlock Text="{Binding SubmittedUtc}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

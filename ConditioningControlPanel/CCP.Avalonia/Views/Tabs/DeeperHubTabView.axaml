<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.DeeperHubTabView"
             x:DataType="vm:DeeperHubTabViewModel">

  <Design.DataContext>
    <vm:DeeperHubTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#0B1026" />
            <GradientStop Offset="1" Color="#1A3A5C" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.10"
                  Background="White"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-50,-90" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_deeper_hub_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="{loc:Str tab_deeper_hub_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Search / reload -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding SearchText}"
                 PlaceholderText="{loc:Str tab_deeper_hub_search_library_placeholder}" />
        <Button Grid.Column="1"
                Content="{loc:Str tab_deeper_hub_reload_content}"
                Command="{Binding ReloadLibraryCommand}"
                IsEnabled="{Binding !IsBusy}"
                Margin="12,0,0,0" />
      </Grid>

      <!-- Filters -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{Binding AllCount, StringFormat='All ({0})'}"
                    Command="{Binding SetMediaTypeFilterCommand}"
                    CommandParameter="all" />
            <Button Content="{Binding VideoCount, StringFormat='Video ({0})'}"
                    Command="{Binding SetMediaTypeFilterCommand}"
                    CommandParameter="video" />
            <Button Content="{Binding AudioCount, StringFormat='Audio ({0})'}"
                    Command="{Binding SetMediaTypeFilterCommand}"
                    CommandParameter="audio" />
            <ToggleButton Content="{Binding HapticsCount, StringFormat='Haptics ({0})'}"
                          IsChecked="{Binding FilterHaptics, Mode=TwoWay}"
                          Command="{Binding ToggleHapticsFilterCommand}" />
            <ToggleButton Content="{Binding WebcamCount, StringFormat='Webcam ({0})'}"
                          IsChecked="{Binding FilterWebcam, Mode=TwoWay}"
                          Command="{Binding ToggleWebcamFilterCommand}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{loc:Str tab_deeper_hub_sort_text}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PinkBrush}"
                       FontWeight="SemiBold" />
            <Button Content="{loc:Str tab_deeper_hub_recent_content}"
                    Command="{Binding SetSortModeCommand}"
                    CommandParameter="recent" />
            <Button Content="{loc:Str tab_deeper_hub_name_content}"
                    Command="{Binding SetSortModeCommand}"
                    CommandParameter="name" />
            <Button Content="{loc:Str tab_deeper_hub_creator_content}"
                    Command="{Binding SetSortModeCommand}"
                    CommandParameter="creator" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Library list -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0"
                     Text="{Binding LibraryCountText}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontWeight="SemiBold"
                     Margin="0,0,0,12" />

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding FilteredEntries}"
                   x:Name="HubList"
                   Background="Transparent"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:DeeperLibraryRowViewModel">
                <Border Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,8">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Type badge -->
                    <Border Grid.Column="0"
                            Width="40"
                            Height="40"
                            CornerRadius="8"
                            Margin="0,0,12,0"
                            Background="{Binding MediaType, Converter={StaticResource MediaTypeToBrushConverter}}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding MediaType, Converter={StaticResource MediaTypeToGlyphConverter}}"
                                 FontSize="20"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                    </Border>

                    <!-- Name + meta -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                      <TextBlock Text="{Binding Name}"
                                 Foreground="{DynamicResource TextLightBrush}"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Creator}"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontSize="12"
                                   IsVisible="{Binding ShowCreator}" />
                        <TextBlock Text="·"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontSize="12"
                                   IsVisible="{Binding ShowCreator}" />
                        <TextBlock Text="{Binding MediaSourceLabel}"
                                   Foreground="{DynamicResource PinkBrush}"
                                   FontSize="12" />
                        <TextBlock Text="{Binding TimestampDisplay}"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   FontSize="11" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding Tags}"
                                    IsVisible="{Binding ShowTags}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="x:String">
                            <Border Background="{DynamicResource DeeperAccentTransparent20Brush}"
                                    CornerRadius="4"
                                    Padding="6,2"
                                    Margin="0,0,6,4">
                              <TextBlock Text="{Binding}"
                                         FontSize="11"
                                         Foreground="{DynamicResource TextDimBrush}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Column="2"
                                Orientation="Vertical"
                                Spacing="6"
                                MinWidth="80"
                                Margin="12,0,0,0">
                      <Button Content="{loc:Str tab_deeper_hub_open_content}"
                              Command="{Binding $parent[ListBox].((vm:DeeperHubTabViewModel)DataContext).OpenEntryCommand}"
                              CommandParameter="{Binding}" />
                      <Button Content="{loc:Str tab_deeper_hub_play_content}"
                              Command="{Binding $parent[ListBox].((vm:DeeperHubTabViewModel)DataContext).PlayEntryCommand}"
                              CommandParameter="{Binding}" />
                      <Button Content="{loc:Str tab_deeper_hub_delete_content}"
                              Theme="{StaticResource DangerButton}"
                              Command="{Binding $parent[ListBox].((vm:DeeperHubTabViewModel)DataContext).DeleteEntryCommand}"
                              CommandParameter="{Binding}" />
                      <Button Content="{loc:Str tab_deeper_hub_submit_content}"
                              IsVisible="{Binding IsCatalogueEligible}"
                              Command="{Binding $parent[ListBox].((vm:DeeperHubTabViewModel)DataContext).SubmitEntryCommand}"
                              CommandParameter="{Binding}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="8"
                      IsVisible="{Binding FilteredEntries.Count, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
            <TextBlock Text="🌊"
                       FontSize="48"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding EmptyStateText}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

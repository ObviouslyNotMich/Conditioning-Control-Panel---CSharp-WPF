<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:models="using:ConditioningControlPanel.Models"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Core.Localization;assembly=CCP.Core"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.AssetsTabView"
             x:DataType="vm:AssetsTabViewModel">

  <Design.DataContext>
    <vm:AssetsTabViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,5,*" Margin="12">
    <!-- Header with title and actions -->
    <Grid Grid.Row="0" Margin="0,0,0,10">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="{Binding [section_assets_content_packs], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PinkBrush}"
                   VerticalAlignment="Center" />
        <Button Content="?"
                Width="22"
                Height="22"
                CornerRadius="11"
                Padding="0"
                FontSize="12"
                FontWeight="Bold"
                Background="{DynamicResource TransparentPinkBrush}"
                Foreground="White"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                VerticalAlignment="Center"
                ToolTip.Tip="{Binding [section_assets_content_packs], Source={x:Static loc:LocalizationManager.Instance}}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="{Binding [btn_refresh_2], Source={x:Static loc:LocalizationManager.Instance}}"
                Command="{Binding RefreshAssetTreeCommand}"
                ToolTip.Tip="{Binding [tooltip_refresh_assets], Source={x:Static loc:LocalizationManager.Instance}}"
                Theme="{DynamicResource OutlineButton}"
                Padding="12,6" />
        <Button Content="{Binding [btn_get_packs], Source={x:Static loc:LocalizationManager.Instance}}"
                Command="{Binding OpenCreatorDiscordCommand}"
                ToolTip.Tip="{Binding [tooltip_get_packs], Source={x:Static loc:LocalizationManager.Instance}}"
                Theme="{DynamicResource OutlineButton}"
                Padding="12,6" />
        <Button Content="{Binding [btn_open_folder], Source={x:Static loc:LocalizationManager.Instance}}"
                Command="{Binding OpenAssetsFolderCommand}"
                ToolTip.Tip="{Binding [tooltip_open_assets_folder_in_explorer], Source={x:Static loc:LocalizationManager.Instance}}"
                Theme="{DynamicResource OutlineButton}"
                Padding="12,6" />
      </StackPanel>
    </Grid>

    <!-- TOP: Content Packs Section -->
    <Border Grid.Row="1"
            Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12"
            IsVisible="{Binding IsPacksSectionVisible}">
      <Grid RowDefinitions="Auto,*">
        <!-- Section header -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
            <TextBlock Text="{Binding [label_community_content_packs], Source={x:Static loc:LocalizationManager.Instance}}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       VerticalAlignment="Center" />
            <Button Content="?"
                    Width="22"
                    Height="22"
                    CornerRadius="11"
                    Padding="0"
                    FontSize="12"
                    FontWeight="Bold"
                    Background="{DynamicResource TransparentPinkBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource PinkBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{Binding [label_community_content_packs], Source={x:Static loc:LocalizationManager.Instance}}" />
          </StackPanel>
          <TextBlock Text="{Binding [label_after_downloading_a_pack_just_drag_and_drop_t], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="11"
                     FontStyle="Italic"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center" />
        </Grid>

        <!-- Horizontal scrolling pack cards -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="0,0,0,8">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <ItemsControl ItemsSource="{Binding AvailablePacks}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="10" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:PackCardViewModel">
                  <features:ContentPackCard Title="{Binding Name}"
                                            Description="{Binding Description}"
                                            SizeDisplay="{Binding SizeDisplay}"
                                            ImageCount="{Binding ImageCount}"
                                            VideoCount="{Binding VideoCount}"
                                            PreviewImageUri="{Binding PreviewImageUrl}"
                                            IsExternal="{Binding IsExternal}"
                                            IsDownloaded="{Binding IsDownloaded}"
                                            IsDownloading="{Binding IsDownloading}"
                                            DownloadProgress="{Binding DownloadProgress}"
                                            DownloadButtonText="{Binding DownloadButtonText}"
                                            ActivateButtonText="{Binding ActivateButtonText}"
                                            InstallCommand="{Binding $parent[ItemsControl].((vm:AssetsTabViewModel)DataContext).TogglePackCommand}"
                                            InstallCommandParameter="{Binding}"
                                            ActivateCommand="{Binding $parent[ItemsControl].((vm:AssetsTabViewModel)DataContext).ActivatePackCommand}"
                                            ActivateCommandParameter="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Creator Card: Join Discord -->
            <Border Width="176"
                    Height="240"
                    Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource DiscordBlueBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    ClipToBounds="True">
              <Grid RowDefinitions="72,*">
                <Border Grid.Row="0"
                        Background="{DynamicResource DiscordBlueBrush}"
                        CornerRadius="8,8,0,0"
                        ClipToBounds="True">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="💬"
                               FontSize="44"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
                <Grid Grid.Row="1" Margin="8,4,8,4">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0"
                             Text="{Binding [label_create_your_own_pack], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontWeight="Bold"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="12"
                             Margin="0,0,0,2" />
                  <TextBlock Grid.Row="1"
                             Text="{Binding [label_are_you_a_content_creator_join_our_discord_to], Source={x:Static loc:LocalizationManager.Instance}}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             FontSize="10"
                             TextWrapping="Wrap"
                             MaxHeight="52"
                             VerticalAlignment="Top" />
                  <TextBlock Grid.Row="2"
                             Text="{Binding [label_get_featured_in_the_app], Source={x:Static loc:LocalizationManager.Instance}}"
                             Foreground="{DynamicResource DiscordBlueBrush}"
                             FontSize="9"
                             Margin="0,2,0,4"
                             FontWeight="SemiBold" />
                  <Button Grid.Row="3"
                          Content="{Binding [label_join_discord], Source={x:Static loc:LocalizationManager.Instance}}"
                          Command="{Binding OpenCreatorDiscordCommand}"
                          Background="{DynamicResource DiscordBlueBrush}"
                          Foreground="White"
                          BorderThickness="0"
                          Padding="8,4"
                          FontSize="11"
                          FontWeight="SemiBold"
                          CornerRadius="4"
                          HorizontalAlignment="Stretch" />
                </Grid>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Splitter (hidden alongside PacksSection) -->
    <GridSplitter Grid.Row="2"
                  Height="5"
                  HorizontalAlignment="Stretch"
                  Background="Transparent"
                  IsVisible="{Binding IsPacksSectionVisible}" />

    <!-- BOTTOM: Interactive File Browser -->
    <Border Grid.Row="3"
            Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
      <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
            <TextBlock Text="{Binding [section_asset_browser], Source={x:Static loc:LocalizationManager.Instance}}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       VerticalAlignment="Center" />
            <Button Content="?"
                    Width="22"
                    Height="22"
                    CornerRadius="11"
                    Padding="0"
                    FontSize="12"
                    FontWeight="Bold"
                    Background="{DynamicResource TransparentPinkBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource PinkBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center"
                    ToolTip.Tip="{Binding [section_asset_browser], Source={x:Static loc:LocalizationManager.Instance}}" />
          </StackPanel>
          <TextBlock Text="{Binding AssetCountsText}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="12"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center" />
        </Grid>

        <!-- Action bar with preset selector -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Left: Select/Deselect buttons -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
            <Button Content="{Binding [btn_select_all], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding SelectAllAssetsCommand}"
                    Theme="{DynamicResource OutlineButton}"
                    Padding="10,4"
                    FontSize="11" />
            <Button Content="{Binding [btn_deselect_all], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding DeselectAllAssetsCommand}"
                    Theme="{DynamicResource OutlineButton}"
                    Padding="10,4"
                    FontSize="11" />
          </StackPanel>

          <!-- Right: Preset selector -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
            <TextBlock Text="{Binding [label_preset_2], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0" />
            <ComboBox ItemsSource="{Binding AssetPresets}"
                      SelectedItem="{Binding SelectedAssetPreset}"
                      Width="180"
                      FontSize="11"
                      VerticalAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="models:AssetPreset">
                  <TextBlock Text="{Binding DisplayText}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="{Binding [btn_save_as], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding SaveAssetPresetCommand}"
                    ToolTip.Tip="{Binding [tooltip_save_current_selection_as_a_new_preset], Source={x:Static loc:LocalizationManager.Instance}}"
                    Theme="{DynamicResource PinkButton}"
                    Padding="8,4"
                    FontSize="11" />
            <Button Content="{Binding [btn_update], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding UpdateAssetPresetCommand}"
                    ToolTip.Tip="{Binding [tooltip_update_selected_preset_with_current_selection], Source={x:Static loc:LocalizationManager.Instance}}"
                    Theme="{DynamicResource OutlineButton}"
                    Padding="8,4"
                    FontSize="11" />
            <Button Content="{Binding [btn_delete], Source={x:Static loc:LocalizationManager.Instance}}"
                    Command="{Binding DeleteAssetPresetCommand}"
                    ToolTip.Tip="{Binding [tooltip_delete_selected_preset], Source={x:Static loc:LocalizationManager.Instance}}"
                    Theme="{DynamicResource OutlineButton}"
                    Padding="8,4"
                    FontSize="11" />
          </StackPanel>
        </Grid>

        <!-- Split view: TreeView on left, Thumbnails on right -->
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- LEFT: Folder TreeView -->
          <Border Grid.Column="0"
                  Background="{DynamicResource DarkerBgBrush}"
                  CornerRadius="6"
                  Padding="4">
            <TreeView ItemsSource="{Binding AssetTree}"
                      SelectedItem="{Binding SelectedFolder}">
              <TreeView.Styles>
                <Style Selector="TreeViewItem">
                  <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
                  <Setter Property="FontSize" Value="12" />
                  <Setter Property="Padding" Value="2" />
                </Style>
                <Style Selector="TreeViewItem:selected">
                  <Setter Property="Foreground" Value="White" />
                </Style>
              </TreeView.Styles>
              <TreeView.DataTemplates>
                <TreeDataTemplate DataType="models:AssetTreeItem"
                                  ItemsSource="{Binding Children}">
                  <StackPanel Orientation="Horizontal" Spacing="4" Margin="2">
                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                              Command="{Binding $parent[TreeView].((vm:AssetsTabViewModel)DataContext).ToggleFolderCheckCommand}"
                              CommandParameter="{Binding}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="📁"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0" />
                    <TextBlock Text="{Binding Name}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FileCountDisplay}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="10"
                               Margin="4,0,0,0"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </TreeDataTemplate>
              </TreeView.DataTemplates>
            </TreeView>
          </Border>

          <!-- Splitter -->
          <GridSplitter Grid.Column="1"
                        Width="5"
                        HorizontalAlignment="Stretch"
                        Background="Transparent" />

          <!-- RIGHT: Thumbnail Preview Grid -->
          <Border Grid.Column="2"
                  Background="{DynamicResource DarkerBgBrush}"
                  CornerRadius="6"
                  Padding="4">
            <Grid>
              <ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            IsVisible="{Binding HasCurrentFiles}">
                <ItemsControl ItemsSource="{Binding CurrentFiles}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:AssetFileItem">
                      <Border Width="100"
                              Height="120"
                              Margin="4"
                              Background="{DynamicResource SurfaceBgBrush}"
                              BorderBrush="{DynamicResource PanelAccentBrush}"
                              BorderThickness="2"
                              CornerRadius="6"
                              Cursor="Hand">
                        <Border.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="{Binding [section_preview], Source={x:Static loc:LocalizationManager.Instance}}"
                                      Command="{Binding $parent[ItemsControl].((vm:AssetsTabViewModel)DataContext).OpenAssetPreviewCommand}"
                                      CommandParameter="{Binding}" />
                            <Separator />
                            <MenuItem Header="{Binding [section_open_in_explorer], Source={x:Static loc:LocalizationManager.Instance}}"
                                      Command="{Binding $parent[ItemsControl].((vm:AssetsTabViewModel)DataContext).OpenAssetInExplorerCommand}"
                                      CommandParameter="{Binding}" />
                          </ContextMenu>
                        </Border.ContextMenu>
                        <Grid RowDefinitions="*,Auto">
                          <Border Grid.Row="0"
                                  Background="{DynamicResource DarkerBgBrush}"
                                  CornerRadius="6,6,0,0"
                                  ClipToBounds="True">
                            <Grid>
                              <Image Source="{Binding FullPath, Converter={StaticResource PackUriToBitmapConverter}}"
                                     Stretch="UniformToFill" />
                              <StackPanel HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding IsVideo}">
                                <TextBlock Text="🎬"
                                           FontSize="28"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding [label_video], Source={x:Static loc:LocalizationManager.Instance}}"
                                           FontSize="9"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                              </StackPanel>
                              <TextBlock Text="⏳"
                                         FontSize="14"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsVisible="{Binding IsLoadingThumbnail}" />
                            </Grid>
                          </Border>

                          <CheckBox Grid.Row="0"
                                    IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                    Command="{Binding $parent[ItemsControl].((vm:AssetsTabViewModel)DataContext).ToggleFileCheckCommand}"
                                    CommandParameter="{Binding}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="4" />

                          <Border Grid.Row="1"
                                  Background="#303050"
                                  Padding="4,2"
                                  CornerRadius="0,0,4,4">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="9"
                                       Foreground="{DynamicResource TextLightBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip.Tip="{Binding Name}" />
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <!-- Empty state -->
              <TextBlock Text="{Binding EmptyThumbnailsText}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="13"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !HasCurrentFiles}" />
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>

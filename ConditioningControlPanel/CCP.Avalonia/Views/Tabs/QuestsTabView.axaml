<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Core.Localization;assembly=CCP.Core"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.QuestsTabView"
             x:DataType="vm:QuestsTabViewModel">

  <Design.DataContext>
    <vm:QuestsTabViewModel />
  </Design.DataContext>

  <Grid>
    <ScrollViewer>
      <StackPanel Margin="16" Spacing="12">
        <!-- Sub-tab navigation -->
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Button Content="{Binding [btn_daily_weekly], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding ShowDailyWeeklyCommand}"
                  Theme="{DynamicResource PinkButton}"
                  Width="130" />
          <Button Content="{Binding [btn_bimbo_journal], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding ShowRoadmapCommand}"
                  Theme="{DynamicResource OutlineButton}"
                  Width="150" />
        </StackPanel>

        <!-- Daily / Weekly Quests Panel -->
        <StackPanel IsVisible="{Binding DailyWeeklyPanelVisible}" Spacing="16">
          <!-- Season title banner -->
          <Border Background="{DynamicResource DarkerBgBrush}"
                  CornerRadius="12"
                  Padding="20,14"
                  BorderThickness="1"
                  BorderBrush="#3D3D60">
            <TextBlock Text="{Binding SeasonTitle}"
                       FontSize="28"
                       FontWeight="ExtraBold"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
              <TextBlock.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <GradientStop Color="{DynamicResource PinkColor}" Offset="0.0" />
                  <GradientStop Color="#DA70D6" Offset="0.25" />
                  <GradientStop Color="{DynamicResource DarkPinkColor}" Offset="0.5" />
                  <GradientStop Color="#DA70D6" Offset="0.75" />
                  <GradientStop Color="{DynamicResource PinkColor}" Offset="1.0" />
                </LinearGradientBrush>
              </TextBlock.Foreground>
            </TextBlock>
          </Border>

          <!-- Header -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding [label_quests], Source={x:Static loc:LocalizationManager.Instance}}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{Binding QuestStatsText}"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center" />
          </Grid>

          <!-- Two-column quest cards -->
          <Grid ColumnDefinitions="*,20,*">
            <!-- Daily Quest -->
            <StackPanel Grid.Column="0" Spacing="8">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="☀️" FontSize="20" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding [label_daily_quest], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="#FFD700"
                             VerticalAlignment="Center" />
                  <Border Background="#3D3D60" CornerRadius="8" Padding="6,2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DailyCounterText}" FontSize="11" FontWeight="Bold" Foreground="#FFD700" />
                  </Border>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding [label_resets_at_midnight], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
              </Grid>

              <!-- Daily progress segments -->
              <Grid ColumnDefinitions="*,4,*,4,*">
                <Border Grid.Column="0" Height="6" CornerRadius="3"
                        Background="{Binding DailySegmentsCompleted[0], Converter={StaticResource BoolToBrushConverter}}" />
                <Border Grid.Column="2" Height="6" CornerRadius="3"
                        Background="{Binding DailySegmentsCompleted[1], Converter={StaticResource BoolToBrushConverter}}" />
                <Border Grid.Column="4" Height="6" CornerRadius="3"
                        Background="{Binding DailySegmentsCompleted[2], Converter={StaticResource BoolToBrushConverter}}" />
              </Grid>
              <TextBlock Text="{Binding [label_complete_3_daily_quests_1_weekly_quest], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center" />

              <features:QuestCard IsVisible="{Binding DailyCardVisible}"
                                  Title="{Binding DailyQuestName}"
                                  Description="{Binding DailyQuestDescription}"
                                  Glyph="{Binding DailyQuestIcon}"
                                  ImageUri="{Binding DailyImageUri}"
                                  ProgressFraction="{Binding DailyProgressFraction}"
                                  ProgressText="{Binding DailyProgressText}"
                                  XpText="{Binding DailyXpText}"
                                  IsCompleted="{Binding DailyCompletedVisible}"
                                  RerollText="{Binding DailyRerollText}"
                                  RerollEnabled="{Binding DailyRerollEnabled}"
                                  RerollCommand="{Binding RerollDailyCommand}"
                                  BorderBrushOverride="#FFD700" />

              <!-- All daily quests completed message -->
              <Border IsVisible="{Binding DailyAllCompletedMessageVisible}"
                      Background="#2D4A2D"
                      CornerRadius="10"
                      Padding="15"
                      MinHeight="180">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                  <TextBlock Text="✅" FontSize="44" HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_all_daily_quests_completed], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="#00E676"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_check_back_tomorrow_for_new_quests], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="12"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Weekly Quest -->
            <StackPanel Grid.Column="2" Spacing="8">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="🌙" FontSize="20" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding [label_weekly_quest], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="#9370DB"
                             VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding [label_resets_sunday], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
              </Grid>
              <TextBlock Text="{Binding [label_1_weekly_quest_to_complete], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="10"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center" />

              <features:QuestCard Title="{Binding WeeklyQuestName}"
                                  Description="{Binding WeeklyQuestDescription}"
                                  Glyph="{Binding WeeklyQuestIcon}"
                                  ImageUri="{Binding WeeklyImageUri}"
                                  ProgressFraction="{Binding WeeklyProgressFraction}"
                                  ProgressText="{Binding WeeklyProgressText}"
                                  XpText="{Binding WeeklyXpText}"
                                  IsCompleted="{Binding WeeklyCompletedVisible}"
                                  RerollText="{Binding WeeklyRerollText}"
                                  RerollEnabled="{Binding WeeklyRerollEnabled}"
                                  RerollCommand="{Binding RerollWeeklyCommand}"
                                  BorderBrushOverride="#9370DB" />
            </StackPanel>
          </Grid>

          <!-- Quest complete banner -->
          <Border IsVisible="{Binding QuestCompleteBannerVisible}"
                  Background="#2D4A2D"
                  CornerRadius="10"
                  Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
              <TextBlock Text="✨" FontSize="26" />
              <TextBlock Text="{Binding [label_quest_complete], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="18"
                         FontWeight="Bold"
                         Foreground="#00E676"
                         VerticalAlignment="Center" />
              <TextBlock Text="✨" FontSize="26" />
            </StackPanel>
          </Border>

          <!-- Quest streak calendar -->
          <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="10" Padding="15,12">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding [label_quest_streak], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding StreakText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFD700"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <Button Grid.Column="2"
                        Content="{Binding [btn_fix_day], Source={x:Static loc:LocalizationManager.Instance}}"
                        Command="{Binding FixStreakCommand}"
                        Theme="{DynamicResource OutlineButton}"
                        Padding="8,3"
                        FontSize="11"
                        IsVisible="{Binding FixStreakVisible}"
                        VerticalAlignment="Center" />
              </Grid>

              <ItemsControl ItemsSource="{Binding CalendarDays}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:StreakDayViewModel">
                    <Button Command="{Binding $parent[ItemsControl].((vm:QuestsTabViewModel)DataContext).FixStreakDayCommand}"
                            CommandParameter="{Binding}"
                            Background="{Binding BackgroundBrush}"
                            Foreground="{Binding ForegroundBrush}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="8,10"
                            Width="44"
                            Height="52">
                      <TextBlock Text="{Binding DayLabel}"
                                 FontSize="10"
                                 FontWeight="SemiBold"
                                 TextAlignment="Center"
                                 TextWrapping="Wrap" />
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock IsVisible="{Binding FixStreakStatusVisible}"
                         Text="{Binding FixStreakStatusText}"
                         FontSize="11"
                         Foreground="{DynamicResource PinkBrush}"
                         TextAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Quest statistics -->
          <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="15">
            <StackPanel Spacing="15">
              <TextBlock Text="{Binding [label_quest_statistics], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="White" />
              <Grid ColumnDefinitions="*,*,*">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TotalDailyCompletedText}"
                             FontSize="28"
                             FontWeight="Bold"
                             Foreground="#FFD700"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_daily_completed], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TotalWeeklyCompletedText}"
                             FontSize="28"
                             FontWeight="Bold"
                             Foreground="#9370DB"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_weekly_completed], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TotalQuestXpText}"
                             FontSize="28"
                             FontWeight="Bold"
                             Foreground="{DynamicResource PinkBrush}"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_total_xp_earned], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Roadmap Panel -->
        <StackPanel IsVisible="{Binding RoadmapPanelVisible}" Spacing="16">
          <TextBlock Text="{Binding [label_look_how_far_you_ve_come_sweetie], Source={x:Static loc:LocalizationManager.Instance}}"
                     FontSize="26"
                     FontStyle="Italic"
                     FontWeight="Light"
                     Foreground="#CC88AACC"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />

          <Border Background="#30FFD700"
                  BorderBrush="#AAFFD700"
                  BorderThickness="1.5"
                  CornerRadius="6"
                  Padding="14,10"
                  MaxWidth="700"
                  HorizontalAlignment="Center">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding [label_what_is_the_bimbo_journal], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#FFD700" />
              <TextBlock Text="{Binding [label_each_track_has_steps_that_ask_you_to_take_a_p], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="12"
                         Foreground="#DDFFFFFF"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding [label_click_a_step_take_the_pic_and_upload_it_to_ma], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="12"
                         Foreground="#DDFFFFFF"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding [label_complete_all_steps_in_a_track_to_unlock_the_n], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="12"
                         Foreground="#DDFFFFFF"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding [label_all_photos_are_stored_locally_on_your_pc_only], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="11"
                         FontStyle="Italic"
                         Foreground="#AAFFD700" />
            </StackPanel>
          </Border>

          <!-- Track selector tabs -->
          <ItemsControl ItemsSource="{Binding RoadmapTracks}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:RoadmapTrackViewModel">
                <Button Content="{Binding Name}"
                        Command="{Binding $parent[ItemsControl].((vm:QuestsTabViewModel)DataContext).SelectTrackCommand}"
                        CommandParameter="{Binding Track}"
                        Theme="{DynamicResource OutlineButton}"
                        Padding="10,6" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Track info header -->
          <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="15">
            <Grid>
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding TrackName}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PinkBrush}" />
                <TextBlock Text="{Binding TrackSubtitle}"
                           FontSize="14"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding TrackProgressText}"
                           FontSize="12"
                           Foreground="#AAAAAA"
                           Margin="0,5,0,0" />
              </StackPanel>
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Spacing="5"
                          IsVisible="{Binding ShowBadgeIndicator}">
                <TextBlock Text="🏆" FontSize="26" />
                <TextBlock Text="{Binding [label_badge_earned], Source={x:Static loc:LocalizationManager.Instance}}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#FFD700"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Grid>
          </Border>

          <!-- Locked track overlay -->
          <Border IsVisible="{Binding IsTrackLocked}"
                  Background="#CC1A1A2E"
                  CornerRadius="10"
                  Padding="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
              <TextBlock Text="🔒" FontSize="52" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding LockReason}"
                         FontSize="16"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         TextAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Horizontal scrolling roadmap -->
          <Border Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource GlassBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="10"
                  MinHeight="240">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding RoadmapNodes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:RoadmapNodeViewModel">
                    <features:RoadmapNodeCard Title="{Binding Title}"
                                              Requirement="{Binding Requirement}"
                                              StatusText="{Binding StatusText}"
                                              StepNumber="{Binding StepNumber}"
                                              AccentColor="{Binding AccentColor}"
                                              IsLocked="{Binding IsLocked}"
                                              Command="{Binding $parent[ItemsControl].((vm:QuestsTabViewModel)DataContext).SelectNodeCommand}"
                                              CommandParameter="{Binding}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <!-- Roadmap statistics -->
          <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="15">
            <StackPanel Spacing="15">
              <TextBlock Text="{Binding [label_transformation_progress], Source={x:Static loc:LocalizationManager.Instance}}"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="White" />
              <Grid ColumnDefinitions="*,*,*">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TotalStepsText}"
                             FontSize="24"
                             FontWeight="Bold"
                             Foreground="{DynamicResource PinkBrush}"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_steps_completed], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding TotalPhotosText}"
                             FontSize="24"
                             FontWeight="Bold"
                             Foreground="#9370DB"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_photos_submitted], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                  <TextBlock Text="{Binding JourneyDaysText}"
                             FontSize="24"
                             FontWeight="Bold"
                             Foreground="#FFD700"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding [label_days_on_journey], Source={x:Static loc:LocalizationManager.Instance}}"
                             FontSize="11"
                             Foreground="{DynamicResource TextMutedBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <!-- Login required overlay -->
    <Border IsVisible="{Binding IsLoginOverlayVisible}"
            Background="#E6151528"
            CornerRadius="12"
            Padding="40"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
        <TextBlock Text="🔒" FontSize="52" HorizontalAlignment="Center" />
        <TextBlock Text="{Binding [label_login_required], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PinkBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding [label_log_in_with_discord_or_patreon_to_access_ques], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="14"
                   Foreground="#AA99AA"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="350" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

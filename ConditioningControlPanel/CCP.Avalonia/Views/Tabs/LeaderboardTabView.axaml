<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.LeaderboardTabView"
             x:DataType="vm:LeaderboardTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:LeaderboardTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="{DynamicResource PanelBg}" />
            <GradientStop Offset="1" Color="#4A2C6A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="{DynamicResource TextLightBrush}"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_leaderboard_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{loc:Str tab_leaderboard_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Mode toggles -->
      <ItemsControl ItemsSource="{Binding Modes}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="12" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:LeaderboardModeViewModel">
            <Button Content="{Binding Label}"
                    Command="{Binding $parent[ItemsControl].((vm:LeaderboardTabViewModel)DataContext).SetModeCommand}"
                    CommandParameter="{Binding Key}"
                    Background="{Binding AccentColor}"
                    Foreground="{DynamicResource TextLightBrush}"
                    FontWeight="SemiBold"
                    Padding="16,8"
                    CornerRadius="8" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Season info -->
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding StatusText}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontWeight="SemiBold" />
        <TextBlock Text="{Binding SeasonText}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextLightBrush}" />
        <TextBlock Text="{Binding SubtitleText}"
                   Foreground="{DynamicResource TextMutedBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Sort card -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="{loc:Str tab_leaderboard_sort_text}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PinkBrush}"
                       FontWeight="SemiBold" />
            <Button Content="{loc:Str tab_leaderboard_name_content}"
                    Command="{Binding SortCommand}"
                    CommandParameter="name"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str tab_leaderboard_online_content}"
                    Command="{Binding SortCommand}"
                    CommandParameter="online"
                    IsEnabled="{Binding !IsBusy}" />
            <Button Content="{loc:Str tab_leaderboard_achievements_content}"
                    Command="{Binding SortCommand}"
                    CommandParameter="achievements"
                    IsEnabled="{Binding !IsBusy}" />
          </StackPanel>
          <Button Content="{loc:Str tab_leaderboard_view_selected_profile_content}"
                  Command="{Binding ViewSelectedProfileCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Left" />
        </StackPanel>
      </Border>

      <!-- Leaderboard list -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <ListBox ItemsSource="{Binding Entries}"
                 SelectedItem="{Binding SelectedEntry}"
                 Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:LeaderboardEntryViewModel">
              <Border Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="12"
                      Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <!-- Rank badge -->
                  <Border Grid.Column="0"
                          Width="40"
                          Height="40"
                          CornerRadius="20"
                          Background="{DynamicResource TransparentPinkBrush}"
                          BoxShadow="0 0 15 0 #FFFF69B4"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0">
                    <TextBlock Text="{Binding Rank, Converter={StaticResource RankToGlyphConverter}}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PinkBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>

                  <!-- Name + meta -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextLightBrush}" />
                      <TextBlock Text="🌟"
                                 IsVisible="{Binding IsSeason0Og}" />
                      <Border Background="#22FF69B4"
                              CornerRadius="8"
                              Padding="6,2"
                              BoxShadow="0 0 12 0 #FFFF69B4"
                              IsVisible="{Binding IsOnline}">
                        <TextBlock Text="🟢 Online"
                                   FontSize="10"
                                   Foreground="{DynamicResource PinkBrush}"
                                   FontWeight="SemiBold" />
                      </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                      <TextBlock Text="{Binding Level, StringFormat='Lv {0}'}"
                                 Foreground="{DynamicResource PinkBrush}"
                                 FontSize="12" />
                      <TextBlock Text="{Binding Xp, StringFormat='XP {0:F0}'}"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 FontSize="12" />
                      <TextBlock Text="{Binding AchievementsCount, StringFormat='🏆 {0}'}"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 FontSize="12" />
                    </StackPanel>
                  </StackPanel>

                  <!-- Discord button -->
                  <Button Grid.Column="2"
                          Content="{loc:Str tab_leaderboard_discord_content}"
                          Command="{Binding $parent[ListBox].((vm:LeaderboardTabViewModel)DataContext).OpenDiscordProfileCommand}"
                          CommandParameter="{Binding DiscordId}"
                          VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

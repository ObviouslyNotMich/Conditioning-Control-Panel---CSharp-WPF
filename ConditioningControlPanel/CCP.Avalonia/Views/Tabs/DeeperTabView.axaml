<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="using:ConditioningControlPanel.Core.Localization"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.DeeperTabView"
             x:DataType="vm:DeeperTabViewModel">

  <Design.DataContext>
    <vm:DeeperTabViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <DataTemplate x:Key="DeeperLibraryRowTemplate" DataType="vm:DeeperLibraryRowViewModel">
      <Border x:Name="RowBorder"
              Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent20Brush}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10,8"
              Margin="0,0,0,6"
              Cursor="Hand"
              PointerPressed="DeeperRow_PointerPressed">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Type badge -->
          <Border Grid.Column="0"
                  Width="36"
                  Height="36"
                  CornerRadius="6"
                  Margin="0,0,10,0"
                  Background="{Binding MediaTypeBadgeBg}"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding MediaTypeIcon}"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>

          <!-- Name + meta -->
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding Name}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis" />
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0" Spacing="4">
              <!-- Submission status pill -->
              <Border Background="{Binding SubmissionBadgeBg}"
                      IsVisible="{Binding ShowSubmissionBadge}"
                      CornerRadius="8"
                      Padding="6,1"
                      ToolTip.Tip="{Binding SubmissionBadgeTooltip}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding SubmissionBadgeGlyph}"
                             Foreground="{Binding SubmissionBadgeFg}"
                             FontSize="10"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SubmissionBadgeLabel}"
                             Foreground="{Binding SubmissionBadgeFg}"
                             FontSize="10"
                             FontWeight="SemiBold" />
                </StackPanel>
              </Border>

              <!-- Creator -->
              <TextBlock Text="{Binding CreatorDisplay}"
                         IsVisible="{Binding ShowCreator}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="11" />
              <TextBlock Text="·"
                         IsVisible="{Binding ShowCreator}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="11" />

              <!-- Media source -->
              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding ShowMediaSource}"
                          Spacing="4">
                <TextBlock Text="{Binding MediaSourceGlyph}"
                           Foreground="{Binding MediaSourceBrush}"
                           FontSize="11"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding MediaSourceLabel}"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="11"
                           MaxWidth="220"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="·"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="11" />
              </StackPanel>

              <!-- Auto-tag chips -->
              <ItemsControl ItemsSource="{Binding TagBadges}"
                            IsVisible="{Binding ShowTags}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="vm:DeeperLibraryTagViewModel">
                    <Border Background="{Binding Background}"
                            CornerRadius="8"
                            Padding="6,1">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Glyph}"
                                   Foreground="{Binding Foreground}"
                                   FontSize="10" />
                        <TextBlock Text="{Binding Label}"
                                   Foreground="{Binding Foreground}"
                                   FontSize="10" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Timestamp -->
              <TextBlock Text="{Binding TimestampDisplay}"
                         IsVisible="{Binding ShowTimestamp}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="11" />
            </StackPanel>
          </StackPanel>

          <!-- Row actions -->
          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Spacing="4">
            <Button Content="📤"
                    IsVisible="{Binding ShowSubmitButton}"
                    IsEnabled="{Binding SubmitEnabled}"
                    ToolTip.Tip="{Binding SubmitTooltip}"
                    Theme="{StaticResource DeeperRowActionBtnStyle}"
                    Command="{Binding $parent[ItemsControl].((vm:DeeperTabViewModel)DataContext).SubmitEntryCommand}"
                    CommandParameter="{Binding}" />
            <Button Content="▶"
                    ToolTip.Tip="{Binding [deeper_hub_tip_row_play], Source={x:Static loc:LocalizationManager.Instance}}"
                    Theme="{StaticResource DeeperRowActionBtnStyle}"
                    Command="{Binding PlayCommand}" />
            <Button Content="🗑"
                    ToolTip.Tip="{Binding [deeper_hub_tip_row_delete], Source={x:Static loc:LocalizationManager.Instance}}"
                    Foreground="{DynamicResource DangerBrush}"
                    Theme="{StaticResource DeeperRowActionBtnStyle}"
                    Command="{Binding DeleteCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="28,20,28,20"
          MaxWidth="1080"
          HorizontalAlignment="Center"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto">

      <!-- Header -->
      <Grid Grid.Row="0" Margin="0,0,0,18">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="🌊"
                   FontSize="32"
                   VerticalAlignment="Center"
                   Margin="0,0,14,0" />

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding [deeper_empty_title], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="{DynamicResource DeeperAccentBrush}"
                       FontSize="22"
                       FontWeight="Bold" />
            <Border Margin="0,4,0,0"
                    Padding="7,2"
                    VerticalAlignment="Center"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ToolTip.Tip="{Binding [deeper_beta_notice], Source={x:Static loc:LocalizationManager.Instance}}">
              <TextBlock Text="{Binding [deeper_beta_badge], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource DeeperAccentBrush}"
                         FontSize="10"
                         FontWeight="Bold" />
            </Border>
          </StackPanel>
          <TextBlock Text="{Binding [deeper_empty_pitch], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="12"
                     Margin="0,2,0,0"
                     TextWrapping="Wrap"
                     MaxWidth="700"
                     HorizontalAlignment="Left" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8">
          <Button ToolTip.Tip="{Binding [deeper_tab_tutorial_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding ShowTutorialCommand}"
                  Padding="14,10"
                  FontSize="12"
                  Background="Transparent"
                  Foreground="{DynamicResource DeeperAccentBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1">
            <TextBlock Text="{Binding [deeper_tab_tutorial_btn], Source={x:Static loc:LocalizationManager.Instance}}" />
          </Button>
          <Button Content="{Binding [deeper_tab_open_player], Source={x:Static loc:LocalizationManager.Instance}}"
                  ToolTip.Tip="{Binding [deeper_tab_open_player_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding OpenPlayerCommand}"
                  Padding="16,10"
                  FontSize="12"
                  Background="Transparent"
                  Foreground="{DynamicResource DeeperAccentBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1" />
          <Button ToolTip.Tip="{Binding [deeper_hub_import_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding ImportEnhancementsCommand}"
                  Padding="16,10"
                  FontSize="12"
                  Background="Transparent"
                  Foreground="{DynamicResource DeeperAccentBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1">
            <TextBlock Text="{Binding [deeper_hub_import_btn], Source={x:Static loc:LocalizationManager.Instance}}" />
          </Button>
          <Button Content="{Binding [deeper_empty_cta], Source={x:Static loc:LocalizationManager.Instance}}"
                  ToolTip.Tip="{Binding [deeper_tab_new_enh_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding NewEnhancementCommand}"
                  Padding="22,10"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="{DynamicResource TextLightBrush}"
                  Background="{DynamicResource DeeperAccentBrush}">
            <Button.Theme>
              <ControlTheme TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource DeeperAccentBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Template">
                  <ControlTemplate>
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding Content}" />
                    </Border>
                  </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover">
                  <Setter Property="Background" Value="{DynamicResource DeeperAccentSoftBrush}" />
                </Style>
              </ControlTheme>
            </Button.Theme>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Welcome card -->
      <Border Grid.Row="1"
              IsVisible="{Binding WelcomeCardVisible}"
              Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource DeeperAccentBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="22,18"
              Margin="0,0,0,18">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Grid.Column="0"
                     Text="✨"
                     FontSize="32"
                     VerticalAlignment="Top"
                     Margin="0,0,18,0" />
          <StackPanel Grid.Column="1">
            <TextBlock Text="{Binding [deeper_welcome_card_title], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="{DynamicResource DeeperAccentBrush}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="0,0,0,8" />
            <TextBlock Text="{Binding [deeper_welcome_card_body], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{Binding [deeper_welcome_card_take_tour], Source={x:Static loc:LocalizationManager.Instance}}"
                      Command="{Binding WelcomeTourCommand}"
                      Padding="14,7"
                      FontWeight="SemiBold"
                      Background="{DynamicResource DeeperAccentBrush}"
                      Foreground="{DynamicResource TextLightBrush}"
                      BorderThickness="0" />
              <Button Content="{Binding [deeper_welcome_card_open_demo], Source={x:Static loc:LocalizationManager.Instance}}"
                      Command="{Binding WelcomeDemoCommand}"
                      Padding="14,7"
                      Background="{DynamicResource DeeperAccentTransparent20Brush}"
                      Foreground="{DynamicResource DeeperAccentBrush}"
                      BorderBrush="{DynamicResource DeeperAccentBrush}"
                      BorderThickness="1" />
              <Button Content="{Binding [deeper_welcome_card_dismiss], Source={x:Static loc:LocalizationManager.Instance}}"
                      Command="{Binding DismissWelcomeCommand}"
                      Padding="14,7"
                      Background="Transparent"
                      Foreground="{DynamicResource TextMutedBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="1" />
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Filter + sort strip -->
      <StackPanel Grid.Row="2" Margin="0,0,0,12" Spacing="8">
        <!-- Search + folder button -->
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   PlaceholderText="{Binding [deeper_hub_search_placeholder], Source={x:Static loc:LocalizationManager.Instance}}"
                   Background="{DynamicResource PanelBgBrush}"
                   Foreground="{DynamicResource TextLightBrush}"
                   BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                   BorderThickness="1"
                   Padding="10,8"
                   FontSize="12"
                   ToolTip.Tip="{Binding [deeper_hub_tip_search], Source={x:Static loc:LocalizationManager.Instance}}" />
          <Button Grid.Column="1"
                  ToolTip.Tip="{Binding [deeper_library_open_folder_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Command="{Binding OpenLibraryFolderCommand}"
                  Width="36"
                  Height="36"
                  Padding="0"
                  FontSize="14"
                  Margin="8,0,0,0"
                  Background="Transparent"
                  Foreground="{DynamicResource DeeperAccentBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1">
            <TextBlock Text="📁" />
          </Button>
        </Grid>

        <!-- Filter pills + sort -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Spacing="6">
            <ToggleButton IsChecked="{Binding IsFilterAll, Mode=OneWay}"
                          Command="{Binding FilterAllCommand}"
                          ToolTip.Tip="{Binding [deeper_hub_tip_pill_all], Source={x:Static loc:LocalizationManager.Instance}}"
                          Theme="{StaticResource DeeperPillStyle}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding [deeper_hub_pill_all], Source={x:Static loc:LocalizationManager.Instance}}" />
                <TextBlock Text="{Binding AllCount}"
                           Foreground="{DynamicResource TextDimBrush}" />
              </StackPanel>
            </ToggleButton>
            <ToggleButton IsChecked="{Binding IsFilterVideo, Mode=OneWay}"
                          Command="{Binding FilterVideoCommand}"
                          ToolTip.Tip="{Binding [deeper_hub_tip_pill_video], Source={x:Static loc:LocalizationManager.Instance}}"
                          Theme="{StaticResource DeeperPillStyle}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding [deeper_hub_pill_video], Source={x:Static loc:LocalizationManager.Instance}}" />
                <TextBlock Text="{Binding VideoCount}"
                           Foreground="{DynamicResource TextDimBrush}" />
              </StackPanel>
            </ToggleButton>
            <ToggleButton IsChecked="{Binding IsFilterAudio, Mode=OneWay}"
                          Command="{Binding FilterAudioCommand}"
                          ToolTip.Tip="{Binding [deeper_hub_tip_pill_audio], Source={x:Static loc:LocalizationManager.Instance}}"
                          Theme="{StaticResource DeeperPillStyle}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding [deeper_hub_pill_audio], Source={x:Static loc:LocalizationManager.Instance}}" />
                <TextBlock Text="{Binding AudioCount}"
                           Foreground="{DynamicResource TextDimBrush}" />
              </StackPanel>
            </ToggleButton>

            <Border Width="1"
                    Margin="6,4,10,4"
                    Background="{DynamicResource DeeperAccentTransparent40Brush}" />

            <ToggleButton IsChecked="{Binding FilterHaptics, Mode=OneWay}"
                          Command="{Binding ToggleHapticsFilterCommand}"
                          ToolTip.Tip="{Binding [deeper_hub_tip_pill_haptics], Source={x:Static loc:LocalizationManager.Instance}}"
                          Theme="{StaticResource DeeperPillStyle}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="📳" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{Binding [deeper_hub_pill_haptics], Source={x:Static loc:LocalizationManager.Instance}}" />
                <TextBlock Text="{Binding HapticsCount}"
                           Foreground="{DynamicResource TextDimBrush}" />
              </StackPanel>
            </ToggleButton>
            <ToggleButton IsChecked="{Binding FilterWebcam, Mode=OneWay}"
                          Command="{Binding ToggleWebcamFilterCommand}"
                          ToolTip.Tip="{Binding [deeper_hub_tip_pill_webcam], Source={x:Static loc:LocalizationManager.Instance}}"
                          Theme="{StaticResource DeeperPillStyle}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="📷" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{Binding [deeper_hub_pill_webcam], Source={x:Static loc:LocalizationManager.Instance}}" />
                <TextBlock Text="{Binding WebcamCount}"
                           Foreground="{DynamicResource TextDimBrush}" />
              </StackPanel>
            </ToggleButton>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Spacing="6">
            <Button Command="{Binding OpenCatalogueCommand}"
                    ToolTip.Tip="{Binding [deeper_hub_tip_catalogue], Source={x:Static loc:LocalizationManager.Instance}}"
                    Padding="12,5"
                    Margin="0,0,12,0"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Background="{DynamicResource DeeperAccentBrush}"
                    Foreground="{DynamicResource TextLightBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}"
                    BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="🛍" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="{Binding [deeper_hub_catalogue_btn], Source={x:Static loc:LocalizationManager.Instance}}"
                           VerticalAlignment="Center" />
                <TextBlock Text="↗"
                           Margin="2,0,0,0"
                           Foreground="{DynamicResource DeeperAccentSoftBrush}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <TextBlock Text="{Binding [deeper_hub_sort_label], Source={x:Static loc:LocalizationManager.Instance}}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding SortOptions}"
                      SelectedIndex="{Binding SelectedSortIndex, Mode=TwoWay}"
                      ToolTip.Tip="{Binding [deeper_hub_tip_sort], Source={x:Static loc:LocalizationManager.Instance}}"
                      Background="{DynamicResource TextLightBrush}"
                      Foreground="Black"
                      MinWidth="100"
                      Padding="6,4" />
          </StackPanel>
        </Grid>
      </StackPanel>

      <!-- Library list -->
      <Border Grid.Row="3"
              MinHeight="320"
              Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="14,12">
        <DockPanel LastChildFill="True">
          <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10" LastChildFill="True">
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding LibraryCountText}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11" />
            <TextBlock Text="{Binding [deeper_section_library], Source={x:Static loc:LocalizationManager.Instance}}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="12"
                       FontWeight="Bold" />
          </DockPanel>

          <Grid>
            <ItemsControl x:Name="DeeperLibraryList"
                          ItemsSource="{Binding FilteredEntries}"
                          ItemTemplate="{StaticResource DeeperLibraryRowTemplate}"
                          Background="Transparent" />
            <TextBlock IsVisible="{Binding IsLibraryEmpty}"
                       Text="{Binding LibraryEmptyText}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       TextWrapping="Wrap"
                       MaxWidth="500"
                       Margin="0,40,0,0"
                       TextAlignment="Center" />
          </Grid>
        </DockPanel>
      </Border>

      <!-- Webcam setup card -->
      <Border Grid.Row="4"
              Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="14,12"
              Margin="0,14,0,0">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="📷" FontSize="15" VerticalAlignment="Center" />
              <TextBlock Text="{Binding [blink_trainer_section_webcam], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{Binding [deeper_webcam_blink_recal_tooltip], Source={x:Static loc:LocalizationManager.Instance}}">
              <CheckBox IsChecked="{Binding BlinkToRecalEnabled, Mode=TwoWay}"
                        VerticalAlignment="Center" />
              <TextBlock Text="{Binding [deeper_webcam_blink_recal_label], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="10"
                         VerticalAlignment="Center"
                         Margin="6,0,0,0" />
            </StackPanel>
          </Grid>

          <TextBlock Text="{Binding [deeper_webcam_setup_body], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="10"
                     TextWrapping="Wrap" />

          <Grid ColumnDefinitions="*,16,*">
            <!-- Left: device + monitor -->
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="{Binding [blink_trainer_camera_device], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="11"
                         FontWeight="Medium" />
              <Grid ColumnDefinitions="*,Auto">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding WebcamDevices}"
                          SelectedItem="{Binding SelectedWebcamDevice, Mode=TwoWay}"
                          Foreground="Black"
                          Background="{DynamicResource TextLightBrush}"
                          FontSize="10" />
                <Button Grid.Column="1"
                        Content="{Binding [blink_trainer_camera_refresh], Source={x:Static loc:LocalizationManager.Instance}}"
                        Command="{Binding RefreshWebcamDevicesCommand}"
                        Margin="6,0,0,0"
                        Padding="8,3"
                        FontSize="10"
                        Theme="{StaticResource OutlineButton}" />
              </Grid>

              <TextBlock Text="{Binding [webcam_monitor_label], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="11"
                         FontWeight="Medium" />
              <ComboBox ItemsSource="{Binding Monitors}"
                        SelectedItem="{Binding SelectedMonitor, Mode=TwoWay}"
                        Foreground="Black"
                        Background="{DynamicResource TextLightBrush}"
                        FontSize="10"
                        ToolTip.Tip="{Binding [webcam_monitor_tooltip], Source={x:Static loc:LocalizationManager.Instance}}" />

              <CheckBox IsChecked="{Binding RestrictGazeToCalScreen, Mode=TwoWay}"
                        Content="{Binding [deeper_webcam_restrict_gaze_content], Source={x:Static loc:LocalizationManager.Instance}}"
                        ToolTip.Tip="{Binding [deeper_webcam_restrict_gaze_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                        Foreground="{DynamicResource TextDimBrush}"
                        FontSize="10"
                        Margin="0,4,0,0" />
            </StackPanel>

            <!-- Right: consent + calibration -->
            <StackPanel Grid.Column="2" Spacing="4">
              <Border CornerRadius="6"
                      Padding="10,8"
                      Background="#1A4ADE80"
                      BorderBrush="#4ADE80"
                      BorderThickness="1">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding WebcamConsentStatusText}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="11"
                             FontWeight="Medium" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="{Binding WebcamManageConsentButtonText}"
                            Command="{Binding ManageWebcamConsentCommand}"
                            Padding="8,3"
                            FontSize="10"
                            Theme="{StaticResource OutlineButton}" />
                    <Button Content="{Binding [blink_trainer_consent_revoke], Source={x:Static loc:LocalizationManager.Instance}}"
                            IsVisible="{Binding IsWebcamConsentGranted}"
                            Background="Transparent"
                            Foreground="#FF6060"
                            BorderBrush="#FF6060"
                            BorderThickness="1"
                            Padding="8,3"
                            FontSize="10"
                            ToolTip.Tip="{Binding [blink_trainer_consent_revoke_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                            Command="{Binding RevokeWebcamConsentCommand}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <TextBlock Text="{Binding [blink_trainer_calibration_label], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontSize="11"
                         FontWeight="Medium" />
              <TextBlock Text="{Binding WebcamCalibrationStatusText}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="10"
                         TextWrapping="Wrap" />
              <WrapPanel Orientation="Horizontal">
                <Button Content="{Binding [blink_trainer_calibration_btn], Source={x:Static loc:LocalizationManager.Instance}}"
                        Command="{Binding CalibrateWebcamCommand}"
                        Padding="10,4"
                        Margin="0,0,6,6"
                        FontSize="10"
                        Theme="{StaticResource OutlineButton}" />
                <Button Content="{Binding [blink_trainer_calibration_quick], Source={x:Static loc:LocalizationManager.Instance}}"
                        Command="{Binding QuickRecalWebcamCommand}"
                        Padding="10,4"
                        Margin="0,0,6,6"
                        FontSize="10"
                        Theme="{StaticResource OutlineButton}" />
                <Button Content="{Binding WebcamTrackerButtonText}"
                        Command="{Binding StartStopTrackerCommand}"
                        Padding="10,4"
                        Margin="0,0,0,6"
                        FontSize="10"
                        Theme="{StaticResource OutlineButton}" />
              </WrapPanel>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>

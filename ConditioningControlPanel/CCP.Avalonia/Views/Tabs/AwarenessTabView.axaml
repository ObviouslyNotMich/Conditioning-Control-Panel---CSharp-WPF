<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.AwarenessTabView"
             x:DataType="vm:AwarenessTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:AwarenessTabViewModel />
  </Design.DataContext>

  <Grid>
    <ScrollViewer>
      <StackPanel Spacing="22"
                  Margin="36,28"
                  MaxWidth="980"
                  HorizontalAlignment="Center">

        <!-- Hero banner -->
        <Border CornerRadius="14"
                ClipToBounds="True"
                MaxHeight="320"
                HorizontalAlignment="Center"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1">
          <Image Source="avares://CCP.Avalonia/Assets/features/awareness.png"
                 Stretch="Uniform" />
        </Border>

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Column="0"
                     Text="👁"
                     FontSize="38"
                     VerticalAlignment="Center"
                     Margin="0,0,14,0" />
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{loc:Str tab_awareness_engine_title}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="22"
                       FontWeight="Bold" />
            <TextBlock Text="{loc:Str tab_awareness_engine_subtitle}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="12"
                       Margin="0,2,0,0"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Spacing="12">
            <Button Content="{loc:Str tab_awareness_tutorial_content}"
                    Command="{Binding OpenTutorialCommand}"
                    FontSize="13"
                    FontWeight="Bold"
                    Padding="12,7"
                    BorderThickness="0"
                    Background="{DynamicResource PinkBrush}"
                    Foreground="{DynamicResource TextLightBrush}"
                    CornerRadius="8" />
            <Ellipse Width="8"
                     Height="8"
                     VerticalAlignment="Center"
                     Fill="{Binding StatusColor}" />
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#A0A0A0"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <ToggleSwitch VerticalAlignment="Center"
                          IsChecked="{Binding IsAwarenessMasterEnabled, Mode=TwoWay}" />
          </StackPanel>
        </Grid>

        <!-- Live pulse feed -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="#2E2E48"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18,16">
          <StackPanel>
            <Grid Margin="0,0,0,10">
              <TextBlock Text="{loc:Str tab_awareness_last_detected}"
                         Foreground="#8A8AA0"
                         FontSize="10"
                         FontWeight="Bold"
                         VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="{loc:Str tab_awareness_pulse_empty}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="12"
                       FontStyle="Italic"
                       TextAlignment="Center"
                       Margin="0,18" />
          </StackPanel>
        </Border>

        <!-- Presets placeholder -->
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{loc:Str tab_awareness_presets}"
                       Foreground="#8A8AA0"
                       FontSize="10"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{loc:Str tab_awareness_presets_subtitle}"
                       HorizontalAlignment="Right"
                       Foreground="#8A8AA0"
                       FontSize="10"
                       FontStyle="Italic" />
          </Grid>
          <Border Background="{DynamicResource SurfaceBgBrush}"
                  BorderBrush="#2E2E48"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="18,16">
            <TextBlock Text="{loc:Str tab_awareness_presets_placeholder}"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="12"
                       FontStyle="Italic"
                       TextAlignment="Center" />
          </Border>
        </StackPanel>

        <!-- Timing -->
        <Border Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="14">
            <TextBlock Text="{loc:Str tab_awareness_timing_text}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PinkBrush}" />

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{loc:Str tab_awareness_buffer_timeout_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding BufferTimeoutText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="500"
                      Maximum="5000"
                      Value="{Binding BufferTimeoutMs, Mode=TwoWay}"
                      TickFrequency="100"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{loc:Str tab_awareness_global_cooldown_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding GlobalCooldownText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="1"
                      Maximum="120"
                      Value="{Binding GlobalCooldownSeconds, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{loc:Str tab_awareness_same_word_cooldown_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SameWordCooldownText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="1"
                      Maximum="120"
                      Value="{Binding SameWordCooldownSeconds, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{loc:Str tab_awareness_session_multiplier_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding SessionMultiplierText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="0.5"
                      Maximum="3.0"
                      Value="{Binding SessionMultiplier, Mode=TwoWay}"
                      TickFrequency="0.1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Sources + Safety -->
        <Grid ColumnDefinitions="*,14,*">

          <!-- Signal Sources -->
          <Border Grid.Column="0"
                  Background="{DynamicResource SurfaceBgBrush}"
                  BorderBrush="#2E2E48"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="18,14">
            <StackPanel>
              <TextBlock Text="{loc:Str tab_awareness_signal_sources}"
                         Foreground="#8A8AA0"
                         FontSize="10"
                         FontWeight="Bold"
                         Margin="0,0,0,10" />

              <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,8">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <TextBlock Text="🖵"
                             FontSize="16"
                             VerticalAlignment="Center" />
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str tab_awareness_screen_ocr_title}"
                               Foreground="{DynamicResource TextLightBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Str tab_awareness_screen_ocr_desc}"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="10" />
                  </StackPanel>
                </StackPanel>
                <ToggleSwitch Grid.Column="1"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ScreenOcrEnabled, Mode=TwoWay}" />
              </Grid>

              <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <TextBlock Text="⌨"
                             FontSize="14"
                             VerticalAlignment="Center" />
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str tab_awareness_keyboard_title}"
                               Foreground="{DynamicResource TextLightBrush}"
                               FontSize="12"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Str tab_awareness_keyboard_desc}"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontSize="10" />
                  </StackPanel>
                </StackPanel>
                <ToggleSwitch Grid.Column="1"
                              VerticalAlignment="Center"
                              IsChecked="{Binding KeywordTriggersEnabled, Mode=TwoWay}" />
              </Grid>

              <TextBlock Text="{loc:Str tab_awareness_more_sources_coming}"
                         Foreground="#8A8AA0"
                         FontSize="10"
                         FontStyle="Italic"
                         Margin="0,10,0,0" />
            </StackPanel>
          </Border>

          <!-- Safety -->
          <Border Grid.Column="2"
                  Background="{DynamicResource SurfaceBgBrush}"
                  BorderBrush="#2E2E48"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="18,14">
            <StackPanel>
              <TextBlock Text="{loc:Str tab_awareness_safety}"
                         Foreground="#8A8AA0"
                         FontSize="10"
                         FontWeight="Bold"
                         Margin="0,0,0,10" />

              <CheckBox Content="{loc:Str tab_awareness_ignore_own_ui}"
                        IsChecked="{Binding IgnoreOwnUi, Mode=TwoWay}"
                        Foreground="{DynamicResource TextLightBrush}"
                        FontSize="12"
                        Margin="0,4,0,2" />
              <TextBlock Text="{loc:Str tab_awareness_ignore_own_ui_desc}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="10"
                         TextWrapping="Wrap"
                         Margin="22,0,0,10" />

              <CheckBox Content="{loc:Str tab_awareness_loop_protection}"
                        IsChecked="{Binding LoopProtectionEnabled, Mode=TwoWay}"
                        Foreground="{DynamicResource TextLightBrush}"
                        FontSize="12"
                        Margin="0,4,0,2" />
              <TextBlock Text="{loc:Str tab_awareness_loop_protection_desc}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="10"
                         TextWrapping="Wrap"
                         Margin="22,0,0,10" />

              <CheckBox Content="{loc:Str tab_awareness_highlight_matched_words}"
                        IsChecked="{Binding KeywordHighlightEnabled, Mode=TwoWay}"
                        Foreground="{DynamicResource TextLightBrush}"
                        FontSize="12"
                        Margin="0,4,0,2" />
              <TextBlock Text="{loc:Str tab_awareness_highlight_matched_words_desc}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="10"
                         TextWrapping="Wrap"
                         Margin="22,0,0,6" />

              <StackPanel Orientation="Horizontal" Margin="22,0,0,0" Spacing="6">
                <TextBlock Text="{loc:Str tab_awareness_color}"
                           Foreground="#A0A0B8"
                           FontSize="10"
                           VerticalAlignment="Center" />
                <Button Width="22"
                        Height="22"
                        CornerRadius="3"
                        Background="{DynamicResource PinkBrush}"
                        BorderBrush="#3A3A5A"
                        BorderThickness="1"
                        Command="{Binding SetHighlightColorCommand}"
                        CommandParameter="#FF69B4">
                      </Button>
                <Button Width="22"
                        Height="22"
                        CornerRadius="3"
                        Background="#00E5FF"
                        BorderBrush="#3A3A5A"
                        BorderThickness="1"
                        Command="{Binding SetHighlightColorCommand}"
                        CommandParameter="#00E5FF" />
                <Button Width="22"
                        Height="22"
                        CornerRadius="3"
                        Background="#9DFF00"
                        BorderBrush="#3A3A5A"
                        BorderThickness="1"
                        Command="{Binding SetHighlightColorCommand}"
                        CommandParameter="#9DFF00" />
                <Button Width="22"
                        Height="22"
                        CornerRadius="3"
                        Background="#FF8A00"
                        BorderBrush="#3A3A5A"
                        BorderThickness="1"
                        Command="{Binding SetHighlightColorCommand}"
                        CommandParameter="#FF8A00" />
                <Button Width="22"
                        Height="22"
                        CornerRadius="3"
                        Background="#B388FF"
                        BorderBrush="#3A3A5A"
                        BorderThickness="1"
                        Command="{Binding SetHighlightColorCommand}"
                        CommandParameter="#B388FF" />
                <Button Width="22"
                        Height="22"
                        CornerRadius="3"
                        Background="#FFFFFF"
                        BorderBrush="#3A3A5A"
                        BorderThickness="1"
                        Command="{Binding SetHighlightColorCommand}"
                        CommandParameter="#FFFFFF" />
                <TextBox Text="{Binding HighlightColorHex, Mode=TwoWay}"
                         Width="74"
                         FontSize="10"
                         Background="#1E1E32"
                         Foreground="{DynamicResource TextLightBrush}"
                         BorderBrush="#3A3A5A"
                         Padding="4,3"
                         VerticalAlignment="Center" />
              </StackPanel>

              <CheckBox Content="{loc:Str tab_awareness_highlight_visible_capture_content}"
                        IsChecked="{Binding HighlightVisibleInCapture, Mode=TwoWay}"
                        Foreground="#A0A0A0"
                        FontSize="10"
                        Margin="22,6,0,0" />
            </StackPanel>
          </Border>
        </Grid>

        <!-- OCR settings -->
        <Border Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="14">
            <TextBlock Text="{loc:Str tab_awareness_ocr_settings_text}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PinkBrush}" />

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{loc:Str tab_awareness_scan_interval_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding ScreenOcrIntervalText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="1"
                      Maximum="30"
                      Value="{Binding ScreenOcrIntervalSeconds, Mode=TwoWay}"
                      TickFrequency="1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{loc:Str tab_awareness_keyword_highlight_text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextLightBrush}" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding KeywordHighlightEnabled, Mode=TwoWay}" />
            </Grid>

            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{loc:Str tab_awareness_highlight_duration_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding KeywordHighlightDurationText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
              </Grid>
              <Slider Minimum="0.5"
                      Maximum="5.0"
                      Value="{Binding KeywordHighlightDurationSeconds, Mode=TwoWay}"
                      TickFrequency="0.1"
                      IsSnapToTickEnabled="True" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*">
              <StackPanel Spacing="6" Margin="0,0,6,0">
                <TextBlock Text="{loc:Str tab_awareness_highlight_mode_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding OcrHighlightModeOptions}"
                          SelectedIndex="{Binding SelectedOcrHighlightModeIndex, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
              </StackPanel>
              <StackPanel Spacing="6" Margin="6,0,0,0">
                <TextBlock Text="{loc:Str tab_awareness_confirmation_scans_text}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding OcrConfirmationOptions}"
                          SelectedIndex="{Binding SelectedOcrConfirmationIndex, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Triggers editor -->
        <Border Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="10">
            <TextBlock Text="{loc:Str tab_awareness_triggers_text}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PinkBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="{loc:Str tab_awareness_add_trigger_content}"
                      Command="{Binding AddTriggerCommand}" />
              <Button Content="{loc:Str tab_awareness_import_from_custom_triggers_content}"
                      Command="{Binding ImportFromCustomTriggersCommand}" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Triggers}"
                     Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:KeywordTriggerViewModel">
                  <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                          BorderBrush="{DynamicResource PinkBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="12"
                          Margin="0,4">
                    <StackPanel Spacing="10">
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Keyword, Mode=TwoWay}"
                                 PlaceholderText="{loc:Str tab_awareness_keyword_placeholder}"
                                 VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1"
                                  Content="{loc:Str tab_awareness_enabled_content}"
                                  IsChecked="{Binding Enabled, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Margin="8,0" />
                        <Button Grid.Column="2"
                                Content="{loc:Str tab_awareness_delete_content}"
                                Command="{Binding $parent[ListBox].((vm:AwarenessTabViewModel)DataContext).DeleteTriggerCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>

                      <Grid ColumnDefinitions="*,*">
                        <StackPanel Spacing="6" Margin="0,0,6,0">
                          <TextBlock Text="{loc:Str tab_awareness_visual_effect_text}"
                                     Foreground="{DynamicResource TextLightBrush}"
                                     FontSize="12"
                                     FontWeight="SemiBold" />
                          <ComboBox ItemsSource="{Binding $parent[ListBox].((vm:AwarenessTabViewModel)DataContext).VisualEffectOptions}"
                                    SelectedIndex="{Binding VisualEffectIndex, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Spacing="6" Margin="6,0,0,0">
                          <TextBlock Text="{loc:Str tab_awareness_cooldown_s_text}"
                                     Foreground="{DynamicResource TextLightBrush}"
                                     FontSize="12"
                                     FontWeight="SemiBold" />
                          <Slider Minimum="1"
                                  Maximum="3600"
                                  Value="{Binding CooldownSeconds, Mode=TwoWay}"
                                  TickFrequency="1"
                                  IsSnapToTickEnabled="True" />
                        </StackPanel>
                      </Grid>

                      <Grid ColumnDefinitions="*,*">
                        <StackPanel Spacing="6" Margin="0,0,6,0">
                          <TextBlock Text="{loc:Str tab_awareness_audio_volume_text}"
                                     Foreground="{DynamicResource TextLightBrush}"
                                     FontSize="12"
                                     FontWeight="SemiBold" />
                          <Slider Minimum="0"
                                  Maximum="100"
                                  Value="{Binding AudioVolume, Mode=TwoWay}"
                                  TickFrequency="1"
                                  IsSnapToTickEnabled="True" />
                        </StackPanel>
                        <StackPanel Spacing="6" Margin="6,0,0,0">
                          <TextBlock Text="{loc:Str tab_awareness_audio_file_text}"
                                     Foreground="{DynamicResource TextLightBrush}"
                                     FontSize="12"
                                     FontWeight="SemiBold" />
                          <TextBlock Text="{Binding AudioFileName}"
                                     Opacity="0.8" />
                          <Button Content="{loc:Str tab_awareness_browse_audio_content}"
                                  Command="{Binding $parent[ListBox].((vm:AwarenessTabViewModel)DataContext).BrowseAudioCommand}"
                                  CommandParameter="{Binding}" />
                        </StackPanel>
                      </Grid>

                      <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="{loc:Str tab_awareness_haptic_content}"
                                  IsChecked="{Binding HapticEnabled, Mode=TwoWay}"
                                  Margin="0,0,16,0" />
                        <CheckBox Content="{loc:Str tab_awareness_duck_audio_content}"
                                  IsChecked="{Binding DuckAudio, Mode=TwoWay}" />
                      </WrapPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <!-- Advanced link -->
        <Button HorizontalAlignment="Center"
                Command="{Binding OpenAdvancedCommand}"
                Background="Transparent"
                BorderThickness="0"
                Padding="0">
          <TextBlock Text="{loc:Str tab_awareness_advanced_link}"
                     Foreground="{DynamicResource PinkBrush}"
                     TextDecorations="Underline"
                     FontSize="13" />
        </Button>
      </StackPanel>
    </ScrollViewer>

    <!-- Premium gate overlay -->
    <Border IsVisible="{Binding IsPremiumLocked}"
            Background="#99000010"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="2"
            CornerRadius="10"
            IsHitTestVisible="True"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10">
        <TextBlock Text="🔒"
                   FontSize="52"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str gate_premium_locked}"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextLightBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str gate_premium_subtitle}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="14"
                   HorizontalAlignment="Center" />
        <Button Content="{loc:Str gate_unlock_with_patreon}"
                Command="{Binding UnlockCommand}"
                Padding="20,8"
                Background="{DynamicResource PinkBrush}"
                Foreground="{DynamicResource TextLightBrush}"
                FontWeight="Bold"
                HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>

</UserControl>

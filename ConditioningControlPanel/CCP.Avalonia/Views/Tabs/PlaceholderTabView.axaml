<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.PlaceholderTabView"
             x:DataType="vm:TabItemViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:TabItemViewModel Key="settings"
                         Header="{loc:Str tab_placeholder_dashboard_header}"
                         Icon="📊" />
  </Design.DataContext>

  <StackPanel HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="12">
    <TextBlock Text="{Binding Icon}"
               FontSize="48"
               HorizontalAlignment="Center" />
    <TextBlock Text="{Binding Header}"
               FontSize="24"
               HorizontalAlignment="Center" />
    <TextBlock Text="{Binding Key, StringFormat='{}key: {0}'}"
               FontSize="12"
               Opacity="0.5"
               HorizontalAlignment="Center" />
    <TextBlock Text="{loc:Str tab_placeholder_avalonia_tab_placeholder_text}"
               Opacity="0.7"
               HorizontalAlignment="Center" />
  </StackPanel>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.BlinkTrainerTabView"
             x:DataType="vm:BlinkTrainerTabViewModel">

  <Design.DataContext>
    <vm:BlinkTrainerTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{loc:Str tab_blink_trainer}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="White" />

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="12">
          <Button Content="{Binding TrackerButtonText}"
                  Command="{Binding ToggleTrackingCommand}"
                  HorizontalAlignment="Left" />
          <TextBlock Text="{Binding StatusText}"
                     Foreground="#FF69B4"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding CounterText}"
                     Opacity="0.8" />
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str blink_trainer_section_focus_calibration}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="{loc:Str label_focus_gaze}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="White" />
              <TextBlock Text="{Binding FocusGazeStatus}"
                         Foreground="#FF69B4"
                         FontSize="11" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1"
                          VerticalAlignment="Center"
                          IsChecked="{Binding FocusGazeActive, Mode=TwoWay}" />
          </Grid>

          <WrapPanel Orientation="Horizontal">
            <CheckBox Content="{loc:Str blink_trainer_blink_recalibrate_shortcut}"
                      IsChecked="{Binding BlinkRecalibrateShortcutEnabled, Mode=TwoWay}"
                      Margin="0,0,16,8" />
            <CheckBox Content="{loc:Str blink_trainer_restrict_gaze_calibrated_screen}"
                      IsChecked="{Binding RestrictGazeToCalibratedScreen, Mode=TwoWay}"
                      Margin="0,0,16,8" />
            <CheckBox Content="{loc:Str blink_trainer_debug_cursor}"
                      IsChecked="{Binding DebugCursorEnabled, Mode=TwoWay}"
                      Margin="0,0,16,8" />
          </WrapPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Str blink_trainer_calibration_btn}"
                    Command="{Binding CalibrateCommand}" />
            <Button Content="{loc:Str blink_trainer_tracker_test}"
                    Command="{Binding TrackerTestCommand}" />
            <Button Content="{loc:Str blink_trainer_quick_recalibrate}"
                    Command="{Binding QuickRecalCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str blink_trainer_section_device_selection}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />

          <Grid ColumnDefinitions="*,Auto">
            <ComboBox ItemsSource="{Binding WebcamDevices}"
                      SelectedItem="{Binding SelectedWebcamDevice, Mode=TwoWay}"
                      DisplayMemberBinding="{Binding Name}"
                      HorizontalAlignment="Stretch" />
            <Button Grid.Column="1"
                    Content="{loc:Str blink_trainer_camera_refresh}"
                    Command="{Binding RefreshDevicesCommand}"
                    Margin="8,0,0,0" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <ComboBox ItemsSource="{Binding Monitors}"
                      SelectedItem="{Binding SelectedMonitor, Mode=TwoWay}"
                      DisplayMemberBinding="{Binding Label}"
                      HorizontalAlignment="Stretch" />
            <Button Grid.Column="1"
                    Content="{loc:Str blink_trainer_camera_refresh}"
                    Command="{Binding RefreshMonitorsCommand}"
                    Margin="8,0,0,0" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str blink_trainer_section_privacy_extras}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{loc:Str blink_trainer_review_privacy}"
                    Command="{Binding ReviewPrivacyCommand}" />
            <Button Content="{loc:Str blink_trainer_consent_revoke}"
                    Command="{Binding RevokeConsentCommand}" />
            <Button Content="{loc:Str label_gaze_minigame}"
                    Command="{Binding OpenGazeMinigameCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str blink_trainer_debug_log}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <ListBox ItemsSource="{Binding DebugLog}"
                   Background="Transparent"
                   MaxHeight="200" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             xmlns:features="clr-namespace:ConditioningControlPanel.Avalonia.Features;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.BlinkTrainerTabView"
             x:DataType="vm:BlinkTrainerTabViewModel">

  <Design.DataContext>
    <vm:BlinkTrainerTabViewModel />
  </Design.DataContext>

  <Grid>
    <ScrollViewer>
      <StackPanel Spacing="16" Margin="16">

        <!-- Hero banner -->
        <Border MaxHeight="260"
                CornerRadius="12"
                ClipToBounds="True"
                BorderBrush="#FF69B4"
                BorderThickness="2">
          <Image Source="avares://CCP.Avalonia/Assets/features/blink_trainer.png"
                 Stretch="UniformToFill"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch" />
        </Border>

        <!-- Header row -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      Spacing="12">
            <TextBlock x:Name="EyeLogo"
                       Text="👁️"
                       FontSize="32"
                       VerticalAlignment="Center">
              <TextBlock.Styles>
                <Style Selector="TextBlock#EyeLogo">
                  <Style.Animations>
                    <Animation Duration="0:0:4"
                               IterationCount="Infinite">
                      <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1.0" />
                      </KeyFrame>
                      <KeyFrame Cue="45%">
                        <Setter Property="Opacity" Value="1.0" />
                      </KeyFrame>
                      <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.15" />
                      </KeyFrame>
                      <KeyFrame Cue="55%">
                        <Setter Property="Opacity" Value="1.0" />
                      </KeyFrame>
                      <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0" />
                      </KeyFrame>
                    </Animation>
                  </Style.Animations>
                </Style>
              </TextBlock.Styles>
            </TextBlock>

            <StackPanel VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Text="{loc:Str tab_blink_trainer}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
                <Border Background="{DynamicResource TransparentPinkBrush}"
                        BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="5,2"
                        VerticalAlignment="Center">
                  <TextBlock Text="{loc:Str blink_trainer_beta}"
                             FontSize="10"
                             FontWeight="Bold"
                             Foreground="{DynamicResource PinkBrush}" />
                </Border>
              </StackPanel>
              <TextBlock Text="{loc:Str blink_trainer_tagline}"
                         FontSize="13"
                         Foreground="#AAAAAA" />
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="12"
                      VerticalAlignment="Center">
            <Button Content="{loc:Str btn_help}"
                    Command="{Binding ShowHelpCommand}"
                    Theme="{StaticResource OutlineButton}"
                    Padding="10,5" />
            <ToggleSwitch Content="{loc:Str blink_trainer_blink_recalibrate_shortcut}"
                          IsChecked="{Binding BlinkRecalibrateShortcutEnabled, Mode=TwoWay}"
                          VerticalAlignment="Center" />
          </StackPanel>
        </Grid>

        <!-- Two-column stage + gated zone -->
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="16">

          <!-- Left: stage -->
          <StackPanel Grid.Column="0"
                      Spacing="12"
                      Width="448">
            <Border Width="448"
                    Height="288"
                    CornerRadius="12"
                    ClipToBounds="True"
                    Padding="3"
                    HorizontalAlignment="Left">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Offset="0" Color="#FF69B4" />
                  <GradientStop Offset="1" Color="#9370DB" />
                </LinearGradientBrush>
              </Border.Background>
              <Border Background="{DynamicResource SurfaceBgBrush}"
                      CornerRadius="10"
                      ClipToBounds="True">
                <Grid>
                  <Image Source="avares://CCP.Avalonia/Assets/features/blink_trainer.png"
                         Stretch="UniformToFill"
                         Opacity="0.35" />
                  <TextBlock Text="{Binding PreviewLabel}"
                             Foreground="#AAAAAA"
                             FontSize="13"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource PinkBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">
              <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Ellipse Width="10"
                           Height="10"
                           Fill="{Binding StatusColor}"
                           VerticalAlignment="Center" />
                  <TextBlock Text="{loc:Str blink_trainer_session_status}"
                             Foreground="#AAAAAA"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{Binding StatusText}"
                             Foreground="{Binding StatusColor}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button Content="{Binding SessionButtonText}"
                          Command="{Binding ToggleSessionCommand}"
                          Theme="{StaticResource PinkButton}" />
                  <Button Content="{Binding TrackerButtonText}"
                          Command="{Binding ToggleTrackingCommand}" />
                </StackPanel>

                <TextBlock Text="{Binding CounterText}"
                           Opacity="0.8"
                           FontSize="12" />
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Right: gated content stack -->
          <Grid Grid.Column="1">
            <StackPanel Spacing="14">

              <!-- Asset Packs card -->
              <Border Background="{DynamicResource SurfaceBgBrush}"
                      BorderBrush="{DynamicResource PinkBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="16">
                <StackPanel Spacing="12">
                  <TextBlock Text="{loc:Str blink_trainer_section_asset_packs}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource PinkBrush}" />

                  <ItemsControl ItemsSource="{Binding AssetFolders}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:AssetFolderItem">
                        <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderBrush="{DynamicResource PanelAccentBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,4">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Status}"
                                       Foreground="#888888"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Button Command="{Binding AddFolderCommand}"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0">
                    <Grid HorizontalAlignment="Stretch">
                      <Rectangle Stroke="{DynamicResource PinkBrush}"
                                 StrokeThickness="1.5"
                                 StrokeDashArray="4,3"
                                 RadiusX="8"
                                 RadiusY="8" />
                      <TextBlock Text="{loc:Str blink_trainer_add_folder}"
                                 Foreground="{DynamicResource PinkBrush}"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Padding="15,8" />
                    </Grid>
                  </Button>

                  <ToggleSwitch Content="{loc:Str blink_trainer_include_videos}"
                                OffContent="{loc:Str blink_trainer_include_videos}"
                                ToolTip.Tip="{loc:Str blink_trainer_include_videos_sub}" />
                </StackPanel>
              </Border>

              <!-- Session + Webcam cards -->
              <Grid ColumnDefinitions="* *"
                    ColumnSpacing="14">

                <!-- Session card -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceBgBrush}"
                        BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                  <StackPanel Spacing="14">
                    <TextBlock Text="{loc:Str blink_trainer_section_session}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PinkBrush}" />

                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{loc:Str blink_trainer_duration_label}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SessionDuration, StringFormat='{}{0:0} min'}"
                                   Foreground="{DynamicResource PinkBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                      </Grid>
                      <Slider Minimum="1"
                              Maximum="60"
                              Value="{Binding SessionDuration, Mode=TwoWay}"
                              TickFrequency="1"
                              IsSnapToTickEnabled="True" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{loc:Str blink_trainer_opacity_label}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding OverlayOpacity, StringFormat='{}{0:P0}'}"
                                   Foreground="{DynamicResource PinkBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                      </Grid>
                      <Slider Minimum="0"
                              Maximum="1"
                              Value="{Binding OverlayOpacity, Mode=TwoWay}"
                              TickFrequency="0.05" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Text="{loc:Str blink_trainer_tiling_label}"
                                 Foreground="White"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8">
                        <ToggleButton Content="{loc:Str blink_trainer_tiling_same}"
                                      IsChecked="{Binding !IsMixMode, Mode=TwoWay}"
                                      Theme="{StaticResource TabButton}" />
                        <ToggleButton Content="{loc:Str blink_trainer_tiling_mix}"
                                      IsChecked="{Binding IsMixMode, Mode=TwoWay}"
                                      Theme="{StaticResource TabButton}" />
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Webcam card -->
                <Border Grid.Column="1"
                        Background="{DynamicResource SurfaceBgBrush}"
                        BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                  <StackPanel Spacing="14">
                    <TextBlock Text="{loc:Str blink_trainer_section_webcam}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PinkBrush}" />

                    <StackPanel Spacing="6">
                      <TextBlock Text="{loc:Str blink_trainer_camera_device}"
                                 Foreground="White"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding WebcamDevices}"
                                  SelectedItem="{Binding SelectedWebcamDevice, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Name}"
                                  HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1"
                                Content="{loc:Str blink_trainer_camera_refresh}"
                                Command="{Binding RefreshDevicesCommand}"
                                Margin="8,0,0,0" />
                      </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Text="{loc:Str webcam_monitor_label}"
                                 Foreground="White"
                                 FontSize="13"
                                 FontWeight="SemiBold" />
                      <Grid ColumnDefinitions="*,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding Monitors}"
                                  SelectedItem="{Binding SelectedMonitor, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Label}"
                                  HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1"
                                Content="{loc:Str blink_trainer_camera_refresh}"
                                Command="{Binding RefreshMonitorsCommand}"
                                Margin="8,0,0,0" />
                      </Grid>
                    </StackPanel>

                    <!-- Consent status card -->
                    <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                            CornerRadius="8"
                            Padding="12">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                          <TextBlock Text="{loc:Str blink_trainer_consent_manage}"
                                     Foreground="White"
                                     FontSize="13"
                                     FontWeight="SemiBold" />
                          <TextBlock Text="{Binding ConsentStatusText}"
                                     Foreground="{Binding ConsentGranted, Converter={StaticResource BoolToBrushConverter}}"
                                     FontSize="12" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8">
                          <Button Content="{loc:Str blink_trainer_consent_grant}"
                                  Command="{Binding GrantConsentCommand}"
                                  IsVisible="{Binding !ConsentGranted}" />
                          <Button Content="{loc:Str blink_trainer_consent_revoke_short}"
                                  Command="{Binding RevokeConsentCommand}"
                                  IsVisible="{Binding ConsentGranted}" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <!-- Calibration status + actions -->
                    <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                            CornerRadius="8"
                            Padding="12">
                      <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                          <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{loc:Str blink_trainer_calibration_label}"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CalibrationStatusText}"
                                       Foreground="#888888"
                                       FontSize="12" />
                          </StackPanel>
                          <StackPanel Grid.Column="1"
                                      Orientation="Horizontal"
                                      Spacing="8">
                            <Button Content="{loc:Str blink_trainer_calibration_btn}"
                                    Command="{Binding CalibrateCommand}" />
                            <Button Content="{loc:Str blink_trainer_calibration_quick}"
                                    Command="{Binding QuickRecalCommand}" />
                          </StackPanel>
                        </Grid>

                        <CheckBox Content="{loc:Str blink_trainer_restrict_gaze_calibrated_screen}"
                                  IsChecked="{Binding RestrictGazeToCalibratedScreen, Mode=TwoWay}" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Debug log (kept from original) -->
              <Border Background="{DynamicResource SurfaceBgBrush}"
                      BorderBrush="{DynamicResource PinkBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      Padding="16">
                <StackPanel Spacing="10">
                  <TextBlock Text="{loc:Str blink_trainer_debug_log}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource PinkBrush}" />
                  <ListBox ItemsSource="{Binding DebugLog}"
                           Background="Transparent"
                           MaxHeight="160" />
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Premium gate overlay covers only the right-column gated zone -->
            <features:PremiumGateOverlay IsLocked="{Binding IsPremiumLocked}"
                                         Header="{loc:Str blink_trainer_gate_headline}"
                                         Body="{loc:Str blink_trainer_gate_body}"
                                         ButtonText="{loc:Str blink_trainer_gate_cta}" />
          </Grid>
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>

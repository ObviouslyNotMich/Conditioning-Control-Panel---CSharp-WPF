<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             xmlns:conv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.AchievementsTabView"
             x:DataType="vm:AchievementsTabViewModel">

  <Design.DataContext>
    <vm:AchievementsTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="16" Margin="24">

      <!-- Banner -->
      <Border Height="140"
              CornerRadius="12"
              ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="{DynamicResource PanelBg}" />
            <GradientStop Offset="1" Color="#5A3A1A" />
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Border Opacity="0.12"
                  Background="{DynamicResource TextLightBrush}"
                  Width="260"
                  Height="260"
                  CornerRadius="130"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,-60,-100" />
          <StackPanel VerticalAlignment="Center" Margin="24,0">
            <TextBlock Text="{loc:Str tab_achievements_banner_title}"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <TextBlock Text="{loc:Str tab_achievements_banner_subtitle}"
                       FontSize="14"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       MaxWidth="520"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Actions -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="{loc:Str btn_refresh}"
                Command="{Binding RefreshCommand}" />
        <Button Content="{loc:Str btn_view_season_recap}"
                Command="{Binding ViewSeasonRecapCommand}"
                IsVisible="{Binding HasSeasonRecap}" />
      </StackPanel>

      <!-- Summary -->
      <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding FreeCountText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}" />
            <TextBlock Text="Free Achievements"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource TransparentPinkBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding PatronCountText}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}" />
            <TextBlock Text="Patron Achievements"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Free achievements -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="{loc:Str section_free_achievements}"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextLightBrush}" />
          <ItemsControl ItemsSource="{Binding FreeTiles}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:AchievementTileViewModel">
                <Border Width="160"
                        Height="120"
                        Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="4"
                        ToolTip.Tip="{Binding ToolTip}">
                  <Grid RowDefinitions="Auto,*,Auto,Auto">
                    <Image Grid.Row="0"
                           Source="{Binding IconUri, Converter={StaticResource PackUriToBitmapConverter}}"
                           Width="48"
                           Height="48"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,0,0,6"
                           IsVisible="{Binding IconUri, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextLightBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding Requirement}"
                               FontSize="10"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,4,0,0" />
                    <TextBlock Grid.Row="3"
                               Text="{loc:Str achievement_status_unlocked}"
                               FontSize="11"
                               Foreground="{DynamicResource PinkBrush}"
                               TextAlignment="Center"
                               IsVisible="{Binding IsUnlocked}" />
                    <TextBlock Grid.Row="3"
                               Text="{loc:Str achievement_status_locked}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextAlignment="Center"
                               IsVisible="{Binding !IsUnlocked}" />
                    <Border Grid.Row="0"
                            Grid.RowSpan="4"
                            Background="#CC000000"
                            CornerRadius="8"
                            IsVisible="{Binding !IsUnlocked}">
                      <TextBlock Text="🔒"
                                 FontSize="28"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- Patron achievements -->
      <Border Background="{DynamicResource SurfaceBgBrush}"
              BorderBrush="{DynamicResource TransparentPinkBrush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="16">
        <Grid>
          <StackPanel Spacing="12">
            <TextBlock Text="{loc:Str section_patron_achievements_title}"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextLightBrush}" />
            <ItemsControl ItemsSource="{Binding PatronTiles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:AchievementTileViewModel">
                  <Border Width="160"
                          Height="120"
                          Background="{DynamicResource PanelBgBrush}"
                          BorderBrush="{DynamicResource PinkBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="10"
                          Margin="4"
                          ToolTip.Tip="{Binding ToolTip}">
                    <Grid RowDefinitions="Auto,*,Auto,Auto">
                      <Image Grid.Row="0"
                             Source="{Binding IconUri, Converter={StaticResource PackUriToBitmapConverter}}"
                             Width="48"
                             Height="48"
                             Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Margin="0,0,0,6"
                             IsVisible="{Binding IconUri, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
                      <TextBlock Grid.Row="1"
                                 Text="{Binding Name}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextLightBrush}"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Row="2"
                                 Text="{Binding Requirement}"
                                 FontSize="10"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 Margin="0,4,0,0" />
                      <TextBlock Grid.Row="3"
                                 Text="{loc:Str achievement_status_unlocked}"
                                 FontSize="11"
                                 Foreground="{DynamicResource PinkBrush}"
                                 TextAlignment="Center"
                                 IsVisible="{Binding IsUnlocked}" />
                      <TextBlock Grid.Row="3"
                                 Text="{loc:Str achievement_status_locked}"
                                 FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextAlignment="Center"
                                 IsVisible="{Binding !IsUnlocked}" />
                      <Border Grid.Row="0"
                              Grid.RowSpan="4"
                              Background="#CC000000"
                              CornerRadius="8"
                              IsVisible="{Binding !IsUnlocked}">
                        <TextBlock Text="🔒"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <Border Background="{DynamicResource SurfaceBgBrush}"
                  CornerRadius="12"
                  IsVisible="{Binding ShowPatronOverlay}"
                  Opacity="0.9"
                  Padding="20">
            <Border BoxShadow="0 0 20 0 #80FF69B4">
              <TextBlock Text="{loc:Str msg_patron_achievements_locked}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource PinkBrush}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"
                         TextAlignment="Center" />
            </Border>
          </Border>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

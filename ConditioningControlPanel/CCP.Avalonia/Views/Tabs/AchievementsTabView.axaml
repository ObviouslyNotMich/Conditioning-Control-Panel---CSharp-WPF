<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.AchievementsTabView"
             x:DataType="vm:AchievementsTabViewModel">

  <Design.DataContext>
    <vm:AchievementsTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{loc:Str tab_achievements}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="White" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{loc:Str btn_refresh}"
                Command="{Binding RefreshCommand}" />
        <Button Content="{loc:Str btn_view_season_recap}"
                Command="{Binding ViewSeasonRecapCommand}"
                IsVisible="{Binding HasSeasonRecap}" />
      </StackPanel>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="{loc:Str section_free_achievements}"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="#FF69B4" />
          <TextBlock Text="{Binding FreeCountText}"
                     Opacity="0.8" />
          <ItemsControl ItemsSource="{Binding FreeTiles}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:AchievementTileViewModel">
                <Border Width="160"
                        Height="120"
                        Background="#252540"
                        BorderBrush="#FF69B4"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="4"
                        ToolTip.Tip="{Binding ToolTip}">
                  <Grid RowDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               Foreground="White"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Requirement}"
                               FontSize="10"
                               Opacity="0.7"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,4,0,0" />
                    <TextBlock Grid.Row="2"
                               Text="{loc:Str achievement_status_unlocked}"
                               FontSize="11"
                               Foreground="#FF69B4"
                               TextAlignment="Center"
                               IsVisible="{Binding IsUnlocked}" />
                    <TextBlock Grid.Row="2"
                               Text="{loc:Str achievement_status_locked}"
                               FontSize="11"
                               Foreground="#8888AA"
                               TextAlignment="Center"
                               IsVisible="{Binding !IsUnlocked}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="16">
        <Grid>
          <StackPanel Spacing="10">
            <TextBlock Text="{loc:Str section_patron_achievements_title}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#FF69B4" />
            <TextBlock Text="{Binding PatronCountText}"
                       Opacity="0.8" />
            <ItemsControl ItemsSource="{Binding PatronTiles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:AchievementTileViewModel">
                  <Border Width="160"
                          Height="120"
                          Background="#252540"
                          BorderBrush="#FF69B4"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="10"
                          ToolTip.Tip="{Binding ToolTip}">
                    <Grid RowDefinitions="*,Auto,Auto">
                      <TextBlock Grid.Row="0"
                                 Text="{Binding Name}"
                                 FontWeight="SemiBold"
                                 Foreground="White"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Row="1"
                                 Text="{Binding Requirement}"
                                 FontSize="10"
                                 Opacity="0.7"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 Margin="0,4,0,0" />
                      <TextBlock Grid.Row="2"
                                 Text="{loc:Str achievement_status_unlocked}"
                                 FontSize="11"
                                 Foreground="#FF69B4"
                                 TextAlignment="Center"
                                 IsVisible="{Binding IsUnlocked}" />
                      <TextBlock Grid.Row="2"
                                 Text="{loc:Str achievement_status_locked}"
                                 FontSize="11"
                                 Foreground="#8888AA"
                                 TextAlignment="Center"
                                 IsVisible="{Binding !IsUnlocked}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <Border Background="#1A1A2E"
                  CornerRadius="10"
                  IsVisible="{Binding ShowPatronOverlay}"
                  Opacity="0.9"
                  Padding="20">
            <TextBlock Text="{loc:Str msg_patron_achievements_locked}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#FF69B4"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
          </Border>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

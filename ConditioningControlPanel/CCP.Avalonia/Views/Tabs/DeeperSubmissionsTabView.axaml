<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.Tabs.DeeperSubmissionsTabView"
             x:DataType="vm:DeeperSubmissionsTabViewModel"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia">

  <Design.DataContext>
    <vm:DeeperSubmissionsTabViewModel />
  </Design.DataContext>

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{loc:Str tab_deeper_submissions_deeper_submissions_text}"
                 FontSize="20"
                 FontWeight="Bold"
                 Foreground="White" />

      <TextBlock Text="{loc:Str tab_deeper_submissions_deeper_submissions_track_enhancements_have_submitted_text}"
                 Opacity="0.8"
                 TextWrapping="Wrap" />

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{loc:Str tab_deeper_submissions_refresh_content}"
                Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsBusy}" />
        <Button Content="{loc:Str tab_deeper_submissions_check_statuses_content}"
                Command="{Binding CheckStatusesCommand}"
                IsEnabled="{Binding !IsBusy}" />
      </StackPanel>

      <TextBlock Text="{Binding LastCheckedText}"
                 Opacity="0.7" />

      <Border Background="#1A1A2E"
              BorderBrush="#FF69B4"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12">
        <Grid>
          <ListBox ItemsSource="{Binding Submissions}"
                   x:Name="SubmissionsList"
                   Background="Transparent"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:DeeperSubmissionRowViewModel">
                <Border Background="#252540"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,4">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding FilePath}"
                                 TextWrapping="Wrap"
                                 FontWeight="SemiBold"
                                 Foreground="White" />
                      <TextBlock Text="{Binding CatalogueId}"
                                 Opacity="0.7"
                                 TextWrapping="Wrap" />
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding StatusGlyph}" />
                        <TextBlock Text="{Binding StatusLabel}"
                                   Foreground="#FF69B4" />
                      </StackPanel>
                      <TextBlock Text="{Binding SubmittedUtc, Converter={StaticResource DateTimeToStringConverter}}"
                                 FontSize="11"
                                 Opacity="0.6" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{loc:Str tab_deeper_submissions_record_content}"
                            MinWidth="72"
                            Command="{Binding $parent[ListBox].((vm:DeeperSubmissionsTabViewModel)DataContext).RecordSubmissionCommand}"
                            CommandParameter="{Binding FilePath}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="8"
                      IsVisible="{Binding Submissions.Count, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
            <TextBlock Text="📤"
                       FontSize="32"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{loc:Str tab_deeper_submissions_no_submissions_yet_submit_enhancement_from_text}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       Opacity="0.7" />
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>

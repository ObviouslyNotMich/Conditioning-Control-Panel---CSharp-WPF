<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        xmlns:local="using:ConditioningControlPanel.Avalonia.Views.Deeper"
        x:Class="ConditioningControlPanel.Avalonia.Views.Deeper.EnhancementPlayerWindow"
        Title="Deeper Player"
        Height="768"
        Width="900"
        MinHeight="504"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        DragDrop.AllowDrop="True">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Deeper accent palette (local fallback if global theme differs) -->
      <SolidColorBrush x:Key="DeeperAccentBrush" Color="#FF7B5CFF" />
      <SolidColorBrush x:Key="DeeperAccentSoftBrush" Color="#FFB8A8FF" />
      <SolidColorBrush x:Key="DeeperAccentTransparent20Brush" Color="#337B5CFF" />
      <SolidColorBrush x:Key="DeeperAccentTransparent40Brush" Color="#667B5CFF" />
      <SolidColorBrush x:Key="DeeperLaneCanvasBrush" Color="#FF151528" />
      <SolidColorBrush x:Key="DeeperLaneHeaderBrush" Color="#FF202038" />
      <SolidColorBrush x:Key="DeeperHubAudioBadgeBgBrush" Color="#FF3A3A5C" />
      <SolidColorBrush x:Key="DeeperHubVideoBadgeBgBrush" Color="#FF4A3050" />
      <SolidColorBrush x:Key="DeeperPlayerOverlayBgBrush" Color="#CC000000" />
      <SolidColorBrush x:Key="TextDimBrush" Color="#FF8080A0" />
      <SolidColorBrush x:Key="TextLightBrush" Color="#FFD0D0E0" />
      <SolidColorBrush x:Key="DangerBrush" Color="#FFFF4757" />

      <ControlTheme x:Key="DeeperRoundButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="CornerRadius" Value="6" />
      </ControlTheme>

      <ControlTheme x:Key="EventFilterPill" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DeeperAccentTransparent40Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="10" />
        <Style Selector="^:checked">
          <Setter Property="Background" Value="{DynamicResource DeeperAccentTransparent20Brush}" />
          <Setter Property="Foreground" Value="{DynamicResource DeeperAccentBrush}" />
          <Setter Property="BorderBrush" Value="{DynamicResource DeeperAccentBrush}" />
        </Style>
      </ControlTheme>

      <ControlTheme x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource DeeperAccentBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,4" />
      </ControlTheme>

      <ControlTheme x:Key="DimText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11" />
      </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="18,14"
        RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">

    <!-- Row 0: header strip -->
    <DockPanel Grid.Row="0"
               LastChildFill="False"
               Margin="0,0,0,10">
      <TextBlock DockPanel.Dock="Left"
                 Text="🌊"
                 FontSize="24"
                 VerticalAlignment="Center"
                 Margin="0,0,8,0" />
      <TextBlock DockPanel.Dock="Left"
                 Text="{Binding [deeper_player_title], Source={x:Static loc:LocalizationManager.Instance}}"
                 Theme="{StaticResource HeaderText}"
                 Margin="0,0,12,0"
                 VerticalAlignment="Center"
                 FontSize="18" />
      <Border DockPanel.Dock="Left"
              x:Name="StatusPill"
              CornerRadius="9"
              Padding="9,2"
              BorderThickness="1"
              VerticalAlignment="Center"
              Background="{DynamicResource DeeperAccentTransparent20Brush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}">
        <TextBlock x:Name="StatusPillText"
                   Text="{Binding [deeper_player_pill_empty], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="10"
                   FontWeight="SemiBold" />
      </Border>
      <Button DockPanel.Dock="Right"
              x:Name="BtnOpenInEditor"
              Content="{Binding [deeper_player_open_in_editor], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnOpenInEditor_Click"
              ToolTip.Tip="{Binding [deeper_player_tip_open_in_editor], Source={x:Static loc:LocalizationManager.Instance}}"
              Padding="12,4"
              FontSize="11"
              Background="{DynamicResource DeeperAccentTransparent20Brush}"
              Foreground="{DynamicResource DeeperAccentBrush}"
              BorderBrush="{DynamicResource DeeperAccentBrush}"
              BorderThickness="1"
              IsVisible="False" />
    </DockPanel>

    <!-- Row 1: file context strip -->
    <Border Grid.Row="1"
            Margin="0,0,0,10"
            Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10,8">
      <Grid ColumnDefinitions="Auto,*,Auto">

        <Border Grid.Column="0"
                x:Name="MediaTypeIconBg"
                Width="36"
                Height="36"
                CornerRadius="6"
                Background="{DynamicResource DeeperHubAudioBadgeBgBrush}"
                Margin="0,0,10,0">
          <TextBlock x:Name="MediaTypeIcon"
                     Text="🎵"
                     FontSize="20"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center">
          <TextBlock x:Name="TxtEnhName"
                     Text="{Binding [deeper_player_no_enh], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     FontWeight="Medium"
                     TextTrimming="CharacterEllipsis" />
          <DockPanel LastChildFill="True"
                     Margin="0,2,0,0">
            <TextBlock x:Name="TxtEnhPath"
                       DockPanel.Dock="Bottom"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="9"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="False" />
            <TextBlock x:Name="TxtEnhMetadata"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis" />
          </DockPanel>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <StackPanel x:Name="BrowserZoomCluster"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"
                      IsVisible="{Binding #VideoPane.IsVisible}">
            <TextBlock Text="🔍"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <Button x:Name="BtnZoomOut"
                    Content="−"
                    Click="BtnZoomOut_Click"
                    ToolTip.Tip="{Binding [deeper_zoom_out_tt], Source={x:Static loc:LocalizationManager.Instance}}"
                    Width="22"
                    Height="22"
                    Padding="0"
                    FontSize="13"
                    FontWeight="Bold"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                    BorderThickness="1" />
            <Button x:Name="BtnZoomIn"
                    Content="+"
                    Click="BtnZoomIn_Click"
                    ToolTip.Tip="{Binding [deeper_zoom_in_tt], Source={x:Static loc:LocalizationManager.Instance}}"
                    Width="22"
                    Height="22"
                    Padding="0"
                    FontSize="13"
                    FontWeight="Bold"
                    Margin="3,0,0,0"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                    BorderThickness="1" />
          </StackPanel>

          <Border x:Name="SourcePill"
                  CornerRadius="9"
                  Padding="8,2"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center"
                  BorderThickness="1"
                  Background="{DynamicResource DeeperAccentTransparent20Brush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  IsVisible="False">
            <TextBlock x:Name="TxtEnhSource"
                       Foreground="{DynamicResource DeeperAccentSoftBrush}"
                       FontSize="10"
                       FontWeight="SemiBold" />
          </Border>

          <Button x:Name="BtnChange"
                  Content="{Binding [deeper_player_change], Source={x:Static loc:LocalizationManager.Instance}}"
                  Click="BtnChange_Click"
                  ToolTip.Tip="{Binding [deeper_player_tip_change], Source={x:Static loc:LocalizationManager.Instance}}"
                  Padding="10,4"
                  FontSize="11"
                  Background="{DynamicResource DeeperAccentTransparent20Brush}"
                  Foreground="{DynamicResource DeeperAccentBrush}"
                  BorderBrush="{DynamicResource DeeperAccentBrush}"
                  BorderThickness="1" />

          <Popup x:Name="ChangePopup"
                 PlacementTarget="{Binding #BtnChange}"
                 Placement="Bottom">
            <Border Background="{DynamicResource PanelBgBrush}"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="6"
                    MinWidth="220">
              <StackPanel>
                <Grid x:Name="AudioFileRow"
                      Margin="2,2,2,4"
                      ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             x:Name="TxtAudioPath"
                             Text="{Binding [deeper_player_no_media], Source={x:Static loc:LocalizationManager.Instance}}"
                             Foreground="{DynamicResource TextMutedBrush}"
                             VerticalAlignment="Center"
                             FontSize="10"
                             TextTrimming="CharacterEllipsis"
                             Margin="6,0,6,0" />
                  <Button Grid.Column="1"
                          x:Name="BtnPickAudio"
                          Content="{Binding [deeper_player_pick_media], Source={x:Static loc:LocalizationManager.Instance}}"
                          Click="BtnPickAudio_Click"
                          ToolTip.Tip="{Binding [deeper_player_tip_pick_media], Source={x:Static loc:LocalizationManager.Instance}}"
                          Padding="8,3"
                          FontSize="10"
                          Background="{DynamicResource DeeperAccentTransparent20Brush}"
                          Foreground="{DynamicResource DeeperAccentBrush}"
                          BorderBrush="{DynamicResource DeeperAccentBrush}"
                          BorderThickness="1" />
                </Grid>

                <Button x:Name="BtnPickEnhancement"
                        Click="BtnPickEnhancement_Click"
                        ToolTip.Tip="{Binding [deeper_player_tip_pick_enh], Source={x:Static loc:LocalizationManager.Instance}}"
                        HorizontalContentAlignment="Left"
                        Padding="10,6"
                        Margin="0,2,0,0"
                        FontSize="11"
                        Background="Transparent"
                        Foreground="{DynamicResource TextLightBrush}"
                        BorderThickness="0">
                  <TextBlock>
                    <Run Text="📄 " />
                    <Run Text="{Binding [deeper_player_pick_enh], Source={x:Static loc:LocalizationManager.Instance}}" />
                  </TextBlock>
                </Button>
                <Button x:Name="BtnLoadUrl"
                        Click="BtnLoadUrl_Click"
                        ToolTip.Tip="{Binding [deeper_player_tip_load_url], Source={x:Static loc:LocalizationManager.Instance}}"
                        HorizontalContentAlignment="Left"
                        Padding="10,6"
                        Margin="0,2,0,0"
                        FontSize="11"
                        Background="Transparent"
                        Foreground="{DynamicResource TextLightBrush}"
                        BorderThickness="0">
                  <TextBlock>
                    <Run Text="🌐 " />
                    <Run Text="{Binding [deeper_player_load_url], Source={x:Static loc:LocalizationManager.Instance}}" />
                  </TextBlock>
                </Button>
                <Button x:Name="BtnCreateNewEnhancement"
                        Click="BtnCreateNewEnhancement_Click"
                        ToolTip.Tip="{Binding [deeper_player_tip_create_new], Source={x:Static loc:LocalizationManager.Instance}}"
                        HorizontalContentAlignment="Left"
                        Padding="10,6"
                        Margin="0,2,0,0"
                        FontSize="11"
                        Background="Transparent"
                        Foreground="{DynamicResource TextLightBrush}"
                        BorderThickness="0"
                        IsVisible="False">
                  <TextBlock>
                    <Run Text="✨ " />
                    <Run Text="{Binding [deeper_player_create_new_btn], Source={x:Static loc:LocalizationManager.Instance}}" />
                  </TextBlock>
                </Button>
                <Button x:Name="BtnUnloadEnhancement"
                        Click="BtnUnloadEnhancement_Click"
                        ToolTip.Tip="{Binding [deeper_player_tip_unload], Source={x:Static loc:LocalizationManager.Instance}}"
                        HorizontalContentAlignment="Left"
                        Padding="10,6"
                        Margin="0,2,0,0"
                        FontSize="11"
                        Background="Transparent"
                        Foreground="{DynamicResource TextMutedBrush}"
                        BorderThickness="0"
                        IsVisible="False">
                  <TextBlock>
                    <Run Text="✕ " />
                    <Run Text="{Binding [deeper_player_unload], Source={x:Static loc:LocalizationManager.Instance}}" />
                  </TextBlock>
                </Button>
              </StackPanel>
            </Border>
          </Popup>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 2: media pane -->
    <Grid Grid.Row="2"
          Margin="0,0,0,10">
      <Border x:Name="AudioPane"
              Background="{DynamicResource DeeperLaneCanvasBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
              BorderThickness="1"
              CornerRadius="4"
              Height="80"
              VerticalAlignment="Top">
        <Canvas x:Name="WaveformCanvas"
                ClipToBounds="True"
                PointerPressed="WaveformCanvas_PointerPressed">
          <Path x:Name="WaveformPath"
                Stroke="{DynamicResource DeeperAccentBrush}"
                StrokeThickness="1.2"
                StrokeLineCap="Round" />
          <Line x:Name="PlayheadLine"
                StartPoint="0,0"
                EndPoint="0,0"
                Stroke="White"
                StrokeThickness="1.5"
                IsHitTestVisible="False" />
        </Canvas>
      </Border>

      <Border x:Name="VideoPane"
              Background="Black"
              BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
              BorderThickness="1"
              CornerRadius="4"
              IsVisible="False">
        <Grid>
          <vlc:VideoView x:Name="VideoView" />
          <TextBlock x:Name="TxtVideoStatus"
                     Text="{Binding [deeper_player_video_loading], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="11"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     IsHitTestVisible="False" />
        </Grid>
      </Border>

      <Border x:Name="NowRegionPanel"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,8,10,0"
              Padding="8,3"
              CornerRadius="6"
              Background="{DynamicResource DeeperPlayerOverlayBgBrush}"
              IsVisible="False"
              IsHitTestVisible="False"
              ZIndex="20">
        <StackPanel Orientation="Horizontal">
          <Rectangle x:Name="NowRegionSwatch"
                     Width="8"
                     Height="8"
                     RadiusX="2"
                     RadiusY="2"
                     Margin="0,0,6,0"
                     VerticalAlignment="Center"
                     Fill="{DynamicResource DeeperAccentBrush}" />
          <TextBlock x:Name="TxtNowRegion"
                     Text=""
                     Foreground="White"
                     FontSize="10"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Row 3: mini-timeline -->
    <StackPanel Grid.Row="3"
                x:Name="MiniTimelinePanel"
                Margin="0,0,0,10"
                IsVisible="False">
      <DockPanel LastChildFill="False"
                 Margin="0,0,0,3">
        <TextBlock DockPanel.Dock="Left"
                   Text="{Binding [deeper_player_minitimeline_label], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource DeeperAccentSoftBrush}"
                   FontSize="10"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBlock DockPanel.Dock="Right"
                   x:Name="TxtMiniTimelineReadout"
                   Text="0:00 / 0:00"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="10"
                   FontFamily="Consolas"
                   VerticalAlignment="Center" />
      </DockPanel>
      <Border x:Name="MiniTimelineHost"
              Background="{DynamicResource DeeperLaneCanvasBrush}"
              BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
              BorderThickness="1"
              CornerRadius="4"
              Height="32"
              Cursor="Hand"
              ToolTip.Tip="{Binding [deeper_player_tip_minitimeline], Source={x:Static loc:LocalizationManager.Instance}}">
        <Canvas x:Name="MiniTimelineCanvas"
                ClipToBounds="True"
                Background="Transparent"
                SizeChanged="MiniTimelineCanvas_SizeChanged"
                PointerPressed="MiniTimelineCanvas_PointerPressed"
                PointerMoved="MiniTimelineCanvas_PointerMoved"
                PointerReleased="MiniTimelineCanvas_PointerReleased"
                PointerCaptureLost="MiniTimelineCanvas_PointerCaptureLost" />
      </Border>
    </StackPanel>

    <!-- Row 4: transport -->
    <DockPanel Grid.Row="4"
               LastChildFill="False"
               Margin="0,0,0,10">
      <Button x:Name="BtnPlayPause"
              DockPanel.Dock="Left"
              Content="▶"
              Click="BtnPlayPause_Click"
              ToolTip.Tip="{Binding [deeper_player_tip_play_pause], Source={x:Static loc:LocalizationManager.Instance}}"
              Width="38"
              Height="32"
              Padding="0"
              Background="{DynamicResource DeeperAccentBrush}"
              Foreground="White"
              BorderThickness="0"
              FontSize="15" />
      <Button DockPanel.Dock="Left"
              Content="⏹"
              Click="BtnStop_Click"
              ToolTip.Tip="{Binding [deeper_player_tip_stop], Source={x:Static loc:LocalizationManager.Instance}}"
              Width="32"
              Height="32"
              Padding="0"
              Margin="6,0,0,0"
              Background="{DynamicResource DeeperAccentTransparent20Brush}"
              Foreground="{DynamicResource DeeperAccentBrush}"
              BorderBrush="{DynamicResource DeeperAccentBrush}"
              BorderThickness="1"
              FontSize="13" />
      <TextBlock x:Name="TxtCurrent"
                 DockPanel.Dock="Left"
                 Text="0:00"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="12"
                 FontFamily="Consolas"
                 VerticalAlignment="Center"
                 Margin="14,0,4,0" />
      <TextBlock DockPanel.Dock="Left"
                 Text="/"
                 Foreground="{DynamicResource TextDimBrush}"
                 FontSize="12"
                 VerticalAlignment="Center" />
      <TextBlock x:Name="TxtTotal"
                 DockPanel.Dock="Left"
                 Text="0:00"
                 Foreground="{DynamicResource TextMutedBrush}"
                 FontSize="12"
                 FontFamily="Consolas"
                 VerticalAlignment="Center"
                 Margin="4,0,0,0" />

      <StackPanel x:Name="VolumePanel"
                  DockPanel.Dock="Right"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="12,0,0,0">
        <TextBlock Text="🔊"
                   FontSize="14"
                   VerticalAlignment="Center"
                   Margin="0,0,4,0" />
        <Slider x:Name="SliderVolume"
                Width="90"
                Minimum="0"
                Maximum="100"
                Value="80"
                VerticalAlignment="Center"
                ToolTip.Tip="{Binding [deeper_player_tip_volume], Source={x:Static loc:LocalizationManager.Instance}}"
                ValueChanged="SliderVolume_ValueChanged" />
      </StackPanel>

      <Button x:Name="BtnEyeTracking"
              DockPanel.Dock="Right"
              Content="{Binding [deeper_player_btn_eye_tracking_start], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnEyeTracking_Click"
              ToolTip.Tip="{Binding [deeper_player_tt_eye_tracking], Source={x:Static loc:LocalizationManager.Instance}}"
              Padding="12,0"
              Height="32"
              Margin="8,0,0,0"
              FontSize="11"
              Background="{DynamicResource DeeperAccentTransparent20Brush}"
              Foreground="{DynamicResource DeeperAccentBrush}"
              BorderBrush="{DynamicResource DeeperAccentBrush}"
              BorderThickness="1" />
      <Button x:Name="BtnPictureInPicture"
              DockPanel.Dock="Right"
              Content="{Binding [deeper_player_btn_pip], Source={x:Static loc:LocalizationManager.Instance}}"
              Click="BtnPictureInPicture_Click"
              ToolTip.Tip="{Binding [deeper_player_tt_pip], Source={x:Static loc:LocalizationManager.Instance}}"
              Padding="12,0"
              Height="32"
              Margin="8,0,0,0"
              FontSize="11"
              Background="{DynamicResource DeeperAccentTransparent20Brush}"
              Foreground="{DynamicResource DeeperAccentBrush}"
              BorderBrush="{DynamicResource DeeperAccentBrush}"
              BorderThickness="1"
              IsVisible="False" />
    </DockPanel>

    <!-- Row 5: structured event log -->
    <Border Grid.Row="5"
            Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
      <StackPanel>
        <Border Background="{DynamicResource DeeperLaneHeaderBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                Padding="12,6">
          <TextBlock x:Name="TxtStatus"
                     Text="{Binding [deeper_player_status_idle], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="10"
                     TextWrapping="Wrap" />
        </Border>

        <DockPanel LastChildFill="False"
                   Margin="10,6,10,4">
          <TextBlock DockPanel.Dock="Left"
                     Text="📋"
                     FontSize="13"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0" />
          <TextBlock DockPanel.Dock="Left"
                     Text="{Binding [deeper_player_event_log], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource DeeperAccentBrush}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0" />
          <ToggleButton DockPanel.Dock="Left"
                        x:Name="PillFilterAll"
                        Theme="{StaticResource EventFilterPill}"
                        IsChecked="True"
                        Margin="0,0,4,0"
                        Tag="all"
                        ToolTip.Tip="{Binding [deeper_player_tip_pill_all], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="EventFilterPill_Click">
            <TextBlock>
              <Run Text="{Binding [deeper_player_pill_all], Source={x:Static loc:LocalizationManager.Instance}}" />
              <Run Text=" " />
              <Run x:Name="TxtFilterCountAll" Text="0" />
            </TextBlock>
          </ToggleButton>
          <ToggleButton DockPanel.Dock="Left"
                        x:Name="PillFilterActions"
                        Theme="{StaticResource EventFilterPill}"
                        Margin="0,0,4,0"
                        Tag="action"
                        ToolTip.Tip="{Binding [deeper_player_tip_pill_actions], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="EventFilterPill_Click">
            <TextBlock>
              <Run Text="{Binding [deeper_player_pill_actions], Source={x:Static loc:LocalizationManager.Instance}}" />
              <Run Text=" " />
              <Run x:Name="TxtFilterCountActions" Text="0" />
            </TextBlock>
          </ToggleButton>
          <ToggleButton DockPanel.Dock="Left"
                        x:Name="PillFilterEngine"
                        Theme="{StaticResource EventFilterPill}"
                        Margin="0,0,4,0"
                        Tag="engine"
                        ToolTip.Tip="{Binding [deeper_player_tip_pill_engine], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="EventFilterPill_Click">
            <TextBlock>
              <Run Text="{Binding [deeper_player_pill_engine], Source={x:Static loc:LocalizationManager.Instance}}" />
              <Run Text=" " />
              <Run x:Name="TxtFilterCountEngine" Text="0" />
            </TextBlock>
          </ToggleButton>
          <ToggleButton DockPanel.Dock="Left"
                        x:Name="PillFilterErrors"
                        Theme="{StaticResource EventFilterPill}"
                        Margin="0,0,4,0"
                        Tag="error"
                        ToolTip.Tip="{Binding [deeper_player_tip_pill_errors], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="EventFilterPill_Click">
            <TextBlock>
              <Run Text="{Binding [deeper_player_pill_errors], Source={x:Static loc:LocalizationManager.Instance}}" />
              <Run Text=" " />
              <Run x:Name="TxtFilterCountErrors" Text="0" />
            </TextBlock>
          </ToggleButton>
          <Button DockPanel.Dock="Right"
                  x:Name="BtnCollapseEventLog"
                  Content="▾"
                  Click="BtnCollapseEventLog_Click"
                  ToolTip.Tip="{Binding [deeper_player_tip_collapse], Source={x:Static loc:LocalizationManager.Instance}}"
                  Width="22"
                  Height="20"
                  Padding="0"
                  FontSize="11"
                  Background="Transparent"
                  Foreground="{DynamicResource TextMutedBrush}"
                  BorderThickness="0" />
          <Button DockPanel.Dock="Right"
                  x:Name="BtnClearEvents"
                  Content="🗑"
                  Click="BtnClearEvents_Click"
                  ToolTip.Tip="{Binding [deeper_player_tip_clear], Source={x:Static loc:LocalizationManager.Instance}}"
                  Width="22"
                  Height="20"
                  Padding="0"
                  FontSize="10"
                  Margin="0,0,4,0"
                  Background="Transparent"
                  Foreground="{DynamicResource TextMutedBrush}"
                  BorderThickness="0" />
        </DockPanel>

        <ScrollViewer x:Name="EventScroll"
                      MaxHeight="140"
                      VerticalScrollBarVisibility="Auto"
                      Padding="10,2,10,8">
          <ItemsControl x:Name="LstEvents">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="local:EnhancementPlayerWindow+EventLogEntry">
                <Border Margin="0,1,0,1"
                        Padding="6,3"
                        CornerRadius="3"
                        Background="{Binding RowBgBrush}">
                  <Grid ColumnDefinitions="50,18,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding TimestampDisplay}"
                               Foreground="{DynamicResource TextDimBrush}"
                               FontFamily="Consolas"
                               FontSize="9"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding IconGlyph}"
                               Foreground="{Binding IconBrush}"
                               FontSize="10"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               FontFamily="Consolas"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0">
                      <Run Text="{Binding RuleLabel}"
                           Foreground="{Binding RuleLabelBrush}"
                           FontWeight="SemiBold" />
                      <Run Text="{Binding Description}"
                           Foreground="{DynamicResource TextLightBrush}" />
                    </TextBlock>
                    <Button Grid.Column="3"
                            Content="{Binding [deeper_player_event_open_in_editor], Source={x:Static loc:LocalizationManager.Instance}}"
                            Tag="{Binding RuleId}"
                            Click="EventOpenInEditor_Click"
                            ToolTip.Tip="{Binding [deeper_player_tip_event_open], Source={x:Static loc:LocalizationManager.Instance}}"
                            IsVisible="{Binding OpenInEditorVisible}"
                            Padding="6,1"
                            FontSize="9"
                            Background="Transparent"
                            Foreground="{DynamicResource DeeperAccentSoftBrush}"
                            BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                            BorderThickness="1" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>
    </Border>
  </Grid>
</Window>

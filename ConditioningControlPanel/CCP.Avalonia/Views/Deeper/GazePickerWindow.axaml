<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Views.Deeper.GazePickerWindow"
        Title=""
        Width="640"
        Height="480"
        MinWidth="200"
        MinHeight="150"
        WindowDecorations="None"
        ShowInTaskbar="False"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="Manual">

  <Window.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="DeeperAccentBrush" Color="#FF7B5CFF" />
      <SolidColorBrush x:Key="DeeperAccentSoftBrush" Color="#FFB8A8FF" />
      <SolidColorBrush x:Key="DeeperAccentTransparent40Brush" Color="#667B5CFF" />
      <SolidColorBrush x:Key="DeeperGazePickerBackdropBrush" Color="#AA000000" />
      <SolidColorBrush x:Key="DeeperGazePickerHandleFillBrush" Color="#FF2A2A3E" />
      <SolidColorBrush x:Key="DeeperGazePickerToolbarBgBrush" Color="#CC1A1A2E" />
      <SolidColorBrush x:Key="DeeperGazePickerCancelBorderBrush" Color="#66FFFFFF" />
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <!-- Live video preview behind the dim backdrop; source is set in code-behind. -->
    <vlc:VideoView x:Name="VideoView" IsVisible="False" />

    <Border Background="{DynamicResource DeeperGazePickerBackdropBrush}" />

    <Canvas x:Name="PickCanvas"
            Background="Transparent"
            PointerPressed="PickCanvas_PointerPressed"
            PointerMoved="PickCanvas_PointerMoved"
            PointerReleased="PickCanvas_PointerReleased"
            SizeChanged="PickCanvas_SizeChanged">

      <Rectangle x:Name="RectShape"
                 Stroke="{DynamicResource DeeperAccentBrush}"
                 StrokeThickness="2"
                 Fill="{DynamicResource DeeperAccentTransparent40Brush}"
                 IsVisible="False" />

      <Rectangle x:Name="HandleNW" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="NW" />
      <Rectangle x:Name="HandleN" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="N" />
      <Rectangle x:Name="HandleNE" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="NE" />
      <Rectangle x:Name="HandleE" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="E" />
      <Rectangle x:Name="HandleSE" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="SE" />
      <Rectangle x:Name="HandleS" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="S" />
      <Rectangle x:Name="HandleSW" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="SW" />
      <Rectangle x:Name="HandleW" Width="12" Height="12"
                 Fill="{DynamicResource DeeperGazePickerHandleFillBrush}"
                 Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="1.5"
                 PointerPressed="Handle_PointerPressed"
                 Tag="W" />
    </Canvas>

    <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,12,0,0"
            Background="{DynamicResource DeeperGazePickerToolbarBgBrush}" Padding="14,8" CornerRadius="6"
            BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock x:Name="TxtHint"
                   Foreground="White" FontSize="12"
                   VerticalAlignment="Center" />
        <TextBlock x:Name="TxtCoords"
                   Foreground="{DynamicResource DeeperAccentSoftBrush}" FontSize="11"
                   VerticalAlignment="Center" />
        <Button Content="{Binding [deeper_editor_gaze_pick_done], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnDone_Click"
                Padding="14,6" FontSize="11" FontWeight="SemiBold"
                Background="{DynamicResource DeeperAccentBrush}" Foreground="White" BorderThickness="0" />
        <Button Content="{Binding [deeper_editor_gaze_pick_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnCancel_Click"
                Padding="14,6" FontSize="11"
                Background="Transparent" Foreground="White"
                BorderBrush="{DynamicResource DeeperGazePickerCancelBorderBrush}" BorderThickness="1" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

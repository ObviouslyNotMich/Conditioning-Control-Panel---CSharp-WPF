<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Views.Deeper.NewEnhancementDialog"
        Title="{Binding [deeper_dialog_new_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="410"
        Width="540"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        Background="{DynamicResource DarkerBgBrush}">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource DeeperAccentBrush}"
          BorderThickness="1">
    <Grid Margin="22"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto">

      <TextBlock Grid.Row="0"
                 Text="{Binding [deeper_dialog_new_title], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource DeeperAccentBrush}"
                 FontSize="18"
                 FontWeight="Bold"
                 Margin="0,0,0,4" />

      <TextBlock Grid.Row="1"
                 Text="{Binding [deeper_dialog_new_subtitle], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource TextMutedBrush}"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Margin="0,0,0,18" />

      <TextBlock Grid.Row="2"
                 Text="{Binding [deeper_dialog_media_type_label], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Margin="0,0,0,6" />

      <StackPanel Grid.Row="3"
                  Orientation="Horizontal"
                  Margin="0,0,0,16">
        <RadioButton x:Name="RbVideo"
                     IsChecked="True"
                     GroupName="MediaType"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     Padding="8,6"
                     Margin="0,0,16,0">
          <TextBlock>
            <Run Text="🎬 " />
            <Run Text="{Binding [deeper_editor_media_type_video], Source={x:Static loc:LocalizationManager.Instance}}" />
          </TextBlock>
        </RadioButton>
        <RadioButton x:Name="RbAudio"
                     GroupName="MediaType"
                     Foreground="{DynamicResource TextLightBrush}"
                     FontSize="13"
                     Padding="8,6">
          <TextBlock>
            <Run Text="🎵 " />
            <Run Text="{Binding [deeper_editor_media_type_audio], Source={x:Static loc:LocalizationManager.Instance}}" />
          </TextBlock>
        </RadioButton>
      </StackPanel>

      <TextBlock Grid.Row="4"
                 Text="{Binding [deeper_dialog_source_label], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Margin="0,0,0,6" />

      <Grid Grid.Row="5"
            ColumnDefinitions="*,Auto">
        <TextBox x:Name="TxtSource"
                 Grid.Column="0"
                 Background="{DynamicResource PanelBgBrush}"
                 Foreground="White"
                 BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                 Padding="10,8"
                 FontSize="13" />
        <Button x:Name="BtnBrowse"
                Grid.Column="1"
                Content="{Binding [btn_browse], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnBrowse_Click"
                Padding="14,8"
                Margin="8,0,0,0"
                Background="{DynamicResource DeeperAccentTransparent20Brush}"
                Foreground="{DynamicResource DeeperAccentSoftBrush}"
                BorderBrush="{DynamicResource DeeperAccentBrush}"
                BorderThickness="1"
                CornerRadius="6" />
      </Grid>

      <TextBlock Grid.Row="6"
                 Text="{Binding [deeper_dialog_source_hint], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource TextDimBrush}"
                 FontSize="11"
                 Margin="0,6,0,0"
                 TextWrapping="Wrap" />

      <StackPanel Grid.Row="7"
                  Orientation="Vertical"
                  Margin="0,12,0,0">
        <TextBlock Text="{Binding [deeper_tutorial_header], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource TextDimBrush}"
                   FontSize="11"
                   Margin="0,0,0,6" />
        <StackPanel Orientation="Horizontal">
          <Button x:Name="BtnLocalVideoTutorial"
                  Content="{Binding [deeper_tutorial_local_video_btn], Source={x:Static loc:LocalizationManager.Instance}}"
                  ToolTip.Tip="{Binding [deeper_tutorial_local_video_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Click="BtnLocalVideoTutorial_Click"
                  Padding="10,6"
                  Margin="0,0,8,0"
                  FontSize="11"
                  Background="Transparent"
                  Foreground="{DynamicResource DeeperAccentSoftBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6" />
          <Button x:Name="BtnLocalAudioTutorial"
                  Content="{Binding [deeper_tutorial_local_audio_btn], Source={x:Static loc:LocalizationManager.Instance}}"
                  ToolTip.Tip="{Binding [deeper_tutorial_local_audio_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Click="BtnLocalAudioTutorial_Click"
                  Padding="10,6"
                  Margin="0,0,8,0"
                  FontSize="11"
                  Background="Transparent"
                  Foreground="{DynamicResource DeeperAccentSoftBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6" />
          <Button x:Name="BtnTryHypnoTubeTutorial"
                  Content="{Binding [deeper_tutorial_ht_btn], Source={x:Static loc:LocalizationManager.Instance}}"
                  ToolTip.Tip="{Binding [deeper_tutorial_ht_tooltip], Source={x:Static loc:LocalizationManager.Instance}}"
                  Click="BtnTryHypnoTubeTutorial_Click"
                  Padding="10,6"
                  FontSize="11"
                  Background="{DynamicResource DeeperAccentTransparent20Brush}"
                  Foreground="{DynamicResource DeeperAccentSoftBrush}"
                  BorderBrush="{DynamicResource DeeperAccentBrush}"
                  BorderThickness="1"
                  CornerRadius="6" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="8"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,12,0,0">
        <Button Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}"
                Width="90"
                Padding="10,8"
                Margin="0,0,10,0"
                Click="BtnCancel_Click"
                Theme="{StaticResource SecondaryButton}" />
        <Button x:Name="BtnCreate"
                Content="{Binding [deeper_dialog_create], Source={x:Static loc:LocalizationManager.Instance}}"
                Width="120"
                Padding="10,8"
                Click="BtnCreate_Click"
                Theme="{StaticResource ActionButton}" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Views.Deeper.DeeperEditorWindow"
        Title="{Binding [deeper_empty_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="864"
        Width="1180"
        MinHeight="672"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkerBgBrush}"
        DragDrop.AllowDrop="True">

  <Grid>
    <TextBlock Text="{Binding [deeper_editor_avalonia_not_ported], Source={x:Static loc:LocalizationManager.Instance}}"
               Foreground="{DynamicResource TextMutedBrush}"
               FontSize="16"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               TextAlignment="Center"
               TextWrapping="Wrap"
               MaxWidth="600" />
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        xmlns:models="using:ConditioningControlPanel.Models.Deeper"
        x:Class="ConditioningControlPanel.Avalonia.Views.Deeper.DeeperEditorWindow"
        Title="{Binding [deeper_empty_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="864"
        Width="1180"
        MinHeight="672"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkerBgBrush}"
        DragDrop.AllowDrop="True">

  <Window.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="DeeperAccentBrush" Color="#FF7B5CFF" />
      <SolidColorBrush x:Key="DeeperAccentSoftBrush" Color="#FFB8A8FF" />
      <SolidColorBrush x:Key="DeeperAccentTransparent20Brush" Color="#337B5CFF" />
      <SolidColorBrush x:Key="DeeperAccentTransparent40Brush" Color="#667B5CFF" />
      <SolidColorBrush x:Key="TextDimBrush" Color="#FF8080A0" />
      <SolidColorBrush x:Key="TextLightBrush" Color="#FFD0D0E0" />
      <SolidColorBrush x:Key="PanelBgBrush" Color="#FF1A1A2E" />

      <ControlTheme x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource DeeperAccentBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,6" />
      </ControlTheme>

      <ControlTheme x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Margin" Value="0,10,0,3" />
      </ControlTheme>

      <ControlTheme x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource DeeperAccentTransparent20Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource DeeperAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DeeperAccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
      </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="14" RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,12">
      <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="🌊" FontSize="20" VerticalAlignment="Center" />
        <TextBlock x:Name="TxtWindowTitle"
                   Theme="{StaticResource SectionHeader}"
                   FontSize="16"
                   VerticalAlignment="Center" />
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
        <Button x:Name="BtnSave"
                Theme="{StaticResource ToolbarButton}"
                Content="{Binding [menu_file_save], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnSave_Click"
                ToolTip.Tip="{Binding [deeper_editor_tt_save], Source={x:Static loc:LocalizationManager.Instance}}" />
        <Button x:Name="BtnSaveAs"
                Theme="{StaticResource ToolbarButton}"
                Content="{Binding [menu_file_save_as], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnSaveAs_Click" />
        <Button x:Name="BtnPreview"
                Theme="{StaticResource ToolbarButton}"
                Content="{Binding [deeper_editor_preview_title], Source={x:Static loc:LocalizationManager.Instance}}"
                Click="BtnPreview_Click" />
      </StackPanel>
    </DockPanel>

    <!-- Tabs -->
    <TabControl Grid.Row="1" x:Name="EditorTabControl">

      <!-- Timeline -->
      <TabItem Header="{Binding [deeper_editor_tab_timeline], Source={x:Static loc:LocalizationManager.Instance}}">
        <Grid RowDefinitions="Auto,*">
          <!-- Transport / zoom toolbar -->
          <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
            <Button x:Name="BtnZoomOut"
                    DockPanel.Dock="Left"
                    Content="−"
                    Click="BtnZoomOut_Click"
                    Width="28" Height="26" Padding="0"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="6" />
            <TextBlock x:Name="TxtZoomLevel"
                       DockPanel.Dock="Left"
                       Text="100%"
                       Width="52"
                       TextAlignment="Center"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <Button x:Name="BtnZoomIn"
                    DockPanel.Dock="Left"
                    Content="+"
                    Click="BtnZoomIn_Click"
                    Width="28" Height="26" Padding="0"
                    Margin="2,0,12,0"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="6" />
            <TextBlock x:Name="TxtCurrentTime"
                       DockPanel.Dock="Left"
                       Text="0:00"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <TextBlock DockPanel.Dock="Left"
                       Text="/"
                       Foreground="{DynamicResource TextDimBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="TxtTotalTime"
                       DockPanel.Dock="Left"
                       Text="0:00"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="4,0,12,0" />
            <TextBlock Foreground="{DynamicResource TextDimBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Text="{Binding [deeper_editor_scrub_hint], Source={x:Static loc:LocalizationManager.Instance}}"
                       TextTrimming="CharacterEllipsis" />
          </DockPanel>

          <!-- Timeline area -->
          <Grid Grid.Row="1" ColumnDefinitions="96,*">
            <!-- Lane headers -->
            <Grid Grid.Column="0" Background="{DynamicResource PanelBgBrush}">
              <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Grid.Row="0"
                      Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="0,0,1,1"
                      Padding="6,2">
                <DockPanel LastChildFill="True">
                  <TextBlock DockPanel.Dock="Left" Text="▦" FontSize="11"
                             Foreground="{DynamicResource DeeperAccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0" />
                  <TextBlock x:Name="TxtRegionsLaneCount" DockPanel.Dock="Right"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontSize="10" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding [deeper_editor_lane_regions], Source={x:Static loc:LocalizationManager.Instance}}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="11" FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                </DockPanel>
              </Border>
              <Border Grid.Row="1"
                      Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="0,0,1,1"
                      Padding="6,2">
                <DockPanel LastChildFill="True">
                  <TextBlock DockPanel.Dock="Left" Text="✨" FontSize="11"
                             Foreground="{DynamicResource DeeperAccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0" />
                  <TextBlock x:Name="TxtEffectsLaneCount" DockPanel.Dock="Right"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontSize="10" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding [deeper_editor_lane_effects], Source={x:Static loc:LocalizationManager.Instance}}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="11" FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                </DockPanel>
              </Border>
              <Border Grid.Row="2"
                      Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="0,0,1,0"
                      Padding="6,2">
                <DockPanel LastChildFill="True">
                  <TextBlock DockPanel.Dock="Left" Text="📳" FontSize="11"
                             Foreground="{DynamicResource DeeperAccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,4,0" />
                  <TextBlock x:Name="TxtHapticsLaneCount" DockPanel.Dock="Right"
                             Foreground="{DynamicResource TextDimBrush}"
                             FontSize="10" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding [deeper_editor_lane_haptics], Source={x:Static loc:LocalizationManager.Instance}}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="11" FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                </DockPanel>
              </Border>
            </Grid>

            <!-- Scrollable canvas -->
            <ScrollViewer Grid.Column="1"
                          x:Name="TimelineScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
              <Canvas x:Name="TimelineCanvas"
                      Background="{DynamicResource DarkerBgBrush}"
                      Cursor="Hand"
                      PointerPressed="TimelineCanvas_PointerPressed"
                      PointerMoved="TimelineCanvas_PointerMoved"
                      PointerReleased="TimelineCanvas_PointerReleased"
                      PointerWheelChanged="TimelineCanvas_PointerWheelChanged">
                <Line x:Name="PlayheadLine"
                      StartPoint="0,0"
                      EndPoint="0,0"
                      Stroke="{DynamicResource DeeperAccentBrush}"
                      StrokeThickness="2"
                      ZIndex="100" />
              </Canvas>
            </ScrollViewer>
          </Grid>
        </Grid>
      </TabItem>

      <!-- Preview -->
      <TabItem Header="{Binding [deeper_editor_tab_preview], Source={x:Static loc:LocalizationManager.Instance}}">
        <Grid RowDefinitions="Auto,*,Auto" Margin="10">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <TextBlock x:Name="TxtPreviewSource"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
            <Button x:Name="BtnOpenBrowser"
                    Theme="{StaticResource ToolbarButton}"
                    Content="{Binding [deeper_editor_preview_open_browser], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="BtnOpenBrowser_Click" />
            <Button x:Name="BtnLoadWaveform"
                    Theme="{StaticResource ToolbarButton}"
                    Content="{Binding [deeper_editor_preview_load_waveform], Source={x:Static loc:LocalizationManager.Instance}}"
                    Click="BtnLoadWaveform_Click" />
          </StackPanel>

          <Border Grid.Row="1"
                  Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6">
            <Grid>
              <ContentControl x:Name="BrowserPreviewContainer"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
              <TextBlock x:Name="TxtBrowserPlaceholder"
                         Text="{Binding [deeper_editor_preview_placeholder], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="{DynamicResource TextDimBrush}"
                         FontSize="12"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap"
                         TextAlignment="Center"
                         Margin="20"
                         IsVisible="True" />
            </Grid>
          </Border>

          <Border Grid.Row="2"
                  Height="120"
                  Margin="0,10,0,0"
                  Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6">
            <Canvas x:Name="WaveformCanvas"
                    Background="Transparent"
                    SizeChanged="WaveformCanvas_SizeChanged" />
          </Border>
        </Grid>
      </TabItem>

      <!-- Metadata -->
      <TabItem Header="{Binding [deeper_editor_section_metadata], Source={x:Static loc:LocalizationManager.Instance}}">
        <ScrollViewer>
          <StackPanel Margin="10" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_label_name], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtMetaName" TextChanged="Metadata_TextChanged" Watermark="Untitled" />

            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" VerticalAlignment="Center" Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_label_creator], Source={x:Static loc:LocalizationManager.Instance}}" />
              <ToggleButton x:Name="BtnCreatorLockToggle"
                            Grid.Column="1"
                            Content="🔓"
                            Click="BtnCreatorLockToggle_Click"
                            Padding="6,2"
                            Margin="0,10,0,3"
                            Background="Transparent"
                            Foreground="{DynamicResource DeeperAccentSoftBrush}"
                            BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                            BorderThickness="1"
                            CornerRadius="6" />
            </Grid>
            <TextBox x:Name="TxtMetaCreator" TextChanged="Metadata_TextChanged" />

            <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_label_description], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtMetaDescription"
                     TextChanged="Metadata_TextChanged"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="120"
                     VerticalContentAlignment="Top" />

            <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_label_media_source], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBox x:Name="TxtMetaMediaSource" TextChanged="Metadata_TextChanged" LostFocus="TxtMetaMediaSource_LostFocus" />

            <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_label_media_type], Source={x:Static loc:LocalizationManager.Instance}}" />
            <ComboBox x:Name="CmbMediaType" SelectionChanged="CmbMediaType_SelectionChanged" Width="200" HorizontalAlignment="Left" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Regions -->
      <TabItem Header="{Binding [deeper_editor_lane_regions], Source={x:Static loc:LocalizationManager.Instance}}">
        <Grid ColumnDefinitions="260,*">
          <Border Grid.Column="0"
                  Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Margin="0,0,10,0">
            <Grid RowDefinitions="*,Auto">
              <ListBox x:Name="LstRegions"
                       Grid.Row="0"
                       SelectionChanged="LstRegions_SelectionChanged"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:Region">
                    <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                      <Run Text="{Binding Label}" FontWeight="SemiBold" />
                      <Run Text="  " />
                      <Run Text="{Binding Start}" Foreground="{DynamicResource TextDimBrush}" />
                      <Run Text="s → " Foreground="{DynamicResource TextDimBrush}" />
                      <Run Text="{Binding End}" Foreground="{DynamicResource TextDimBrush}" />
                      <Run Text="s" Foreground="{DynamicResource TextDimBrush}" />
                    </TextBlock>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="8">
                <Button x:Name="BtnAddRegion"
                        Content="+"
                        Click="BtnAddRegion_Click"
                        Width="32"
                        Height="28"
                        Padding="0"
                        Background="{DynamicResource DeeperAccentTransparent20Brush}"
                        Foreground="{DynamicResource DeeperAccentBrush}"
                        BorderBrush="{DynamicResource DeeperAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6" />
                <Button x:Name="BtnDeleteRegion"
                        Content="{Binding [deeper_editor_region_delete], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="BtnDeleteRegion_Click"
                        Padding="10,4"
                        Background="Transparent"
                        Foreground="{DynamicResource TextDimBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                        BorderThickness="1"
                        CornerRadius="6" />
              </StackPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Column="1">
            <StackPanel x:Name="RegionDetailPanel" Margin="10">
              <TextBlock Theme="{StaticResource SectionHeader}" Text="{Binding [deeper_editor_section_selected], Source={x:Static loc:LocalizationManager.Instance}}" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_region_label], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtRegionLabel" LostFocus="RegionField_LostFocus" TextChanged="RegionField_TextChanged" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_region_start], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtRegionStart" LostFocus="RegionField_LostFocus" TextChanged="RegionField_TextChanged" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_region_end], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtRegionEnd" LostFocus="RegionField_LostFocus" TextChanged="RegionField_TextChanged" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_region_color], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtRegionColor" LostFocus="RegionField_LostFocus" TextChanged="RegionField_TextChanged" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- Rules -->
      <TabItem Header="{Binding [deeper_editor_lane_rules], Source={x:Static loc:LocalizationManager.Instance}}">
        <Grid ColumnDefinitions="300,*">
          <Border Grid.Column="0"
                  Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Margin="0,0,10,0">
            <Grid RowDefinitions="*,Auto">
              <ListBox x:Name="LstRules"
                       Grid.Row="0"
                       SelectionChanged="LstRules_SelectionChanged"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:EnhancementRule">
                    <TextBlock TextWrapping="Wrap">
                      <Run Text="{Binding Trigger.Type}" Foreground="{DynamicResource DeeperAccentSoftBrush}" />
                      <Run Text=" → " Foreground="{DynamicResource TextDimBrush}" />
                      <Run Text="{Binding Action.Type}" />
                    </TextBlock>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="8">
                <Button x:Name="BtnAddRule"
                        Content="+"
                        Click="BtnAddRule_Click"
                        Width="32"
                        Height="28"
                        Padding="0"
                        Background="{DynamicResource DeeperAccentTransparent20Brush}"
                        Foreground="{DynamicResource DeeperAccentBrush}"
                        BorderBrush="{DynamicResource DeeperAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6" />
                <Button x:Name="BtnDeleteRule"
                        Content="{Binding [deeper_editor_rule_delete], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="BtnDeleteRule_Click"
                        Padding="10,4"
                        Background="Transparent"
                        Foreground="{DynamicResource TextDimBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                        BorderThickness="1"
                        CornerRadius="6" />
              </StackPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Column="1">
            <StackPanel x:Name="RuleDetailPanel" Margin="10">
              <TextBlock Theme="{StaticResource SectionHeader}" Text="{Binding [deeper_editor_section_selected], Source={x:Static loc:LocalizationManager.Instance}}" />

              <CheckBox x:Name="ChkRuleEnabled"
                        Content="{Binding [deeper_editor_rule_enabled], Source={x:Static loc:LocalizationManager.Instance}}"
                        IsCheckedChanged="ChkRuleEnabled_IsCheckedChanged" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_trigger], Source={x:Static loc:LocalizationManager.Instance}}" />
              <ComboBox x:Name="CmbTriggerType" SelectionChanged="CmbTriggerType_SelectionChanged" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_action], Source={x:Static loc:LocalizationManager.Instance}}" />
              <ComboBox x:Name="CmbActionType" SelectionChanged="CmbActionType_SelectionChanged" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_cooldown], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtCooldownMs" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_region_constraint], Source={x:Static loc:LocalizationManager.Instance}}" />
              <ComboBox x:Name="CmbRuleRegionConstraint" SelectionChanged="CmbRuleRegionConstraint_SelectionChanged" Width="240" HorizontalAlignment="Left" />

              <!-- Trigger parameters -->
              <Border Margin="0,14,0,0"
                      Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10">
                <StackPanel>
                  <TextBlock Theme="{StaticResource SectionHeader}" Text="Trigger parameters" />

                  <StackPanel x:Name="PanelTriggerTime">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_trigger_time], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtTriggerTime" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />
                  </StackPanel>

                  <StackPanel x:Name="PanelTriggerRegion">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_region_id], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <ComboBox x:Name="CmbTriggerRegion" SelectionChanged="RuleField_SelectionChanged" Width="240" HorizontalAlignment="Left" />
                  </StackPanel>

                  <StackPanel x:Name="PanelTriggerRect">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_trigger_rect], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBox x:Name="TxtTriggerRect" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="240" HorizontalAlignment="Left" />
                      <Button x:Name="BtnPickTriggerRect"
                              Content="👁"
                              Click="BtnPickTriggerRect_Click"
                              Padding="8,4"
                              Background="{DynamicResource DeeperAccentTransparent20Brush}"
                              Foreground="{DynamicResource DeeperAccentBrush}"
                              BorderBrush="{DynamicResource DeeperAccentBrush}"
                              BorderThickness="1"
                              CornerRadius="6" />
                    </StackPanel>
                  </StackPanel>

                  <StackPanel x:Name="PanelTriggerMinDwell">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_trigger_min_dwell], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtTriggerMinDwell" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />
                  </StackPanel>

                  <StackPanel x:Name="PanelTriggerMinDuration">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_trigger_min_duration], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtTriggerMinDuration" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />
                  </StackPanel>

                  <TextBlock x:Name="TxtTriggerNoParams"
                             Theme="{StaticResource FormLabel}"
                             Text="{Binding [deeper_editor_trigger_no_params], Source={x:Static loc:LocalizationManager.Instance}}"
                             IsVisible="False" />
                </StackPanel>
              </Border>

              <!-- Action parameters -->
              <Border Margin="0,14,0,0"
                      Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="10">
                <StackPanel>
                  <TextBlock Theme="{StaticResource SectionHeader}" Text="Action parameters" />

                  <!-- Seek -->
                  <StackPanel x:Name="PanelActionSeek">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_seek_target], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <ComboBox x:Name="CmbSeekTarget" SelectionChanged="RuleField_SelectionChanged" Width="200" HorizontalAlignment="Left" />
                    <StackPanel x:Name="PanelSeekTime">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_seek_time], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <TextBox x:Name="TxtSeekTime" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel x:Name="PanelSeekRegion">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_region_id], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <ComboBox x:Name="CmbSeekRegion" SelectionChanged="RuleField_SelectionChanged" Width="240" HorizontalAlignment="Left" />
                    </StackPanel>
                  </StackPanel>

                  <!-- Loop region -->
                  <StackPanel x:Name="PanelActionLoopRegion">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_rule_region_id], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <ComboBox x:Name="CmbLoopRegion" SelectionChanged="RuleField_SelectionChanged" Width="240" HorizontalAlignment="Left" />
                  </StackPanel>

                  <!-- Pause -->
                  <TextBlock x:Name="PanelActionPause"
                             Theme="{StaticResource FormLabel}"
                             Text="{Binding [deeper_editor_action_pause_info], Source={x:Static loc:LocalizationManager.Instance}}"
                             IsVisible="False" />

                  <!-- Play audio -->
                  <StackPanel x:Name="PanelActionPlayAudio">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_audio_path], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtAudioPath" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" />
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_volume], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtAudioVolume" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                    <CheckBox x:Name="ChkAudioDuck"
                              Content="{Binding [deeper_editor_action_duck], Source={x:Static loc:LocalizationManager.Instance}}"
                              IsCheckedChanged="ChkAudioDuck_IsCheckedChanged" />
                  </StackPanel>

                  <!-- Trigger haptic -->
                  <StackPanel x:Name="PanelActionTriggerHaptic">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_pattern], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <ComboBox x:Name="CmbActionHapticPattern" SelectionChanged="RuleField_SelectionChanged" Width="200" HorizontalAlignment="Left" />
                    <StackPanel x:Name="PanelActionHapticCustom">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="Custom keyframes (JSON [[t,i],...])" />
                      <TextBox x:Name="TxtActionHapticCustom" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" />
                    </StackPanel>
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_intensity], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtActionHapticIntensity" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_duration_ms], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtActionHapticDurationMs" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />
                  </StackPanel>

                  <!-- Trigger effect -->
                  <StackPanel x:Name="PanelActionTriggerEffect">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_effect_type], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <ComboBox x:Name="CmbEffectType" SelectionChanged="RuleField_SelectionChanged" Width="180" HorizontalAlignment="Left" />
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_value_0_1], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtEffectIntensity" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_duration_ms], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtEffectDurationMs" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />

                    <StackPanel x:Name="PanelEffectHaptic">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_pattern], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <ComboBox x:Name="CmbEffectHapticPattern" SelectionChanged="RuleField_SelectionChanged" Width="200" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel x:Name="PanelEffectFlash">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_audio_path], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <TextBox x:Name="TxtEffectImagePath" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" />
                      <CheckBox x:Name="ChkEffectPlaySound"
                                Content="{Binding [deeper_editor_action_play_sound], Source={x:Static loc:LocalizationManager.Instance}}"
                                IsCheckedChanged="ChkEffectPlaySound_IsCheckedChanged" />
                    </StackPanel>
                    <StackPanel x:Name="PanelEffectSubliminal">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_subliminal_text], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <TextBox x:Name="TxtEffectText" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" />
                    </StackPanel>
                    <StackPanel x:Name="PanelEffectOverlay">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_overlay_kind], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <ComboBox x:Name="CmbEffectOverlayKind" SelectionChanged="RuleField_SelectionChanged" Width="180" HorizontalAlignment="Left" />
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_opacity], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <TextBox x:Name="TxtEffectOpacity" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                    </StackPanel>
                    <StackPanel x:Name="PanelEffectBubble">
                      <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_max_bubbles], Source={x:Static loc:LocalizationManager.Instance}}" />
                      <TextBox x:Name="TxtEffectMaxBubbles" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                    </StackPanel>
                  </StackPanel>

                  <!-- Screen shake -->
                  <StackPanel x:Name="PanelActionScreenShake">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_intensity], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtScreenShakeIntensity" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_duration_ms], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtScreenShakeDurationMs" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="160" HorizontalAlignment="Left" />
                  </StackPanel>

                  <!-- Set intensity -->
                  <StackPanel x:Name="PanelActionSetIntensity">
                    <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_action_value_0_1], Source={x:Static loc:LocalizationManager.Instance}}" />
                    <TextBox x:Name="TxtSetIntensityValue" LostFocus="RuleField_LostFocus" TextChanged="RuleField_TextChanged" Width="120" HorizontalAlignment="Left" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- Haptics -->
      <TabItem Header="{Binding [deeper_editor_lane_haptics], Source={x:Static loc:LocalizationManager.Instance}}">
        <Grid ColumnDefinitions="260,*">
          <Border Grid.Column="0"
                  Background="{DynamicResource PanelBgBrush}"
                  BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Margin="0,0,10,0">
            <Grid RowDefinitions="*,Auto">
              <ListBox x:Name="LstHaptics"
                       Grid.Row="0"
                       SelectionChanged="LstHaptics_SelectionChanged"
                       Background="Transparent"
                       BorderThickness="0">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:HapticEvent">
                    <TextBlock TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                      <Run Text="{Binding Start}" />
                      <Run Text="s  " Foreground="{DynamicResource TextDimBrush}" />
                      <Run Text="{Binding PatternName}" Foreground="{DynamicResource DeeperAccentSoftBrush}" />
                    </TextBlock>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="8">
                <Button x:Name="BtnAddHaptic"
                        Content="+"
                        Click="BtnAddHaptic_Click"
                        Width="32"
                        Height="28"
                        Padding="0"
                        Background="{DynamicResource DeeperAccentTransparent20Brush}"
                        Foreground="{DynamicResource DeeperAccentBrush}"
                        BorderBrush="{DynamicResource DeeperAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="6" />
                <Button x:Name="BtnDeleteHaptic"
                        Content="{Binding [deeper_editor_haptic_delete], Source={x:Static loc:LocalizationManager.Instance}}"
                        Click="BtnDeleteHaptic_Click"
                        Padding="10,4"
                        Background="Transparent"
                        Foreground="{DynamicResource TextDimBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                        BorderThickness="1"
                        CornerRadius="6" />
              </StackPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Column="1">
            <StackPanel x:Name="HapticDetailPanel" Margin="10">
              <TextBlock Theme="{StaticResource SectionHeader}" Text="{Binding [deeper_editor_haptic_event], Source={x:Static loc:LocalizationManager.Instance}}" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_start], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtHapticStart" LostFocus="HapticField_LostFocus" TextChanged="HapticField_TextChanged" Width="160" HorizontalAlignment="Left" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_duration], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtHapticDuration" LostFocus="HapticField_LostFocus" TextChanged="HapticField_TextChanged" Width="160" HorizontalAlignment="Left" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_intensity], Source={x:Static loc:LocalizationManager.Instance}}" />
              <TextBox x:Name="TxtHapticIntensity" LostFocus="HapticField_LostFocus" TextChanged="HapticField_TextChanged" Width="120" HorizontalAlignment="Left" />

              <TextBlock Theme="{StaticResource FormLabel}" Text="{Binding [deeper_editor_haptic_pattern], Source={x:Static loc:LocalizationManager.Instance}}" />
              <ComboBox x:Name="CmbHapticPattern" SelectionChanged="CmbHapticPattern_SelectionChanged" Width="200" HorizontalAlignment="Left" />

              <StackPanel x:Name="PanelHapticCustom">
                <TextBlock Theme="{StaticResource FormLabel}" Text="Custom keyframes (JSON [[t,i],...])" />
                <TextBox x:Name="TxtHapticCustom" LostFocus="HapticField_LostFocus" TextChanged="HapticField_TextChanged" />

                <Border x:Name="CurveEditorPanel"
                        Margin="0,10,0,0"
                        Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Height="160"
                        IsVisible="False">
                  <Canvas x:Name="CurveEditorCanvas"
                          Background="Transparent"
                          PointerPressed="CurveEditorCanvas_PointerPressed"
                          PointerMoved="CurveEditorCanvas_PointerMoved"
                          PointerReleased="CurveEditorCanvas_PointerReleased"
                          SizeChanged="CurveEditorCanvas_SizeChanged" />
                </Border>
              </StackPanel>

              <Button x:Name="BtnHapticTest"
                      Content="{Binding [deeper_editor_haptic_test], Source={x:Static loc:LocalizationManager.Instance}}"
                      Click="BtnHapticTest_Click"
                      Margin="0,16,0,0"
                      Padding="12,5"
                      HorizontalAlignment="Left"
                      Background="{DynamicResource DeeperAccentTransparent20Brush}"
                      Foreground="{DynamicResource DeeperAccentBrush}"
                      BorderBrush="{DynamicResource DeeperAccentBrush}"
                      BorderThickness="1"
                      CornerRadius="6" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>
    </TabControl>

    <!-- Status -->
    <Border Grid.Row="2"
            Margin="0,10,0,0"
            Background="{DynamicResource PanelBgBrush}"
            BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10,6">
      <TextBlock x:Name="TxtValidationStatus"
                 Text=""
                 Foreground="{DynamicResource TextMutedBrush}"
                 FontSize="11" />
    </Border>
  </Grid>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels"
             xmlns:tabs="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
             x:Class="ConditioningControlPanel.Avalonia.Views.MainView"
             x:DataType="vm:MainWindowViewModel">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Views/TabContentDataTemplates.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,Auto,*">

    <!-- Mobile header -->
    <Grid Grid.Row="0"
          Background="{DynamicResource PanelBgBrush}"
          ColumnDefinitions="*,Auto">
      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="12,8">
        <TextBlock Text="💗"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="16"
                   Margin="0,0,8,0"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource TextLightBrush}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
      </StackPanel>
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="12,8"
                  Spacing="8">
        <TextBlock Text="{Binding LevelText}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="12"
                   FontWeight="Bold"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Grid>

    <!-- Mobile quick selectors -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Background="{DynamicResource PanelBgBrush}"
                Margin="12,0,12,8"
                Spacing="8">
      <ComboBox ItemsSource="{Binding AvailableMods}"
                SelectedItem="{Binding SelectedMod}"
                DisplayMemberBinding="{Binding Name}"
                FontSize="12"
                MinWidth="120" />
      <ComboBox ItemsSource="{Binding AvailableLanguages}"
                SelectedItem="{Binding SelectedLanguage}"
                DisplayMemberBinding="{Binding DisplayName}"
                FontSize="12"
                MinWidth="120" />
    </StackPanel>

    <!-- Horizontally scrollable tab strip -->
    <Border Grid.Row="2"
            Background="#12121E"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="0,0,0,1">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
        <ListBox ItemsSource="{Binding Tabs}"
                 SelectedItem="{Binding SelectedTab}"
                 Background="Transparent"
                 Padding="4">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" Spacing="4" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="tabs:TabItemViewModel">
              <Border Padding="10,6"
                      CornerRadius="6"
                      Background="#251A2E">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding Icon}"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Header}"
                             VerticalAlignment="Center"
                             FontSize="12" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>
    </Border>

    <!-- Tab content -->
    <ContentControl Grid.Row="3"
                    Content="{Binding SelectedTab}"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch" />

  </Grid>

</UserControl>

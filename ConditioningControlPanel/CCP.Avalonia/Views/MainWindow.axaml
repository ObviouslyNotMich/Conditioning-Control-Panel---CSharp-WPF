<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConditioningControlPanel.Avalonia.ViewModels"
        xmlns:tabs="using:ConditioningControlPanel.Avalonia.ViewModels.Tabs"
        xmlns:tabViews="using:ConditioningControlPanel.Avalonia.Views.Tabs"
        xmlns:features="using:ConditioningControlPanel.Avalonia.Features"
        xmlns:converters="using:ConditioningControlPanel.Avalonia.Converters"
        xmlns:models="using:ConditioningControlPanel.Avalonia.Models"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1405"
        Height="1000"
        MinWidth="600"
        MinHeight="450"
        WindowDecorations="None"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Resources>
    <converters:StringEqualsConverter x:Key="StringEqualsConverter" />
    <converters:PercentToWidthConverter x:Key="PercentToWidthConverter" />
  </Window.Resources>

  <Window.Styles>
  </Window.Styles>

  <!-- 5-px resize-grip shell around the scaled UI. -->
  <Grid Background="Transparent">
    <Grid.RowDefinitions>
      <RowDefinition Height="5" />
      <RowDefinition Height="*" />
      <RowDefinition Height="5" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5" />
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="5" />
    </Grid.ColumnDefinitions>

    <!-- Corner grips -->
    <Border Grid.Row="0" Grid.Column="0"
            Background="Transparent"
            Cursor="TopLeftCorner"
            Tag="NorthWest"
            PointerPressed="ResizeBorder_PointerPressed" />
    <Border Grid.Row="0" Grid.Column="2"
            Background="Transparent"
            Cursor="TopRightCorner"
            Tag="NorthEast"
            PointerPressed="ResizeBorder_PointerPressed" />
    <Border Grid.Row="2" Grid.Column="0"
            Background="Transparent"
            Cursor="BottomLeftCorner"
            Tag="SouthWest"
            PointerPressed="ResizeBorder_PointerPressed" />
    <Border Grid.Row="2" Grid.Column="2"
            Background="Transparent"
            Cursor="BottomRightCorner"
            Tag="SouthEast"
            PointerPressed="ResizeBorder_PointerPressed" />

    <!-- Edge grips -->
    <Border Grid.Row="0" Grid.Column="1"
            Background="Transparent"
            Cursor="TopSide"
            Tag="North"
            PointerPressed="ResizeBorder_PointerPressed" />
    <Border Grid.Row="1" Grid.Column="0"
            Background="Transparent"
            Cursor="LeftSide"
            Tag="West"
            PointerPressed="ResizeBorder_PointerPressed" />
    <Border Grid.Row="1" Grid.Column="2"
            Background="Transparent"
            Cursor="RightSide"
            Tag="East"
            PointerPressed="ResizeBorder_PointerPressed" />
    <Border Grid.Row="2" Grid.Column="1"
            Background="Transparent"
            Cursor="BottomSide"
            Tag="South"
            PointerPressed="ResizeBorder_PointerPressed" />

    <!-- Scaled WPF-parity layout: 1405x901 design grid. -->
    <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Fill">
      <Grid Width="1405" Height="901">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0"
              Name="TitleBarGrid"
              Height="36"
              Background="{DynamicResource PinkBrush}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="12,0">
            <TextBlock Text="💗"
                       FontSize="16"
                       Foreground="{DynamicResource TextLightBrush}"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource TextLightBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Title-bar status pills (directory listing + webcam active) -->
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Spacing="12"
                      Margin="0,0,12,0">
            <Border IsVisible="{Binding DirectoryStatusVisible}"
                    Background="{DynamicResource PanelAccentBrush}"
                    CornerRadius="12"
                    Padding="10,4"
                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{Binding DirectoryStatusDotColor}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding DirectoryStatusText}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border IsVisible="{Binding WebcamActiveVisible}"
                    Background="#882B2B"
                    CornerRadius="12"
                    Padding="10,4"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    ToolTip.Tip="{loc:Str tooltip_browser_webcam_tracking_on}"
                    PointerPressed="WebcamActivePill_PointerPressed">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{DynamicResource DangerBrush}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding WebcamActiveText}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal">
            <Button Content="🐛"
                    Theme="{StaticResource WindowControlButton}"
                    Click="BugReport_Click"
                    ToolTip.Tip="{loc:Str tooltip_report_bug}" />
            <Button Content="─"
                    Theme="{StaticResource WindowControlButton}"
                    Command="{Binding MinimizeWindowCommand}" />
            <Button Content="☐"
                    Theme="{StaticResource WindowControlButton}"
                    Command="{Binding MaximizeWindowCommand}" />
            <Button Content="✕"
                    Theme="{StaticResource WindowCloseButton}"
                    Command="{Binding CloseWindowCommand}" />
          </StackPanel>
        </Grid>

        <!-- Header / account shell -->
        <Grid Grid.Row="1"
              Background="{DynamicResource PanelBgBrush}"
              ColumnDefinitions="Auto,*,Auto">
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="12,8"
                      Spacing="12">
            <!-- Mod selector + gear -->
            <StackPanel Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
              <ComboBox x:Name="ModSelectorCombo"
                        ItemsSource="{Binding AvailableMods}"
                        SelectedItem="{Binding SelectedMod}"
                        MinWidth="100"
                        Height="28"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Background="{DynamicResource PanelBgBrush}"
                        Foreground="{DynamicResource TextLightBrush}"
                        BorderBrush="{DynamicResource PanelAccentBrush}"
                        CornerRadius="6">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="models:ModListItem">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Ellipse Width="8"
                               Height="8"
                               Fill="{Binding AccentBrush}"
                               VerticalAlignment="Center" />
                      <TextBlock Text="{Binding Name}"
                                 Foreground="{DynamicResource TextLightBrush}"
                                 VerticalAlignment="Center"
                                 FontSize="11" />
                    </StackPanel>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button x:Name="BtnManageMods"
                      Content="⚙"
                      Command="{Binding ManageModsCommand}"
                      Width="28"
                      Height="28"
                      Background="Transparent"
                      Foreground="{DynamicResource TextMutedBrush}"
                      BorderThickness="0"
                      FontSize="14"
                      Padding="0"
                      ToolTip.Tip="{loc:Str tooltip_manage_mods}" />
            </StackPanel>

            <!-- Player title with accent drop shadow -->
            <Border x:Name="PlayerTitleShadowBorder"
                    Background="Transparent"
                    CornerRadius="0"
                    Padding="0"
                    Margin="0,0,12,0">
              <TextBlock x:Name="TxtPlayerTitle"
                         Text="{Binding PlayerTitle}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="18"
                         FontWeight="Bold"
                         VerticalAlignment="Center" />
            </Border>

            <!-- Level pill -->
            <Border Background="{DynamicResource PinkBrush}"
                    CornerRadius="12"
                    Padding="10,4">
              <TextBlock x:Name="TxtLevel"
                         Text="{Binding LevelText}"
                         Foreground="{DynamicResource TextLightBrush}"
                         FontWeight="Bold"
                         FontSize="12" />
            </Border>

            <!-- Header version -->
            <TextBlock x:Name="TxtHeaderVersion"
                       Text="{Binding HeaderVersionText}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="10"
                       FontWeight="Normal"
                       VerticalAlignment="Bottom"
                       Margin="4,0,0,3" />

            <!-- Streak fire pill -->
            <Border x:Name="StreakFirePill"
                    IsVisible="{Binding StreakFirePillVisible}"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0"
                    CornerRadius="11"
                    Padding="7,4"
                    Background="#1E1232"
                    BorderBrush="#5C3D6E"
                    BorderThickness="1">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Viewbox Width="13" Height="13" VerticalAlignment="Center">
                  <Path Fill="#C47DAA"
                        Data="M8,1 C8,1 2.5,6.5 2.5,10 C2.5,13 5,15.5 8,15.5 C11,15.5 13.5,13 13.5,10 C13.5,6.5 8,1 8,1 Z M8,13.5 C6,13.5 4.5,12 4.5,10 C4.5,8 7,5 8,3.8 C9,5 11.5,8 11.5,10 C11.5,12 10,13.5 8,13.5 Z" />
                </Viewbox>
                <TextBlock x:Name="TxtStreakFireCount"
                           Text="{Binding StreakCount}"
                           Foreground="#C9A0D0"
                           FontSize="13"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />
                <Viewbox x:Name="TxtStreakShieldIcon"
                         IsVisible="{Binding StreakShieldVisible}"
                         Width="12"
                         Height="12"
                         VerticalAlignment="Center"
                         Margin="5,0,0,0">
                  <Path Fill="#8B7BA0"
                        Data="M8,1 L2,4 V9.5 C2,13 5,15.5 8,17 C11,15.5 14,13 14,9.5 V4 Z M8,15 C5.8,13.8 4,11.8 4,9.5 V5.2 L8,3 L12,5.2 V9.5 C12,11.8 10.2,13.8 8,15 Z" />
                </Viewbox>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Primary tab buttons -->
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="4">
            <ToggleButton Theme="{StaticResource TabButtonActivePrimary}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="settings"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=settings}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="📊"/><Run Text="{loc:Str tab_dashboard}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="presets"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=presets}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="📋"/><Run Text="{loc:Str tab_presets}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="quests"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=quests}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="📜"/><Run Text="{loc:Str tab_quests}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="enhancements"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=enhancements}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="✨"/><Run Text="{loc:Str tab_enhancements}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButtonDeeper}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="deeper"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=deeper}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="🌊"/><Run Text="{loc:Str tab_deeper}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButtonNeon}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="availablesubjects"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=availablesubjects}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="🛰️"/><Run Text="{loc:Str tab_available_subjects}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="assets"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=assets}"
                          Padding="7,4">
              <TextBlock FontSize="11"><Run Text="📁"/><Run Text="{loc:Str tab_assets}"/></TextBlock>
            </ToggleButton>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="12,8"
                      Spacing="8">
            <!-- Quick preset selector -->
            <ComboBox x:Name="CmbPresets"
                      IsVisible="False"
                      ItemsSource="{Binding AvailablePresets}"
                      SelectedItem="{Binding SelectedPreset}"
                      Width="160"
                      Background="{DynamicResource PanelBgBrush}"
                      Foreground="{DynamicResource TextLightBrush}"
                      BorderBrush="{DynamicResource PinkBrush}"
                      CornerRadius="6">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:PresetItem">
                  <TextBlock Text="{Binding Name}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="11"
                             VerticalAlignment="Center" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Language pill -->
            <ComboBox x:Name="CmbLanguagePill"
                      ItemsSource="{Binding AvailableLanguages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      Width="90"
                      Background="{DynamicResource PanelBgBrush}"
                      Foreground="{DynamicResource TextLightBrush}"
                      BorderBrush="{DynamicResource PanelAccentBrush}"
                      CornerRadius="6">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:LanguageItem">
                  <TextBlock Text="{Binding ShortName}"
                             Foreground="{DynamicResource TextLightBrush}"
                             FontSize="12" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Update available pill with Normal / UpdateAvailable / Urgent states -->
            <Button x:Name="BtnUpdateAvailable"
                    Content="{Binding UpdateButtonText}"
                    Command="{Binding CheckUpdatesCommand}"
                    Tag="{Binding UpdatePillState}"
                    Classes="updatePill"
                    FontSize="11"
                    FontWeight="Bold"
                    Padding="12,6"
                    CornerRadius="6">
              <Button.Styles>
                <Style Selector="Button.updatePill">
                  <Setter Property="Background" Value="{DynamicResource PinkBrush}" />
                  <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource DarkPinkBrush}" />
                  <Setter Property="BorderThickness" Value="1" />
                  <Setter Property="MinWidth" Value="110" />
                  <Setter Property="Height" Value="32" />
                </Style>
                <Style Selector="Button.updatePill[Tag=UpdateAvailable]">
                  <Setter Property="Background" Value="#8B1A4F" />
                  <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}" />
                  <Setter Property="BorderThickness" Value="2" />
                  <Setter Property="FontSize" Value="13" />
                </Style>
                <Style Selector="Button.updatePill[Tag=UrgentUpdate]">
                  <Setter Property="Background" Value="#DC143C" />
                  <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}" />
                  <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                  <Setter Property="BorderThickness" Value="3" />
                  <Setter Property="FontSize" Value="12" />
                  <Setter Property="FontWeight" Value="ExtraBold" />
                </Style>
              </Button.Styles>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Secondary header row: banner + secondary tabs -->
        <Grid Grid.Row="2"
              Background="{DynamicResource SurfaceBgBrush}"
              ColumnDefinitions="*,Auto">
          <!-- Rotating banner -->
          <Border Grid.Column="0"
                  Background="{DynamicResource SurfaceBgBrush}"
                  BorderBrush="{DynamicResource PinkBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,8"
                  Margin="12,6,6,6">
            <Grid>
              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsBannerPrimaryVisible}">
                <TextBlock Text="{Binding BannerPrimaryText}"
                           Foreground="{DynamicResource PinkBrush}"
                           FontSize="14"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Command="{Binding OpenBannerLinkCommand}"
                        CommandParameter="{Binding BannerPrimaryUrl}"
                        Background="Transparent"
                        Foreground="{DynamicResource PinkBrush}"
                        BorderThickness="0"
                        Padding="4,0"
                        Cursor="Hand">
                  <TextBlock Text="{Binding BannerPrimaryUrl}"
                             Foreground="{DynamicResource PinkBrush}"
                             FontSize="14"
                             FontStyle="Italic"
                             TextDecorations="Underline"
                             VerticalAlignment="Center"
                             TextWrapping="Wrap" />
                </Button>
              </StackPanel>

              <TextBlock IsVisible="{Binding IsBannerSecondaryVisible}"
                         Text="{Binding BannerSecondaryText}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontSize="14"
                         FontStyle="Italic"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap" />

              <Button IsVisible="{Binding IsBannerTertiaryVisible}"
                      Command="{Binding OpenBannerLinkCommand}"
                      CommandParameter="{Binding BannerTertiaryUrl}"
                      Background="Transparent"
                      Foreground="{DynamicResource BannerTertiaryBrush}"
                      BorderThickness="0"
                      Padding="0"
                      Cursor="Hand"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding BannerTertiaryText}"
                           Foreground="{DynamicResource BannerTertiaryBrush}"
                           FontSize="14"
                           FontStyle="Italic"
                           FontWeight="Bold"
                           TextDecorations="Underline"
                           TextWrapping="Wrap" />
              </Button>
            </Grid>
          </Border>

          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Margin="12,6"
                      Spacing="6">
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="achievements"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=achievements}"
                          Padding="8,5"
                          FontSize="11">
              <TextBlock><Run Text="🏆"/><Run Text="{loc:Str tab_achievements}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="leaderboard"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=leaderboard}"
                          Padding="8,5"
                          FontSize="11">
              <TextBlock><Run Text="📊"/><Run Text="{loc:Str tab_leaderboard}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="companion"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=companion}"
                          Padding="8,5"
                          FontSize="11">
              <TextBlock><Run Text="🤖"/><Run Text="{loc:Str tab_companion}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButtonDiscord}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="discord"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=discord}"
                          Padding="8,5"
                          FontSize="11">
              <TextBlock><Run Text="👤"/><Run Text="{loc:Str tab_profile}"/></TextBlock>
            </ToggleButton>
            <ToggleButton Theme="{StaticResource TabButton}"
                          Command="{Binding SelectTabCommand}"
                          CommandParameter="lab"
                          IsChecked="{Binding SelectedTab.Key, Mode=OneWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=lab}"
                          Padding="8,5"
                          FontSize="11">
              <TextBlock><Run Text="🧪"/><Run Text="{loc:Str tab_lab}"/></TextBlock>
            </ToggleButton>
            <Button x:Name="BtnPatreonExclusives"
                    Command="{Binding TogglePatreonPopupCommand}"
                    Theme="{StaticResource PatreonButton}"
                    Padding="8,5"
                    FontSize="11">
              <TextBlock><Run Text="⭐"/><Run Text="{loc:Str label_patreon_exclusives}"/></TextBlock>
            </Button>
            <Popup IsOpen="{Binding IsPatreonPopupOpen, Mode=TwoWay}"
                   PlacementTarget="{Binding #BtnPatreonExclusives}"
                   Placement="Bottom"
                   IsLightDismissEnabled="True">
              <Border Background="{DynamicResource PanelBgBrush}"
                      BorderBrush="{DynamicResource PinkBrush}"
                      BorderThickness="2"
                      CornerRadius="6"
                      Padding="6"
                      MinWidth="220">
                <StackPanel Orientation="Vertical" Spacing="4">
                  <Button Command="{Binding SelectPatreonExclusiveTabCommand}"
                          CommandParameter="blinktrainer"
                          Theme="{StaticResource ExclusivesSubmenuButton}"
                          Padding="6,4">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⭐" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Str tab_blink_trainer}" VerticalAlignment="Center" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{DynamicResource PinkBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="9" Foreground="{DynamicResource TextLightBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                  <Button Command="{Binding SelectPatreonExclusiveTabCommand}"
                          CommandParameter="remotecontrol"
                          Theme="{StaticResource ExclusivesSubmenuButton}"
                          Padding="6,4">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🎮" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Str tab_remote_control}" VerticalAlignment="Center" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{DynamicResource PinkBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="9" Foreground="{DynamicResource TextLightBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                  <Button Command="{Binding SelectPatreonExclusiveTabCommand}"
                          CommandParameter="bambitakeover"
                          Theme="{StaticResource ExclusivesSubmenuButton}"
                          Padding="6,4">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🤖" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Str tab_takeover}" VerticalAlignment="Center" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{DynamicResource PinkBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="9" Foreground="{DynamicResource TextLightBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                  <Button Command="{Binding SelectPatreonExclusiveTabCommand}"
                          CommandParameter="haptics"
                          Theme="{StaticResource ExclusivesSubmenuButton}"
                          Padding="6,4">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="💜" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Str tab_haptics}" VerticalAlignment="Center" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{DynamicResource PinkBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="9" Foreground="{DynamicResource TextLightBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                  <Button Command="{Binding SelectPatreonExclusiveTabCommand}"
                          CommandParameter="awareness"
                          Theme="{StaticResource ExclusivesSubmenuButton}"
                          Padding="6,4">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="👁" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Str tab_awareness}" VerticalAlignment="Center" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{DynamicResource PinkBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="9" Foreground="{DynamicResource TextLightBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                  <Button Command="{Binding SelectPatreonExclusiveTabCommand}"
                          CommandParameter="lockdown"
                          Theme="{StaticResource ExclusivesSubmenuButton}"
                          Padding="6,4">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🔒" VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Str tab_lockdown}" VerticalAlignment="Center" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{DynamicResource PinkBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="9" Foreground="{DynamicResource TextLightBrush}" />
                      </Border>
                    </Grid>
                  </Button>
                </StackPanel>
              </Border>
            </Popup>
            <Button Content="?"
                    Command="{Binding ToggleTutorialOverlayCommand}"
                    Width="26"
                    Height="26"
                    Background="{DynamicResource PinkBrush}"
                    Foreground="{DynamicResource TextLightBrush}"
                    FontWeight="Bold"
                    FontSize="16"
                    CornerRadius="13"
                    Padding="0"
                    BorderThickness="0"
                    ToolTip.Tip="{loc:Str btn_help}"
                    Margin="3,0" />
            <Button Content="🐛"
                    Click="BugReport_Click"
                    Width="26"
                    Height="26"
                    Background="{DynamicResource PanelAccentBrush}"
                    Foreground="{DynamicResource TextLightBrush}"
                    FontSize="12"
                    CornerRadius="13"
                    Padding="0"
                    BorderThickness="0"
                    ToolTip.Tip="{loc:Str tooltip_report_bug}"
                    Margin="3,0" />
          </StackPanel>
        </Grid>

        <!-- XP / stat pills row -->
        <Grid Grid.Row="3"
              Background="{DynamicResource PanelBgBrush}">
          <!-- XP bar + stat pills content -->
          <Grid IsVisible="{Binding IsLoggedIn}"
                ColumnDefinitions="*,Auto">
            <!-- Left: level + custom XP bar + XP text -->
            <Grid Grid.Column="0"
                  ColumnDefinitions="Auto,*,Auto"
                  VerticalAlignment="Center"
                  Margin="12,6">
              <TextBlock Grid.Column="0"
                         Text="{Binding LevelText}"
                         Foreground="{DynamicResource PinkBrush}"
                         FontWeight="Bold"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0" />
              <Border Grid.Column="1"
                      Width="200"
                      Background="{DynamicResource PanelAccentBrush}"
                      CornerRadius="4"
                      Height="8"
                      Margin="0,0,10,0">
                <Grid>
                  <Border Background="{DynamicResource PinkBrush}"
                          CornerRadius="4"
                          HorizontalAlignment="Left"
                          Width="{Binding XpPercent,
                                          Converter={StaticResource PercentToWidthConverter},
                                          ConverterParameter=200}" />
                  <Border Background="{DynamicResource PinkBrush}"
                          CornerRadius="4"
                          HorizontalAlignment="Left"
                          IsHitTestVisible="False"
                          Width="{Binding XpPercent,
                                          Converter={StaticResource PercentToWidthConverter},
                                          ConverterParameter=200}"
                          Opacity="{Binding XpFlashOpacity}" />
                </Grid>
              </Border>
              <TextBlock Grid.Column="2"
                         Text="{Binding XpText}"
                         Foreground="{DynamicResource TextMutedBrush}"
                         FontSize="11"
                         VerticalAlignment="Center" />
            </Grid>

            <!-- Right: bonus chips + skill-gated stat pills -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="12,6"
                        Spacing="8">
              <ItemsControl x:Name="XPBarBonusList"
                            ItemsSource="{Binding BonusChips}"
                            VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="6" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#3D1A3D"
                            BorderBrush="{DynamicResource PinkBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="6,2"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding}"
                                 Foreground="{DynamicResource PinkBrush}"
                                 FontSize="10"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                      BorderBrush="{DynamicResource PanelAccentBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="6,2"
                      VerticalAlignment="Center">
                <TextBlock Text="VIP Bonus"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
              </Border>

              <Border IsVisible="{Binding ConditioningTimeVisible}"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      CornerRadius="10"
                      Padding="8,4"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding ConditioningTimeText}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
              </Border>
              <Border IsVisible="{Binding OnlineUsersVisible}"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      CornerRadius="10"
                      Padding="8,4"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding OnlineUsersText}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
              </Border>
              <Border IsVisible="{Binding RankPercentileVisible}"
                      Background="{DynamicResource ElevatedSurfaceBrush}"
                      CornerRadius="10"
                      Padding="8,4"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding RankPercentileText}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="11"
                           VerticalAlignment="Center" />
              </Border>
            </StackPanel>
          </Grid>

          <!-- Login overlay - shown when not logged in -->
          <Border IsVisible="{Binding XPBarLoginOverlayVisible}"
                  Background="#CC1A1A2E"
                  CornerRadius="4"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Padding="12,6">
            <TextBlock Text="{loc:Str msg_login_to_track_xp}"
                       Foreground="{DynamicResource PinkBrush}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.9" />
          </Border>
        </Grid>

        <!-- Tab shell -->
        <ContentControl Grid.Row="4"
                        Content="{Binding SelectedTab}"
                        Margin="8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
          <ContentControl.DataTemplates>
            <DataTemplate DataType="tabs:AppInfoTabViewModel">
              <tabViews:AppInfoTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:SettingsTabViewModel">
              <tabViews:SettingsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:PresetsTabViewModel">
              <tabViews:PresetsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:PresetIOTabViewModel">
              <tabViews:PresetIOTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:QuestsTabViewModel">
              <tabViews:QuestsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:LevelFeaturesTabViewModel">
              <tabViews:LevelFeaturesTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:PatreonTabViewModel">
              <tabViews:PatreonTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:AttentionCheckTabViewModel">
              <features:AttentionCheckFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:BouncingTextTabViewModel">
              <features:BouncingTextFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:BubbleCountTabViewModel">
              <features:BubbleCountFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:BubblePopTabViewModel">
              <features:BubblePopFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:FlashTabViewModel">
              <features:FlashFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:PinkFilterTabViewModel">
              <features:PinkFilterFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:IntensityRampTabViewModel">
              <features:IntensityRampFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:LockCardTabViewModel">
              <features:LockCardFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:MindWipeTabViewModel">
              <features:MindWipeFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:SchedulerTabViewModel">
              <features:SchedulerFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:VisualsTabViewModel">
              <features:VisualsFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:SubliminalTabViewModel">
              <features:SubliminalFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:SystemTabViewModel">
              <features:SystemFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:SpiralTabViewModel">
              <features:SpiralFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:SchedulerRampTabViewModel">
              <features:SchedulerRampFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:VideoTabViewModel">
              <features:VideoFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:WebcamTabViewModel">
              <features:WebcamFeatureControl />
            </DataTemplate>
            <DataTemplate DataType="tabs:DeeperTabViewModel">
              <tabViews:DeeperTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:DeeperHubTabViewModel">
              <tabViews:DeeperHubTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:EnhancementsTabViewModel">
              <tabViews:EnhancementsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:AssetsTabViewModel">
              <tabViews:AssetsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:CatalogueSubmissionsTabViewModel">
              <tabViews:CatalogueSubmissionsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:AchievementsTabViewModel">
              <tabViews:AchievementsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:LeaderboardTabViewModel">
              <tabViews:LeaderboardTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:MarqueeTabViewModel">
              <tabViews:MarqueeTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:AnimationsTabViewModel">
              <tabViews:AnimationsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:DeeperSubmissionsTabViewModel">
              <tabViews:DeeperSubmissionsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:CompanionHubTabViewModel">
              <tabViews:CompanionHubTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:CompanionTabViewModel">
              <tabViews:CompanionTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:BambiTakeoverTabViewModel">
              <tabViews:BambiTakeoverTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:HapticsTabViewModel">
              <tabViews:HapticsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:AwarenessTabViewModel">
              <tabViews:AwarenessTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:LabTabViewModel">
              <tabViews:LabTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:BlinkTrainerTabViewModel">
              <tabViews:BlinkTrainerTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:RemoteControlTabViewModel">
              <tabViews:RemoteControlTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:AvailableSubjectsTabViewModel">
              <tabViews:AvailableSubjectsTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:ProfileTabViewModel">
              <tabViews:ProfileTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:LockdownTabViewModel">
              <tabViews:LockdownTabView />
            </DataTemplate>
            <DataTemplate DataType="tabs:TabItemViewModel">
              <tabViews:PlaceholderTabView />
            </DataTemplate>
          </ContentControl.DataTemplates>
        </ContentControl>

        <!-- Global bottom bar: status text + Start/Pause | Save | Exit -->
        <Grid Grid.Row="5"
              RowDefinitions="Auto,*"
              Margin="10,8">
          <TextBlock Grid.Row="0"
                     Text="{Binding SessionStatusText}"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="11"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Margin="0,0,0,6" />

          <Grid Grid.Row="1"
                ColumnDefinitions="*,*">
            <Grid Grid.Column="0"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,8,0">
              <Button Grid.Column="0"
                      Command="{Binding StartSessionCommand}"
                      HorizontalAlignment="Stretch"
                      Height="50"
                      Theme="{StaticResource PinkButton}"
                      Background="{DynamicResource AccentGradientBrush}"
                      FontSize="18"
                      IsEnabled="{Binding !RemoteControlConnected}"
                      IsVisible="{Binding !RemoteControlConnected}"
                      Opacity="{Binding StartButtonFlashOpacity}">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                  <TextBlock Text="{Binding StartButtonIcon}"
                             FontSize="16"
                             Width="22"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"
                             TextAlignment="Center" />
                  <TextBlock Text="{Binding StartButtonLabel}"
                             FontSize="18"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Grid.Column="1"
                      Content="{Binding PauseButtonText}"
                      Command="{Binding TogglePauseSessionCommand}"
                      IsVisible="{Binding IsEngineRunning}"
                      Width="50"
                      Height="50"
                      Margin="5,0,0,0"
                      Background="#FFA500"
                      Foreground="{DynamicResource TextLightBrush}"
                      FontSize="20"
                      FontWeight="Bold"
                      CornerRadius="6"
                      ToolTip.Tip="{Binding PauseButtonToolTip}" />
            </Grid>

            <Grid Grid.Column="1"
                  ColumnDefinitions="*,*"
                  Margin="8,0,0,0">
              <Button Grid.Column="0"
                      Content="{loc:Str btn_save}"
                      Command="{Binding SaveSettingsCommand}"
                      HorizontalAlignment="Stretch"
                      Margin="0,0,5,0"
                      Height="50"
                      Theme="{StaticResource PinkButton}"
                      FontSize="16" />
              <Button Grid.Column="1"
                      Content="{loc:Str btn_exit_plain}"
                      Command="{Binding ExitApplicationCommand}"
                      HorizontalAlignment="Stretch"
                      Margin="5,0,0,0"
                      Height="50"
                      Theme="{StaticResource DangerButton}"
                      FontSize="16" />
            </Grid>
          </Grid>
        </Grid>

        <!-- Remote control overlay: controller lock screen -->
        <Grid Grid.Row="1"
              Grid.RowSpan="5"
              IsVisible="{Binding RemoteControlOverlayVisible}"
              Background="#CC000000"
              ZIndex="100">
          <Grid RowDefinitions="Auto,*,Auto"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="520">
            <TextBlock Grid.Row="0"
                       Text="🎮"
                       FontSize="64"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextLightBrush}"
                       Margin="0,0,0,12" />
            <StackPanel Grid.Row="1"
                        Spacing="12"
                        HorizontalAlignment="Center">
              <TextBlock Text="{loc:Str label_remote_controlled_title}"
                         FontSize="28"
                         FontWeight="Bold"
                         Foreground="{DynamicResource TextLightBrush}"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding RemoteControlSessionCodeDisplay}"
                         FontSize="14"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center" />
              <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                      CornerRadius="12"
                      Padding="20"
                      Margin="0,16,0,0">
                <StackPanel Spacing="8">
                  <TextBlock Text="{loc:Str label_session_info}"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="{DynamicResource PinkBrush}" />
                  <TextBlock Text="{Binding RemoteControllerSessionNameDisplay}"
                             FontSize="13"
                             Foreground="{DynamicResource TextLightBrush}" />
                  <TextBlock Text="{Binding RemoteControlStatusDisplay}"
                             FontSize="13"
                             Foreground="{DynamicResource TextMutedBrush}" />
                  <TextBlock Text="{Binding RemoteControlPinDisplay}"
                             FontSize="13"
                             Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
              </Border>
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          HorizontalAlignment="Center"
                          Margin="0,12,0,0">
                <Button Content="{loc:Str label_emote_1}"
                        Background="#3D1A3D"
                        Foreground="{DynamicResource PinkBrush}"
                        Padding="12,6"
                        CornerRadius="6" />
                <Button Content="{loc:Str label_emote_2}"
                        Background="#3D1A3D"
                        Foreground="{DynamicResource PinkBrush}"
                        Padding="12,6"
                        CornerRadius="6" />
                <Button Content="{loc:Str label_emote_3}"
                        Background="#3D1A3D"
                        Foreground="{DynamicResource PinkBrush}"
                        Padding="12,6"
                        CornerRadius="6" />
              </StackPanel>
            </StackPanel>
            <Button Grid.Row="2"
                    Content="{loc:Str btn_end_session}"
                    Command="{Binding StopRemoteControlSessionCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,24,0,0"
                    Padding="24,10"
                    Theme="{StaticResource DangerButton}"
                    FontSize="16"
                    FontWeight="Bold" />
          </Grid>
        </Grid>

        <!-- Global drag-and-drop import overlay -->
        <Grid Grid.Row="0"
              Grid.RowSpan="6"
              IsVisible="{Binding DropOverlayVisible}"
              Background="#CC000000"
              ZIndex="101">
          <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                  CornerRadius="16"
                  Padding="40"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center">
            <StackPanel Spacing="12"
                        HorizontalAlignment="Center">
              <TextBlock Text="📁"
                         FontSize="64"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextLightBrush}" />
              <TextBlock Text="{loc:Str label_drop_to_import_title}"
                         FontSize="24"
                         FontWeight="Bold"
                         Foreground="{DynamicResource TextLightBrush}"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{loc:Str label_drop_zone_hint}"
                         FontSize="13"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>

        <!-- Main tutorial overlay -->
        <Grid Grid.Row="0"
              Grid.RowSpan="6"
              IsVisible="{Binding TutorialOverlayVisible}"
              Background="#CC000000"
              ZIndex="102">
          <Border Width="640"
                  Height="520"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Background="{DynamicResource SurfaceBgBrush}"
                  CornerRadius="16">
            <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="20,16">
              <TextBlock Grid.Column="0"
                         Text="{loc:Str label_choose_a_guide}"
                         FontSize="22"
                         FontWeight="Bold"
                         Foreground="{DynamicResource TextLightBrush}"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="✕"
                      Command="{Binding ToggleTutorialOverlayCommand}"
                      Background="Transparent"
                      Foreground="{DynamicResource TextLightBrush}"
                      FontSize="18"
                      Padding="8,4"
                      BorderThickness="0" />
            </Grid>
            <ScrollViewer Grid.Row="1"
                          Margin="20,0">
              <StackPanel Spacing="12">
                <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                        CornerRadius="12"
                        Padding="16">
                  <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0"
                               Text="🚀"
                               FontSize="32"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Text="{loc:Str label_getting_started}"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource TextLightBrush}" />
                      <TextBlock Text="{loc:Str msg_getting_started_desc}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextWrapping="Wrap" />
                      <Button Content="{loc:Str btn_start_guide_lowercase}"
                              Background="#3D1A3D"
                              Foreground="{DynamicResource PinkBrush}"
                              Padding="10,4"
                              CornerRadius="6"
                              HorizontalAlignment="Left" />
                    </StackPanel>
                  </Grid>
                </Border>
                <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                        CornerRadius="12"
                        Padding="16">
                  <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0"
                               Text="🎛️"
                               FontSize="32"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Text="{loc:Str tab_presets}"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource TextLightBrush}" />
                      <TextBlock Text="{loc:Str msg_presets_desc}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextWrapping="Wrap" />
                      <Button Content="{loc:Str btn_start_guide_lowercase}"
                              Background="#3D1A3D"
                              Foreground="{DynamicResource PinkBrush}"
                              Padding="10,4"
                              CornerRadius="6"
                              HorizontalAlignment="Left" />
                    </StackPanel>
                  </Grid>
                </Border>
                <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                        CornerRadius="12"
                        Padding="16">
                  <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0"
                               Text="🔒"
                               FontSize="32"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                      <TextBlock Text="{loc:Str tab_lockdown}"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource TextLightBrush}" />
                      <TextBlock Text="{loc:Str msg_lockdown_desc}"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextMutedBrush}"
                                 TextWrapping="Wrap" />
                      <Button Content="{loc:Str btn_start_guide_lowercase}"
                              Background="#3D1A3D"
                              Foreground="{DynamicResource PinkBrush}"
                              Padding="10,4"
                              CornerRadius="6"
                              HorizontalAlignment="Left" />
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10"
                        Margin="20">
              <Button Content="{loc:Str btn_skip_tutorials}"
                      Command="{Binding ToggleTutorialOverlayCommand}"
                      Background="Transparent"
                      Foreground="{DynamicResource TextMutedBrush}"
                      BorderBrush="{DynamicResource PanelAccentBrush}"
                      BorderThickness="1"
                      Padding="12,6"
                      CornerRadius="6" />
              <Button Content="{loc:Str btn_done}"
                      Command="{Binding ToggleTutorialOverlayCommand}"
                      Background="{DynamicResource PinkBrush}"
                      Foreground="{DynamicResource TextLightBrush}"
                      Padding="12,6"
                      CornerRadius="6" />
            </StackPanel>
          </Grid>
          </Border>
        </Grid>

      </Grid>
    </Viewbox>

    <!-- Browser fullscreen overlay: covers the entire window, outside the scaled Viewbox. -->
    <Grid Grid.Row="0"
          Grid.RowSpan="3"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          IsVisible="{Binding BrowserFullscreenOverlayVisible}"
          Background="Black"
          ZIndex="200" />

    <!-- Notification host: top-right toast stack, outside the scaled Viewbox. -->
    <ItemsControl Grid.Row="0"
                  Grid.RowSpan="3"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  IsVisible="{Binding Notifications.Count, FallbackValue=False}"
                  ItemsSource="{Binding Notifications}"
                  Width="380"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,8,8,0"
                  ZIndex="201">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Spacing="8" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="models:NotificationItem">
          <Border Background="{DynamicResource ElevatedSurfaceBrush}"
                  CornerRadius="10"
                  Padding="14,10"
                  BorderBrush="{DynamicResource PanelAccentBrush}"
                  BorderThickness="1">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding Title}"
                         FontSize="13"
                         FontWeight="Bold"
                         Foreground="{DynamicResource TextLightBrush}" />
              <TextBlock Text="{Binding Message}"
                         FontSize="12"
                         Foreground="{DynamicResource TextMutedBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

  </Grid>

</Window>

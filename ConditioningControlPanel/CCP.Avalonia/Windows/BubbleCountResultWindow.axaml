<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.BubbleCountResultWindow" x:DataType="x:Object"
        Title="{Binding [dialog_how_many_bubbles], Source={x:Static loc:LocalizationManager.Instance}}"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        FontFamily="Comic Sans MS, Segoe UI"
        KeyDown="Window_KeyDown">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <!-- Semi-transparent background -->
    <Rectangle Fill="#E0000000" />

    <!-- Content Card -->
    <Border x:Name="ContentCard"
            Background="#FF2D2D3A"
            CornerRadius="20"
            Padding="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="500"
            MaxWidth="600">

      <StackPanel>
        <!-- Title -->
        <TextBlock Text="{Binding [label_how_many_bubbles], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="40"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PinkBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20" />

        <!-- Instruction -->
        <TextBlock Text="{Binding [label_enter_the_number_of_bubbles_you_counted], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="18"
                   Foreground="{DynamicResource PinkBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30" />

        <!-- Number Input -->
        <TextBox x:Name="TxtAnswer"
                 FontSize="48"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextLightBrush}"
                 Background="#40FFFFFF"
                 BorderBrush="{DynamicResource PinkBrush}"
                 BorderThickness="3"
                 Padding="20,10"
                 HorizontalAlignment="Center"
                 MinWidth="200"
                 TextAlignment="Center"
                 MaxLength="3"
                 TextChanged="OnTextChanged" />

        <!-- Attempts remaining -->
        <TextBlock x:Name="TxtAttempts"
                   Text="{Binding [label_attempts_remaining_3], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="16"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0" />

        <!-- Feedback -->
        <TextBlock x:Name="TxtFeedback"
                   Text=""
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,0"
                   IsVisible="False" />

        <!-- Submit Button -->
        <Button x:Name="BtnSubmit"
                Content="{Binding [btn_submit], Source={x:Static loc:LocalizationManager.Instance}}"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                Background="{DynamicResource PinkBrush}"
                BorderThickness="0"
                Padding="40,15"
                Margin="0,30,0,0"
                HorizontalAlignment="Center"
                Click="BtnSubmit_Click"
                CornerRadius="10">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="{DynamicResource TransparentPinkBrush}" />
            </Style>
          </Button.Styles>
        </Button>

        <!-- Strict Mode Indicator -->
        <TextBlock x:Name="TxtStrict"
                   Text="{Binding [label_strict_mode_must_answer_correctly], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="14"
                   Foreground="{DynamicResource DangerBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"
                   IsVisible="False" />

        <!-- ESC Hint -->
        <TextBlock x:Name="TxtEscHint"
                   Text="{Binding [label_press_esc_to_skip_won_t_earn_xp], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="12"
                   Foreground="#666666"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,0" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

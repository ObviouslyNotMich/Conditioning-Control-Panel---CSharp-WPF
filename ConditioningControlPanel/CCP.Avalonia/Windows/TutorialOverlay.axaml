<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.TutorialOverlay"
        Title="{loc:Str window_tutorial_overlay_tutorial_title}"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        CanResize="False"
        KeyDown="OnKeyDown">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid x:Name="RootGrid">
    <Canvas x:Name="SpotlightCanvas" IsHitTestVisible="True" />

    <Border x:Name="TextPanel"
            Background="#F0252542"
            CornerRadius="12"
            BorderBrush="{DynamicResource PinkBrush}"
            BorderThickness="2"
            MaxWidth="460"
            Padding="20"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            BoxShadow="0 0 20 0 #66FF69B4">

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtStepCounter"
                   Grid.Row="0"
                   Text="{loc:Str window_tutorial_overlay_step_1_6_text}"
                   Foreground="#808090"
                   FontSize="11"
                   Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
          <TextBlock x:Name="TxtIcon" Text="~" FontSize="24"
                     Foreground="{DynamicResource PinkBrush}" FontWeight="Bold"
                     Margin="0,0,10,0" VerticalAlignment="Center" />
          <TextBlock x:Name="TxtTitle"
                     Text="{loc:Str window_tutorial_overlay_welcome_text}"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="18" FontWeight="Bold"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock x:Name="TxtDescription"
                   Grid.Row="2"
                   Text="{loc:Str window_tutorial_overlay_description_text_goes_here_text}"
                   Foreground="#C0C0C0"
                   FontSize="13"
                   TextWrapping="Wrap"
                   LineHeight="20"
                   Margin="0,0,0,10" />

        <Button x:Name="BtnSupport"
                Grid.Row="3"
                Content="{loc:Str window_tutorial_overlay_visit_linktreecodebambi_content}"
                Click="BtnSupport_Click"
                IsVisible="False"
                HorizontalAlignment="Center"
                Margin="0,5,0,15"
                Background="{DynamicResource PinkBrush}"
                Foreground="White"
                FontWeight="Bold"
                Padding="20,10"
                FontSize="13"
                BorderThickness="0"
                CornerRadius="6">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="{DynamicResource TransparentPinkBrush}" />
            </Style>
          </Button.Styles>
        </Button>

        <StackPanel x:Name="FollowUpPanel" Grid.Row="4" Orientation="Vertical"
                    IsVisible="False" Margin="0,4,0,12">
          <Button x:Name="BtnFollowUp1" Click="BtnFollowUp1_Click"
                  HorizontalAlignment="Stretch" IsVisible="False"
                  Margin="0,0,0,6"
                  Background="{DynamicResource PinkBrush}" Foreground="White"
                  FontWeight="Bold" Padding="14,9" FontSize="13"
                  BorderThickness="0" CornerRadius="6" />
          <Button x:Name="BtnFollowUp2" Click="BtnFollowUp2_Click"
                  HorizontalAlignment="Stretch" IsVisible="False"
                  Margin="0,0,0,6"
                  Background="Transparent" Foreground="{DynamicResource PinkBrush}"
                  BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                  Padding="14,9" FontSize="13" CornerRadius="6" />
          <Button x:Name="BtnFollowUp3" Click="BtnFollowUp3_Click"
                  HorizontalAlignment="Stretch" IsVisible="False"
                  Background="Transparent" Foreground="#A0A0B0"
                  BorderThickness="0"
                  Padding="14,9" FontSize="12" />
        </StackPanel>

        <Grid Grid.Row="5">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Button x:Name="BtnSkip"
                  Grid.Column="0"
                  Content="{loc:Str window_tutorial_overlay_skip_tutorial_content}"
                  Click="BtnSkip_Click"
                  Background="Transparent" Foreground="#808090"
                  BorderThickness="0" FontSize="12"
                  Padding="0" />

          <Button x:Name="BtnSkipStep"
                  Grid.Column="2"
                  Content="{loc:Str window_tutorial_overlay_skip_step_content}"
                  Click="BtnSkipStep_Click"
                  Margin="0,0,10,0"
                  IsVisible="False"
                  Background="Transparent" Foreground="#A0A0B0"
                  BorderBrush="#404060" BorderThickness="1"
                  FontSize="11" Padding="10,4" CornerRadius="4" />

          <Button x:Name="BtnPrevious"
                  Grid.Column="3"
                  Content="{loc:Str window_tutorial_overlay_previous_content}"
                  Click="BtnPrevious_Click"
                  Margin="0,0,10,0"
                  IsVisible="False"
                  Background="Transparent" Foreground="{DynamicResource PinkBrush}"
                  BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                  Padding="15,8" FontSize="13" CornerRadius="6" />

          <Button x:Name="BtnNext"
                  Grid.Column="4"
                  Content="{loc:Str window_tutorial_overlay_next_content}"
                  Click="BtnNext_Click"
                  Background="{DynamicResource PinkBrush}" Foreground="White"
                  FontWeight="Bold" Padding="20,10" FontSize="13"
                  BorderThickness="0" CornerRadius="6" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

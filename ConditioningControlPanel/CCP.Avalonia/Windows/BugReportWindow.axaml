<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.BugReportWindow"
        Title="{Binding [bug_report_title], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="760" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F1E"
        Foreground="#E0E0E0"
        CanResize="True"
        MinWidth="560" MinHeight="560">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <ControlTheme x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PinkBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,10,0,4" />
      </ControlTheme>

      <ControlTheme x:Key="FormBox" TargetType="TextBox">
        <Setter Property="Background" Value="#1A1A2E" />
        <Setter Property="Foreground" Value="#E0E0E0" />
        <Setter Property="BorderBrush" Value="#3D3D60" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
      </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>

  <Grid Margin="20" RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,6">
      <TextBlock Text="{Binding [bug_report_title], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="{DynamicResource PinkBrush}"
                 FontSize="20" FontWeight="Bold" />
      <TextBlock Text="{Binding [bug_report_privacy_notice], Source={x:Static loc:LocalizationManager.Instance}}"
                 Foreground="#9898B0" FontSize="11" TextWrapping="Wrap"
                 Margin="0,6,0,0" />
    </StackPanel>

    <!-- Scrollable form body -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,8">
      <StackPanel>
        <TextBlock Text="{Binding [bug_report_description_label], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource FormLabel}" />
        <TextBox x:Name="TxtDescription" Theme="{StaticResource FormBox}"
                 Height="80" MaxLength="4000"
                 TextChanged="OnFieldChanged" />

        <TextBlock Text="{Binding [bug_report_steps_label], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource FormLabel}" />
        <TextBox x:Name="TxtSteps" Theme="{StaticResource FormBox}"
                 Height="70" MaxLength="4000"
                 TextChanged="OnFieldChanged" />

        <TextBlock Text="{Binding [bug_report_metadata_label], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource FormLabel}" />
        <Border Background="#14142A" BorderBrush="#3D3D60" BorderThickness="1" CornerRadius="4" Padding="10,8">
          <TextBlock x:Name="TxtMetadataSummary" Foreground="#B0B0C8" FontSize="11"
                     FontFamily="Consolas" TextWrapping="Wrap" />
        </Border>

        <CheckBox x:Name="ChkIncludeAppLog"
                  Content="{Binding [bug_report_include_log_checkbox], Source={x:Static loc:LocalizationManager.Instance}}"
                  Foreground="#D0D0E0" FontSize="12"
                  Margin="0,14,0,0" IsChecked="False"
                  IsCheckedChanged="OnFieldChanged" />

        <TextBlock x:Name="TxtScrubberCounts" Foreground="#9898B0" FontSize="11"
                   Margin="0,10,0,0" TextWrapping="Wrap" />

        <TextBlock Text="{Binding [bug_report_preview_label], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource FormLabel}" />
        <Border Background="#0A0A18" BorderBrush="#3D3D60" BorderThickness="1" CornerRadius="4">
          <TextBox x:Name="TxtPreview" IsReadOnly="True" TextWrapping="NoWrap"
                   Background="Transparent" Foreground="#B0B0C8" BorderThickness="0"
                   FontFamily="Consolas" FontSize="11"
                   Height="260"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto" />
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Footer buttons -->
    <Grid Grid.Row="2" Margin="0,4,0,0" ColumnDefinitions="*,Auto,Auto">
      <TextBlock x:Name="TxtStatus" Grid.Column="0" Foreground="#9898B0" FontSize="11"
                 VerticalAlignment="Center" TextWrapping="Wrap" />
      <Button x:Name="BtnCancel" Grid.Column="1"
              Content="{Binding [bug_report_cancel], Source={x:Static loc:LocalizationManager.Instance}}" Click="BtnCancel_Click"
              Background="#1A1A2E" Foreground="#C0C0D0" BorderBrush="#3D3D60"
              BorderThickness="1" Padding="18,8" Margin="0,0,10,0" />
      <Button x:Name="BtnSend" Grid.Column="2"
              Content="{Binding [bug_report_send], Source={x:Static loc:LocalizationManager.Instance}}" Click="BtnSend_Click"
              Background="{DynamicResource PinkBrush}" Foreground="White"
              BorderThickness="0" Padding="22,8"
              FontWeight="SemiBold" IsEnabled="False" />
    </Grid>
  </Grid>
</Window>

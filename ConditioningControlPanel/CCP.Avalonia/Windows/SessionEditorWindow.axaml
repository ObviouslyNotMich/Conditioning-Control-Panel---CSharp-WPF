<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        xmlns:local="clr-namespace:ConditioningControlPanel.Avalonia.Windows;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.SessionEditorWindow"
        Title="{Binding [label_session_editor], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="765" Width="765"
        MinHeight="680" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="True"
        PointerPressed="Window_PointerPressed"
        x:CompileBindings="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="12" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2">
      <Grid RowDefinitions="Auto,*">
        <!-- Title Bar -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Margin="2,2,2,0" ColumnDefinitions="*,Auto"
              PointerPressed="TitleBar_PointerPressed">
          <TextBlock Text="{Binding [label_session_editor], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#E0E0E0" FontSize="12"
                     VerticalAlignment="Center" Margin="12,8" />

          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,8,4">
            <Button x:Name="BtnHelp" Content="?" Click="BtnHelp_Click" Width="24" Height="24"
                    Background="{DynamicResource PinkBrush}" Foreground="White" FontSize="12" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" ToolTip.Tip="{Binding [tooltip_how_to_use_the_session_editor], Source={x:Static loc:LocalizationManager.Instance}}">
              <Button.Theme>
                <ControlTheme TargetType="Button">
                  <Setter Property="Template">
                    <ControlTemplate>
                      <Border Background="{TemplateBinding Background}" CornerRadius="12" Width="24" Height="24">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                    </ControlTemplate>
                  </Setter>
                </ControlTheme>
              </Button.Theme>
            </Button>
            <Button Content="−" Click="BtnMinimize_Click" Width="24" Height="24"
                    Background="Transparent" Foreground="#888" FontSize="14"
                    BorderThickness="0" Cursor="Hand" Margin="4,0,0,0" />
            <Button Content="✕" Click="BtnClose_Click" Width="24" Height="24"
                    Background="Transparent" Foreground="#888" FontSize="12"
                    BorderThickness="0" Cursor="Hand" />
          </StackPanel>
        </Grid>

        <!-- Scrollable Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
            <!-- Session Name + Stats -->
            <StackPanel Grid.Row="0" Margin="20,12,20,8">
              <TextBox x:Name="TxtSessionName" Text="{Binding [label_my_new_session], Source={x:Static loc:LocalizationManager.Instance}}"
                       FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PinkBrush}"
                       Background="Transparent" BorderThickness="0"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       CaretBrush="{DynamicResource PinkBrush}" SelectionBrush="{DynamicResource PinkBrush}"
                       ToolTip.Tip="{Binding [tooltip_click_to_edit_session_name], Source={x:Static loc:LocalizationManager.Instance}}" />

              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <TextBlock x:Name="TxtDifficulty" Text="{Binding [label_easy], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#90EE90" FontSize="11" FontWeight="SemiBold" Margin="0,0,15,0" />
                <TextBlock x:Name="TxtXP" Text="{Binding [label_300_xp], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#FFD700" FontSize="11" FontWeight="SemiBold" Margin="0,0,15,0" />
                <TextBlock x:Name="TxtDuration" Text="{Binding [label_30_min_2], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="#E0E0E0" FontSize="11" Margin="0,0,0,0" />
              </StackPanel>
            </StackPanel>

            <!-- Duration Slider -->
            <Grid Grid.Row="1" Margin="20,6,20,6" ColumnDefinitions="Auto,*,Auto">
              <TextBlock Text="{Binding [setting_duration], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#B0B0B0" FontSize="11"
                         VerticalAlignment="Center" Margin="0,0,10,0" />

              <Slider x:Name="SliderDuration" Grid.Column="1"
                      Minimum="5" Maximum="181" Value="30"
                      TickFrequency="5" IsSnapToTickEnabled="True"
                      ValueChanged="SliderDuration_ValueChanged" />

              <TextBlock x:Name="TxtDurationValue" Grid.Column="2" Text="{Binding [label_30_min_2], Source={x:Static loc:LocalizationManager.Instance}}"
                         Foreground="#E0E0E0" FontSize="11" FontWeight="SemiBold"
                         VerticalAlignment="Center" Margin="10,0,0,0" Width="45" />
            </Grid>

            <!-- Timeline -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Margin="20,6,20,6" Padding="10" MinHeight="100" MaxHeight="180">
              <Grid RowDefinitions="Auto,*">
                <Canvas x:Name="CanvasMarkers" Grid.Row="0" Height="16" Margin="0,0,0,4" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,15,0">
                  <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4"
                          x:Name="TimelineDropZone"
                          PointerEntered="Timeline_PointerEntered"
                          PointerExited="Timeline_PointerExited">
                    <Canvas x:Name="CanvasTimeline" ClipToBounds="True" MinHeight="40" Background="Transparent">
                      <TextBlock Text="{Binding [label_drag_features_here_to_add_them_to_the_timelin], Source={x:Static loc:LocalizationManager.Instance}}"
                                 Foreground="#555" FontSize="10" FontStyle="Italic"
                                 Canvas.Left="8" Canvas.Top="12"
                                 x:Name="TxtTimelineHint" />
                    </Canvas>
                  </Border>
                </ScrollViewer>
              </Grid>
            </Border>

            <!-- Feature Icons Grid - Horizontal Layout -->
            <Border Grid.Row="3" Margin="20,6,20,6">
              <Grid x:Name="FeatureIconsPanel" ColumnDefinitions="*,*,*,*,*">
                <StackPanel Grid.Column="0" Margin="3,0">
                  <TextBlock Text="{Binding [label_audio], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="{DynamicResource PinkBrush}" FontSize="9" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Margin="0,3,0,5" />
                  <StackPanel x:Name="AudioFeatures" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="3,0">
                  <TextBlock Text="{Binding [label_video], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="{DynamicResource PinkBrush}" FontSize="9" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Margin="0,3,0,5" />
                  <StackPanel x:Name="VideoFeatures" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="3,0">
                  <TextBlock Text="{Binding [label_overlays_2], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="{DynamicResource PinkBrush}" FontSize="9" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Margin="0,3,0,5" />
                  <StackPanel x:Name="OverlayFeatures" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="3,0">
                  <TextBlock Text="{Binding [label_interactive], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="{DynamicResource PinkBrush}" FontSize="9" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Margin="0,3,0,5" />
                  <StackPanel x:Name="InteractiveFeatures" HorizontalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="3,0">
                  <TextBlock Text="{Binding [label_extras_2], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="{DynamicResource PinkBrush}" FontSize="9" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Margin="0,3,0,5" />
                  <StackPanel x:Name="ExtrasFeatures" HorizontalAlignment="Center" />
                </StackPanel>
              </Grid>
            </Border>

            <!-- Bottom Section: Description + Buttons -->
            <Grid Grid.Row="4" Margin="20,6,20,15" RowDefinitions="Auto,Auto">
              <Grid Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                <Button Content="{Binding [btn_import], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource SecondaryButton}"
                        Click="BtnImport_Click" Margin="0,0,8,0" FontSize="11" Padding="12,6" />
                <Button Grid.Column="1" Content="{Binding [btn_export], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource SecondaryButton}"
                        Click="BtnExport_Click" FontSize="11" Padding="12,6" />

                <Button Grid.Column="3" Content="{Binding [btn_cancel], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource SecondaryButton}"
                        Click="BtnCancel_Click" Margin="0,0,8,0" FontSize="11" Padding="12,6" />
                <Button Grid.Column="4" Content="{Binding [btn_save_session], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource ActionButton}"
                        Click="BtnSave_Click" FontSize="11" Padding="12,6" />
              </Grid>

              <Grid Grid.Row="1" RowDefinitions="Auto,Auto">
                <TextBlock Text="{Binding [label_vibe_description], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#888" FontSize="10" Margin="0,0,0,4" />
                <TextBox x:Name="TxtDescription" Grid.Row="1"
                         Height="55" TextWrapping="Wrap" AcceptsReturn="True"
                         Background="{DynamicResource PanelBgBrush}" Foreground="#E0E0E0"
                         BorderBrush="#353555" BorderThickness="1"
                         Padding="8" FontSize="11" ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ToolTip.Tip="{Binding [tooltip_enter_a_description_for_your_session], Source={x:Static loc:LocalizationManager.Instance}}" />
              </Grid>
            </Grid>
          </Grid>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Popup overlay for settings -->
    <Popup x:Name="SettingsPopup" Placement="Pointer">
      <local:FeatureSettingsPopup x:Name="FeatureSettings" />
    </Popup>

    <!-- Tutorial Overlay -->
    <Border x:Name="TutorialOverlay" IsVisible="False" Background="#E0000000" CornerRadius="12">
      <Grid>
        <Border Background="Transparent" PointerPressed="TutorialOverlay_Close" />

        <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="12" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
                MaxWidth="600" MaxHeight="550" VerticalAlignment="Center" HorizontalAlignment="Center"
                Margin="50">
          <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="10,10,0,0" Padding="20,15">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding [label_how_to_use_the_session_editor], Source={x:Static loc:LocalizationManager.Instance}}"
                           Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <Button Content="✕" Click="TutorialOverlay_Close"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="Transparent" Foreground="#888" FontSize="14"
                        BorderThickness="0" Cursor="Hand" Margin="0,-5,-5,0" />
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
              <StackPanel>
                <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <Border Background="#4CAF50" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                        <TextBlock Text="1" Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding [label_hover_to_see_description], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding [label_hover_over_any_feature_icon_to_see_its_name_a], Source={x:Static loc:LocalizationManager.Instance}}"
                               Foreground="#B0B0B0" FontSize="13" TextWrapping="Wrap" Margin="34,0,0,0" />
                  </StackPanel>
                </Border>

                <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <Border Background="#2196F3" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                        <TextBlock Text="2" Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding [label_drag_to_create_segments], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding [label_drag_a_feature_icon_onto_the_timeline_to_crea], Source={x:Static loc:LocalizationManager.Instance}}"
                               Foreground="#B0B0B0" FontSize="13" TextWrapping="Wrap" Margin="34,0,0,0" />
                  </StackPanel>
                </Border>

                <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <Border Background="#FF9800" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                        <TextBlock Text="3" Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding [label_resize_move_segments], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding [label_drag_the_left_or_right_edge_handles_to_resize], Source={x:Static loc:LocalizationManager.Instance}}"
                               Foreground="#B0B0B0" FontSize="13" TextWrapping="Wrap" Margin="34,0,0,0" />
                  </StackPanel>
                </Border>

                <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <Border Background="#9C27B0" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                        <TextBlock Text="4" Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                      <TextBlock Text="{Binding [label_right_click_to_edit_settings], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding [label_right_click_any_segment_on_the_timeline_to_op], Source={x:Static loc:LocalizationManager.Instance}}"
                               Foreground="#B0B0B0" FontSize="13" TextWrapping="Wrap" Margin="34,0,0,0" />
                  </StackPanel>
                </Border>

                <Border Background="#203A20" CornerRadius="8" Padding="15" BorderBrush="#4CAF50" BorderThickness="1">
                  <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                      <Border Background="#4CAF50" CornerRadius="12" Width="24" Height="24" Margin="0,0,10,0">
                        <TextBlock Text="*" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Text="{Binding [label_full_session_coverage], Source={x:Static loc:LocalizationManager.Instance}}" Foreground="#4CAF50" FontSize="14" FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding [label_to_make_an_effect_last_the_entire_session_sim], Source={x:Static loc:LocalizationManager.Instance}}"
                               Foreground="#A5D6A7" FontSize="13" TextWrapping="Wrap" Margin="34,0,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" CornerRadius="0,0,10,10" Padding="20,15">
              <Button Content="{Binding [btn_got_it], Source={x:Static loc:LocalizationManager.Instance}}" Theme="{StaticResource ActionButton}"
                      HorizontalAlignment="Center" Click="TutorialOverlay_Close"
                      Padding="40,10" />
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>

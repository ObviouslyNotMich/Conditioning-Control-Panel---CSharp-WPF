<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.LockCardWindow" x:DataType="x:Object"
        Title="{Binding [dialog_lock_card], Source={x:Static loc:LocalizationManager.Instance}}"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <!-- Semi-transparent background -->
  <Grid x:Name="MainGrid" Background="#E6000000">

    <!-- Centered card -->
    <Border x:Name="CardBorder"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="16"
            Padding="50,40"
            MinWidth="500"
            MaxWidth="700"
            Background="{DynamicResource DarkerBgBrush}">

      <StackPanel>
        <!-- Lock icon and title -->
        <TextBlock Text="🔐"
                   FontSize="52"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10" />
        <TextBlock x:Name="TxtTitle"
                   Text="{Binding [label_type_to_unlock_2], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"
                   Foreground="{DynamicResource PinkBrush}" />

        <!-- The phrase to type -->
        <TextBlock x:Name="TxtPhrase"
                   Text="{Binding [label_good_girls_obey], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"
                   Margin="0,0,0,25" TextWrapping="Wrap" TextAlignment="Center"
                   Foreground="{DynamicResource PinkBrush}" />

        <!-- Input field -->
        <Border x:Name="InputBorder" CornerRadius="8" Padding="15,12" Margin="0,0,0,20"
                Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource PinkBrush}"
                BorderThickness="2">
          <TextBox x:Name="TxtInput"
                   Background="Transparent"
                   BorderThickness="0"
                   FontSize="20"
                   Foreground="{DynamicResource TextLightBrush}"
                   TextAlignment="Center"
                   TextChanged="TxtInput_TextChanged"
                   MaxLength="200">
            <TextBox.CaretBrush>
              <SolidColorBrush Color="{DynamicResource PinkColor}" />
            </TextBox.CaretBrush>
          </TextBox>
        </Border>

        <!-- Progress indicator -->
        <Grid Margin="0,10,0,0" ColumnDefinitions="Auto,*,Auto">
          <TextBlock x:Name="TxtProgress" Grid.Column="0" Text="0 / 3"
                     FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"
                     Foreground="#888888" />

          <Border x:Name="ProgressBarContainer" Grid.Column="1" Background="{DynamicResource PanelAccentBrush}"
                  CornerRadius="4" Height="8" MinWidth="200">
            <Border x:Name="ProgressBar" Background="{DynamicResource PinkBrush}" CornerRadius="4"
                    HorizontalAlignment="Left" Width="0" />
          </Border>

          <TextBlock x:Name="TxtStrict" Grid.Column="2" Text=""
                     FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"
                     Foreground="{DynamicResource DangerBrush}" />
        </Grid>

        <!-- Hint text -->
        <TextBlock x:Name="TxtHint"
                   Text="{Binding [label_type_the_phrase_exactly_as_shown_above], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="11" HorizontalAlignment="Center" Margin="0,20,0,0"
                   Foreground="#666666" FontStyle="Italic" />

        <!-- Completion message (hidden initially) -->
        <StackPanel x:Name="CompletionPanel" IsVisible="False" Margin="0,20,0,0">
          <TextBlock Text="{Binding [label_good_girl_2], Source={x:Static loc:LocalizationManager.Instance}}"
                     FontSize="24" FontWeight="Bold"
                     HorizontalAlignment="Center" Foreground="#00E676" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- ESC hint (only if not strict) -->
    <TextBlock x:Name="TxtEscHint"
               Text="{Binding [label_press_esc_to_close_if_allowed], Source={x:Static loc:LocalizationManager.Instance}}"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,30"
               FontSize="11"
               Foreground="#444444" />
  </Grid>
</Window>

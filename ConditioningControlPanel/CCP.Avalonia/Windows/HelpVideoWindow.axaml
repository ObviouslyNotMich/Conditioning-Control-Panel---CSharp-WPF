<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.HelpVideoWindow"
        Title="{loc:Str window_help_video_help_title}"
        Width="480"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        CanResize="False"
        WindowDecorations="None"
        ShowInTaskbar="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
          BoxShadow="0 0 20 0 #80000000">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Titlebar -->
      <Border Grid.Row="0"
              Background="{DynamicResource PanelBgBrush}"
              BorderBrush="{DynamicResource PanelAccentBrush}"
              BorderThickness="0,0,0,1"
              PointerPressed="Titlebar_PointerPressed">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Icon (glyph) -->
          <Border Grid.Column="0"
                  Width="28" Height="28"
                  Margin="14,10,10,10"
                  CornerRadius="6"
                  Background="#33FF69B4">
            <TextBlock x:Name="TxtGlyph"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource PinkBrush}"/>
          </Border>

          <!-- Title -->
          <TextBlock Grid.Column="1"
                     x:Name="TxtTitle"
                     Text="{loc:Str window_help_video_help_title}"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="15"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis"/>

          <!-- Close button -->
          <Button Grid.Column="2"
                  x:Name="BtnClose"
                  Click="BtnClose_Click"
                  Cursor="Hand"
                  Width="38" Height="38"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="#808080"
                  ToolTip.Tip="{loc:Str tooltip_close_escape}"
                  CornerRadius="0">
            <TextBlock Text="✕"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="#808080"/>
          </Button>
        </Grid>
      </Border>

      <!-- Video surface (collapsed when no clip / LibVLC unavailable: fail soft) -->
      <Border x:Name="VideoContainer"
              Grid.Row="1"
              Height="270"
              Background="#000000"
              IsVisible="False">
        <vlc:VideoView x:Name="VideoView"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>
      </Border>

      <!-- Caption (below the clip) -->
      <TextBlock x:Name="TxtCaption"
                 Grid.Row="2"
                 Margin="16,14,16,8"
                 Foreground="{DynamicResource TextLightBrush}"
                 FontSize="13"
                 TextWrapping="Wrap"
                 LineHeight="19"
                 IsVisible="False"/>

      <!-- Watch full tutorial (hidden when no URL) -->
      <Button x:Name="BtnFullTutorial"
              Grid.Row="3"
              Margin="16,4,16,16"
              HorizontalAlignment="Left"
              Padding="14,7"
              Cursor="Hand"
              Click="BtnFullTutorial_Click"
              Background="{DynamicResource TransparentPinkBrush}"
              Foreground="{DynamicResource PinkBrush}"
              BorderBrush="{DynamicResource PinkBrush}"
              BorderThickness="1"
              FontSize="13"
              FontWeight="SemiBold"
              Content="{loc:Str help_video_watch_full_tutorial}"
              IsVisible="False"
              CornerRadius="6"/>
    </Grid>
  </Border>
</Window>

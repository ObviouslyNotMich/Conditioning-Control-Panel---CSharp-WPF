<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.MantraWindow" x:DataType="x:Object"
        Title="{Binding [dialog_mantra_lab], Source={x:Static loc:LocalizationManager.Instance}}"
        WindowState="Maximized"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <SolidColorBrush x:Key="SecondaryBrush" Color="#9966CC" />
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <!-- Layer 0: Radial gradient base -->
    <Border x:Name="BaseLayer">
      <Border.Background>
        <RadialGradientBrush Center="50%,50%" RadiusX="70%" RadiusY="70%">
          <GradientStop Color="#1A0A2E" Offset="0"/>
          <GradientStop Color="#0A0514" Offset="1"/>
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <!-- Layer 1: Color wash overlay (intensity tied to streak) -->
    <Border x:Name="WashLayer" Opacity="0">
      <Border.Background>
        <RadialGradientBrush Center="50%,50%" RadiusX="60%" RadiusY="60%">
          <GradientStop Color="#6633AA" Offset="0"/>
          <GradientStop Color="Transparent" Offset="1"/>
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <!-- Layer 2: Glow overlay (pulsing) -->
    <Border x:Name="GlowOverlay" Opacity="0">
      <Border.Background>
        <RadialGradientBrush Center="50%,60%" RadiusX="40%" RadiusY="40%">
          <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
          <GradientStop Color="Transparent" Offset="1"/>
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <!-- Layer 3: Vignette -->
    <Border>
      <Border.Background>
        <RadialGradientBrush Center="50%,50%" RadiusX="80%" RadiusY="80%">
          <GradientStop Color="Transparent" Offset="0.4"/>
          <GradientStop Color="#80000000" Offset="1"/>
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <!-- Content Grid -->
    <Grid Margin="40">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Top: Counters -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
        <StackPanel Margin="30,0">
          <TextBlock Text="{Binding [label_reps], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="#606080" FontSize="11" HorizontalAlignment="Center" FontWeight="Bold"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock x:Name="TxtCompletions" Text="0" Foreground="{DynamicResource TextLightBrush}" FontSize="36" FontWeight="Bold"/>
            <TextBlock x:Name="TxtTarget" Text="/10" Foreground="#606080" FontSize="24" VerticalAlignment="Bottom" Margin="2,0,0,4"/>
          </StackPanel>
        </StackPanel>
        <StackPanel Margin="30,0">
          <TextBlock Text="{Binding [label_streak], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="#606080" FontSize="11" HorizontalAlignment="Center" FontWeight="Bold"/>
          <TextBlock x:Name="TxtStreak" Text="0" Foreground="{DynamicResource PinkBrush}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
        <StackPanel Margin="30,0">
          <TextBlock Text="{Binding [label_best], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="#606080" FontSize="11" HorizontalAlignment="Center" FontWeight="Bold"/>
          <TextBlock x:Name="TxtBestStreak" Text="0" Foreground="{DynamicResource SecondaryBrush}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
      </StackPanel>

      <!-- Center: Mantra text -->
      <Viewbox Grid.Row="1" MaxWidth="1400" MaxHeight="300" VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border x:Name="MantraBorder"
                BoxShadow="0 0 30 0 #9966CC">
          <TextBlock x:Name="TxtMantra"
                     FontSize="72" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"
                     MaxWidth="1400" Padding="20"
                     RenderTransformOrigin="50%,50%"/>
        </Border>
      </Viewbox>

      <!-- Bottom: Input area -->
      <Border Grid.Row="2" Background="#20FFFFFF" CornerRadius="12" Padding="20,14"
              HorizontalAlignment="Center" MaxWidth="800" MinWidth="500" Margin="0,0,0,40"
              BorderThickness="1.5"
              x:Name="InputBorderHost">
        <Border.BorderBrush>
          <SolidColorBrush Color="{DynamicResource TransparentPink40}"/>
        </Border.BorderBrush>
        <Grid ColumnDefinitions="*,Auto">
          <TextBox x:Name="TxtInput" Grid.Column="0"
                   Background="Transparent" Foreground="{DynamicResource TextLightBrush}" FontSize="22"
                   BorderThickness="0"
                   VerticalAlignment="Center"
                   TextChanged="TxtInput_TextChanged"
                   KeyDown="TxtInput_KeyDown">
            <TextBox.CaretBrush>
              <SolidColorBrush Color="{DynamicResource PinkColor}" />
            </TextBox.CaretBrush>
          </TextBox>
          <TextBlock Grid.Column="1" Text="{Binding [label_esc_to_exit], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource PanelAccentBrush}" FontSize="11"
                     VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>
      </Border>
    </Grid>

    <!-- Session complete overlay -->
    <Border x:Name="CompletionOverlay" Background="#E0000000" IsVisible="False">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border BoxShadow="0 0 40 0 #E6FF69B4">
          <TextBlock Text="{Binding [label_session_complete], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="{DynamicResource PinkBrush}" FontSize="48" FontWeight="Bold"
                     HorizontalAlignment="Center"/>
        </Border>
        <TextBlock x:Name="TxtCompletionStats" Text="" Foreground="{DynamicResource SecondaryBrush}" FontSize="22"
                   HorizontalAlignment="Center" Margin="0,16,0,0"/>
        <TextBlock Text="{Binding [label_press_any_key_to_close], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="#606080" FontSize="14"
                   HorizontalAlignment="Center" Margin="0,24,0,0"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>

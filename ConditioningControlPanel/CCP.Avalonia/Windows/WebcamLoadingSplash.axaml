<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.WebcamLoadingSplash"
        Title="{loc:Str window_webcam_loading_splash_starting_eye_tracking_title}"
        Width="420" Height="200"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        PointerPressed="Window_PointerPressed">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="15"
          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
          BoxShadow="0 5 20 0 #80000000">
    <Grid Margin="28,18" RowDefinitions="Auto,Auto,Auto,Auto,*">
      <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock Text="&#x1F441;" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center" />
        <TextBlock Text="{loc:Str window_webcam_loading_splash_starting_eye_tracking_title}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource PinkBrush}"
                   VerticalAlignment="Center"
                   FontFamily="Segoe UI" />
      </StackPanel>

      <TextBlock x:Name="TxtStatus"
                 Grid.Row="1"
                 Text="{loc:Str window_webcam_loading_splash_preparing_eyetracking_engine_text}"
                 FontSize="12"
                 Foreground="#CCCCCC"
                 HorizontalAlignment="Center"
                 Margin="0,12,0,12"
                 FontFamily="Segoe UI" />

      <Grid Grid.Row="2" Height="8">
        <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4" />
        <Border x:Name="ProgressFill" CornerRadius="4" HorizontalAlignment="Stretch"
                RenderTransformOrigin="0,0.5">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="{DynamicResource PinkColor}" Offset="0" />
              <GradientStop Color="#DA70D6" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <Border.RenderTransform>
            <ScaleTransform ScaleX="0" ScaleY="1" />
          </Border.RenderTransform>
        </Border>
      </Grid>

      <TextBlock Grid.Row="3"
                 Text="{loc:Str window_webcam_loading_splash_first_run_can_take_a_few_text}"
                 FontSize="10"
                 Foreground="#888888"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 Margin="0,14,0,0"
                 FontFamily="Segoe UI" />

      <TextBlock Grid.Row="4"
                 Text="{loc:Str window_webcam_loading_splash_drag_move_text}"
                 FontSize="9"
                 Foreground="#555555"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,8,0,0"
                 FontFamily="Segoe UI" />
    </Grid>
  </Border>
</Window>

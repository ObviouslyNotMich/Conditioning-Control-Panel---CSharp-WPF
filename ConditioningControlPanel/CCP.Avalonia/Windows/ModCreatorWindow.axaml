<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.ModCreatorWindow"
        Title="{loc:Str dialog_mod_creator}"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        CanResize="True"
        PointerPressed="TitleBar_PointerPressed">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Dark TextBox -->
      <ControlTheme x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#252542" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#505070" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="White" />
        <Setter Property="CornerRadius" Value="4" />
      </ControlTheme>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="#1A1A2E" CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
          BoxShadow="0 0 30 0 #80000000">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Border Grid.Row="0" Background="#252542" CornerRadius="12,12,0,0" Padding="20,10"
              PointerPressed="TitleBar_PointerPressed">
        <Grid>
          <TextBlock Text="{loc:Str dialog_mod_creator}"
                     Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"
                     VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="?" Click="BtnHelp_Click"
                    Background="Transparent" Foreground="{DynamicResource PinkBrush}" FontSize="16" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Padding="8,2" Width="30" Height="30"
                    ToolTip.Tip="{loc:Str tooltip_mod_creator_tutorial}"
                    CornerRadius="4"/>
            <Button Content="_" Click="BtnMinimize_Click"
                    Background="Transparent" Foreground="#B0B0B0" FontSize="14"
                    BorderThickness="0" Cursor="Hand" Padding="8,2" Width="30" Height="30"
                    CornerRadius="4"/>
            <Button Content="{loc:Str window_mod_creator_x_content}" Click="BtnClose_Click"
                    Background="Transparent" Foreground="#B0B0B0" FontSize="16" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Padding="8,2" Width="30" Height="30"
                    CornerRadius="4"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Main Content -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="200"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1E1E36" CornerRadius="0,0,0,12" Padding="0,8">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SidebarPanel"/>
          </ScrollViewer>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Column="1" x:Name="ContentScroll"
                      VerticalScrollBarVisibility="Auto" Padding="20,10,20,10">
          <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>
      </Grid>

      <!-- Bottom Bar -->
      <Border Grid.Row="2" Background="#252542" CornerRadius="0,0,12,12" Padding="15,10">
        <Grid>
          <TextBlock x:Name="TxtStatus" Foreground="#808080" FontSize="12"
                     VerticalAlignment="Center" HorizontalAlignment="Left"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{loc:Str btn_load_ccpmod}"
                    Theme="{StaticResource SecondaryButton}"
                    Click="BtnLoad_Click" Margin="0,0,8,0"/>
            <Button Content="{loc:Str btn_reset_all}"
                    Theme="{StaticResource DangerButton}"
                    Click="BtnReset_Click" Margin="0,0,8,0"/>
            <Button Content="{loc:Str btn_export_as_ccpmod}"
                    Theme="{StaticResource ActionButton}"
                    Click="BtnExport_Click"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.HapticsSetupWindow"
        Title="{loc:Str dialog_haptics_setup_guide}"
        Height="700" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <SolidColorBrush x:Key="SecondaryBrush" Color="#9B59B6" />
    </ResourceDictionary>
  </Window.Resources>

  <Border CornerRadius="12" Background="{DynamicResource DarkerBgBrush}"
          BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="2"
          BoxShadow="0 0 30 0 #80000000">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <Grid Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Margin="0"
            ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Margin="15,10">
          <TextBlock x:Name="TxtTitle"
                     Text="{loc:Str dialog_haptics_setup_guide}"
                     Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
        </StackPanel>
        <Button Grid.Column="1" Content="{loc:Str window_haptics_setup_x_content}" Width="30" Height="30"
                Background="Transparent" Foreground="#808080"
                BorderThickness="0" FontSize="14" Cursor="Hand"
                Click="BtnClose_Click" Margin="0,5,10,5"
                CornerRadius="4"/>
      </Grid>

      <!-- Content Area -->
      <Grid Grid.Row="1" Margin="20">

        <!-- Provider Selection (Initial Screen) -->
        <Grid x:Name="ProviderSelectionGrid" IsVisible="True">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{loc:Str label_select_your_device_type}"
                       Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Button x:Name="BtnSelectLovense" Width="280" Height="80"
                    Background="#2D2D4A" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
                    Cursor="Hand" Click="BtnSelectLovense_Click" Margin="0,10"
                    CornerRadius="8">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{loc:Str label_lovense}"
                           Foreground="{DynamicResource PinkBrush}" FontSize="20"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{loc:Str label_connect}"
                           Foreground="White" FontSize="20"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button x:Name="BtnSelectButtplug" Width="280" Height="80"
                    Background="#2D2D4A" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="2"
                    Cursor="Hand" Click="BtnSelectButtplug_Click" Margin="0,10"
                    CornerRadius="8">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{loc:Str label_buttplug_io}"
                           Foreground="{DynamicResource SecondaryBrush}" FontSize="20"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{loc:Str label_intiface}"
                           Foreground="White" FontSize="18"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>

        <!-- Lovense Tutorial Slides -->
        <Grid x:Name="LovenseSlides" IsVisible="False">
          <!-- Slide 1: Discover + Game Mode -->
          <Grid x:Name="LovenseSlide1" IsVisible="True">
            <StackPanel>
              <Border Background="{DynamicResource PinkBrush}" CornerRadius="4" Padding="8,4"
                      HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Text="{loc:Str label_step_1}"
                           Foreground="White" FontWeight="Bold" FontSize="12"/>
              </Border>
              <TextBlock Text="{loc:Str label_open_lovense_remote_app_2}"
                         Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
              <TextBlock Text="{loc:Str window_haptics_setup_1_open_lovense_remote_app_on}" xml:space="preserve"
                         TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15" />
              <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                <Image x:Name="ImgLovenseStep1" Stretch="Uniform"/>
              </Border>
            </StackPanel>
          </Grid>

          <!-- Slide 2: Enable LAN -->
          <Grid x:Name="LovenseSlide2" IsVisible="False">
            <StackPanel>
              <Border Background="{DynamicResource PinkBrush}" CornerRadius="4" Padding="8,4"
                      HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Text="{loc:Str label_step_2}"
                           Foreground="White" FontWeight="Bold" FontSize="12"/>
              </Border>
              <TextBlock Text="{loc:Str label_enable_lan_connection}"
                         Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
              <TextBlock Text="{loc:Str window_haptics_setup_1_toggle_enable_lan_on}" xml:space="preserve"
                         TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15" />
              <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                <Image x:Name="ImgLovenseStep2" Stretch="Uniform"/>
              </Border>
            </StackPanel>
          </Grid>

          <!-- Slide 3: Enter URL -->
          <Grid x:Name="LovenseSlide3" IsVisible="False">
            <StackPanel VerticalAlignment="Center">
              <Border Background="{DynamicResource PinkBrush}" CornerRadius="4" Padding="8,4"
                      HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Text="{loc:Str label_step_3}"
                           Foreground="White" FontWeight="Bold" FontSize="12"/>
              </Border>
              <TextBlock Text="{loc:Str label_enter_connection_url}"
                         Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

              <Border Background="#2D2D4A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                  <TextBlock Text="{loc:Str label_in_the_conditioning_control_panel}"
                             Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                  <TextBlock Text="{loc:Str window_haptics_setup_1_select_lovense_connect_as_provider}" xml:space="preserve"
                             TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" />

                  <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="12" Margin="0,10,0,10">
                    <TextBlock Text="{loc:Str window_haptics_setup_httpipport_text}" Foreground="{DynamicResource PinkBrush}"
                               FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                  </Border>

                  <TextBlock Text="{loc:Str label_example}"
                             Foreground="#808080" FontSize="12" Margin="0,5,0,5"/>
                  <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="10">
                    <TextBlock Text="{loc:Str window_haptics_setup_http192168110420010_text}" Foreground="#00FF00"
                               FontSize="14" FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                  </Border>

                  <TextBlock Text="{loc:Str window_haptics_setup_3_click_connect}" xml:space="preserve"
                             TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,15,0,0" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Grid>

        <!-- Buttplug.io Tutorial Slides -->
        <Grid x:Name="ButtplugSlides" IsVisible="False">
          <!-- Slide 1: Start Engine -->
          <Grid x:Name="ButtplugSlide1" IsVisible="True">
            <StackPanel>
              <Border Background="{DynamicResource SecondaryBrush}" CornerRadius="4" Padding="8,4"
                      HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Text="{loc:Str label_step_1}"
                           Foreground="White" FontWeight="Bold" FontSize="12"/>
              </Border>
              <TextBlock Text="{loc:Str label_start_intiface_central}"
                         Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
              <TextBlock Text="{loc:Str window_haptics_setup_1_download_install_intiface_central}" xml:space="preserve"
                         TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15" />
              <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                <Image x:Name="ImgButtplugStep1" Stretch="Uniform"/>
              </Border>
            </StackPanel>
          </Grid>

          <!-- Slide 2: Find Device -->
          <Grid x:Name="ButtplugSlide2" IsVisible="False">
            <StackPanel>
              <Border Background="{DynamicResource SecondaryBrush}" CornerRadius="4" Padding="8,4"
                      HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Text="{loc:Str label_step_2}"
                           Foreground="White" FontWeight="Bold" FontSize="12"/>
              </Border>
              <TextBlock Text="{loc:Str label_connect_your_device}"
                         Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
              <TextBlock Text="{loc:Str window_haptics_setup_1_put_toy_pairing_mode}" xml:space="preserve"
                         TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,0,0,15" />
              <Border Background="#2D2D4A" CornerRadius="8" Padding="10" MaxHeight="400">
                <Image x:Name="ImgButtplugStep2" Stretch="Uniform"/>
              </Border>
            </StackPanel>
          </Grid>

          <!-- Slide 3: Enter URL -->
          <Grid x:Name="ButtplugSlide3" IsVisible="False">
            <StackPanel VerticalAlignment="Center">
              <Border Background="{DynamicResource SecondaryBrush}" CornerRadius="4" Padding="8,4"
                      HorizontalAlignment="Left" Margin="0,0,0,10">
                <TextBlock Text="{loc:Str label_step_3}"
                           Foreground="White" FontWeight="Bold" FontSize="12"/>
              </Border>
              <TextBlock Text="{loc:Str label_enter_connection_url}"
                         Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

              <Border Background="#2D2D4A" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                  <TextBlock Text="{loc:Str label_in_the_conditioning_control_panel}"
                             Foreground="White" FontSize="14" Margin="0,0,0,15"/>
                  <TextBlock Text="{loc:Str window_haptics_setup_1_select_buttplugio_intiface_as_provider}" xml:space="preserve"
                             TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" />

                  <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="12" Margin="0,10,0,10">
                    <TextBlock Text="{loc:Str label_ws_localhost_12345}"
                               Foreground="{DynamicResource SecondaryBrush}"
                               FontSize="16" FontWeight="Bold" FontFamily="Consolas"
                               HorizontalAlignment="Center"/>
                  </Border>

                  <TextBlock Text="{loc:Str window_haptics_setup_default_intiface_server_address}" xml:space="preserve"
                             TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,10,0,0" />

                  <TextBlock Text="{loc:Str window_haptics_setup_3_click_connect_2}" xml:space="preserve"
                             TextWrapping="Wrap" Foreground="#B0B0B0" FontSize="13" Margin="0,15,0,0" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Grid>
      </Grid>

      <!-- Navigation Footer -->
      <Grid Grid.Row="2" Background="{DynamicResource PanelBgBrush}" Margin="0"
            ColumnDefinitions="*,Auto,*">

        <Button x:Name="BtnPrevious" Content="{loc:Str btn_previous}"
                Grid.Column="0" HorizontalAlignment="Left"
                Background="#353555" Foreground="White"
                BorderThickness="0" Padding="20,10" Margin="15,10"
                FontSize="13" Cursor="Hand" IsVisible="False"
                Click="BtnPrevious_Click"
                CornerRadius="6"/>

        <StackPanel x:Name="SlideIndicators" Grid.Column="1"
                    Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Center" IsVisible="False">
          <Ellipse x:Name="Dot1" Width="10" Height="10" Fill="{DynamicResource PinkBrush}" Margin="5,0"/>
          <Ellipse x:Name="Dot2" Width="10" Height="10" Fill="{DynamicResource PanelAccentBrush}" Margin="5,0"/>
          <Ellipse x:Name="Dot3" Width="10" Height="10" Fill="{DynamicResource PanelAccentBrush}" Margin="5,0"/>
        </StackPanel>

        <Button x:Name="BtnNext" Content="{loc:Str btn_next}"
                Grid.Column="2" HorizontalAlignment="Right"
                Background="{DynamicResource PinkBrush}" Foreground="White"
                BorderThickness="0" Padding="20,10" Margin="15,10"
                FontSize="13" Cursor="Hand" IsVisible="False"
                Click="BtnNext_Click"
                CornerRadius="6"/>

        <Button x:Name="BtnDone" Content="{loc:Str btn_done}"
                Grid.Column="2" HorizontalAlignment="Right"
                Background="#00AA00" Foreground="White"
                BorderThickness="0" Padding="20,10" Margin="15,10"
                FontSize="13" Cursor="Hand" IsVisible="False"
                Click="BtnClose_Click"
                CornerRadius="6"/>
      </Grid>
    </Grid>
  </Border>
</Window>

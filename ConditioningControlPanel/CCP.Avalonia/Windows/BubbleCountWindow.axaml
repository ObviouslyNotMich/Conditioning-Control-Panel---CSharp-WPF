<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.BubbleCountWindow"
        Title="{Binding [dialog_bubble_count_challenge], Source={x:Static loc:LocalizationManager.Instance}}"
        WindowDecorations="None"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        CanResize="False"
        WindowState="Maximized"
        WindowStartupLocation="Manual"
        FontFamily="Comic Sans MS, Segoe UI"
        KeyDown="Window_KeyDown">

  <Grid x:Name="MainGrid">
    <!-- Video Player -->
    <vlc:VideoView x:Name="VideoView"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" />

    <!-- Top Info Bar -->
    <Border Background="#80000000"
            VerticalAlignment="Top"
            Padding="20,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock Text="{Binding [label_count_the_bubbles], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PinkBrush}" />
        <TextBlock x:Name="TxtDifficulty"
                   Text="{Binding [label_medium_2], Source={x:Static loc:LocalizationManager.Instance}}"
                   FontSize="22"
                   Foreground="{DynamicResource PinkBrush}"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0" />
      </StackPanel>
    </Border>

    <!-- Strict Mode Indicator -->
    <TextBlock x:Name="TxtStrict"
               Text="{Binding [label_strict], Source={x:Static loc:LocalizationManager.Instance}}"
               FontSize="18"
               FontWeight="Bold"
               Foreground="#FF6B6B"
               VerticalAlignment="Top"
               HorizontalAlignment="Right"
               Margin="0,15,20,0"
               IsVisible="False" />

    <!-- ESC Hint -->
    <TextBlock x:Name="TxtEscHint"
               Text="{Binding [label_press_esc_to_skip_won_t_earn_xp], Source={x:Static loc:LocalizationManager.Instance}}"
               FontSize="16"
               Foreground="#888888"
               VerticalAlignment="Bottom"
               HorizontalAlignment="Center"
               Margin="0,0,0,20" />
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.QuizReportWindow" x:DataType="x:Object"
        Title="{Binding [dialog_quiz_report], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="700" Height="750"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Black"
        KeyDown="Window_KeyDown"
        x:CompileBindings="False">

  <Grid>
    <!-- Background -->
    <Border>
      <Border.Background>
        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.4" RadiusX="0.8" RadiusY="0.8">
          <GradientStop Color="#1A0A2E" Offset="0" />
          <GradientStop Color="#0A0514" Offset="1" />
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <!-- Vignette -->
    <Border IsHitTestVisible="False">
      <Border.Background>
        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
          <GradientStop Color="Transparent" Offset="0.5" />
          <GradientStop Color="#80000000" Offset="1" />
        </RadialGradientBrush>
      </Border.Background>
    </Border>

    <Grid Margin="30,20,30,20" RowDefinitions="Auto,*,Auto">
      <!-- Header -->
      <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
        <TextBlock Text="{Binding [label_quiz_report], Source={x:Static loc:LocalizationManager.Instance}}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextLightBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,4" />
        <TextBlock x:Name="TxtSubtitle" Foreground="#808090" FontSize="13"
                   HorizontalAlignment="Center" Margin="0,0,0,6" />
        <TextBlock x:Name="TxtScore" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PinkBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Scrollable content -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
        <StackPanel x:Name="ContentPanel" MaxWidth="600" HorizontalAlignment="Center" />
      </ScrollViewer>

      <!-- Close button -->
      <Button Grid.Row="2" Content="{Binding [btn_close], Source={x:Static loc:LocalizationManager.Instance}}" HorizontalAlignment="Center"
              Background="#20FFFFFF" Foreground="#B0B0C8" FontWeight="Bold" FontSize="14"
              BorderThickness="1" Padding="28,10" Click="BtnClose_Click">
        <Button.BorderBrush>
          <SolidColorBrush Color="#40FFFFFF" />
        </Button.BorderBrush>
      </Button>
    </Grid>
  </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.AchievementPopup"
        Title="{loc:Str window_achievement_achievement_unlocked_title}"
        Width="400" Height="200"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        PointerPressed="Window_PointerPressed">

    <Border Background="#E0151530" CornerRadius="12" BorderBrush="{StaticResource PinkBrush}" BorderThickness="2"
            Margin="10">
        <Border.BoxShadow>0 0 20 0 #80FF69B4</Border.BoxShadow>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Achievement Image -->
            <Border Grid.Column="0" Width="120" Height="120" Background="{StaticResource DarkerBgBrush}" Margin="0,0,15,0">
                <Image x:Name="AchievementImage" Stretch="Uniform" Margin="5"/>
            </Border>

            <!-- Text Content -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <!-- Trophy Icon + "Achievement Unlocked" -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock x:Name="TxtHeaderIcon" Text="🏆" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtHeaderText" Text="{loc:Str window_achievement_achievement_unlocked_text}" Foreground="#FFD700"
                               FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Achievement Name -->
                <TextBlock x:Name="TxtName" Text="{loc:Str window_achievement_achievement_name_text}"
                           Foreground="{StaticResource PinkBrush}"
                           FontWeight="Bold" FontSize="18"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- Flavor Text -->
                <TextBlock x:Name="TxtFlavor" Text="{loc:Str window_achievement_flavor_text_goes_here_text}"
                           Foreground="#AAAAAA" FontSize="12"
                           TextWrapping="Wrap" FontStyle="Italic"/>
            </StackPanel>

            <!-- Close Button -->
            <Button Grid.Column="1" Content="✕"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="24" Height="24" Margin="0,-5,-5,0"
                    Background="Transparent" Foreground="#888888"
                    BorderThickness="0"
                    Click="BtnClose_Click">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="#888888" />
                    </Style>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                </Button.Styles>
            </Button>
        </Grid>
    </Border>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.QuizWindow"
        Title="{loc:Str dialog_quiz}"
        Width="900" Height="750"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        CanResize="True"
        Background="Black"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        x:CompileBindings="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid RowDefinitions="Auto,*">
    <!-- Title bar -->
    <Border x:Name="TitleBar" Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Height="36"
            PointerPressed="TitleBar_PointerPressed">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{loc:Str dialog_quiz}" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="14,0,0,0" />
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button x:Name="BtnMaximizeTitleBar" Content="☐" Width="36" Height="36"
                  BorderThickness="0" FontSize="14" Cursor="Hand"
                  Click="BtnMaximizeTitleBar_Click"
                  ToolTip.Tip="{loc:Str tooltip_maximize_restore}"
                  Background="Transparent" Foreground="#808080" />
          <Button x:Name="BtnCloseTitleBar" Content="✕" Width="36" Height="36"
                  BorderThickness="0" FontSize="14" Cursor="Hand"
                  Click="BtnCloseTitleBar_Click"
                  ToolTip.Tip="{loc:Str tooltip_close_escape}"
                  Background="Transparent" Foreground="#808080" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Content area -->
    <Grid Grid.Row="1">
      <!-- Background layers -->
      <Border x:Name="BackgroundBorder">
        <Border.Background>
          <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.4" RadiusX="0.8" RadiusY="0.8">
            <GradientStop Color="#1A0A2E" Offset="0" />
            <GradientStop Color="#0A0514" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>

      <!-- Glow overlay -->
      <Border x:Name="GlowOverlay" Opacity="0.05" IsHitTestVisible="False">
        <Border.Background>
          <RadialGradientBrush Center="0.5,0.4" RadiusX="0.5" RadiusY="0.5">
            <GradientStop Color="{DynamicResource PinkColor}" Offset="0" />
            <GradientStop Color="Transparent" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>

      <!-- Vignette -->
      <Border IsHitTestVisible="False">
        <Border.Background>
          <RadialGradientBrush Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
            <GradientStop Color="Transparent" Offset="0.5" />
            <GradientStop Color="#80000000" Offset="1" />
          </RadialGradientBrush>
        </Border.Background>
      </Border>

      <!-- CATEGORY SELECT PANEL -->
      <Grid x:Name="CategorySelectPanel" IsVisible="True">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
          <!-- Title -->
          <Border HorizontalAlignment="Center" Margin="0,0,0,8"
                  BoxShadow="0 0 30 0 #60FF69B4">
            <TextBlock Text="{loc:Str label_sissy_quiz}" FontSize="58" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" />
          </Border>
          <TextBlock Text="{loc:Str label_ai_generated_personality_quiz}" Foreground="#808090" FontSize="19"
                     HorizontalAlignment="Center" Margin="0,0,0,40" />

          <TextBlock Text="{loc:Str label_choose_your_category}" Foreground="#B0B0C8" FontSize="22"
                     HorizontalAlignment="Center" Margin="0,0,0,20" />

          <!-- Dynamic category buttons (populated from code-behind) -->
          <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="CategoryButtonsPanel" />
          </ScrollViewer>

          <!-- ESC hint -->
          <TextBlock Text="{loc:Str label_press_esc_to_close}" Foreground="{DynamicResource PanelAccentBrush}" FontSize="13"
                     HorizontalAlignment="Center" Margin="0,24,0,0" />
        </StackPanel>
      </Grid>

      <!-- LOADING PANEL -->
      <Grid x:Name="LoadingPanel" IsVisible="False">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock x:Name="TxtLoadingDots" Text="{loc:Str label_generating_2}" FontSize="36" FontWeight="Bold"
                     Foreground="{DynamicResource PinkBrush}" HorizontalAlignment="Center" />
          <TextBlock x:Name="TxtLoadingFlavor" Text="{loc:Str label_the_quiz_master_is_thinking_up_something_devi}"
                     Foreground="#606080" FontSize="19" HorizontalAlignment="Center" Margin="0,12,0,0" />
        </StackPanel>
      </Grid>

      <!-- QUESTION PANEL -->
      <Grid x:Name="QuestionPanel" IsVisible="False" RowDefinitions="Auto,*">
        <!-- Top bar: progress dots + score -->
        <StackPanel Grid.Row="0" Margin="40,16,40,0">
          <Grid ColumnDefinitions="*,Auto">
            <!-- Progress dots -->
            <StackPanel x:Name="ProgressDotsPanel" Orientation="Horizontal" VerticalAlignment="Center" />

            <!-- Score -->
            <TextBlock x:Name="ScoreText" Grid.Column="1" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}" VerticalAlignment="Center" />
          </Grid>

          <!-- AI disclaimer -->
          <TextBlock Text="{loc:Str quiz_ai_disclaimer}"
                     FontSize="11"
                     FontStyle="Italic"
                     Foreground="#808090"
                     TextWrapping="Wrap"
                     Margin="0,6,0,0"
                     HorizontalAlignment="Left" />
        </StackPanel>

        <!-- Scrollable question + answers -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      MaxWidth="600" Margin="40,8,40,24">

            <!-- Question text -->
            <Grid Margin="0,0,0,18">
              <Grid x:Name="QuestionContentGrid">
                <TextBlock x:Name="TxtQuestion" FontSize="32" FontWeight="Bold"
                           Foreground="White" TextWrapping="Wrap" TextAlignment="Center" />
              </Grid>
            </Grid>

            <!-- Answer buttons -->
            <StackPanel x:Name="AnswersPanel">
              <Border x:Name="AnswerA" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                      PointerPressed="Answer_Click" Tag="0"
                      PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                      Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Text="{loc:Str window_quiz_a_text}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource PinkBrush}"
                             VerticalAlignment="Center" Margin="0,0,16,0" />
                  <TextBlock x:Name="TxtAnswerA" Grid.Column="1" FontSize="18" Foreground="#D0D0E0"
                             TextWrapping="Wrap" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <Border x:Name="AnswerB" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                      PointerPressed="Answer_Click" Tag="1"
                      PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                      Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Text="{loc:Str window_quiz_b_text}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource PinkBrush}"
                             VerticalAlignment="Center" Margin="0,0,16,0" />
                  <TextBlock x:Name="TxtAnswerB" Grid.Column="1" FontSize="18" Foreground="#D0D0E0"
                             TextWrapping="Wrap" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <Border x:Name="AnswerC" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                      PointerPressed="Answer_Click" Tag="2"
                      PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                      Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Text="{loc:Str window_quiz_c_text}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource PinkBrush}"
                             VerticalAlignment="Center" Margin="0,0,16,0" />
                  <TextBlock x:Name="TxtAnswerC" Grid.Column="1" FontSize="18" Foreground="#D0D0E0"
                             TextWrapping="Wrap" VerticalAlignment="Center" />
                </Grid>
              </Border>

              <Border x:Name="AnswerD" Cursor="Hand" CornerRadius="10" Margin="0,0,0,10" Padding="20,16"
                      PointerPressed="Answer_Click" Tag="3"
                      PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                      Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Text="{loc:Str window_quiz_d_text}" FontWeight="Bold" FontSize="20" Foreground="{DynamicResource PinkBrush}"
                             VerticalAlignment="Center" Margin="0,0,16,0" />
                  <TextBlock x:Name="TxtAnswerD" Grid.Column="1" FontSize="18" Foreground="#D0D0E0"
                             TextWrapping="Wrap" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- RESULT PANEL -->
      <Grid x:Name="ResultPanel" IsVisible="False">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      MaxWidth="600" Margin="40">
            <!-- Score header -->
            <TextBlock Text="{loc:Str label_your_result}" FontSize="24" FontWeight="Bold"
                       Foreground="#808090" HorizontalAlignment="Center" Margin="0,0,0,8" />

            <TextBlock x:Name="TxtFinalScore" FontSize="67" FontWeight="Bold"
                       Foreground="{DynamicResource PinkBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />

            <TextBlock x:Name="TxtScoreLabel" FontSize="19" Foreground="#606080"
                       HorizontalAlignment="Center" Margin="0,0,0,30" />

            <!-- Profile card -->
            <Border CornerRadius="14" Padding="24,20" Margin="0,0,0,30"
                    Background="#12FFFFFF"
                    BorderThickness="1">
              <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#40FF69B4" Offset="0" />
                  <GradientStop Color="#409B59B6" Offset="1" />
                </LinearGradientBrush>
              </Border.BorderBrush>
              <TextBlock x:Name="TxtProfileText" FontSize="22" Foreground="#C0C0D8"
                         TextWrapping="Wrap" LineHeight="34" TextAlignment="Center" />
            </Border>

            <!-- Quiz Session -->
            <Border x:Name="BtnTrySession" Cursor="Hand" CornerRadius="10" Padding="20,16"
                    Margin="0,0,0,20" IsHitTestVisible="False" Opacity="0.5"
                    Background="#209B59B6" BorderBrush="#409B59B6" BorderThickness="1.5"
                    PointerPressed="BtnTrySession_Click"
                    PointerEntered="BtnTrySession_PointerEntered" PointerExited="BtnTrySession_PointerExited">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtTrySessionIcon" Text="{loc:Str label_text_8}" FontSize="22"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock x:Name="TxtTrySessionLabel" Text="{loc:Str label_generating_your_session}"
                           Foreground="#C0C0D8" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- Score Trend -->
            <TextBlock x:Name="TxtTrendHeader" Text="{loc:Str label_your_journey}" FontSize="14" FontWeight="Bold"
                       Foreground="#606080" HorizontalAlignment="Center" Margin="0,0,0,10"
                       IsVisible="False" />
            <StackPanel x:Name="TrendPanel" Margin="0,0,0,20" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button x:Name="BtnPlayAgain" Content="{loc:Str btn_play_again}"
                      Background="{DynamicResource PanelBgBrush}" Foreground="White" FontWeight="Bold" FontSize="19"
                      BorderThickness="0" Padding="28,14" Margin="0,0,12,0"
                      Click="BtnPlayAgain_Click" />
              <Button x:Name="BtnCloseResult" Content="{loc:Str btn_close}"
                      Background="#20FFFFFF" Foreground="#B0B0C8" FontWeight="Bold" FontSize="19"
                      BorderThickness="1" Padding="28,14"
                      Click="BtnCloseResult_Click">
                <Button.BorderBrush>
                  <SolidColorBrush Color="#40FFFFFF" />
                </Button.BorderBrush>
              </Button>
            </StackPanel>

            <!-- AI disclaimer -->
            <TextBlock Text="{loc:Str quiz_ai_disclaimer}"
                       FontSize="11"
                       FontStyle="Italic"
                       Foreground="#808090"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,24,0,0" />
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <!-- ERROR PANEL -->
      <Grid x:Name="ErrorPanel" IsVisible="False">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
          <TextBlock Text="{loc:Str label_oops}" FontSize="34" FontWeight="Bold" Foreground="#FF6B6B"
                     HorizontalAlignment="Center" Margin="0,0,0,12" />
          <TextBlock x:Name="TxtError" FontSize="17" Foreground="#808090"
                     TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24" />
          <Button Content="{loc:Str btn_try_again}"
                  Background="{DynamicResource PanelBgBrush}" Foreground="White" FontWeight="Bold" FontSize="17"
                  BorderThickness="0" Padding="24,12" HorizontalAlignment="Center"
                  Click="BtnPlayAgain_Click" />
          <TextBlock Text="{loc:Str label_press_esc_to_close}" Foreground="{DynamicResource PanelAccentBrush}" FontSize="13"
                     HorizontalAlignment="Center" Margin="0,16,0,0" />
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>

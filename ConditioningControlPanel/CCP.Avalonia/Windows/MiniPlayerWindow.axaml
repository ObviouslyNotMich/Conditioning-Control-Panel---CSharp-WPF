<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        xmlns:loc="using:ConditioningControlPanel.Core.Localization"
        x:Class="ConditioningControlPanel.Avalonia.Windows.MiniPlayerWindow"
        Title="{Binding [section_preview], Source={x:Static loc:LocalizationManager.Instance}}"
        Height="350" Width="450"
        MinHeight="200" MinWidth="300"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        CanResize="True"
        KeyDown="Window_KeyDown"
        PointerPressed="Window_PointerPressed">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border CornerRadius="8" Background="{DynamicResource DarkerBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
          BoxShadow="0 0 20 0 #80000000">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="32"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Title Bar -->
      <Grid Grid.Row="0" Background="{DynamicResource PanelBgBrush}"
            ColumnDefinitions="*,Auto">
        <TextBlock x:Name="TxtFileName"
                   Text="{Binding [section_preview], Source={x:Static loc:LocalizationManager.Instance}}"
                   Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="12,0,0,0"
                   TextTrimming="CharacterEllipsis"/>
        <Button Grid.Column="1" Content="✕" Width="32" Height="32"
                BorderThickness="0" FontSize="14" Cursor="Hand"
                Click="BtnClose_Click"
                ToolTip.Tip="{Binding [tooltip_close_escape], Source={x:Static loc:LocalizationManager.Instance}}"
                Background="Transparent" Foreground="#808080"
                CornerRadius="0"/>
      </Grid>

      <!-- Content Area -->
      <Grid Grid.Row="1" Background="#000000">
        <!-- Video Player (LibVLC) -->
        <Border x:Name="VideoContainer" IsVisible="False">
          <vlc:VideoView x:Name="VideoView"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"/>
        </Border>

        <!-- Image/GIF Display -->
        <Image x:Name="ImagePreview" Stretch="Uniform" IsVisible="False"/>

        <!-- Loading Indicator -->
        <Grid x:Name="LoadingOverlay" IsVisible="False">
          <TextBlock Text="{Binding [label_loading_2], Source={x:Static loc:LocalizationManager.Instance}}"
                     Foreground="#808080" FontSize="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
      </Grid>

      <!-- Video Controls (only shown for videos) -->
      <Grid x:Name="VideoControls" Grid.Row="2" Background="{DynamicResource PanelBgBrush}" Height="40" IsVisible="False"
            ColumnDefinitions="Auto,*,Auto">

        <!-- Play/Pause Button -->
        <Button x:Name="BtnPlayPause" Grid.Column="0"
                Content="▶" Width="36" Height="28"
                Background="#353555" Foreground="{DynamicResource PinkBrush}"
                BorderThickness="0" FontSize="12" Cursor="Hand"
                Margin="8,0,0,0"
                Click="BtnPlayPause_Click"
                ToolTip.Tip="{Binding [tooltip_play_pause_space], Source={x:Static loc:LocalizationManager.Instance}}"
                CornerRadius="4"/>

        <!-- Seek Slider -->
        <Slider x:Name="SeekSlider" Grid.Column="1"
                Minimum="0" Maximum="100" Value="0"
                VerticalAlignment="Center" Margin="10,0"
                PointerPressed="SeekSlider_PointerPressed"
                PointerReleased="SeekSlider_PointerReleased"
                ValueChanged="SeekSlider_ValueChanged"/>

        <!-- Time Display -->
        <TextBlock x:Name="TxtTime" Grid.Column="2"
                   Text="00:00 / 00:00" Foreground="#808080" FontSize="11"
                   VerticalAlignment="Center" Margin="0,0,12,0"
                   FontFamily="Consolas"/>
      </Grid>
    </Grid>
  </Border>
</Window>

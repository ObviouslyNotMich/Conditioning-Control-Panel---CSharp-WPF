<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
             x:Class="ConditioningControlPanel.Avalonia.Windows.FeatureSettingsPopup" x:DataType="x:Object"
             Width="320">
  <Border Background="{DynamicResource SurfaceBgBrush}"
          BorderBrush="{DynamicResource PinkBrush}"
          BorderThickness="2"
          CornerRadius="10"
          Padding="15">
    <Grid RowDefinitions="Auto,Auto,*,Auto">

      <!-- Header -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
        <TextBlock x:Name="TxtIcon"
                   Width="26"
                   Height="26"
                   FontSize="20"
                   Text="⚡"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   Foreground="{DynamicResource TextLightBrush}" />
        <StackPanel>
          <TextBlock x:Name="TxtFeatureName"
                     Foreground="{DynamicResource PinkBrush}"
                     FontSize="16"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="TxtEventType"
                     Foreground="{DynamicResource TextMutedBrush}"
                     FontSize="11" />
        </StackPanel>
      </StackPanel>

      <!-- Minute position -->
      <Grid Grid.Row="1" Margin="0,0,0,15" ColumnDefinitions="Auto,*,Auto">
        <TextBlock Text="{loc:Str feature_settings_minute}"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="12"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0" />
        <Slider x:Name="SliderMinute"
                Grid.Column="1"
                Minimum="0"
                Maximum="120"
                Value="0"
                ValueChanged="SliderMinute_ValueChanged" />
        <TextBlock x:Name="TxtMinuteValue"
                   Grid.Column="2"
                   Text="0"
                   Foreground="White"
                   FontSize="12"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"
                   Margin="10,0,0,0" />
      </Grid>

      <!-- Dynamic settings -->
      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="300">
        <StackPanel x:Name="SettingsPanel" />
      </ScrollViewer>

      <!-- Buttons -->
      <Grid Grid.Row="3" Margin="0,15,0,0" ColumnDefinitions="Auto,*,Auto">
        <Button x:Name="BtnDelete"
                Content="{loc:Str btn_delete}"
                Theme="{StaticResource DangerButton}"
                Click="BtnDelete_Click" />
        <Button x:Name="BtnDone"
                Grid.Column="2"
                Content="{loc:Str btn_done}"
                Theme="{StaticResource PinkButton}"
                Click="BtnDone_Click" />
      </Grid>
    </Grid>
  </Border>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.EasterEggWindow"
        Title="..."
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://CCP.Avalonia/Dialogs/DialogResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="12"
          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
          BoxShadow="0 0 30 0 #80FF69B4">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Close Button -->
      <Button Grid.Row="0" Content="×" Click="BtnClose_Click"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Background="Transparent" Foreground="#666666" FontSize="20"
              BorderThickness="0" Cursor="Hand" Margin="0,10,15,0"
              Width="30" Height="30"/>

      <!-- Content -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,10,25,10">
        <StackPanel>
          <TextBlock Text="{loc:Str window_easter_egg_congrats}" xml:space="preserve"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" LineHeight="20" />
          <TextBlock x:Name="TxtReaderCount"
                     FontFamily="Consolas" FontSize="11"
                     Foreground="#FF4444"
                     Margin="0,15,0,5"
                     HorizontalAlignment="Center"
                     IsVisible="False"/>
        </StackPanel>
      </ScrollViewer>

      <!-- Footer -->
      <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" CornerRadius="0,0,10,10" Padding="20,12">
        <Button Content="{loc:Str btn_close_2}"
                Click="BtnClose_Click"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Background="{DynamicResource PinkBrush}"
                Foreground="White"
                FontWeight="Bold"
                FontSize="13"
                Padding="30,10"
                CornerRadius="6"
                BorderThickness="0"/>
      </Border>
    </Grid>
  </Border>
</Window>

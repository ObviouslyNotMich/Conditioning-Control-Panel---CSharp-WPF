<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.PopQuizWindow" x:DataType="x:Object"
        Title="{loc:Str window_pop_quiz_pop_quiz_title}"
        Width="500" Height="420"
        WindowStartupLocation="CenterScreen"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        KeyDown="Window_KeyDown">

  <Border CornerRadius="16" Margin="10"
          Background="#F0151530"
          BorderThickness="1.5"
          BoxShadow="0 0 20 0 #80000000">
    <Border.BorderBrush>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource TransparentPink60}" Offset="0" />
        <GradientStop Color="{DynamicResource TransparentPink40}" Offset="1" />
      </LinearGradientBrush>
    </Border.BorderBrush>

    <Grid Margin="24,20">
      <!-- Question Panel -->
      <StackPanel x:Name="QuestionPanel" VerticalAlignment="Center">
        <TextBlock x:Name="TxtQuestion"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextLightBrush}" TextWrapping="Wrap" TextAlignment="Center"
                   Margin="0,0,0,24" />

        <StackPanel x:Name="AnswersPanel">
          <Border x:Name="AnswerA" Cursor="Hand" CornerRadius="8" Margin="0,0,0,8" Padding="14,10"
                  PointerPressed="Answer_Click"
                  PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                  Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1"
                  Tag="0">
            <TextBlock x:Name="TxtAnswerA" FontSize="15" Foreground="#D0D0E0"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </Border>

          <Border x:Name="AnswerB" Cursor="Hand" CornerRadius="8" Margin="0,0,0,8" Padding="14,10"
                  PointerPressed="Answer_Click"
                  PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                  Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1"
                  Tag="1">
            <TextBlock x:Name="TxtAnswerB" FontSize="15" Foreground="#D0D0E0"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </Border>

          <Border x:Name="AnswerC" Cursor="Hand" CornerRadius="8" Margin="0,0,0,8" Padding="14,10"
                  PointerPressed="Answer_Click"
                  PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                  Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1"
                  Tag="2">
            <TextBlock x:Name="TxtAnswerC" FontSize="15" Foreground="#D0D0E0"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </Border>

          <Border x:Name="AnswerD" Cursor="Hand" CornerRadius="8" Margin="0,0,0,8" Padding="14,10"
                  PointerPressed="Answer_Click"
                  PointerEntered="Answer_PointerEntered" PointerExited="Answer_PointerExited"
                  Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1"
                  Tag="3">
            <TextBlock x:Name="TxtAnswerD" FontSize="15" Foreground="#D0D0E0"
                       TextWrapping="Wrap" TextAlignment="Center" />
          </Border>
        </StackPanel>

        <TextBlock x:Name="TxtEscHint"
                   Text="{loc:Str window_pop_quiz_esc_skip_text}" Foreground="#303050" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,8,0,0" />
      </StackPanel>

      <!-- Affirmation Panel (shown after answering) -->
      <StackPanel x:Name="AffirmationPanel"
                  IsVisible="False"
                  VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock x:Name="TxtAffirmation"
                   FontSize="22" FontWeight="SemiBold"
                   Foreground="{DynamicResource PinkBrush}"
                   TextWrapping="Wrap" TextAlignment="Center" />
        <TextBlock x:Name="TxtXpAwarded"
                   Text="{loc:Str window_pop_quiz_25_xp_text}" Foreground="#808090" FontSize="14" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,10,0,0" />
      </StackPanel>
    </Grid>
  </Border>
</Window>

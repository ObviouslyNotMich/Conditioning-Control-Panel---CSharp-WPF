<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Avalonia.Localization;assembly=CCP.Avalonia"
        x:Class="ConditioningControlPanel.Avalonia.Windows.WebcamGazeTrackerWindow" x:DataType="x:Object"
        Title="{loc:Str window_webcam_gaze_tracker_gaze_tracker_test_title}"
        Background="Black"
        WindowDecorations="None"
        WindowState="Maximized"
        CanResize="False"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

  <Grid>
    <Canvas x:Name="DotCanvas">
      <Ellipse x:Name="Dot" Width="36" Height="36" IsVisible="False">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#FF80E0FF" Offset="0" />
            <GradientStop Color="#FF00B0FF" Offset="0.6" />
            <GradientStop Color="#FF005080" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
    </Canvas>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,40,0,0">
      <TextBlock Text="{loc:Str window_webcam_gaze_tracker_gaze_tracker_test_title}" Foreground="{DynamicResource TextLightBrush}"
                 FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
      <TextBlock Text="{loc:Str window_webcam_gaze_tracker_look_around_screen_cyan_dot_should_text}"
                 Foreground="{DynamicResource TextDimBrush}" FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Center" />
      <TextBlock x:Name="TxtCoords" Text="" Foreground="#00B0FF" FontSize="12"
                 Margin="0,4,0,0" HorizontalAlignment="Center" FontFamily="Consolas" />
    </StackPanel>

    <Border x:Name="ErrorPanel" IsVisible="False"
            Background="#221A1A" BorderBrush="#FF4040" BorderThickness="2"
            CornerRadius="10" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center"
            MaxWidth="520">
      <StackPanel>
        <TextBlock Text="{loc:Str window_webcam_gaze_tracker_tracker_test_unavailable_text}" Foreground="#FF8080" FontSize="18"
                   FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock x:Name="TxtErrorDetail" Text="" Foreground="White" FontSize="13"
                   Margin="0,12,0,16" TextWrapping="Wrap" HorizontalAlignment="Center" />
        <Button x:Name="BtnErrorClose" Content="{loc:Str window_webcam_gaze_tracker_close_content}" Padding="20,8"
                Background="#00B0FF" Foreground="Black" BorderThickness="0"
                FontWeight="Bold" Click="BtnErrorClose_Click"
                HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

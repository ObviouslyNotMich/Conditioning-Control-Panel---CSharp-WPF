<Window x:Class="ConditioningControlPanel.ModSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        Title="{loc:Str dialog_choose_your_experience}"
        Height="480" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="12" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="{loc:Str dialog_choose_your_experience}"
                       Foreground="{DynamicResource PinkBrush}" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Subtitle -->
            <TextBlock Grid.Row="1" Text="{loc:Str label_select_a_theme_to_customize_your_experience_y}"
                       Foreground="#B0B0B0" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,25" TextWrapping="Wrap" TextAlignment="Center"/>

            <!-- Mode Selection Cards -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bambi Sleep Card -->
                <Border x:Name="CardBambi" Grid.Column="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="10"
                        Cursor="Hand" MouseLeftButtonDown="CardBambi_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelAccentBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                    <Setter Property="Background" Value="#2A2A4A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" Margin="20">
                        <TextBlock Text="{loc:Str label_bs}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource PinkBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Str label_bambi_sleep}" FontSize="18" FontWeight="SemiBold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#A0A0A0" FontSize="12" LineHeight="18">
                            <Run Text="{loc:Str label_bambi_sleep_specific_content}"/>
                            <LineBreak/>
                            <Run Text="{loc:Str label_includes_bambicloud_browser}"/>
                            <LineBreak/>
                            <Run Text="{loc:Str label_bambi_themed_triggers_and_prompts}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Sissy Hypno Card -->
                <Border x:Name="CardSissy" Grid.Column="2" Background="{DynamicResource PanelBgBrush}" CornerRadius="10"
                        Cursor="Hand" MouseLeftButtonDown="CardSissy_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelAccentBrush}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBrush}"/>
                                    <Setter Property="Background" Value="#2A2A4A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center" Margin="20">
                        <TextBlock Text="{loc:Str label_sh}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Str label_sissy_hypno}" FontSize="18" FontWeight="SemiBold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" Foreground="#A0A0A0" FontSize="12" LineHeight="18">
                            <Run Text="{loc:Str label_generic_sissy_hypno_content}"/>
                            <LineBreak/>
                            <Run Text="{loc:Str label_hypnotube_browser_only}"/>
                            <LineBreak/>
                            <Run Text="{loc:Str label_universal_triggers_and_prompts}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Install mod link -->
            <TextBlock Grid.Row="3" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Hyperlink x:Name="InstallModLink" Click="InstallModLink_Click"
                           Foreground="#606080" FontSize="11">
                    Have a .ccpmod file? Install it here
                </Hyperlink>
            </TextBlock>
        </Grid>
    </Border>
</Window>

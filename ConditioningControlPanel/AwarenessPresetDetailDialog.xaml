<Window x:Class="ConditioningControlPanel.AwarenessPresetDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        Title="Preset"
        Height="720" Width="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Topmost="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Dark-themed ComboBox style so the closed selection box and popup both
             render on dark chrome with white text, matching the rest of the app.
             The default WPF ComboBox template ignores Background on the closed
             state and shows white-on-white, which is unreadable. -->
        <Style x:Key="DialogDarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#1E1E32" BorderBrush="#3A3A5C" BorderThickness="1" CornerRadius="3" Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="#B0B0B0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 3.5 3.5 L 7 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,18,3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1E1E32" BorderBrush="#3A3A5C" BorderThickness="1" CornerRadius="3" Margin="0,1,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#1E1E32"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FF69B4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" CornerRadius="0">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Policy banner (full or slim) -->
                <RowDefinition Height="Auto"/>  <!-- Header: icon + name -->
                <RowDefinition Height="Auto"/>  <!-- Description -->
                <RowDefinition Height="Auto"/>  <!-- AI badge -->
                <RowDefinition Height="Auto"/>  <!-- Triggers label -->
                <RowDefinition Height="*"/>     <!-- Trigger list -->
                <RowDefinition Height="Auto"/>  <!-- Footer note -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- CCBill AI Addendum: content-policy banner. Full version until acked, then slim. -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <Border x:Name="PolicyBannerFull" Padding="12" CornerRadius="4"
                        Background="#3D3520" BorderBrush="#A98E3A" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#9888;" FontSize="16" Foreground="#E5C76B"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Str prompt_editor_policy_full}"
                                       Foreground="#F0E2A6" FontSize="12" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                            <Button x:Name="BtnPolicyReadFull"
                                    Content="{loc:Str prompt_editor_policy_read}"
                                    Background="Transparent" Foreground="#E5C76B"
                                    BorderThickness="0" FontSize="11" Cursor="Hand"
                                    Padding="8,4" Margin="0,0,8,0"
                                    Click="BtnPolicyRead_Click"/>
                            <Button x:Name="BtnPolicyGotIt"
                                    Content="{loc:Str prompt_editor_policy_got_it}"
                                    Background="#A98E3A" Foreground="White"
                                    BorderThickness="0" FontSize="11" Cursor="Hand"
                                    Padding="12,4"
                                    Click="BtnPolicyGotIt_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border x:Name="PolicyBannerSlim" Visibility="Collapsed"
                        Padding="10,6" CornerRadius="4" Background="#2A2520"
                        BorderBrush="#A98E3A" BorderThickness="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#9888;" FontSize="13" Foreground="#E5C76B"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Str prompt_editor_policy_slim}"
                                   Foreground="#C8B47A" FontSize="11" TextWrapping="Wrap"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button x:Name="BtnPolicyReadSlim"
                                Content="{loc:Str prompt_editor_policy_read}"
                                Background="Transparent" Foreground="#E5C76B"
                                BorderThickness="0" FontSize="11" Cursor="Hand"
                                Padding="4,0" VerticalAlignment="Center"
                                Click="BtnPolicyRead_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Header -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <!-- Built-in: static icon + name (shown when preset.IsBuiltIn) -->
                <TextBlock x:Name="TxtIcon" FontSize="36" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <StackPanel x:Name="NameReadPanel" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtName" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtAuthor" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>

                <!-- Custom: editable icon + name (shown when !preset.IsBuiltIn) -->
                <TextBox x:Name="TxtIconEdit" FontSize="28"
                         Width="60" Height="52" MaxLength="4"
                         Background="#1E1E32" Foreground="White"
                         BorderBrush="#3A3A5A" BorderThickness="1"
                         VerticalAlignment="Center" HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         Margin="0,0,14,0" Visibility="Collapsed"
                         ToolTip="Emoji or short label for the card (e.g. 🎯)"/>
                <StackPanel x:Name="NameEditPanel" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBox x:Name="TxtNameEdit" Foreground="White" FontSize="22" FontWeight="Bold"
                             Background="#1E1E32" BorderBrush="#3A3A5A" BorderThickness="1"
                             Padding="4,2" MinWidth="300"
                             ToolTip="Preset name shown on the card"/>
                    <TextBlock Text="Custom preset" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Description (read-only variant) -->
            <TextBlock Grid.Row="2" x:Name="TxtDescription"
                       Foreground="#C8C8D6" FontSize="13"
                       TextWrapping="Wrap" Margin="0,0,0,10"/>

            <!-- Description (editable variant — shown for custom presets) -->
            <TextBox Grid.Row="2" x:Name="TxtDescriptionEdit"
                     Foreground="White" FontSize="12"
                     Background="#1E1E32" BorderBrush="#3A3A5A" BorderThickness="1"
                     Padding="6,4" TextWrapping="Wrap" AcceptsReturn="True"
                     MinHeight="44" MaxHeight="80"
                     Margin="0,0,0,10" Visibility="Collapsed"
                     ToolTip="Short description shown on the card"/>

            <!-- AI badge -->
            <Border Grid.Row="3" x:Name="BrdAiBadge" Visibility="Collapsed"
                    Background="#2A1A3E" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,12">
                <TextBlock Text="AI required for best experience — falls back to canned lines offline"
                           Foreground="{DynamicResource PinkBrush}" FontSize="10" FontWeight="SemiBold"/>
            </Border>

            <!-- Triggers label -->
            <TextBlock Grid.Row="4" Text="TRIGGERS" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <!-- Trigger list - rows built imperatively in code-behind so each action
                 type gets its own inline editor without needing 8 XAML DataTemplates.
                 An "+ Add trigger" button is injected at the bottom of TriggerStack
                 when the dialog is in an editable state. -->
            <Border Grid.Row="5" Background="#1A1A2E" BorderBrush="#2E2E48" BorderThickness="1" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TriggerStack" Margin="10"/>
                </ScrollViewer>
            </Border>

            <!-- Footer note (only visible when installed) -->
            <TextBlock Grid.Row="6" x:Name="TxtFooterNote"
                       Text="Changes save automatically."
                       Foreground="#8A8AA0" FontSize="10" FontStyle="Italic"
                       Margin="0,8,0,0" Visibility="Collapsed"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <!-- Delete is only shown for user-created presets (replaces Clone). -->
                <Button x:Name="BtnDeletePreset" Content="Delete preset" Padding="12,8" Margin="0,0,8,0"
                        Background="#5A3030" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Visibility="Collapsed"
                        Click="BtnDeletePreset_Click"/>
                <Button x:Name="BtnClone" Content="Clone to custom" Padding="12,8" Margin="0,0,8,0"
                        Background="#2A2A44" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="BtnClone_Click"/>
                <Button x:Name="BtnClose" Content="Close" Padding="12,8" Margin="0,0,8,0"
                        Background="#2A2A44" Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="BtnClose_Click"/>
                <Button x:Name="BtnInstall" Content="Install" Padding="16,8"
                        Background="{DynamicResource PinkBrush}" Foreground="White"
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                        Click="BtnInstall_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

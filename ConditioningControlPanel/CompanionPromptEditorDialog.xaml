<Window x:Class="ConditioningControlPanel.CompanionPromptEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        xmlns:local="clr-namespace:ConditioningControlPanel"
        Title="{loc:Str dialog_customize_ai_companion}"
        Width="700" Height="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Converter for hiding empty descriptions -->
        <local:NullOrEmptyToCollapsedConverter x:Key="NullToCollapsedConverter"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PinkBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SectionDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#808080"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PromptTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PanelAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PanelAccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" Padding="20,15">
            <StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Str label_customize_your_ai_companion}"
                                   Foreground="{StaticResource PinkBrush}"
                                   FontSize="20" FontWeight="Bold"/>
                        <Border Background="#FF6B6B" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str label_beta}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <!-- Active Prompt Badge -->
                    <Border x:Name="ActivePromptBadge" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="{DynamicResource DarkerBgBrush}" CornerRadius="12" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Str label_active}" Foreground="#707070" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtActivePromptName" Text="{loc:Str label_default}" Foreground="#9370DB"
                                       FontSize="11" FontWeight="SemiBold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <TextBlock Text="{loc:Str label_edit_the_prompts_that_control_how_your_compan}"
                           Foreground="#808080" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <CheckBox x:Name="ChkUseCustom" Content="{loc:Str btn_enable_custom_prompts}"
                              Foreground="White" VerticalContentAlignment="Center"
                              Checked="ChkUseCustom_Changed" Unchecked="ChkUseCustom_Changed"/>
                    <TextBlock Text="{loc:Str label_uncheck_to_use_default_prompts}"
                               Foreground="#606060" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="ContentPanel">

                <!-- CCBill AI Addendum: content-policy banner. Full version on first display;
                     after "Got it" is clicked it collapses to a non-dismissable slim reminder. -->
                <Border x:Name="PolicyBannerFull"
                        Margin="0,0,0,16"
                        Padding="12"
                        CornerRadius="4"
                        Background="#3D3520"
                        BorderBrush="#A98E3A"
                        BorderThickness="1">
                    <StackPanel>
                        <DockPanel LastChildFill="True" Margin="0,0,0,6">
                            <TextBlock Text="&#9888;"
                                       FontSize="16"
                                       Foreground="#E5C76B"
                                       VerticalAlignment="Top"
                                       Margin="0,0,8,0"
                                       DockPanel.Dock="Left"/>
                            <TextBlock Text="{loc:Str prompt_editor_policy_full}"
                                       Foreground="#F0E2A6"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                            <Button x:Name="BtnPolicyReadFull"
                                    Content="{loc:Str prompt_editor_policy_read}"
                                    Background="Transparent"
                                    Foreground="#E5C76B"
                                    BorderThickness="0"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Padding="8,4"
                                    Margin="0,0,8,0"
                                    Click="BtnPolicyRead_Click"/>
                            <Button x:Name="BtnPolicyGotIt"
                                    Content="{loc:Str prompt_editor_policy_got_it}"
                                    Background="#A98E3A"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="11"
                                    Cursor="Hand"
                                    Padding="12,4"
                                    Click="BtnPolicyGotIt_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Slim version: always visible after acknowledgement. -->
                <Border x:Name="PolicyBannerSlim"
                        Visibility="Collapsed"
                        Margin="0,0,0,12"
                        Padding="10,6"
                        CornerRadius="4"
                        Background="#2A2520"
                        BorderBrush="#A98E3A"
                        BorderThickness="0,0,0,2">
                    <DockPanel LastChildFill="True">
                        <TextBlock Text="&#9888;"
                                   FontSize="13"
                                   Foreground="#E5C76B"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   DockPanel.Dock="Left"/>
                        <Button x:Name="BtnPolicyReadSlim"
                                Content="{loc:Str prompt_editor_policy_read}"
                                Background="Transparent"
                                Foreground="#E5C76B"
                                BorderThickness="0"
                                FontSize="11"
                                Cursor="Hand"
                                Padding="4,0"
                                VerticalAlignment="Center"
                                DockPanel.Dock="Right"
                                Click="BtnPolicyRead_Click"/>
                        <TextBlock Text="{loc:Str prompt_editor_policy_slim}"
                                   Foreground="#C8B47A"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                    </DockPanel>
                </Border>

                <!-- Personality / behavior only — provider, model, host, and effect
                     permissions all live in the AI Brain panel on the Companion tab. -->

                <!-- Section 1: Personality -->
                <Expander IsExpanded="True" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="{loc:Str setting_personality_normal_mode}" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Define who your companion is. Their vibe, tone, and what topics they like to talk about.
                            This is used when Slut Mode is OFF.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtPersonality" Style="{StaticResource PromptTextBox}"
                                     Height="120" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="{loc:Str btn_reset}" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetPersonality_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 2: Explicit Reaction -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="{loc:Str setting_explicit_topic_handling}" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            How should your companion react when you mention explicit topics in Normal Mode?
                            (In Slut Mode, this is ignored and they respond explicitly.)
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtExplicitReaction" Style="{StaticResource PromptTextBox}"
                                     Height="100" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="{loc:Str btn_reset}" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetExplicitReaction_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 3: Slut Mode -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Str setting_slut_mode_personality}" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="{loc:Str label_patreon}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Define the companion's personality when Slut Mode is enabled.
                            This is more explicit and trigger-heavy. Requires Patreon Premium.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSlutMode" Style="{StaticResource PromptTextBox}"
                                     Height="140" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="{loc:Str btn_reset}" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetSlutMode_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 4: Knowledge Base -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="{loc:Str setting_knowledge_base}" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Files, videos, and resources your companion knows about and can recommend.
                            List audio files, video series, creators, etc.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtKnowledgeBase" Style="{StaticResource PromptTextBox}"
                                     Height="140" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="{loc:Str btn_reset}" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetKnowledgeBase_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 5: Context Reactions -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="{loc:Str setting_screen_awareness_reactions}" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            How your companion reacts to different apps and websites you're viewing.
                            The companion receives context like [App: Chrome | Title: Reddit - r/BambiSleep].
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtContextReactions" Style="{StaticResource PromptTextBox}"
                                     Height="180" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="{loc:Str btn_reset}" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetContextReactions_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 6: Output Rules -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <TextBlock Text="{loc:Str setting_output_rules}" Style="{StaticResource SectionHeader}"/>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Control how long responses are, emoji usage, and response frequency.
                            Keep responses short for a texting feel.
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtOutputRules" Style="{StaticResource PromptTextBox}"
                                     Height="100" TextChanged="OnTextChanged"/>
                            <Button Grid.Column="1" Content="{loc:Str btn_reset}" Style="{StaticResource ResetButton}"
                                    VerticalAlignment="Top" Margin="5,0,0,0"
                                    Click="ResetOutputRules_Click"/>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Section 7: Global Knowledge Base Links -->
                <Expander IsExpanded="False" Margin="0,0,0,15">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Str setting_global_knowledge_base_links}" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="{loc:Str label_all_personalities}" Foreground="#50C878" FontSize="11"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Style="{StaticResource SectionDescription}">
                            Add URLs to hypno content that your companion knows about and can recommend.
                            These links apply to ALL personalities, regardless of which preset is active.
                        </TextBlock>

                        <!-- Links List -->
                        <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <ListBox x:Name="LstKnowledgeLinks" Height="120"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" FontSize="11"
                                     SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Url}" Foreground="#707070" FontSize="10"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#A0A0A0" FontSize="10"
                                                       TextWrapping="Wrap" Visibility="{Binding Description, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Add/Remove Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{loc:Str btn_add_link}" Style="{StaticResource ResetButton}"
                                    Padding="12,6" Click="AddKnowledgeLink_Click"/>
                            <Button Content="{loc:Str btn_remove_selected}" Style="{StaticResource ResetButton}"
                                    Padding="12,6" Margin="8,0,0,0" Click="RemoveKnowledgeLink_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnResetAll" Content="{loc:Str btn_reset_all_to_defaults}"
                        Style="{StaticResource ResetButton}"
                        HorizontalAlignment="Left"
                        Click="ResetAll_Click"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnCancel" Content="{loc:Str btn_cancel}"
                            Style="{StaticResource SecondaryButton}"
                            Width="80" Margin="0,0,10,0"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Content="{loc:Str btn_save}"
                            Style="{StaticResource ActionButton}"
                            Width="80"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

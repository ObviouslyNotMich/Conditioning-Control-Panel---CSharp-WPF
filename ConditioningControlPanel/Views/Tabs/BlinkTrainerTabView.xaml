<UserControl x:Class="ConditioningControlPanel.Views.Tabs.BlinkTrainerTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="36,28,36,28">
                <StackPanel MaxWidth="960" HorizontalAlignment="Center">
    
                    <!-- Hero banner -->
                    <Border CornerRadius="14" Margin="0,0,0,24" ClipToBounds="True" MaxHeight="320"
                            HorizontalAlignment="Center" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                        <Image x:Name="ImgBlinkTrainerFeature" x:FieldModifier="internal" Source="pack://application:,,,/Resources/features/blink_trainer.png"
                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
    
                    <!-- ═══ HEADER ZONE ═══ -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Animated eye logo (40x40). Storyboard toggles open/closed visibility on a
                             4s loop: open 3.6s, closed 0.4s. Fill pulls from PinkBrush at render time. -->
                        <Grid Grid.Column="0" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,18,0">
                            <!-- Open eye: outer almond outline + pupil -->
                            <Canvas x:Name="EyeLogoOpen" Width="48" Height="48">
                                <Path Stroke="{DynamicResource PinkBrush}" StrokeThickness="2.6"
                                      Fill="Transparent" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M 4,24 Q 24,6 44,24 Q 24,42 4,24 Z"/>
                                <Ellipse Canvas.Left="17" Canvas.Top="17" Width="14" Height="14"
                                         Fill="{DynamicResource PinkBrush}"/>
                                <Ellipse Canvas.Left="21" Canvas.Top="19" Width="4" Height="4"
                                         Fill="White" Opacity="0.85"/>
                            </Canvas>
                            <!-- Closed eye: shallow arc (lashes implicit) -->
                            <Canvas x:Name="EyeLogoClosed" Width="48" Height="48" Visibility="Collapsed">
                                <Path Stroke="{DynamicResource PinkBrush}" StrokeThickness="2.6"
                                      Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M 5,26 Q 24,18 43,26"/>
                                <Path Stroke="{DynamicResource PinkBrush}" StrokeThickness="1.6"
                                      Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Opacity="0.55"
                                      Data="M 10,22 L 8,18 M 24,20 L 24,15 M 38,22 L 40,18"/>
                            </Canvas>
                            <!-- Drives the blink animation. Started in code-behind when tab becomes visible,
                                 stopped when it hides so we're not consuming CPU off-screen. -->
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard x:Name="EyeLogoBlinkStoryboardBegin">
                                        <Storyboard x:Name="EyeLogoBlinkStoryboard" RepeatBehavior="Forever">
                                            <!-- Open eye: visible 0.0-3.6s, hidden 3.6-4.0s -->
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="EyeLogoOpen"
                                                                            Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                                <DiscreteObjectKeyFrame KeyTime="0:0:3.6">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Collapsed</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                                <DiscreteObjectKeyFrame KeyTime="0:0:4.0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="EyeLogoClosed"
                                                                            Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Collapsed</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                                <DiscreteObjectKeyFrame KeyTime="0:0:3.6">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                                <DiscreteObjectKeyFrame KeyTime="0:0:4.0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Collapsed</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                        </Grid>
    
                        <!-- Title + BETA chip + tagline -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Str tab_blink_trainer}" Foreground="White" FontSize="28" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="22" ShadowDepth="0" Opacity="0.55"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <Border Background="#33FF69B4" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="6,1" Margin="10,4,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Str blink_trainer_beta}" Foreground="{DynamicResource PinkBrush}" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{loc:Str blink_trainer_tagline}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                       FontStyle="Italic" Margin="0,4,0,0"/>
                        </StackPanel>
    
                        <!-- Help button — TODO Phase H: wire HelpContentService entry for "BlinkTrainer" -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button x:Name="HelpBtnBlinkTrainer" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}"
                                    HorizontalAlignment="Right" Tag="BlinkTrainer"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"
                                        ToolTip="Blink fast 6 times in a row to stop everything and jump to recalibration.">
                                <TextBlock Text="Blink to recal" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <CheckBox x:Name="ChkBlinkRecalBlinkTrainer" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                                          Checked="ChkBlinkRecalShortcut_Changed" Unchecked="ChkBlinkRecalShortcut_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
    
                    <!-- ═══ STAGE + GATED ZONES (side-by-side, v5.9.9) ═══
                         Stage frame on the left at 80% of its previous size; the gated
                         content (status row, Start button, asset/session/webcam cards)
                         stacks vertically on the right so users no longer have to scroll
                         to reach the controls. The gate overlay sits in the right column
                         only — the stage stays visible to entice non-premium users. -->
                    <Grid Margin="0,32,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Stage column: preview frame on top, action panel (status +
                             Start session + tracker toggle) directly underneath. v5.9.9
                             moved the actions out of the right column so they live next
                             to the visual they control. BlinkTrainerStageActions is
                             disabled by RefreshBlinkTrainerGate for non-premium users. -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                        <Border x:Name="BlinkTrainerStageFrame"
                                Width="448" Height="288"
                                VerticalAlignment="Top"
                                CornerRadius="16"
                                BorderThickness="2"
                                Background="{DynamicResource SurfaceBgBrush}">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource NeonPurpleColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <!-- Inner clip border — parent's CornerRadius doesn't clip its child's
                                 content, only its own background. Wrap content in a Border with the
                                 same CornerRadius (minus the parent's BorderThickness) and
                                 ClipToBounds=True so the swapping Image / MediaElement controls
                                 don't bleed past the rounded corners. -->
                            <Border CornerRadius="14" ClipToBounds="True" Background="Transparent">
                                <Grid x:Name="BlinkTrainerStageContent">
                                    <!-- Two overlapping images for demo cross-fade. Live mode uses
                                         the same pair but hard-cuts (no fade animation). -->
                                    <Image x:Name="BlinkTrainerStageImageA" x:FieldModifier="internal" Stretch="UniformToFill" Opacity="1"/>
                                    <Image x:Name="BlinkTrainerStageImageB" x:FieldModifier="internal" Stretch="UniformToFill" Opacity="0"/>
                                    <!-- Video preview surface. Hidden by default; flipped to Opacity=1
                                         when a video is picked in live mode (Demo mode never picks
                                         videos). MediaElement default volume is honoured by IsMuted=True. -->
                                    <MediaElement x:Name="BlinkTrainerStageMedia" x:FieldModifier="internal"
                                                  LoadedBehavior="Manual"
                                                  UnloadedBehavior="Stop"
                                                  Stretch="UniformToFill"
                                                  IsMuted="True"
                                                  Opacity="0"
                                                  MediaEnded="BlinkTrainerStageMedia_MediaEnded"/>
                                </Grid>
                            </Border>
                        </Border>
    
                        <!-- ═══ STAGE ACTIONS (under preview) ═══
                             Moved from the right column in v5.9.9 so the controls
                             sit next to the visual they drive. IsEnabled is toggled
                             by RefreshBlinkTrainerGate. -->
                        <StackPanel x:Name="BlinkTrainerStageActions" x:FieldModifier="internal">
    
                            <!-- ═══ STATUS ROW ═══ -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                <!-- Idle-state opacity pulse. Started / stopped by the Phase D state
                                     machine via FindResource("BlinkTrainerStatusDotPulse"). -->
                                <Ellipse x:Name="BlinkTrainerStatusDot" x:FieldModifier="internal" Width="10" Height="10"
                                         Fill="{DynamicResource PinkBrush}" Margin="0,0,10,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Resources>
                                        <Storyboard x:Key="BlinkTrainerStatusDotPulse" RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.4"
                                                             Duration="0:0:0.8">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </Ellipse.Resources>
                                </Ellipse>
                                <TextBlock x:Name="BlinkTrainerStatusText" x:FieldModifier="internal"
                                           Text="{loc:Str blink_trainer_status_ready}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="BlinkTrainerStatusAction" x:FieldModifier="internal"
                                        Visibility="Collapsed"
                                        Margin="12,0,0,0"
                                        Style="{StaticResource OutlineButton}"
                                        Padding="10,4"
                                        FontSize="12"/>
                            </StackPanel>
    
                            <!-- ═══ START BUTTON ═══ -->
                            <Button x:Name="BtnBlinkTrainerStartSession" x:FieldModifier="internal"
                                    Content="{loc:Str blink_trainer_start_session}"
                                    HorizontalAlignment="Center"
                                    Margin="0,14,0,0"
                                    Padding="32,12"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Style="{StaticResource SmallPinkButton}"
                                    Click="BtnBlinkTrainerStartSession_Click"/>
    
                            <!-- Tracker toggle (v5.9.9). Mirrors the Lab BtnWebcamDebugStart
                                 so Blink Trainer users can stop the webcam without leaving
                                 the tab. Label/colour are refreshed by
                                 RefreshBlinkTrainerTrackerButton. -->
                            <Button x:Name="BtnBlinkTrainerStartStopTracker" x:FieldModifier="internal"
                                    Content="Start tracker"
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0"
                                    Padding="22,8"
                                    FontSize="12"
                                    Style="{StaticResource OutlineButton}"
                                    Click="BtnBlinkTrainerStartStopTracker_Click"/>
                        </StackPanel>
                        </StackPanel>
    
                    <!-- ═══ GATED ZONE (right column) ═══
                         3 stacked control cards (Asset Packs / Webcam+Session row).
                         Covered by BlinkTrainerGate for non-premium users; the stage
                         on the left stays visible to show the feature in action. -->
                    <Grid Grid.Column="2" x:Name="BlinkTrainerGatedZone">
                        <StackPanel x:Name="BlinkTrainerGatedContent" x:FieldModifier="internal">
    
                    <!-- ═══ CONTROLS ZONE ═══
                         Stacked vertically (was a 3-col grid below the stage in v5.9.8).
                         Asset Packs / Session / Webcam cards keep their original styling
                         and bindings — only the layout direction changed. -->
                    <StackPanel Margin="0,28,0,0">
    
                        <!-- ── Asset Packs ── -->
                        <Border
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="18"
                                VerticalAlignment="Top">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource PinkColor}" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="{loc:Str blink_trainer_section_asset_packs}"
                                           Foreground="{DynamicResource PinkBrush}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Margin="0,0,0,14"/>
    
                                <!-- Folder cards. Populated by RebuildBlinkTrainerFolderCards() in code-behind. -->
                                <StackPanel x:Name="BlinkTrainerFolderCardsHost" x:FieldModifier="internal"/>
    
                                <!-- Add-folder button with dashed pink border. WPF doesn't support
                                     dashed Border strokes natively, so a Rectangle sits behind/around
                                     the Button to draw the dashes. IsHitTestVisible=False on the
                                     Rectangle ensures clicks pass through to the Button. -->
                                <Grid>
                                    <Rectangle Stroke="{DynamicResource PinkBrush}"
                                               StrokeThickness="1"
                                               StrokeDashArray="4 3"
                                               RadiusX="8" RadiusY="8"
                                               IsHitTestVisible="False"
                                               SnapsToDevicePixels="True"/>
                                    <Button x:Name="BtnBlinkTrainerAddFolderCard"
                                            Content="{loc:Str blink_trainer_add_folder}"
                                            HorizontalAlignment="Stretch"
                                            Padding="12,8"
                                            Background="Transparent"
                                            Foreground="{DynamicResource PinkBrush}"
                                            FontWeight="SemiBold" FontSize="12"
                                            Cursor="Hand"
                                            BorderThickness="0"
                                            Click="BtnBlinkTrainerAddFolderCard_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
    
                                <!-- Include videos toggle. ToggleStyle targets CheckBox (not
                                     ToggleButton), so this is a styled CheckBox. -->
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Str blink_trainer_include_videos}" Foreground="White" FontSize="12"/>
                                        <TextBlock Text="{loc:Str blink_trainer_include_videos_sub}"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              x:Name="ToggleBlinkTrainerIncludeVideos" x:FieldModifier="internal"
                                              Style="{StaticResource ToggleStyle}"
                                              VerticalAlignment="Center"
                                              Checked="ToggleBlinkTrainerIncludeVideos_Changed"
                                              Unchecked="ToggleBlinkTrainerIncludeVideos_Changed"/>
                                </Grid>
                            </StackPanel>
                        </Border>
    
                        <!-- Webcam (left) + Session (right) — side-by-side row.
                             XML order is Session first, Webcam second; Grid.Column
                             places them left/right independent of declaration order. -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
    
                        <!-- ── Session ── -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="18"
                                VerticalAlignment="Top">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource PinkColor}" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="{loc:Str blink_trainer_section_session}"
                                           Foreground="{DynamicResource PinkBrush}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Margin="0,0,0,14"/>
    
                                <!-- Duration -->
                                <StackPanel Margin="0,0,0,18">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="{loc:Str blink_trainer_duration_label}" Foreground="White" FontSize="12" FontWeight="Medium"/>
                                        <TextBlock x:Name="TxtBlinkTrainerDurationValue" x:FieldModifier="internal" Text="10 min"
                                                   Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <ScaleTransform/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Grid>
                                    <Slider x:Name="SliderBlinkTrainerDurationNew" x:FieldModifier="internal"
                                            Minimum="1" Maximum="180" Value="10"
                                            Margin="0,2,0,0"
                                            Style="{StaticResource BlinkTrainerGradientSlider}"
                                            ValueChanged="SliderBlinkTrainerDurationNew_Changed"
                                            PreviewMouseLeftButtonDown="BlinkTrainerSlider_DragStart"
                                            PreviewMouseLeftButtonUp="BlinkTrainerSlider_DragEnd"
                                            LostMouseCapture="BlinkTrainerSlider_LostCapture"/>
                                </StackPanel>
    
                                <!-- Overlay opacity -->
                                <StackPanel Margin="0,0,0,18">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="{loc:Str blink_trainer_opacity_label}" Foreground="White" FontSize="12" FontWeight="Medium"/>
                                        <TextBlock x:Name="TxtBlinkTrainerOpacityValue" x:FieldModifier="internal" Text="80%"
                                                   Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <ScaleTransform/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Grid>
                                    <Slider x:Name="SliderBlinkTrainerOpacityNew" x:FieldModifier="internal"
                                            Minimum="1" Maximum="100" Value="80"
                                            Margin="0,2,0,0"
                                            Style="{StaticResource BlinkTrainerGradientSlider}"
                                            ValueChanged="SliderBlinkTrainerOpacityNew_Changed"
                                            PreviewMouseLeftButtonDown="BlinkTrainerSlider_DragStart"
                                            PreviewMouseLeftButtonUp="BlinkTrainerSlider_DragEnd"
                                            LostMouseCapture="BlinkTrainerSlider_LostCapture"
                                            Loaded="SliderBlinkTrainerOpacityNew_Loaded"/>
                                </StackPanel>
    
                                <!-- Mix-mode visual toggle -->
                                <TextBlock Text="{loc:Str blink_trainer_tiling_label}" Foreground="White" FontSize="12" FontWeight="Medium" Margin="0,8,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
    
                                    <Border x:Name="BlinkTrainerMixOptionSame" x:FieldModifier="internal" Grid.Column="0"
                                            CornerRadius="8" Padding="10" Cursor="Hand"
                                            Background="#11000000"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"
                                            MouseLeftButtonUp="BlinkTrainerMixOptionSame_Click">
                                        <StackPanel>
                                            <UniformGrid Rows="2" Columns="2" Width="60" Height="60" HorizontalAlignment="Center">
                                                <Border Background="{DynamicResource PinkBrush}" Margin="2"/>
                                                <Border Background="{DynamicResource PinkBrush}" Margin="2"/>
                                                <Border Background="{DynamicResource PinkBrush}" Margin="2"/>
                                                <Border Background="{DynamicResource PinkBrush}" Margin="2"/>
                                            </UniformGrid>
                                            <TextBlock Text="{loc:Str blink_trainer_tiling_same}" Foreground="White" FontSize="11"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
    
                                    <Border x:Name="BlinkTrainerMixOptionMix" x:FieldModifier="internal" Grid.Column="2"
                                            CornerRadius="8" Padding="10" Cursor="Hand"
                                            Background="#11000000"
                                            BorderThickness="2"
                                            BorderBrush="Transparent"
                                            MouseLeftButtonUp="BlinkTrainerMixOptionMix_Click">
                                        <StackPanel>
                                            <UniformGrid Rows="2" Columns="2" Width="60" Height="60" HorizontalAlignment="Center">
                                                <Border Background="#FF69B4" Margin="2"/>
                                                <Border Background="#B47BFF" Margin="2"/>
                                                <Border Background="#FFB1E0" Margin="2"/>
                                                <Border Background="#E07BFF" Margin="2"/>
                                            </UniformGrid>
                                            <TextBlock Text="{loc:Str blink_trainer_tiling_mix}" Foreground="White" FontSize="11"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
    
                        <!-- ── Webcam ── -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="18"
                                VerticalAlignment="Top">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource PinkColor}" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="{loc:Str blink_trainer_section_webcam}"
                                           Foreground="{DynamicResource PinkBrush}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Margin="0,0,0,14"/>
    
                                <!-- Camera device picker. Both this combo and the Lab's CmbWebcamDevice
                                     read/write the same WebcamDeviceIndex setting; tab-show repopulation
                                     keeps them in sync without explicit cross-tab wiring. -->
                                <TextBlock Text="{loc:Str blink_trainer_camera_device}" Foreground="White" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Foreground=Black explicit per feedback_combobox_text_color memory -->
                                    <ComboBox Grid.Column="0" x:Name="CmbBlinkTrainerWebcamDevice" x:FieldModifier="internal"
                                              Foreground="Black" Background="White"
                                              FontSize="11"
                                              SelectionChanged="CmbBlinkTrainerWebcamDevice_SelectionChanged"/>
                                    <Button Grid.Column="1" Content="{loc:Str blink_trainer_camera_refresh}"
                                            Margin="6,0,0,0"
                                            Padding="10,4" FontSize="11"
                                            Style="{StaticResource OutlineButton}"
                                            Click="BtnBlinkTrainerWebcamRefresh_Click"/>
                                </Grid>
    
                                <!-- Monitor picker — mirrors the Lab CmbWebcamMonitor.
                                     Both write WebcamCalibrationScreen; selection is kept
                                     in sync via SyncWebcamMonitorComboSelections. -->
                                <TextBlock Text="{loc:Str webcam_monitor_label}"
                                           Foreground="White" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                                <ComboBox x:Name="CmbBlinkTrainerWebcamMonitor" x:FieldModifier="internal"
                                          Foreground="Black" Background="White"
                                          FontSize="11"
                                          Margin="0,0,0,14"
                                          ToolTip="{loc:Str webcam_monitor_tooltip}"
                                          SelectionChanged="CmbBlinkTrainerWebcamMonitor_SelectionChanged"/>
    
                                <!-- Consent status. Border colors driven from code-behind in
                                     RefreshBlinkTrainerWebcamColumn (DataTrigger would need a
                                     bool→state binding helper that doesn't exist; code-behind is
                                     less fragile). Status text + button content are also set from
                                     code-behind to flip between granted / required wording. -->
                                <Border x:Name="BlinkTrainerConsentCard" x:FieldModifier="internal"
                                        CornerRadius="8" Padding="12" Margin="0,0,0,14"
                                        Background="#1A4ADE80"
                                        BorderBrush="#4ADE80" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="BlinkTrainerConsentStatus" x:FieldModifier="internal"
                                                   Foreground="White" FontSize="12" FontWeight="Medium"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button x:Name="BtnBlinkTrainerManageConsent" x:FieldModifier="internal"
                                                    Padding="10,4" FontSize="11"
                                                    Style="{StaticResource OutlineButton}"
                                                    Click="BtnBlinkTrainerManageConsent_Click"/>
                                            <Button x:Name="BtnBlinkTrainerRevokeConsent" x:FieldModifier="internal"
                                                    Margin="8,0,0,0"
                                                    Padding="10,4" FontSize="10"
                                                    Visibility="Collapsed"
                                                    Background="Transparent" Foreground="#FF6060"
                                                    BorderBrush="#FF6060" BorderThickness="1"
                                                    Cursor="Hand"
                                                    Content="{loc:Str blink_trainer_consent_revoke_short}"
                                                    ToolTip="{loc:Str blink_trainer_consent_revoke_tooltip}"
                                                    Click="BtnBlinkTrainerRevokeConsent_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
    
                                <!-- Calibration -->
                                <TextBlock Text="{loc:Str blink_trainer_calibration_label}" Foreground="White" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                                <TextBlock x:Name="BlinkTrainerCalibrationStatus" x:FieldModifier="internal"
                                           Text="{loc:Str blink_trainer_calibration_none}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{loc:Str blink_trainer_calibration_btn}"
                                            Padding="12,5" Margin="0,0,8,0" FontSize="11"
                                            Style="{StaticResource OutlineButton}"
                                            Click="BtnBlinkTrainerCalibrate_Click"/>
                                    <Button Content="{loc:Str blink_trainer_calibration_quick}"
                                            Padding="12,5" FontSize="11"
                                            Style="{StaticResource OutlineButton}"
                                            Click="BtnBlinkTrainerQuickRecal_Click"/>
                                </StackPanel>
    
                                <!-- Mirror of Lab ChkRestrictGazeToCalScreen. Both bind to
                                     AppSettings.RestrictGazeContentToCalibratedScreen and
                                     keep each other in sync via the shared handler path. -->
                                <CheckBox x:Name="ChkBlinkTrainerRestrictGazeToCalScreen" x:FieldModifier="internal"
                                          Content="Restrict gaze-reactive effects to the calibrated screen"
                                          ToolTip="Advanced: leave on unless you know what you're doing. Affects how gaze-reactive effects map to your monitors."
                                          Foreground="#AAAAAA" FontSize="11"
                                          Margin="0,14,0,0"
                                          Checked="ChkBlinkTrainerRestrictGazeToCalScreen_Changed"
                                          Unchecked="ChkBlinkTrainerRestrictGazeToCalScreen_Changed"/>
                            </StackPanel>
                        </Border>
                        </Grid>
                    </StackPanel>
    
                        </StackPanel>
    
                        <!-- Premium gate overlay. Sits on top of the gated StackPanel (status
                             row + Start button + stacked control cards). Stage and header
                             remain visible so the user sees the feature working before the ask. -->
                        <Border x:Name="BlinkTrainerGate" x:FieldModifier="internal"
                                Visibility="Collapsed"
                                Background="#CC0A0A14">
                            <Border CornerRadius="16"
                                    Background="{DynamicResource ElevatedSurfaceBrush}"
                                    BorderThickness="2"
                                    MaxWidth="480"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="36,32">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                                        <GradientStop Color="{DynamicResource NeonPurpleColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource PinkColor}"
                                                      BlurRadius="40" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
    
                                <StackPanel HorizontalAlignment="Center">
                                    <Image Width="44" Height="44"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"
                                           Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                                    <TextBlock Text="{loc:Str blink_trainer_gate_headline}"
                                               Foreground="White"
                                               FontSize="22" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{loc:Str blink_trainer_gate_body}"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontSize="13"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="340"
                                               Margin="0,0,0,24"/>
                                    <Button x:Name="BtnBlinkTrainerGateUnlock"
                                            Content="{loc:Str blink_trainer_gate_cta}"
                                            Padding="32,12"
                                            FontSize="14" FontWeight="Bold"
                                            Style="{StaticResource SmallPinkButton}"
                                            HorizontalAlignment="Center"
                                            Click="BtnBlinkTrainerGateUnlock_Click"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                    </Grid>
    
                </StackPanel>
            </Grid>
        </ScrollViewer>
</UserControl>

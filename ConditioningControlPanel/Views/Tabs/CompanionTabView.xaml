<UserControl x:Class="ConditioningControlPanel.Views.Tabs.CompanionTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <Border Style="{StaticResource SectionPanel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
    
                    <!-- Tab Header -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Str tab_companion}" Foreground="White" FontSize="26" FontWeight="Bold">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#9370DB" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{loc:Str label_manage_your_ai_companion_personalities_and_co}" Foreground="{DynamicResource TextDimBrush}" FontSize="13" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button x:Name="BtnCompanionTutorial" Grid.Column="1" Content="🎓 Tutorial"
                                Style="{StaticResource SmallPinkButton}"
                                VerticalAlignment="Center"
                                Click="BtnCompanionTutorial_Click"
                                ToolTip="Walk through the Companion tab — the roster, AI Brain, behavior sliders, and phrase library."/>
                    </Grid>
    
                    <!-- SINGLE-COLUMN BODY: always-visible region (hero · roster · quick controls) then collapsed accordions -->
                    <StackPanel>
    
                    <!-- HERO STRIP -->
                    <Border x:Name="CompanionHeroBorder" CornerRadius="14" Padding="16" Margin="0,0,0,10" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1A32" Offset="0"/>
                                <GradientStop Color="#241A38" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                                <GradientStop Color="{DynamicResource PatreonPurple}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="18" ShadowDepth="0" Opacity="0.18"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
    
                            <!-- Avatar: dark gradient bg, head/shoulders bitmap crop -->
                            <Border Grid.Column="0" Width="96" Height="96" CornerRadius="48" Margin="0,0,16,0"
                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0E0A1C" Offset="0"/>
                                        <GradientStop Color="#1B0F2A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Clip>
                                    <EllipseGeometry Center="48,48" RadiusX="48" RadiusY="48"/>
                                </Border.Clip>
                                <Image x:Name="HeroAvatarImage" x:FieldModifier="internal" Stretch="UniformToFill"
                                       VerticalAlignment="Top" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                            </Border>
    
                            <!-- Body -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock x:Name="TxtActiveCompanionName" x:FieldModifier="internal" Text="{loc:Str label_bambi_sprite}" Foreground="White" FontSize="31" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtActiveCompanionLevel" x:FieldModifier="internal" Text="{loc:Str label_level_1}" Foreground="#888" FontSize="26" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                    </StackPanel>
                                    <Button x:Name="BtnChatShortcut" Grid.Column="1"
                                            Click="BtnChatShortcut_Click"
                                            ToolTip="{loc:Str tooltip_change_chat_shortcut}"
                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                            BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                            Padding="10,4" FontSize="12" Cursor="Hand" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Width="15" Height="15" Margin="0,0,6,0"
                                                   Source="{Binding Source='💬', Converter={StaticResource EmojiToImageSource}}"/>
                                            <TextBlock x:Name="TxtChatShortcutLabel" x:FieldModifier="internal" Text="Ctrl+T" Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBlock x:Name="TxtActiveCompanionDesc" x:FieldModifier="internal" Text="{loc:Str label_gains_bonus_xp_based_on_pink_filter_intensity}" Foreground="{DynamicResource TextDimBrush}" FontSize="16" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <Grid Margin="0,10,0,0">
                                    <ProgressBar x:Name="PrgCompanion0" x:FieldModifier="internal" Height="30" Value="0" Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}"/>
                                    <Border x:Name="PrgCompanion0FlashOverlay" x:FieldModifier="internal" Height="30" CornerRadius="2"
                                            Background="{DynamicResource PinkBrush}"
                                            HorizontalAlignment="Left"
                                            Opacity="0" IsHitTestVisible="False">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="24" ShadowDepth="0" Opacity="0.95"/>
                                        </Border.Effect>
                                    </Border>
                                    <TextBlock x:Name="TxtActiveCompanionXP" x:FieldModifier="internal" Text="{loc:Str label_0_550_xp}" Foreground="{DynamicResource PinkBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#2A1A3A" CornerRadius="10" Padding="10,4" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                                            <TextBlock x:Name="PillAiProvider" x:FieldModifier="internal" Text="{loc:Str label_ai_status_pill_off}" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#1F2A3A" CornerRadius="10" Padding="10,4" Margin="6,0,0,0" BorderBrush="#9370DB" BorderThickness="1">
                                            <TextBlock x:Name="PillAwareness" x:FieldModifier="internal" Text="{loc:Str label_awareness_pill_off}" Foreground="#9370DB" FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button x:Name="BtnSwitchCompanion" Content="{loc:Str btn_companion_switch}" Click="BtnSwitchCompanion_Click"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                                Padding="12,6" FontSize="16" Cursor="Hand" Margin="4,2,4,2"/>
                                        <Button x:Name="BtnDetachCompanionTab" x:FieldModifier="internal" Content="{loc:Str btn_detach}" Click="BtnDetachCompanion_Click"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                Padding="12,6" FontSize="16" Cursor="Hand" Margin="4,2,4,2"
                                                ToolTip="{Binding Text, ElementName=TxtDetachStatusCompanion}"/>
                                        <Button x:Name="BtnCustomizeCompanion" Click="BtnCustomizeCompanion_Click"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                                Padding="12,6" FontSize="16" Cursor="Hand" Margin="4,2,4,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{loc:Str label_customize_ai}" Foreground="White"/>
                                                <TextBlock x:Name="TxtCustomizePromptName" x:FieldModifier="internal" Text="{loc:Str label_default}" Foreground="#9370DB" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnResetCompanionMemory" Content="🧹 Reset Memory" Click="BtnResetCompanionMemory_Click"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#FF8B5A" BorderThickness="1"
                                                Padding="12,6" FontSize="16" Cursor="Hand" Margin="4,2,4,2"
                                                ToolTip="Wipe the AI companion's conversation memory. Useful if she's stuck repeating an old pattern (like skipping links) — she'll start fresh on the next message."/>
                                        <StackPanel Orientation="Horizontal" Margin="4,2,4,2" VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_show_companion}" Foreground="{DynamicResource TextDimBrush}" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <CheckBox x:Name="ChkAvatarEnabledCompanion" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                      Checked="ChkAvatarEnabled_Changed" Unchecked="ChkAvatarEnabled_Changed"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="4,2,4,2" VerticalAlignment="Center">
                                            <Image Width="19" Height="19" VerticalAlignment="Center" Margin="0,0,5,0"
                                                   Source="{Binding Source='🔇', Converter={StaticResource EmojiToImageSource}}"/>
                                            <CheckBox x:Name="ChkMuteAvatarCompanion" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                      Checked="ChkMuteAvatar_Changed" Unchecked="ChkMuteAvatar_Changed"
                                                      ToolTip="{loc:Str label_mute_avatar}"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
    
                    <!-- Hidden compat: detach status text and companion status -->
                    <TextBlock x:Name="TxtDetachStatusCompanion" x:FieldModifier="internal" Text="{loc:Str label_anchored_to_main_window}" Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtCompanionStatus" Text="" Visibility="Collapsed"/>
    
                    <!-- COMPANION ROSTER TRAY (toggled by Switch button) -->
                    <Border x:Name="CompanionRosterTray" x:FieldModifier="internal" Visibility="Collapsed" CornerRadius="12" Padding="14" Margin="0,0,0,10"
                            Background="{DynamicResource ElevatedSurfaceBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Str label_companions}" Foreground="{DynamicResource PinkBrush}" FontSize="16" FontWeight="Bold"/>
                                    <Border Background="#FF6B6B" CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str label_beta}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Button x:Name="HelpBtnCompanions" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="Companions"/>
                                </StackPanel>
                            </Grid>
                            <UniformGrid Rows="2" Columns="3">
                                <Border x:Name="CompanionCard0" x:FieldModifier="internal" CornerRadius="8" Margin="0,0,5,5"
                                        Padding="12,10" Cursor="Hand" MouseLeftButtonDown="CompanionCard_Click" Tag="0"
                                        BorderThickness="2" BorderBrush="Transparent">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A32" Offset="0"/>
                                            <GradientStop Color="#201A38" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtCompanion0Name" x:FieldModifier="internal" Text="{loc:Str label_synthetic_blowdoll}" Foreground="{DynamicResource PinkBrush}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtCompanion0Lock" x:FieldModifier="internal" Text=" [50]" Foreground="#FFD700" FontSize="11" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtCompanion0Level" x:FieldModifier="internal" Text="{loc:Str label_lv_1}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{loc:Str label_pink_filter_xp_bonus}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button x:Name="BtnCompanion0Personality" Content="🎭" FontSize="12" Padding="4,1"
                                                    Background="{DynamicResource DarkerBgBrush}" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="BtnCompanionPersonality_Click" Tag="0" ToolTip="{loc:Str tooltip_assign_ai_personality}"/>
                                            <TextBlock x:Name="TxtCompanion0Prompt" x:FieldModifier="internal" Text="" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CompanionCard1" x:FieldModifier="internal" CornerRadius="8" Margin="5,0,0,5"
                                        Padding="12,10" Cursor="Hand" MouseLeftButtonDown="CompanionCard_Click" Tag="1"
                                        BorderThickness="2" BorderBrush="Transparent">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A32" Offset="0"/>
                                            <GradientStop Color="#201A38" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtCompanion1Name" x:FieldModifier="internal" Text="{loc:Str label_perfect_fuckpuppet}" Foreground="#9370DB" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtCompanion1Lock" x:FieldModifier="internal" Text=" [100]" Foreground="#FFD700" FontSize="11" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtCompanion1Level" x:FieldModifier="internal" Text="{loc:Str label_lv_1}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{loc:Str label_autonomy_xp_bonus}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button x:Name="BtnCompanion1Personality" Content="🎭" FontSize="12" Padding="4,1"
                                                    Background="{DynamicResource DarkerBgBrush}" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="BtnCompanionPersonality_Click" Tag="1" ToolTip="{loc:Str tooltip_assign_ai_personality}"/>
                                            <TextBlock x:Name="TxtCompanion1Prompt" x:FieldModifier="internal" Text="" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CompanionCard2" x:FieldModifier="internal" CornerRadius="8" Margin="0,5,5,0"
                                        Padding="12,10" Cursor="Hand" MouseLeftButtonDown="CompanionCard_Click" Tag="2"
                                        BorderThickness="2" BorderBrush="Transparent">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A32" Offset="0"/>
                                            <GradientStop Color="#201A38" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtCompanion2Name" x:FieldModifier="internal" Text="{loc:Str label_brainwashed_slavedoll}" Foreground="#50C878" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtCompanion2Lock" x:FieldModifier="internal" Text=" [125]" Foreground="#FFD700" FontSize="11" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtCompanion2Level" x:FieldModifier="internal" Text="{loc:Str label_lv_1}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{loc:Str label_constant_xp_drain}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button x:Name="BtnCompanion2Personality" Content="🎭" FontSize="12" Padding="4,1"
                                                    Background="{DynamicResource DarkerBgBrush}" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="BtnCompanionPersonality_Click" Tag="2" ToolTip="{loc:Str tooltip_assign_ai_personality}"/>
                                            <TextBlock x:Name="TxtCompanion2Prompt" x:FieldModifier="internal" Text="" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CompanionCard3" x:FieldModifier="internal" CornerRadius="8" Margin="5,5,0,0"
                                        Padding="12,10" Cursor="Hand" MouseLeftButtonDown="CompanionCard_Click" Tag="3"
                                        BorderThickness="2" BorderBrush="Transparent">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A32" Offset="0"/>
                                            <GradientStop Color="#201A38" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtCompanion3Name" x:FieldModifier="internal" Text="{loc:Str label_platinum_puppet}" Foreground="#FF6B6B" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtCompanion3Lock" x:FieldModifier="internal" Text=" [150]" Foreground="#FFD700" FontSize="11" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtCompanion3Level" x:FieldModifier="internal" Text="{loc:Str label_lv_1}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{loc:Str label_strict_mode_bonuses}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button x:Name="BtnCompanion3Personality" Content="🎭" FontSize="12" Padding="4,1"
                                                    Background="{DynamicResource DarkerBgBrush}" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="BtnCompanionPersonality_Click" Tag="3" ToolTip="{loc:Str tooltip_assign_ai_personality}"/>
                                            <TextBlock x:Name="TxtCompanion3Prompt" x:FieldModifier="internal" Text="" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="CompanionCard4" x:FieldModifier="internal" CornerRadius="8" Margin="0,5,5,0"
                                        Padding="12,10" Cursor="Hand" MouseLeftButtonDown="CompanionCard_Click" Tag="4"
                                        BorderThickness="2" BorderBrush="Transparent">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A32" Offset="0"/>
                                            <GradientStop Color="#201A38" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtCompanion4Name" x:FieldModifier="internal" Text="{loc:Str label_bambi_cow}" Foreground="#F5DEB3" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TxtCompanion4Lock" x:FieldModifier="internal" Text=" [75]" Foreground="#FFD700" FontSize="11" VerticalAlignment="Center" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtCompanion4Level" x:FieldModifier="internal" Text="{loc:Str label_lv_1}" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{loc:Str label_session_completion_bonus}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button x:Name="BtnCompanion4Personality" Content="🎭" FontSize="12" Padding="4,1"
                                                    Background="{DynamicResource DarkerBgBrush}" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="BtnCompanionPersonality_Click" Tag="4" ToolTip="{loc:Str tooltip_assign_ai_personality}"/>
                                            <TextBlock x:Name="TxtCompanion4Prompt" x:FieldModifier="internal" Text="" Foreground="#555" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
    
                    <!-- AI BRAIN SECTION -->
                    <Grid Margin="0,0,0,10">
                        <Border CornerRadius="14" Padding="16" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource SurfaceBg}" Offset="0"/>
                                    <GradientStop Color="#1F1B36" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PatreonPurple}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{loc:Str label_ai_brain}" Foreground="{DynamicResource PinkBrush}" FontSize="24" FontWeight="Bold"/>
                                        <Border Background="#2A1A3A" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                                            <TextBlock Text="{loc:Str label_free_for_all_users}" Foreground="{DynamicResource PinkBrush}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                    <Button x:Name="HelpBtnAiChat" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="AiChat"/>
                                </Grid>
                                <TextBlock Text="{loc:Str label_ai_brain_subtitle}" Foreground="{DynamicResource TextDimBrush}" FontSize="16" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtAiStatus" x:FieldModifier="internal" Text="{loc:Str label_ai_initializing}" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" Margin="0,0,0,12"/>
    
                                <!-- Provider radios -->
                                <TextBlock Text="{loc:Str label_provider}" Foreground="White" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <StackPanel x:Name="AiProviderRadioGroup" Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton x:Name="RadioAiOff" x:FieldModifier="internal" GroupName="AiProvider" Content="{loc:Str label_provider_off}" Foreground="White" FontSize="17" Margin="0,0,16,0" Checked="RadioAiOff_Checked"/>
                                    <RadioButton x:Name="RadioAiCloud" x:FieldModifier="internal" GroupName="AiProvider" Content="{loc:Str label_provider_cloud}" Foreground="White" FontSize="17" Margin="0,0,16,0" Checked="RadioAiCloud_Checked"/>
                                    <RadioButton x:Name="RadioAiLocal" x:FieldModifier="internal" GroupName="AiProvider" Content="{loc:Str label_provider_local}" Foreground="White" FontSize="17" Margin="0,0,16,0" Checked="RadioAiLocal_Checked"/>
                                    <RadioButton x:Name="RadioAiOpenAiCompatible" x:FieldModifier="internal" GroupName="AiProvider" Content="{loc:Str label_provider_custom}" Foreground="White" FontSize="17" Checked="RadioAiOpenAiCompatible_Checked"/>
                                </StackPanel>
    
                                <!-- Daily request limit (OpenAI-compatible provider only) -->
                                <Grid x:Name="DailyLimitPanel" x:FieldModifier="internal" Margin="0,0,0,8" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Str label_daily_request_limit}" Foreground="White" FontSize="14"/>
                                        <TextBlock Text="{loc:Str label_daily_request_limit_hint}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtDailyLimit" x:FieldModifier="internal" Grid.Column="1" Width="60" Height="28"
                                             VerticalAlignment="Center"
                                             Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                             BorderBrush="#505050" BorderThickness="1" Padding="4,0" FontSize="13"
                                             HorizontalContentAlignment="Right" VerticalContentAlignment="Center"
                                             LostFocus="TxtDailyLimit_LostFocus"/>
                                </Grid>
    
                                <!-- Local config -->
                                <Border x:Name="LocalConfigPanel" x:FieldModifier="internal" Visibility="Collapsed" CornerRadius="8" Padding="10" Margin="0,0,0,12"
                                        Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#9370DB" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str label_local_ollama_config}" Foreground="#9370DB" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{loc:Str label_ollama_model}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                                <TextBox x:Name="TxtAiModel" x:FieldModifier="internal" Text="qwen3.5:latest"
                                                         Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                         BorderBrush="#505050" BorderThickness="1" Padding="6,4" FontSize="13" Margin="0,3,0,0"
                                                         Style="{StaticResource FocusGlowTextBox}" LostFocus="TxtAiModel_LostFocus"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{loc:Str label_ollama_host}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                                <TextBox x:Name="TxtAiHost" x:FieldModifier="internal" Text="http://localhost:11434/"
                                                         Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                         BorderBrush="#505050" BorderThickness="1" Padding="6,4" FontSize="13" Margin="0,3,0,0"
                                                         Style="{StaticResource FocusGlowTextBox}" LostFocus="TxtAiHost_LostFocus"/>
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock x:Name="TxtAiHealthStatus" x:FieldModifier="internal" Text="{loc:Str label_status_unknown}" Foreground="{DynamicResource TextDimBrush}" FontSize="13" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="BtnSetupLocalAi" Content="{loc:Str btn_setup_local_ai}"
                                                        Background="{StaticResource PinkBrush}" Foreground="White" BorderThickness="0"
                                                        Padding="10,4" FontSize="13" Cursor="Hand" Margin="0,0,8,0"
                                                        Click="BtnSetupLocalAi_Click"/>
                                                <Button x:Name="BtnTestOllamaConnection" Content="{loc:Str label_test_connection}"
                                                        Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                                        Padding="10,4" FontSize="13" Cursor="Hand" Click="BtnTestOllamaConnection_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
    
                                <!-- OpenAI-compatible config -->
                                <Border x:Name="OpenAiCompatibleConfigPanel" x:FieldModifier="internal" Visibility="Collapsed" CornerRadius="8" Padding="10" Margin="0,0,0,12"
                                        Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#9370DB" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str label_custom_ai_config}" Foreground="#9370DB" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
    
                                            <!-- Endpoint URL -->
                                            <StackPanel Grid.Row="0" Margin="0,0,0,4">
                                                <TextBlock Text="{loc:Str label_custom_endpoint}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                                <TextBox x:Name="TxtOpenAiEndpoint" x:FieldModifier="internal"
                                                         Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                         BorderBrush="#505050" BorderThickness="1" Padding="6,4" FontSize="13" Margin="0,3,0,0"
                                                         Style="{StaticResource FocusGlowTextBox}" LostFocus="TxtOpenAiEndpoint_LostFocus"
                                                         ToolTip="{loc:Str label_custom_endpoint_placeholder}"/>
                                            </StackPanel>
    
                                            <!-- API Key -->
                                            <StackPanel Grid.Row="1" Margin="0,4,0,4">
                                                <TextBlock Text="{loc:Str label_custom_api_key}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                                <PasswordBox x:Name="TxtOpenAiApiKey" x:FieldModifier="internal"
                                                             Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                             BorderBrush="#505050" BorderThickness="1" Padding="6,4" FontSize="13" Margin="0,3,0,0"
                                                             PasswordChanged="TxtOpenAiApiKey_PasswordChanged"/>
                                            </StackPanel>
    
                                            <!-- Model + Test connection -->
                                            <Grid Grid.Row="2" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{loc:Str label_custom_model}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                                    <TextBox x:Name="TxtOpenAiModel" x:FieldModifier="internal"
                                                             Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                             BorderBrush="#505050" BorderThickness="1" Padding="6,4" FontSize="13" Margin="0,3,0,0"
                                                             Style="{StaticResource FocusGlowTextBox}" LostFocus="TxtOpenAiModel_LostFocus"
                                                             ToolTip="{loc:Str label_custom_model_placeholder}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8,0,0,0">
                                                    <Button x:Name="BtnOpenAiSamplerSettings" Content="{loc:Str btn_sampler_settings}"
                                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                                            Padding="10,4" FontSize="13" Cursor="Hand" Margin="0,0,8,0"
                                                            Click="BtnOpenAiSamplerSettings_Click"
                                                            ToolTip="{loc:Str hint_sampler_settings}"/>
                                                    <Button x:Name="BtnTestOpenAiConnection" Content="{loc:Str label_test_connection}"
                                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                                            Padding="10,4" FontSize="13" Cursor="Hand" Click="BtnTestOpenAiConnection_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
    
                                        <TextBlock x:Name="TxtOpenAiHealthStatus" x:FieldModifier="internal" Text="{loc:Str label_status_unknown}" Foreground="{DynamicResource TextDimBrush}" FontSize="13" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
    
                                <!-- Live actions — only meaningful when local AI is selected
                                     (cloud AI can't trigger effects, so the feed stays empty). -->
                                <StackPanel x:Name="LiveActionsContainer" x:FieldModifier="internal" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Str label_live_actions}" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <Border CornerRadius="8" Padding="10" Margin="0,0,0,10" MinHeight="60" MaxHeight="140"
                                            Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#22808080" BorderThickness="1">
                                        <Grid>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl x:Name="LiveActionsList" x:FieldModifier="internal">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13" Margin="0,2"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                            <TextBlock x:Name="TxtLiveActionsPlaceholder" x:FieldModifier="internal" Text="{loc:Str label_live_actions_placeholder}"
                                                       Foreground="#666" FontSize="13" FontStyle="Italic" TextWrapping="Wrap"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
    
                                <!-- Slut Mode toggle: swaps the active personality's prompt with the
                                     spicier SlutModePersonality variant when on. Available to all users. -->
                                <Grid Margin="0,4,0,8">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str label_slut_mode}" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="{loc:Str label_slut_mode_subtitle}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkSlutMode" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ChkSlutMode_Changed" Unchecked="ChkSlutMode_Changed"/>
                                </Grid>
    
                                <Button x:Name="BtnOpenAdvancedPersonality" Content="{loc:Str label_open_advanced_personality}"
                                        Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                        Padding="10,8" FontSize="14" Cursor="Hand" Click="BtnCustomizeCompanion_Click"/>
                            </StackPanel>
                        </Border>
    
                        <Border x:Name="AiFeaturesLockOverlay" x:FieldModifier="internal" Background="#CC1A1A2E" CornerRadius="14" Panel.ZIndex="100">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,15">
                                <Image Width="42" Height="42" HorizontalAlignment="Center" Margin="0,0,0,8" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock Text="{loc:Str label_login_required}" Foreground="{DynamicResource PinkBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{loc:Str label_login_with_discord_or_patreon_to_use_ai_featu}"
                                           Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
    
                    <!-- BEHAVIOUR & TRIGGERS — collapsible accordion (collapsed by default) -->
                    <Expander x:Name="SectionBehaviour" x:FieldModifier="internal" Style="{StaticResource CollapsibleCard}" IsExpanded="False"
                              Expanded="CompanionSection_ExpandedChanged" Collapsed="CompanionSection_ExpandedChanged">
                        <Expander.Header>
                            <TextBlock Text="{loc:Str label_behavior_and_triggers}" Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
                        </Expander.Header>
                        <StackPanel>
                            <Grid Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str label_idle_giggle_interval}" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="{loc:Str label_how_often_companion_speaks_when_idle}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtIdleIntervalCompanion" x:FieldModifier="internal" Text="{loc:Str label_120s}" Foreground="{DynamicResource PinkBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="SliderIdleIntervalCompanion" x:FieldModifier="internal" Style="{StaticResource PinkSlider}"
                                    Minimum="20" Maximum="300" Value="120" Margin="0,6,0,12"
                                    ValueChanged="SliderIdleInterval_ValueChanged"/>
    
                            <Grid Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str label_bubble_duration}" Foreground="White" FontSize="14"/>
                                    <TextBlock Text="{loc:Str desc_bubble_duration}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtBubbleDurationCompanion" x:FieldModifier="internal" Text="2s" Foreground="{DynamicResource PinkBrush}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Slider x:Name="SliderBubbleDurationCompanion" x:FieldModifier="internal" Style="{StaticResource PinkSlider}"
                                    Minimum="1" Maximum="10" Value="2" Margin="0,6,0,12"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ToolTip="{loc:Str tooltip_bubble_duration}"
                                    ValueChanged="SliderBubbleDuration_ValueChanged"/>
    
                            <!-- Awareness Mode toggle — reunited here from the old AI Brain "Capabilities" block.
                                 Flipping it on reveals the cooldown/consent panel directly below. -->
                            <Grid Margin="0,4,0,8">
                                <TextBlock Text="{loc:Str label_capability_awareness}" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkAwarenessMode" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          IsChecked="False"
                                          Checked="ChkAwarenessMode_Changed" Unchecked="ChkAwarenessMode_Changed"/>
                            </Grid>
    
                            <Border x:Name="AwarenessSettingsPanel" x:FieldModifier="internal" Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,12" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{loc:Str label_awareness_settings}" Foreground="{DynamicResource PinkBrush}" FontSize="14" FontWeight="Bold"/>
                                            <Button x:Name="HelpBtnAwareness" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="6,0,0,0" Tag="WindowAwareness"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="{loc:Str label_reaction_cooldown}" Foreground="White" FontSize="13"/>
                                        <TextBlock x:Name="TxtAwarenessCooldown" x:FieldModifier="internal" Text="{loc:Str label_90s}" Foreground="{DynamicResource PinkBrush}" HorizontalAlignment="Right" FontSize="13" FontWeight="Bold"/>
                                    </Grid>
                                    <Slider x:Name="SliderAwarenessCooldown" x:FieldModifier="internal" Style="{StaticResource PinkSlider}"
                                            Minimum="10" Maximum="300" Value="90" Margin="0,6,0,8"
                                            ValueChanged="SliderAwarenessCooldown_ValueChanged"/>
                                    <Border Background="#2A1A1A" CornerRadius="6" Padding="8" BorderBrush="#FF6B6B" BorderThickness="1">
                                        <StackPanel>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚠️" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Str label_privacy_notice}" Foreground="#FF6B6B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button x:Name="BtnPrivacySpoiler" x:FieldModifier="internal" Content="{loc:Str btn_click_to_reveal}"
                                                        Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                                        HorizontalAlignment="Right" FontSize="12" Cursor="Hand"
                                                        Click="BtnPrivacySpoiler_Click"/>
                                            </Grid>
                                            <TextBlock x:Name="TxtPrivacyDetails" x:FieldModifier="internal" Visibility="Collapsed"
                                                       TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="12" Margin="0,8,0,0"
                                                       Text="{loc:Str label_this_feature_reads_the_name_of_the_active_win}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
    
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Str label_trigger_mode}" Foreground="#9370DB" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="{loc:Str label_random_conditioning_phrases_with_audio}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkTriggerModeCompanion" x:FieldModifier="internal" Grid.Column="1" Style="{StaticResource ToggleStyle}"
                                          VerticalAlignment="Center"
                                          Checked="ChkTriggerMode_Changed" Unchecked="ChkTriggerMode_Changed"/>
                            </Grid>
                            <StackPanel x:Name="TriggerSettingsPanelCompanion" x:FieldModifier="internal" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Str label_interval}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <Slider x:Name="SliderTriggerIntervalCompanion" x:FieldModifier="internal" Style="{StaticResource PinkSlider}"
                                        Width="150" Minimum="10" Maximum="600" Value="60"
                                        VerticalAlignment="Center" Margin="10,0,0,0"
                                        ValueChanged="SliderTriggerInterval_ValueChanged"/>
                                <TextBlock x:Name="TxtTriggerIntervalCompanion" x:FieldModifier="internal" Text="{loc:Str label_60s}" Foreground="#9370DB" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button x:Name="BtnEditTriggersCompanion" Content="{loc:Str btn_edit_phrases_2}"
                                        Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                        Padding="10,4" FontSize="13" Margin="14,0,0,0" Cursor="Hand"
                                        Click="BtnEditTriggers_Click"/>
                            </StackPanel>
    
                            <Border BorderBrush="#353550" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,10,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_mute_whispers}" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{loc:Str label_mute_subliminal_audio}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkMuteWhispersCompanion" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkMuteWhispers_Changed" Unchecked="ChkMuteWhispers_Changed"/>
                                    </Grid>
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_pause_browser}" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{loc:Str label_pause_embedded_browser_audio}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkPauseBrowserCompanion" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkPauseBrowser_Changed" Unchecked="ChkPauseBrowser_Changed"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Expander>
    
                    <!-- PHRASES & PERSONALITY — collapsible accordion (collapsed by default) -->
                    <Expander x:Name="SectionPhrases" x:FieldModifier="internal" Style="{StaticResource CollapsibleCard}" IsExpanded="False"
                              Expanded="CompanionSection_ExpandedChanged" Collapsed="CompanionSection_ExpandedChanged">
                        <Expander.Header>
                            <TextBlock Text="{loc:Str label_phrases_and_personality}" Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
                        </Expander.Header>
                        <StackPanel>
                            <Border CornerRadius="8" Padding="10" Margin="0,4,0,10" BorderBrush="#339370DB" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#16162B" Offset="0"/>
                                        <GradientStop Color="#1C1635" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str label_active_personality}" Foreground="{DynamicResource TextDimBrush}" FontSize="13"/>
                                        <TextBlock x:Name="TxtActivePromptName" x:FieldModifier="internal" Text="{loc:Str label_default_built_in}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="BtnDeactivatePrompt" x:FieldModifier="internal" Content="{loc:Str btn_reset}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                            FontSize="13" Padding="10,4" Cursor="Hand" Visibility="Collapsed"
                                            Click="BtnDeactivatePrompt_Click"/>
                                </Grid>
                            </Border>
    
                            <Button x:Name="BtnManagePhrases"
                                    Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                    Padding="10,8" FontSize="16" Cursor="Hand" Margin="0,0,0,8"
                                    Click="BtnManagePhrases_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{loc:Str label_manage_phrases}" Foreground="White"/>
                                    <TextBlock x:Name="TxtPhraseCount" x:FieldModifier="internal" Text="{loc:Str label_0_active}" Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>
    
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CmbPhrasePresets" x:FieldModifier="internal" Grid.Column="0" FontSize="13"
                                          Style="{StaticResource DarkComboBoxStyle}"
                                          DisplayMemberPath="DisplayText"
                                          SelectedValuePath="Id"
                                          SelectionChanged="CmbPhrasePresets_SelectionChanged"/>
                                <Button Content="{loc:Str btn_save}" Grid.Column="1"
                                        Style="{StaticResource SmallPinkButton}"
                                        Padding="10,4" FontSize="13" Margin="6,0,0,0"
                                        ToolTip="{loc:Str tooltip_save_current_phrase_config_as_a_preset}"
                                        Click="BtnSavePhrasePreset_Click"/>
                                <Button Content="{loc:Str btn_delete}" Grid.Column="2"
                                        Style="{StaticResource OutlineButton}"
                                        Padding="10,4" FontSize="13" Margin="4,0,0,0"
                                        ToolTip="{loc:Str tooltip_delete_selected_phrase_preset}"
                                        Click="BtnDeletePhrasePreset_Click"/>
                            </Grid>
                        </StackPanel>
                    </Expander>
    
                    <!-- CONTENT (Hypnotube link pool, per-mod) — collapsible accordion (collapsed by default) -->
                    <Expander x:Name="SectionContent" x:FieldModifier="internal" Style="{StaticResource CollapsibleCard}" IsExpanded="False"
                              Expanded="CompanionSection_ExpandedChanged" Collapsed="CompanionSection_ExpandedChanged">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Str label_hypnotube_links}" Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
                                <Button x:Name="HelpBtnVideoLinks" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="HypnotubeLinks"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel>
                            <!-- Per-mod scope signpost: these links are scoped to the active mod, unlike the global settings above. -->
                            <Border CornerRadius="6" Padding="10,6" Margin="0,4,0,8"
                                    Background="#2A1A3A" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Str label_current_mode}" FontSize="14" Foreground="#AAA" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtHypnotubeModeLabel" x:FieldModifier="internal" Text="{loc:Str label_bambi_sleep}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PinkBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{loc:Str label_video_links_pool_desc}" FontSize="13" Foreground="{DynamicResource TextDimBrush}" Margin="0,0,0,6" TextWrapping="Wrap"/>
    
                            <!-- Column headers, aligned to the row template (name * · gap · link 2* · open · bin) -->
                            <Grid Margin="2,0,2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Str label_col_name}" Foreground="#888" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="{loc:Str label_col_link}" Foreground="#888" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>
    
                            <!-- Mod-aware video link pool: one name+URL row per video, add with +, remove with the bin. -->
                            <Border CornerRadius="8" Padding="8" MinHeight="60" MaxHeight="260" Margin="0,0,0,8"
                                    BorderBrush="#22808080" BorderThickness="1" Background="{DynamicResource SurfaceBgBrush}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="VideoLinkPoolPanel" x:FieldModifier="internal">
                                        <TextBlock x:Name="TxtNoVideoLinks" x:FieldModifier="internal" Text="{loc:Str label_no_video_links_yet}"
                                                   Foreground="#505050" FontSize="13" FontStyle="Italic"
                                                   HorizontalAlignment="Center" Margin="0,16,0,16"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <Button x:Name="BtnAddVideoLink" Content="{loc:Str btn_add_link_to_pool}"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                    FontSize="13" Padding="14,7" Cursor="Hand"
                                    Click="BtnAddVideoLink_Click"/>
                        </StackPanel>
                    </Expander>
    
                    <!-- COMMUNITY PROMPTS — collapsible accordion (collapsed by default) -->
                    <Expander x:Name="SectionCommunity" x:FieldModifier="internal" Style="{StaticResource CollapsibleCard}" IsExpanded="False"
                              Expanded="CompanionSection_ExpandedChanged" Collapsed="CompanionSection_ExpandedChanged">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{loc:Str label_community_prompts}" Foreground="#9370DB" FontSize="18" FontWeight="Bold"/>
                                <Border Background="#FF6B6B" CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Str label_beta}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <Button x:Name="HelpBtnPrompts" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="CommunityPrompts"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnBrowsePrompts" Grid.Column="0" Content="{loc:Str btn_browse}"
                                        Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                        FontSize="14" Padding="0,8" Margin="0,0,4,0" Cursor="Hand" Click="BtnBrowsePrompts_Click"/>
                                <Button x:Name="BtnImportPrompt" Grid.Column="1" Content="{loc:Str btn_import}"
                                        Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                        FontSize="14" Padding="0,8" Margin="4,0,4,0" Cursor="Hand" Click="BtnImportPrompt_Click"/>
                                <Button x:Name="BtnExportPrompt" Grid.Column="2" Content="{loc:Str btn_export}"
                                        Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                        FontSize="14" Padding="0,8" Margin="4,0,8,0" Cursor="Hand" Click="BtnExportPrompt_Click"/>
                                <Button x:Name="BtnRefreshPrompts" x:FieldModifier="internal" Grid.Column="3" Content="{loc:Str btn_refresh}"
                                        Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                        FontSize="13" Padding="8,2" Cursor="Hand" Click="BtnRefreshPrompts_Click"/>
                            </Grid>
    
                            <TextBlock Text="{loc:Str label_installed_prompts}" Foreground="{DynamicResource TextDimBrush}" FontSize="13" Margin="0,4,0,6"/>
                            <Border CornerRadius="8" Padding="10" MinHeight="80" MaxHeight="120" Margin="0,0,0,12" BorderBrush="#22808080" BorderThickness="1"
                                    Background="{DynamicResource SurfaceBgBrush}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="InstalledPromptsPanel" x:FieldModifier="internal">
                                        <TextBlock x:Name="TxtNoInstalledPrompts" Text="{loc:Str label_no_prompts_installed_yet}"
                                                   Foreground="#505050" FontSize="14" FontStyle="Italic"
                                                   HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
    
                        </StackPanel>
                    </Expander>
    
                    </StackPanel>
    
                    <!-- Hidden help buttons kept for SetHelpContent compat -->
                    <Button x:Name="HelpBtnCompanionSettings" x:FieldModifier="internal" Visibility="Collapsed" Tag="CompanionSettings"/>
                    <Button x:Name="HelpBtnQuickControls" x:FieldModifier="internal" Visibility="Collapsed" Tag="QuickControls"/>
    
                </StackPanel>
            </ScrollViewer>
        </Border>
</UserControl>

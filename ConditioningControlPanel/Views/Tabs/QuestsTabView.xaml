<UserControl x:Class="ConditioningControlPanel.Views.Tabs.QuestsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <Grid>
        <Border Style="{StaticResource SectionPanel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <!-- Sub-tab Navigation -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button x:Name="BtnQuestSubDaily" x:FieldModifier="internal" Content="{loc:Str btn_daily_weekly}"
                                Style="{StaticResource TabButtonActive}"
                                Click="BtnQuestSubDaily_Click" Width="120"/>
                        <Button x:Name="BtnQuestSubRoadmap" x:FieldModifier="internal" Content="{loc:Str btn_bimbo_journal}"
                                Style="{StaticResource TabButton}"
                                Click="BtnQuestSubRoadmap_Click" Margin="10,0,0,0" Width="150"/>
                    </StackPanel>
    
                    <!-- Daily/Weekly Quests Panel -->
                    <StackPanel x:Name="DailyWeeklyPanel" x:FieldModifier="internal">
                        <!-- Season Title Banner -->
                        <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="12" Padding="20,14" Margin="0,0,0,18"
                                BorderThickness="1" BorderBrush="#3D3D60">
                            <TextBlock x:Name="TxtSeasonTitle" x:FieldModifier="internal" Text="{loc:Str label_airhead_april}"
                                       FontSize="28" FontWeight="ExtraBold" FontStyle="Italic"
                                       HorizontalAlignment="Center" TextAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush x:Name="SeasonTitleBrush" x:FieldModifier="internal" StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop x:Name="SeasonGrad1" Color="{DynamicResource PinkColor}" Offset="0.0"/>
                                        <GradientStop x:Name="SeasonGrad2" Color="#DA70D6" Offset="0.25"/>
                                        <GradientStop x:Name="SeasonGrad3" Color="{DynamicResource DarkPink}" Offset="0.5"/>
                                        <GradientStop x:Name="SeasonGrad4" Color="#DA70D6" Offset="0.75"/>
                                        <GradientStop x:Name="SeasonGrad5" Color="{DynamicResource PinkColor}" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
                                </TextBlock.Effect>
                                <!-- Season title shimmer managed in code-behind (StartSeasonTitleShimmer/StopSeasonTitleShimmer) -->
                            </TextBlock>
                        </Border>
    
                        <!-- Header -->
                        <Grid Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <helpers:EmojiTextBlock Text="{loc:Str label_quests}" Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
                                <Button x:Name="HelpBtnQuests" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="Quests"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtQuestStats" x:FieldModifier="internal" Text="{loc:Str label_0_completed_this_week}"
                                       Foreground="#888888" FontSize="12" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
    
                        <!-- Two-column layout for Daily and Weekly -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- DAILY QUEST CARD -->
                        <ContentControl Grid.Column="0" Style="{StaticResource AnimatedGradientPanel}"
                                BorderThickness="2" BorderBrush="#FFD700">
                            <StackPanel>
                                <!-- Card Header -->
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="22" Height="22"
                                               Source="{Binding Source='☀️', Converter={StaticResource EmojiToImageSource}}"/>
                                        <TextBlock Text="{loc:Str label_daily_quest}" Foreground="#FFD700"
                                                   FontSize="16" FontWeight="Bold" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                        <!-- Daily quest counter badge -->
                                        <Border x:Name="DailyQuestCounterBadge" Background="#3D3D60" CornerRadius="8"
                                                Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TxtDailyQuestCounter" x:FieldModifier="internal" Text="0/3"
                                                       Foreground="#FFD700" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{loc:Str label_resets_at_midnight}" Foreground="#666666"
                                               FontSize="10" HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
    
                                <!-- Daily Progress Segments -->
                                <Grid Margin="0,8,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="DailySegment1" x:FieldModifier="internal" Grid.Column="0" Background="#3D3D60"
                                            CornerRadius="3" Height="6"/>
                                    <Border x:Name="DailySegment2" x:FieldModifier="internal" Grid.Column="2" Background="#3D3D60"
                                            CornerRadius="3" Height="6"/>
                                    <Border x:Name="DailySegment3" x:FieldModifier="internal" Grid.Column="4" Background="#3D3D60"
                                            CornerRadius="3" Height="6"/>
                                </Grid>
                                <TextBlock Text="{loc:Str label_complete_3_daily_quests_1_weekly_quest}"
                                           Foreground="#666666" FontSize="10"
                                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
    
                                <!-- Quest Content -->
                                <Border x:Name="DailyQuestCard" x:FieldModifier="internal" Background="{DynamicResource PanelBgBrush}"
                                        CornerRadius="10" Padding="15" MinHeight="180">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <helpers:EmojiTextBlock x:Name="TxtDailyQuestIcon" x:FieldModifier="internal" Text=""
                                                                    FontSize="24" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                            <TextBlock x:Name="TxtDailyQuestName" x:FieldModifier="internal" Text="{loc:Str label_loading_2}"
                                                       Foreground="White" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Left" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="TxtDailyQuestDesc" x:FieldModifier="internal" Text=""
                                                       Foreground="#AAAAAA" FontSize="12"
                                                       HorizontalAlignment="Left" TextWrapping="Wrap"
                                                       MaxWidth="180"/>
    
                                            <!-- Progress Bar -->
                                            <Grid Margin="0,12,0,0">
                                                <Border x:Name="DailyProgressTrack" x:FieldModifier="internal" Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Height="10">
                                                    <Border x:Name="DailyProgressFill" x:FieldModifier="internal" Background="#FFD700"
                                                            CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock x:Name="TxtDailyProgress" x:FieldModifier="internal" Text="0 / 0"
                                                       Foreground="#FFD700" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Left" Margin="0,5,0,0"/>
    
                                            <!-- XP Reward -->
                                            <Border Background="#3D3D60" CornerRadius="5"
                                                    Padding="10,5" Margin="0,10,0,0"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="TxtDailyXP" x:FieldModifier="internal" Text="{loc:Str label_0_xp}"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="14"
                                                               FontWeight="Bold"/>
                                                    <TextBlock x:Name="TxtDailyStreakBonus" x:FieldModifier="internal" Text=""
                                                               Foreground="#FFB347" FontSize="12"
                                                               FontWeight="Bold" Margin="6,1,0,0"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe UI Emoji"
                                                               Visibility="Collapsed"/>
                                                    <TextBlock x:Name="TxtDailyRerollBonus" x:FieldModifier="internal" Text=""
                                                               Foreground="#7BC8F6" FontSize="12"
                                                               FontWeight="Bold" Margin="6,1,0,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <!-- Quest Image -->
                                        <Border Grid.Column="1" CornerRadius="12" Margin="10,0,0,0"
                                                Width="150" Height="150" Background="{DynamicResource DarkerBgBrush}">
                                            <Border.Clip>
                                                <RectangleGeometry RadiusX="12" RadiusY="12" Rect="0,0,150,150"/>
                                            </Border.Clip>
                                            <Grid>
                                                <Image x:Name="ImgDailyQuest" x:FieldModifier="internal" Stretch="UniformToFill"/>
                                                <!-- Checkmark overlay for completed state -->
                                                <Border x:Name="DailyCompletedOverlay" x:FieldModifier="internal" Background="#802D4A2D"
                                                        Visibility="Collapsed">
                                                    <TextBlock Text="✓" Foreground="#00E676" FontSize="64"
                                                               FontWeight="Bold" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"/>
                                                        </TextBlock.Effect>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
    
                                <!-- All Daily Quests Completed Message -->
                                <Border x:Name="DailyAllCompletedMessage" x:FieldModifier="internal" Background="#2D4A2D" CornerRadius="10"
                                        Padding="15" MinHeight="180" Visibility="Collapsed">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Image Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,10"
                                               Source="{Binding Source='✅', Converter={StaticResource EmojiToImageSource}}"/>
                                        <TextBlock Text="{loc:Str label_all_daily_quests_completed}" Foreground="#00E676"
                                                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock Text="{loc:Str label_check_back_tomorrow_for_new_quests}" Foreground="#888888"
                                                   FontSize="12" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
    
                                <!-- Reroll Button -->
                                <Button x:Name="BtnRerollDaily" x:FieldModifier="internal" Content="{loc:Str btn_reroll}"
                                        Style="{StaticResource OutlineButton}"
                                        Margin="0,15,0,0" Click="BtnRerollDaily_Click"
                                        ToolTip="{loc:Str tooltip_reroll_for_a_different_quest_once_per_day}"/>
                            </StackPanel>
                        </ContentControl>
    
                        <!-- WEEKLY QUEST CARD -->
                        <ContentControl Grid.Column="2" Style="{StaticResource AnimatedGradientPanel}"
                                BorderThickness="2" BorderBrush="#9370DB">
                            <StackPanel>
                                <!-- Card Header -->
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="22" Height="22"
                                               Source="{Binding Source='🌙', Converter={StaticResource EmojiToImageSource}}"/>
                                        <TextBlock Text="{loc:Str label_weekly_quest}" Foreground="#9370DB"
                                                   FontSize="16" FontWeight="Bold" Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{loc:Str label_resets_sunday}" Foreground="#666666"
                                               FontSize="10" HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="{loc:Str label_1_weekly_quest_to_complete}"
                                           Foreground="#666666" FontSize="10"
                                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
    
                                <!-- Quest Content -->
                                <Border x:Name="WeeklyQuestCard" Background="{DynamicResource PanelBgBrush}"
                                        CornerRadius="10" Padding="15" MinHeight="180">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <helpers:EmojiTextBlock x:Name="TxtWeeklyQuestIcon" x:FieldModifier="internal" Text=""
                                                                    FontSize="24" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                            <TextBlock x:Name="TxtWeeklyQuestName" x:FieldModifier="internal" Text="{loc:Str label_loading_2}"
                                                       Foreground="White" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Left" Margin="0,0,0,5"/>
                                            <TextBlock x:Name="TxtWeeklyQuestDesc" x:FieldModifier="internal" Text=""
                                                       Foreground="#AAAAAA" FontSize="12"
                                                       HorizontalAlignment="Left" TextWrapping="Wrap"
                                                       MaxWidth="180"/>
    
                                            <!-- Progress Bar -->
                                            <Grid Margin="0,12,0,0">
                                                <Border x:Name="WeeklyProgressTrack" x:FieldModifier="internal" Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Height="10">
                                                    <Border x:Name="WeeklyProgressFill" x:FieldModifier="internal" Background="#9370DB"
                                                            CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock x:Name="TxtWeeklyProgress" x:FieldModifier="internal" Text="0 / 0"
                                                       Foreground="#9370DB" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Left" Margin="0,5,0,0"/>
    
                                            <!-- XP Reward -->
                                            <Border Background="#3D3D60" CornerRadius="5"
                                                    Padding="10,5" Margin="0,10,0,0"
                                                    HorizontalAlignment="Left">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="TxtWeeklyXP" x:FieldModifier="internal" Text="{loc:Str label_0_xp}"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="14"
                                                               FontWeight="Bold"/>
                                                    <TextBlock x:Name="TxtWeeklyStreakBonus" x:FieldModifier="internal" Text=""
                                                               Foreground="#FFB347" FontSize="12"
                                                               FontWeight="Bold" Margin="6,1,0,0"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe UI Emoji"
                                                               Visibility="Collapsed"/>
                                                    <TextBlock x:Name="TxtWeeklyRerollBonus" x:FieldModifier="internal" Text=""
                                                               Foreground="#7BC8F6" FontSize="12"
                                                               FontWeight="Bold" Margin="6,1,0,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <!-- Quest Image -->
                                        <Border Grid.Column="1" CornerRadius="12" Margin="10,0,0,0"
                                                Width="150" Height="150" Background="{DynamicResource DarkerBgBrush}">
                                            <Border.Clip>
                                                <RectangleGeometry RadiusX="12" RadiusY="12" Rect="0,0,150,150"/>
                                            </Border.Clip>
                                            <Grid>
                                                <Image x:Name="ImgWeeklyQuest" x:FieldModifier="internal" Stretch="UniformToFill"/>
                                                <!-- Checkmark overlay for completed state -->
                                                <Border x:Name="WeeklyCompletedOverlay" x:FieldModifier="internal" Background="#802D4A2D"
                                                        Visibility="Collapsed">
                                                    <TextBlock Text="✓" Foreground="#00E676" FontSize="64"
                                                               FontWeight="Bold" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"/>
                                                        </TextBlock.Effect>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
    
                                <!-- Reroll Button -->
                                <Button x:Name="BtnRerollWeekly" x:FieldModifier="internal" Content="{loc:Str btn_reroll}"
                                        Style="{StaticResource OutlineButton}"
                                        Margin="0,15,0,0" Click="BtnRerollWeekly_Click"
                                        ToolTip="{loc:Str tooltip_reroll_for_a_different_quest_once_per_week}"/>
                            </StackPanel>
                        </ContentControl>
                    </Grid>
    
                        <!-- Quest Complete Banner (shown briefly when quest completes) -->
                        <Border x:Name="QuestCompleteBanner" x:FieldModifier="internal" Background="#2D4A2D" CornerRadius="10"
                                Padding="15" Margin="0,20,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Width="26" Height="26" Source="{Binding Source='✨', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock x:Name="TxtQuestComplete" x:FieldModifier="internal" Text="{loc:Str label_quest_complete}"
                                           Foreground="#00E676" FontSize="18" FontWeight="Bold"
                                           Margin="10,0" VerticalAlignment="Center"/>
                                <Image Width="26" Height="26" Source="{Binding Source='✨', Converter={StaticResource EmojiToImageSource}}"/>
                            </StackPanel>
                        </Border>
    
                        <!-- Quest Streak Calendar -->
                        <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="10" Padding="15,12" Margin="0,20,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <helpers:EmojiTextBlock Grid.Column="0" Text="{loc:Str label_quest_streak}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtQuestStreakCount" x:FieldModifier="internal" Grid.Column="1" Text="" Foreground="#FFD700"
                                               FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button x:Name="BtnFixStreak" x:FieldModifier="internal" Grid.Column="2" Content="{loc:Str btn_fix_day}"
                                            Style="{StaticResource OutlineButton}" Padding="8,3" FontSize="11"
                                            Click="BtnFixStreak_Click" Visibility="Collapsed" VerticalAlignment="Center"/>
                                </Grid>
                                <Canvas x:Name="StreakCalendarCanvas" x:FieldModifier="internal" Height="50" ClipToBounds="True"
                                       SizeChanged="StreakCalendarCanvas_SizeChanged"/>
                                <TextBlock x:Name="TxtFixStreakStatus" x:FieldModifier="internal" Text="" Foreground="{DynamicResource PinkBrush}" FontSize="11"
                                           TextAlignment="Center" Margin="0,5,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
    
                        <!-- Quest Statistics Section -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="15" Margin="0,20,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="{loc:Str label_quest_statistics}" Foreground="White"
                                               FontSize="14" FontWeight="Bold"/>
                                    <Button x:Name="HelpBtnQuestStats" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="QuestStats"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTotalDailyCompleted" x:FieldModifier="internal" Text="0"
                                                   Foreground="#FFD700" FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_daily_completed}" Foreground="#888888"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTotalWeeklyCompleted" x:FieldModifier="internal" Text="0"
                                                   Foreground="#9370DB" FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_weekly_completed}" Foreground="#888888"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtTotalQuestXP" x:FieldModifier="internal" Text="0"
                                                   Foreground="{DynamicResource PinkBrush}" FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_total_xp_earned}" Foreground="#888888"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <!-- End Daily/Weekly Panel -->
    
                    <!-- Bimbo Journal Panel -->
                    <StackPanel x:Name="RoadmapPanel" x:FieldModifier="internal" Visibility="Collapsed">
                        <!-- Journal Header -->
                        <TextBlock Text="{loc:Str label_look_how_far_you_ve_come_sweetie}"
                                   FontSize="26" FontStyle="Italic" FontWeight="Light"
                                   Foreground="#CC88AACC" HorizontalAlignment="Center"
                                   Margin="0,0,0,8" TextAlignment="Center"/>
    
                        <!-- Journal Info Box -->
                        <Border Background="#30FFD700" BorderBrush="#AAFFD700" BorderThickness="1.5"
                                CornerRadius="6" Padding="14,10" Margin="20,0,20,14" MaxWidth="700"
                                HorizontalAlignment="Center">
                            <StackPanel>
                                <helpers:EmojiTextBlock Text="{loc:Str label_what_is_the_bimbo_journal}" Foreground="#FFD700" FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#DDFFFFFF" FontSize="12" LineHeight="18">
                                    <Run Text="{loc:Str label_each_track_has_steps_that_ask_you_to_take_a_p}"/>
                                    <LineBreak/>
                                    <Run Text="{loc:Str label_click_a_step_take_the_pic_and_upload_it_to_ma}"/>
                                    <LineBreak/>
                                    <Run Text="{loc:Str label_complete_all_steps_in_a_track_to_unlock_the_n}"/>
                                </TextBlock>
                                <TextBlock Foreground="#AAFFD700" FontSize="11" FontStyle="Italic" Margin="0,8,0,0"
                                           Text="{loc:Str label_all_photos_are_stored_locally_on_your_pc_only}"/>
                            </StackPanel>
                        </Border>
    
                        <!-- Track Selector Tabs -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button x:Name="BtnTrack1" x:FieldModifier="internal" Content="{loc:Str btn_the_empty_doll}"
                                    Style="{StaticResource TabButtonActive}"
                                    Click="BtnTrack_Click" Tag="EmptyDoll" Width="130"/>
                            <Button x:Name="BtnTrack2" x:FieldModifier="internal" Content="{loc:Str btn_the_obedient_puppet}"
                                    Style="{StaticResource TabButton}"
                                    Click="BtnTrack_Click" Tag="ObedientPuppet" Margin="10,0,0,0" Width="150"/>
                            <Button x:Name="BtnTrack3" x:FieldModifier="internal" Content="{loc:Str btn_the_slutty_blowdoll}"
                                    Style="{StaticResource TabButton}"
                                    Click="BtnTrack_Click" Tag="SluttyBlowdoll" Margin="10,0,0,0" Width="150"/>
                        </StackPanel>
    
                        <!-- Track Info Header -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Button x:Name="HelpBtnRoadmap" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Tag="Roadmap"/>
                                <StackPanel>
                                    <TextBlock x:Name="TxtRoadmapTrackName" x:FieldModifier="internal" Text="{loc:Str btn_the_empty_doll}"
                                               Foreground="{DynamicResource PinkBrush}" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtRoadmapTrackSubtitle" x:FieldModifier="internal" Text="{loc:Str label_gateway_phase}"
                                               Foreground="#888888" FontSize="14"/>
                                    <TextBlock x:Name="TxtRoadmapTrackProgress" x:FieldModifier="internal" Text="{loc:Str label_0_7_steps_completed}"
                                               Foreground="#AAAAAA" FontSize="12" Margin="0,5,0,0"/>
                                </StackPanel>
                                <!-- Badge indicator for final track -->
                                <StackPanel x:Name="BadgeIndicator" x:FieldModifier="internal" Orientation="Horizontal"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                    <Image Width="26" Height="26"
                                           Source="{Binding Source='🏆', Converter={StaticResource EmojiToImageSource}}"/>
                                    <TextBlock Text="{loc:Str label_badge_earned}" Foreground="#FFD700" FontSize="14"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
    
                        <!-- Locked Track Overlay -->
                        <Border x:Name="TrackLockedOverlay" x:FieldModifier="internal" Background="#CC1A1A2E" CornerRadius="10"
                                Padding="40" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Width="52" Height="52" HorizontalAlignment="Center" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock x:Name="TxtLockReason" x:FieldModifier="internal" Text="{loc:Str label_complete_the_previous_track_to_unlock}"
                                           Foreground="White" FontSize="16" Margin="0,15,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
    
                        <!-- Horizontal Scrolling Roadmap -->
                        <ContentControl x:Name="RoadmapScrollContainer" x:FieldModifier="internal" Style="{StaticResource AnimatedGradientPanelWide}"
                                MinHeight="220">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          PreviewMouseWheel="HorizontalScrollViewer_PreviewMouseWheel">
                                <StackPanel x:Name="RoadmapNodesPanel" x:FieldModifier="internal" Orientation="Horizontal" Margin="10,15"/>
                            </ScrollViewer>
                        </ContentControl>
    
                        <!-- Roadmap Statistics -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="15" Margin="0,15,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="{loc:Str label_transformation_progress}" Foreground="White"
                                               FontSize="14" FontWeight="Bold"/>
                                    <Button x:Name="HelpBtnRoadmapStats" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="RoadmapStats"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtRoadmapTotalSteps" x:FieldModifier="internal" Text="0 / 21"
                                                   Foreground="{DynamicResource PinkBrush}" FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_steps_completed}" Foreground="#888888"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtRoadmapPhotos" x:FieldModifier="internal" Text="0"
                                                   Foreground="#9370DB" FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_photos_submitted}" Foreground="#888888"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtRoadmapJourneyDays" x:FieldModifier="internal" Text="--"
                                                   Foreground="#FFD700" FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_days_on_journey}" Foreground="#888888"
                                                   FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <!-- End Roadmap Panel -->
                </StackPanel>
            </ScrollViewer>
        </Border>
    
        <!-- Login Required Overlay -->
        <Border x:Name="QuestsLoginOverlay" x:FieldModifier="internal" Background="#E6151528" CornerRadius="12" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <Image Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,15" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                <TextBlock Text="{loc:Str label_login_required}" Foreground="{DynamicResource PinkBrush}" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="{loc:Str label_log_in_with_discord_or_patreon_to_access_ques}"
                           Foreground="#AA99AA" FontSize="14" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
            </StackPanel>
        </Border>
        </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Views.Tabs.PatreonTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <Border Style="{StaticResource SectionPanel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PatreonTabContent" x:FieldModifier="internal" Margin="15">
                    <Grid Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{loc:Str label_patreon_exclusives}" Foreground="White" FontSize="22" FontWeight="Bold">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{loc:Str label_premium_features_for_supporters}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button x:Name="HelpBtnPatreon" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="PatreonExclusives"/>
                    </Grid>
    
                    <!-- Patreon Login Status -->
                    <Border x:Name="PatreonLoginCard" x:FieldModifier="internal" CornerRadius="12" Padding="15" Margin="0,0,0,15"
                            Background="{DynamicResource ElevatedSurfaceBrush}"
                            BorderBrush="#FF424D" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
    
                            <StackPanel>
                                <TextBlock x:Name="TxtPatreonStatus" x:FieldModifier="internal" Text="{loc:Str label_not_connected}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtPatreonTier" x:FieldModifier="internal" Text="{loc:Str label_login_to_unlock_exclusive_features}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            </StackPanel>
    
                            <Button x:Name="BtnPatreonLogin" x:FieldModifier="internal" Grid.Column="1"
                                    Content="{loc:Str btn_login}"
                                    Background="#FF424D" Foreground="White"
                                    BorderThickness="0" Padding="15,8"
                                    FontWeight="Bold" FontSize="12"
                                    Cursor="Hand"
                                    Click="BtnPatreonLogin_Click"/>
                        </Grid>
                    </Border>
    
                    <!-- Discord Login Status -->
                    <Border x:Name="DiscordLoginCard" x:FieldModifier="internal" CornerRadius="12" Padding="15" Margin="0,0,0,15"
                            Background="{DynamicResource ElevatedSurfaceBrush}"
                            BorderBrush="#5865F2" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
    
                            <StackPanel>
                                <TextBlock x:Name="TxtDiscordStatus" x:FieldModifier="internal" Text="{loc:Str label_not_connected}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtDiscordInfo" x:FieldModifier="internal" Text="{loc:Str label_link_discord_for_community_features}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            </StackPanel>
    
                            <Button x:Name="BtnDiscordLogin" x:FieldModifier="internal" Grid.Column="1"
                                    Content="{loc:Str btn_login}"
                                    Background="#5865F2" Foreground="White"
                                    BorderThickness="0" Padding="15,8"
                                    FontWeight="Bold" FontSize="12"
                                    Cursor="Hand"
                                    Click="BtnDiscordLogin_Click"/>
                        </Grid>
                    </Border>
    
                    <!-- Account Linking Section (visible when logged in but other provider not linked) -->
                    <Border x:Name="AccountLinkingSection" x:FieldModifier="internal" Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                            BorderBrush="#FFD700" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{loc:Str label_link_accounts}" Foreground="#FFD700" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="{loc:Str label_link_both_providers_to_access_your_account_fr}"
                                       Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
    
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnLinkPatreon" x:FieldModifier="internal"
                                        Content="{loc:Str btn_link_patreon}"
                                        Background="#FF424D" Foreground="White"
                                        BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand" Visibility="Collapsed"
                                        Click="BtnLinkPatreon_Click"/>
                                <Button x:Name="BtnLinkDiscord" x:FieldModifier="internal"
                                        Content="{loc:Str btn_link_discord}"
                                        Background="#5865F2" Foreground="White"
                                        BorderThickness="0" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand" Visibility="Collapsed"
                                        Click="BtnLinkDiscord_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
    
                    <!-- Cloud Settings Backup Section (visible when user has cloud identity) -->
                    <Border x:Name="CloudSettingsBackupSection" x:FieldModifier="internal" Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                            BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{loc:Str label_cloud_settings_backup}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtCloudBackupStatus" x:FieldModifier="internal"
                                       Text="{loc:Str label_checking_backup_status}"
                                       Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
    
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnBackupSettingsNow" x:FieldModifier="internal"
                                        Content="{loc:Str btn_backup_now}"
                                        Background="{DynamicResource SecondaryBrush}" Foreground="White"
                                        BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnBackupSettingsNow_Click"/>
                                <Button x:Name="BtnRestoreSettings" x:FieldModifier="internal"
                                        Content="{loc:Str btn_restore_from_cloud}"
                                        Background="Transparent" Foreground="{DynamicResource SecondaryBrush}"
                                        BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnRestoreSettings_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
    
                    <!-- Data & Privacy Section (visible when user has cloud identity) -->
                    <Border x:Name="DataPrivacySection" x:FieldModifier="internal" Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                            BorderBrush="#555" BorderThickness="1" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{loc:Str label_data_privacy}" Foreground="#B0B0B0" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="{loc:Str label_export_your_cloud_data_or_view_our_privacy_po}"
                                       Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
    
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnExportData" x:FieldModifier="internal"
                                        Content="{loc:Str btn_export_my_data}"
                                        Background="#555" Foreground="White"
                                        BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnExportData_Click"/>
                                <Button x:Name="BtnPrivacyPolicy"
                                        Content="{loc:Str btn_privacy_policy}"
                                        Background="Transparent" Foreground="#888"
                                        BorderBrush="#555" BorderThickness="1" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnPrivacyPolicy_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
    
                    <!-- 2-Column Grid of Feature Expanders (wrapped with Patreon lock overlay) -->
                    <Grid Margin="0,10,0,0">
                    <!-- Patreon-Only Overlay for entire features grid -->
                    <Border x:Name="PatreonFeaturesOverlay" x:FieldModifier="internal" Background="#CC1A1A2E" CornerRadius="12" Panel.ZIndex="100">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,10" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                            <TextBlock Text="{loc:Str section_patreon_exclusive_features}" Foreground="{DynamicResource PinkBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{loc:Str label_support_on_patreon_to_unlock_autonomy_remote}"
                                       Foreground="#AAAAAA" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                            <Button Content="{loc:Str btn_visit_patreon}" Background="#FF424D" Foreground="White"
                                    BorderThickness="0" Padding="20,10" Margin="0,18,0,0"
                                    FontWeight="Bold" FontSize="13" Cursor="Hand"
                                    Click="BtnVisitPatreon_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E8363F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                    <!-- Actual features grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
    
                        <!-- Row 0, Col 0: Bambi Takeover — moved to BambiTakeoverTab -->
    
                        <!-- Row 0, Col 2: Remote Control — moved to RemoteControlTab -->
    
                        <!-- Row 1, Col 0: Keyword Triggers -->
                        <Expander Grid.Row="1" Grid.Column="0" Style="{StaticResource CollapsibleCard}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Str label_keyword_triggers}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel>
                                <!-- Header row -->
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{loc:Str label_keyword_triggers_2}" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtKeywordTriggersLocked" x:FieldModifier="internal" Text="{loc:Str label_in_beta_testing_for_patreon_supporters}"
                                                   Foreground="#DAA520" FontSize="10" FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button x:Name="HelpBtnKeywordTriggers" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}"
                                                VerticalAlignment="Center" Margin="0,0,8,0" Tag="KeywordTriggers" Panel.ZIndex="1"/>
                                        <Button x:Name="BtnKeywordTriggersStartStop" x:FieldModifier="internal" Content="{loc:Str btn_start}"
                                                Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="11"
                                                Padding="14,4" BorderThickness="0" Cursor="Hand"
                                                Click="BtnKeywordTriggersStartStop_Click"/>
                                    </StackPanel>
                                </Grid>
    
                                <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap">
                                        <Run Text="{loc:Str label_your_everyday_typing_becomes_part_of_your_con}"/>
                                    </TextBlock>
    
                                <!-- Settings panel -->
                                <StackPanel x:Name="KeywordTriggersSettingsPanel" Margin="0,10,0,0">
    
                                    <!-- Global settings row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
    
                                        <!-- Buffer timeout -->
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0"
                                                    ToolTip="{loc:Str tooltip_how_long_to_wait_after_a_keystroke_before_che}">
                                            <TextBlock Text="{loc:Str label_buffer_timeout}" Foreground="#A0A0A0" FontSize="10"/>
                                            <Grid>
                                                <Slider x:Name="SliderKeywordBufferTimeout" x:FieldModifier="internal" Minimum="1000" Maximum="10000"
                                                        TickFrequency="500" IsSnapToTickEnabled="True"
                                                        ValueChanged="SliderKeywordBufferTimeout_ValueChanged"/>
                                                <TextBlock x:Name="TxtKeywordBufferTimeout" x:FieldModifier="internal" Text="{loc:Str label_3_0s}"
                                                           Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                            </Grid>
                                        </StackPanel>
    
                                        <!-- Global cooldown -->
                                        <StackPanel Grid.Column="1" Margin="6,0,6,0"
                                                    ToolTip="{loc:Str tooltip_minimum_time_between_any_two_trigger_activati}">
                                            <TextBlock Text="{loc:Str label_global_cooldown}" Foreground="#A0A0A0" FontSize="10"/>
                                            <Grid>
                                                <Slider x:Name="SliderKeywordGlobalCooldown" x:FieldModifier="internal" Minimum="1" Maximum="120"
                                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                                        ValueChanged="SliderKeywordGlobalCooldown_ValueChanged"/>
                                                <TextBlock x:Name="TxtKeywordGlobalCooldown" x:FieldModifier="internal" Text="{loc:Str setting_5s}"
                                                           Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                            </Grid>
                                        </StackPanel>
    
                                        <!-- Session XP boost -->
                                        <StackPanel Grid.Column="2" Margin="6,0,0,0"
                                                    ToolTip="{loc:Str tooltip_xp_multiplier_bonus_when_triggers_fire_during}">
                                            <TextBlock Text="{loc:Str label_session_xp_boost}" Foreground="#A0A0A0" FontSize="10"/>
                                            <Grid>
                                                <Slider x:Name="SliderKeywordSessionMultiplier" x:FieldModifier="internal" Minimum="1.0" Maximum="3.0"
                                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                        ValueChanged="SliderKeywordSessionMultiplier_ValueChanged"/>
                                                <TextBlock x:Name="TxtKeywordSessionMultiplier" x:FieldModifier="internal" Text="1.5x"
                                                           Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
    
                                    <!-- Screen OCR -->
                                    <Border CornerRadius="6" Padding="8" Margin="0,0,0,8"
                                            Background="{DynamicResource DarkerBgBrush}" BorderBrush="#353550" BorderThickness="1">
                                        <StackPanel>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{loc:Str label_screen_text_detection_ocr}" Foreground="#C0C0C0" FontSize="12" FontWeight="SemiBold"/>
                                                    <Button x:Name="HelpBtnScreenOcr" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}"
                                                            VerticalAlignment="Center" Margin="6,0,0,0" Tag="ScreenOcr" Panel.ZIndex="1"/>
                                                </StackPanel>
                                                <CheckBox x:Name="ChkScreenOcrEnabled" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                                          Checked="ChkScreenOcrEnabled_Changed" Unchecked="ChkScreenOcrEnabled_Changed"/>
                                            </Grid>
                                            <TextBlock Text="{loc:Str label_scans_your_screen_for_trigger_keywords_using}"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            <CheckBox x:Name="ChkKeywordHighlightEnabled" x:FieldModifier="internal" Content="{loc:Str setting_highlight_matched_keywords_on_screen}"
                                                      Foreground="#A0A0A0" FontSize="10" Margin="0,4,0,0"
                                                      IsChecked="True"
                                                      Checked="ChkKeywordHighlightEnabled_Changed"
                                                      Unchecked="ChkKeywordHighlightEnabled_Changed"
                                                      ToolTip="{loc:Str tooltip_show_a_glowing_overlay_over_the_word_when_ocr}"/>
                                            <StackPanel x:Name="HighlightDurationPanel" x:FieldModifier="internal" Visibility="Collapsed" Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{loc:Str label_highlight_mode}" Foreground="#A0A0A0" FontSize="10" VerticalAlignment="Center"/>
                                                    <ComboBox x:Name="CmbOcrHighlightMode" x:FieldModifier="internal" Margin="6,0,0,0" MinWidth="110"
                                                              Style="{StaticResource DarkComboBoxStyle}" FontSize="10"
                                                              SelectionChanged="CmbOcrHighlightMode_SelectionChanged"
                                                              ToolTip="{loc:Str tooltip_all_matches_highlights_every_keyword_immediat}">
                                                        <ComboBoxItem Content="{loc:Str btn_all_matches}"/>
                                                        <ComboBoxItem Content="{loc:Str btn_random_subset}"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <CheckBox x:Name="ChkHighlightVisibleInCapture" x:FieldModifier="internal" Content="{loc:Str setting_show_highlights_in_screen_capture_streams}"
                                                          Foreground="#A0A0A0" FontSize="10" Margin="0,2,0,4"
                                                          Checked="ChkHighlightVisibleInCapture_Changed"
                                                          Unchecked="ChkHighlightVisibleInCapture_Changed"
                                                          ToolTip="{loc:Str tooltip_when_enabled_keyword_highlights_will_be_visib}"/>
                                                <TextBlock Text="{loc:Str label_highlight_duration}" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid ToolTip="{loc:Str tooltip_how_long_the_pink_highlight_stays_on_screen_0}">
                                                    <Slider x:Name="SliderKeywordHighlightDuration" x:FieldModifier="internal" Minimum="0.3" Maximum="5.0"
                                                            TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordHighlightDuration_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordHighlightDuration" x:FieldModifier="internal" Text="{loc:Str label_0_6s}"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel x:Name="ScreenOcrIntervalPanel" x:FieldModifier="internal" Visibility="Collapsed" Margin="0,6,0,0">
                                                <TextBlock Text="{loc:Str label_scan_interval}" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid ToolTip="{loc:Str tooltip_how_often_to_scan_your_screen_for_trigger_key}">
                                                    <Slider x:Name="SliderScreenOcrInterval" x:FieldModifier="internal" Minimum="2" Maximum="10"
                                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderScreenOcrInterval_ValueChanged"/>
                                                    <TextBlock x:Name="TxtScreenOcrInterval" x:FieldModifier="internal" Text="{loc:Str label_3s}"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="Confirm before firing" Foreground="#A0A0A0" FontSize="10" VerticalAlignment="Center"/>
                                                    <ComboBox x:Name="CmbOcrConfirmation" x:FieldModifier="internal" Margin="6,0,0,0" MinWidth="150"
                                                              Style="{StaticResource DarkComboBoxStyle}" FontSize="10"
                                                              SelectionChanged="CmbOcrConfirmation_SelectionChanged"
                                                              ToolTip="How many consecutive scans a word must stay on screen before it fires. Higher settings stop stray highlights when you scroll or tab away, at the cost of a slightly slower reaction.">
                                                        <ComboBoxItem Content="Fire on first sight"/>
                                                        <ComboBoxItem Content="Double-confirm (recommended)"/>
                                                        <ComboBoxItem Content="Triple-confirm"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
    
                                    <!-- Trigger list -->
                                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0"
                                                  PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                                        <StackPanel x:Name="KeywordTriggerListPanel" x:FieldModifier="internal"/>
                                    </ScrollViewer>
    
                                    <!-- Action buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="{loc:Str btn_add_trigger}" Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold"
                                                FontSize="11" Padding="12,6" BorderThickness="0" Cursor="Hand"
                                                Click="BtnAddKeywordTrigger_Click"/>
                                        <Button Content="{loc:Str btn_import_from_trigger_mode}" Background="#353550" Foreground="#A0A0A0"
                                                FontSize="11" Padding="12,6" Margin="8,0,0,0" BorderThickness="0" Cursor="Hand"
                                                Click="BtnImportFromCustomTriggers_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
    
                        <!-- Row 2, Full Width: Haptic Feedback — moved to HapticsTab -->
    
                    </Grid>
                    </Grid>
    
                    <!-- Patreon Info Box -->
                    <Border x:Name="SupportDevelopmentCard" x:FieldModifier="internal" CornerRadius="12" Padding="15" Margin="0,10,0,0"
                            Background="{DynamicResource ElevatedSurfaceBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{loc:Str section_support_development}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,8,0,0">
                                <Run Text="{loc:Str section_patreon_unlocks}"/> <Run x:Name="RunPatreonFeatures" x:FieldModifier="internal" Text="{loc:Str section_ai_chat_window_awareness_slut_mode_takeover}" Foreground="White"/>
                            </TextBlock>
                            <Button x:Name="BtnVisitPatreon" Content="{loc:Str btn_visit_patreon}"
                                    Background="{DynamicResource SecondaryBrush}" Foreground="White"
                                    BorderThickness="0" Padding="15,8" Margin="0,12,0,0"
                                    HorizontalAlignment="Left" FontSize="12"
                                    Cursor="Hand"
                                    Click="BtnVisitPatreon_Click"/>
                        </StackPanel>
                    </Border>
    
                </StackPanel>
            </ScrollViewer>
        </Border>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Views.Tabs.EnhancementsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- Hidden container for named elements (used programmatically) -->
        <StackPanel Visibility="Collapsed">
            <TextBlock x:Name="TxtSkillPoints" x:FieldModifier="internal" Text="0"/>
            <TextBlock x:Name="TxtXpMultiplier" x:FieldModifier="internal" Text="1.00x"/>
            <helpers:EmojiTextBlock x:Name="TxtPinkRushIndicator" x:FieldModifier="internal" Text="{loc:Str label_rush}"/>
            <TextBlock x:Name="TxtConditioningTime" x:FieldModifier="internal" Text="{loc:Str label_0h_0m}"/>
            <WrapPanel x:Name="ActiveBonusesList" x:FieldModifier="internal"/>
            <Border x:Name="ActiveBonusesPanel" x:FieldModifier="internal"/>
        </StackPanel>

        <Border x:Name="SkillTreeOuterBorder" x:FieldModifier="internal" Background="#151528" CornerRadius="12" Padding="5" Margin="20,5,20,20">
            <ScrollViewer x:Name="SkillTreeScroller"
                     Style="{StaticResource SkillTreeScrollViewerStyle}"
                     HorizontalScrollBarVisibility="Visible"
                     VerticalScrollBarVisibility="Disabled"
                     PreviewMouseWheel="SkillTreeScroller_PreviewMouseWheel">
                <Canvas x:Name="SkillTreeCanvas" x:FieldModifier="internal" Width="2400" Height="460" HorizontalAlignment="Left">
                    <!-- Header and skill nodes will be drawn programmatically -->
                </Canvas>
            </ScrollViewer>
        </Border>

        <!-- Login Required Overlay -->
        <Border x:Name="EnhancementsLoginOverlay" x:FieldModifier="internal" Background="#E6151528" CornerRadius="12" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <Image Width="52" Height="52" HorizontalAlignment="Center" Margin="0,0,0,15" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                <TextBlock Text="{loc:Str label_login_required}" Foreground="{DynamicResource PinkBrush}" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="{loc:Str label_log_in_with_discord_or_patreon_to_access_enha}"
                           Foreground="#AA99AA" FontSize="14" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Views.Tabs.LockdownTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="36,28,36,28">
                <StackPanel MaxWidth="720" HorizontalAlignment="Center">
    
                    <!-- Header -->
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Width="44" Height="44" VerticalAlignment="Center" Margin="0,0,16,0" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str tab_lockdown_mode}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                            <TextBlock Text="{loc:Str label_lock_yourself_into_a_timed_conditioning_sessi}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
    
                    <!-- Lockdown card (lifted from Lab) + premium gate overlay -->
                    <Grid>
                        <Border x:Name="LockdownCardBorder" x:FieldModifier="internal" CornerRadius="12" Padding="24,22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A32" Offset="0"/>
                                    <GradientStop Color="#201A38" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PatreonPurple}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>2</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <Border x:Name="LockdownImageBorder" CornerRadius="10" Margin="0,0,0,18"
                                        Height="220" BorderThickness="2" ClipToBounds="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="#12FFFFFF"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="LockdownImageBorderBrush" x:FieldModifier="internal" Color="#FF1493"/>
                                    </Border.BorderBrush>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="LockdownImageGlow" x:FieldModifier="internal" Color="#FF1493" BlurRadius="14" ShadowDepth="0" Opacity="0.7"/>
                                    </Border.Effect>
                                    <!-- Lockdown pulse managed in code-behind (StartLockdownPulse/StopLockdownPulse) -->
                                    <Image Source="pack://application:,,,/Resources/lockdown_icon.png" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
    
                                <!-- Setup Panel (visible when lockdown is NOT active) -->
                                <StackPanel x:Name="LockdownSetupPanel" x:FieldModifier="internal">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <TextBlock Text="{loc:Str label_duration_2}" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox x:Name="CmbLockdownDuration" x:FieldModifier="internal" Width="140" SelectedIndex="1"
                                                  Background="{DynamicResource DarkerBgBrush}" Foreground="Black" FontSize="13" BorderBrush="{DynamicResource PanelAccentBrush}">
                                            <ComboBoxItem Content="{loc:Str btn_5_minutes}" Tag="5" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_10_minutes}" Tag="10" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_15_minutes}" Tag="15" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str label_30_minutes}" Tag="30" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_60_minutes}" Tag="60" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_2_hours}" Tag="120" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_4_hours}" Tag="240" Foreground="Black"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button x:Name="BtnActivateLockdown" Content="{loc:Str btn_activate}" Cursor="Hand"
                                            Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="13"
                                            BorderThickness="0" Padding="16,10" HorizontalAlignment="Left"
                                            Click="BtnActivateLockdown_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
    
                                <!-- Active Panel (visible when lockdown IS active) -->
                                <StackPanel x:Name="LockdownActivePanel" x:FieldModifier="internal" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Str label_lockdown_active}" Foreground="#DC143C" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TxtLockdownTimer" x:FieldModifier="internal" Text="00:00" Foreground="#DC143C" FontWeight="Bold" FontSize="36"
                                               Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonDown="TxtLockdownTimer_Click"/>
                                    <TextBox x:Name="TxtLockdownExit" x:FieldModifier="internal" Visibility="Collapsed"
                                             Background="#1A0A0A" Foreground="#DC143C" BorderBrush="#DC143C" BorderThickness="1"
                                             FontSize="13" Padding="8,6" Margin="0,8,0,0"
                                             KeyDown="TxtLockdownExit_KeyDown"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
    
                        <!-- Translucent gating overlay (only for free users) -->
                        <Border x:Name="LockdownGate" x:FieldModifier="internal" Visibility="Collapsed"
                                Background="#99000010" BorderBrush="#FF69B4" BorderThickness="2"
                                CornerRadius="12" IsHitTestVisible="True">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Width="52" Height="52" HorizontalAlignment="Center" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock Text="{loc:Str gate_premium_locked}" FontSize="22"
                                           FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Str gate_premium_subtitle}" FontSize="14"
                                           Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                                <Button Click="BtnGateUnlock_Click" Padding="20,8" Background="#FF69B4"
                                        Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                                    <helpers:EmojiTextBlock Text="{loc:Str gate_unlock_with_patreon}"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
    
                </StackPanel>
            </Grid>
        </ScrollViewer>
</UserControl>

                        </Grid>
                    </StackPanel>
                </Border>
    
                <!-- Deeper Section -->
                <Border x:Name="DeeperSection" CornerRadius="12" Padding="10,7" Margin="0,0,0,6"
                        Background="{DynamicResource ElevatedSurfaceBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Image Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"
                                       Source="{Binding Source='🌊', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_deeper}"
                                           Foreground="{DynamicResource DeeperAccentBrush}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                    ToolTip="{loc:Str tooltip_deeper_enable}">
                            <CheckBox x:Name="ChkEnableDeeper" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                      Checked="ChkEnableDeeper_Changed" Unchecked="ChkEnableDeeper_Changed"/>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_deeper_enable}" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        </Grid>
        <!-- /LegacyDashboardHost -->
    
        <!-- RIGHT HALF (Browser / Audio / Quick Links) — col 2 (after premium rail + feature grid) -->
        <Grid Grid.Column="2" Grid.Row="0" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
    
            <!-- Browser Section -->
            <Border Grid.Row="0" CornerRadius="12" Padding="9" Margin="0,0,0,5"
                    Background="{DynamicResource ElevatedSurfaceBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                <StackPanel>
                    <!-- Browser Header - single row with title, tabs, status, webcam toggle, pop out -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <helpers:EmojiTextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_browser}" Margin="0"/>
                            <Button x:Name="HelpBtnBrowser" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="Browser"/>
                        </StackPanel>
                        <!-- Site Toggle - inline -->
                        <Border Grid.Column="1" Background="{DynamicResource PanelAccentBrush}" CornerRadius="10" Padding="2" Margin="10,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="RbBambiCloud" x:FieldModifier="internal" Content="{loc:Str btn_bambicloud}" GroupName="BrowserSite"
                                             IsChecked="True" Checked="BrowserSiteToggle_Changed"
                                             Foreground="{DynamicResource TextLightBrush}" FontSize="10" Cursor="Hand" Margin="2,1">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="border" Background="Transparent" CornerRadius="8" Padding="8,3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource PinkBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#353565"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsChecked" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PinkButtonHoveredBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbHypnoTube" x:FieldModifier="internal" Content="{loc:Str btn_hypnotube}" GroupName="BrowserSite"
                                         Checked="BrowserSiteToggle_Changed"
                                         Foreground="{DynamicResource TextLightBrush}" FontSize="10" Cursor="Hand" Margin="2,1">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="border" Background="Transparent" CornerRadius="8" Padding="8,3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PinkBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#353565"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsChecked" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PinkButtonHoveredBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            </StackPanel>
                        </Border>
                        <!-- Reload / Home button - sits just right of the site toggle.
                             Reloads the current site's homepage; gives a way out of a
                             stuck/blank page (e.g. after a remote video is stopped), since
                             re-clicking an already-selected site radio won't reload. -->
                        <Button Grid.Column="2" x:Name="BtnReloadBrowser"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Click="BtnReloadBrowser_Click"
                                ToolTip="{loc:Str tooltip_reload_browser}"
                                FontSize="11" Padding="6,3" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#33FF69B4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#55FF69B4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <helpers:EmojiTextBlock Text="🔄"/>
                        </Button>
                        <!-- Status indicator -->
                        <TextBlock Grid.Column="3" x:Name="TxtBrowserStatus" x:FieldModifier="internal" Text="{loc:Str label_loading}"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <!-- Deeper auto-bind badge (Phase 9). Shows when an enhancement is active for the current page. -->
                        <Border Grid.Column="3" x:Name="DeeperBrowserBadge" x:FieldModifier="internal" Visibility="Collapsed"
                                Background="{DynamicResource DeeperAccentTransparent20Brush}"
                                BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                                CornerRadius="3" Padding="6,1" Margin="0,0,8,0"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                ToolTip="{Binding ElementName=DeeperBrowserBadge, Path=Tag}">
                            <TextBlock x:Name="TxtDeeperBrowserBadge" x:FieldModifier="internal"
                                       Text="🌊 Deeper"
                                       Foreground="{DynamicResource DeeperAccentBrush}"
                                       FontSize="9" FontWeight="SemiBold"/>
                        </Border>
                        <!-- Webcam Tracking toggle - inline, sits between status badge and pop-out.
                             Off: "📷 Webcam"  On: "📷 Webcam On" (label updated in code-behind
                             from OnTrackingStateChanged). Click runs the consent → calibrate →
                             start flow if needed; second click stops tracking. -->
                        <Button Grid.Column="4" x:Name="BtnWebcamTracking" x:FieldModifier="internal"
                                Click="BtnWebcamTracking_Click"
                                ToolTip="{loc:Str tooltip_browser_webcam_tracking_off}"
                                FontSize="9" Padding="6,3" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#33FF69B4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#55FF69B4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <helpers:EmojiTextBlock x:Name="TxtWebcamTracking" x:FieldModifier="internal" Text="{loc:Str btn_browser_webcam_tracking_off}"/>
                        </Button>
                        <!-- Mute browser audio toggle (BambiCloud / HypnoTube video) -->
                        <Button Grid.Column="5" x:Name="BtnMuteBrowser" x:FieldModifier="internal"
                                Click="BtnMuteBrowser_Click" Cursor="Hand"
                                ToolTip="Mute / unmute browser audio (BambiCloud / HypnoTube)"
                                Background="Transparent" BorderThickness="0" Padding="5,2" Margin="4,0,0,0"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#55FF69B4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <helpers:EmojiTextBlock x:Name="TxtBrowserMute" x:FieldModifier="internal" Text="🔊" FontSize="13"/>
                        </Button>
                        <!-- Pop Out button -->
                        <Button Grid.Column="6" x:Name="BtnPopOutBrowser" x:FieldModifier="internal" Content="{loc:Str btn_pop_out}"
                                Click="BtnPopOutBrowser_Click"
                                ToolTip="{loc:Str tooltip_pop_out_browser_to_resizable_window}"
                                FontSize="9" Padding="6,3" VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource PinkBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource PinkButtonHoveredBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#E05A9E"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
    
                    <!-- Browser Container -->
                    <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" ClipToBounds="True" Height="340">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
    
                            <!-- Deeper "Enhance if possible" toggle (always visible) -->
                            <Border x:Name="BrowserEnhanceToolbar" Grid.Row="0"
                                    Background="{DynamicResource PanelBgBrush}" Padding="8,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleEnhanceIfPossible" x:FieldModifier="internal" Grid.Column="0"
                                              Content="{loc:Str browser_enhance_label}"
                                              Foreground="{DynamicResource TextLightBrush}" FontSize="11"
                                              VerticalAlignment="Center" Cursor="Hand"
                                              Checked="ToggleEnhanceIfPossible_Changed"
                                              Unchecked="ToggleEnhanceIfPossible_Changed"
                                              ToolTip="{loc:Str browser_enhance_tooltip}"/>
                                    <TextBlock x:Name="TxtEnhanceMatchStatus" x:FieldModifier="internal" Grid.Column="1"
                                               Text="{loc:Str browser_enhance_match_none}"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
    
                            <!-- Audio Sync Controls (shown when audio sync enabled) -->
                            <Border x:Name="AudioSyncLatencyPanel" x:FieldModifier="internal" Grid.Row="1" Background="{DynamicResource PanelBgBrush}" Padding="6,3" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
    
                                    <!-- Delay Slider (left half) -->
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{loc:Str label_delay}" Foreground="#AAAAAA" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Slider x:Name="SliderAudioSyncLatency" x:FieldModifier="internal" Grid.Column="1" Minimum="-600" Maximum="600" Value="0"
                                                VerticalAlignment="Center" ValueChanged="SliderAudioSyncLatency_Changed"
                                                ToolTip="{loc:Str tooltip_adjust_haptic_timing_positive_earlier_negativ}"/>
                                        <TextBlock x:Name="TxtAudioSyncLatency" x:FieldModifier="internal" Grid.Column="2" Text="{loc:Str label_0ms}" Foreground="{DynamicResource PinkBrush}" FontSize="9"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
    
                                    <!-- Intensity Slider (right half) -->
                                    <Grid Grid.Column="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{loc:Str label_power}" Foreground="#AAAAAA" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <Slider x:Name="SliderAudioSyncIntensity" x:FieldModifier="internal" Grid.Column="1" Minimum="0" Maximum="100" Value="100"
                                                VerticalAlignment="Center" ValueChanged="SliderAudioSyncIntensity_Changed"
                                                ToolTip="{loc:Str tooltip_live_intensity_control_reduce_if_vibration_is}"/>
                                        <TextBlock x:Name="TxtAudioSyncIntensity" x:FieldModifier="internal" Grid.Column="2" Text="100%" Foreground="{DynamicResource PinkBrush}" FontSize="9"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>
    
                            <Grid x:Name="BrowserContainer" x:FieldModifier="internal" Grid.Row="2">
                                <!-- WebView2 will be added here programmatically -->
                                <TextBlock x:Name="BrowserLoadingText" x:FieldModifier="internal"
                                           Text="{loc:Str label_click_to_load_browser}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="BrowserLoadingText_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
    
            <!-- Audio Section + Quick Actions -->
            <Grid Grid.Row="1" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
    
                <!-- Audio Section (left half) -->
                <Border x:Name="AudioSection" Grid.Column="0" CornerRadius="12" Padding="9" Margin="0,0,0,6"
                        Background="{DynamicResource ElevatedSurfaceBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Grid>
                            <helpers:EmojiTextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_audio}" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="HelpBtnAudio" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="Audio" Margin="0,0,8,0"/>
                                <TextBlock Text="{loc:Str label_duck}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <CheckBox x:Name="ChkAudioDuck" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          IsChecked="True"
                                          Checked="ChkAudioDuck_Changed" Unchecked="ChkAudioDuck_Changed"
                                          ToolTip="{loc:Str tooltip_automatically_reduce_other_app_volumes_during}"/>
                            </StackPanel>
                        </Grid>
    
                        <!-- Master Volume -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_master}" FontSize="10"
                                       ToolTip="{loc:Str tooltip_master_volume_for_all_audio}"/>
                            <Slider Grid.Column="1" x:Name="SliderMaster" x:FieldModifier="internal" Minimum="0" Maximum="100" Value="50"
                                    Margin="4,0" ValueChanged="SliderMaster_Changed"
                                    ToolTip="{loc:Str tooltip_overall_audio_volume_level}"/>
                            <TextBlock x:Name="TxtMaster" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource ValueLabel}" Text="50%" FontSize="10"/>
                        </Grid>
    
                        <!-- Video Volume -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_video}" FontSize="10"
                                       ToolTip="{loc:Str tooltip_volume_for_mandatory_videos}"/>
                            <Slider Grid.Column="1" x:Name="SliderVideoVolume" x:FieldModifier="internal" Minimum="0" Maximum="100" Value="50"
                                    Margin="4,0" ValueChanged="SliderVideoVolume_Changed"
                                    ToolTip="{loc:Str tooltip_separate_volume_control_for_videos}"/>
                            <TextBlock x:Name="TxtVideoVolume" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource ValueLabel}" Text="50%" FontSize="10"/>
                        </Grid>
    
                        <!-- Duck % -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str label_duck}" FontSize="10"
                                       ToolTip="{loc:Str tooltip_how_much_to_reduce_other_audio}"/>
                            <Slider Grid.Column="1" x:Name="SliderDuck" x:FieldModifier="internal" Minimum="0" Maximum="100" Value="80"
                                    Margin="4,0" ValueChanged="SliderDuck_Changed"
                                    ToolTip="{loc:Str tooltip_ducking_percentage_80_reduce_other_audio_to_2}"/>
                            <TextBlock x:Name="TxtDuck" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource ValueLabel}" Text="80%" FontSize="10"/>
                        </Grid>
    
                        <!-- Audio Output device picker — route CCP audio to a chosen device
                             (e.g. private headset) so streamers can use the program without
                             their viewers hearing the audio on the system default endpoint. -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_output}" FontSize="10"
                                       ToolTip="{loc:Str tooltip_audio_output_device}"/>
                            <ComboBox Grid.Column="1" x:Name="CmbAudioOutputDevice" x:FieldModifier="internal"
                                      Margin="4,0,4,0" Foreground="Black" Background="White"
                                      ToolTip="{loc:Str tooltip_audio_output_device}"
                                      SelectionChanged="CmbAudioOutputDevice_SelectionChanged"/>
                            <Button Grid.Column="2" x:Name="BtnAudioOutputRefresh" Content="↻"
                                    Click="BtnAudioOutputRefresh_Click"
                                    ToolTip="Re-scan playback devices."
                                    Padding="8,2" Background="#33FF69B4" Foreground="White" FontSize="10"
                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" Cursor="Hand"/>
                        </Grid>
    
                        <!-- Don't-duck-browser toggle + Audio Test on the same row -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      x:Name="ChkExcludeBambiCloudDucking" x:FieldModifier="internal"
                                      VerticalAlignment="Center"
                                      Content="{loc:Str setting_don_t_duck_browser}"
                                      IsChecked="True"
                                      Checked="ChkExcludeBambiCloudDucking_Changed"
                                      Unchecked="ChkExcludeBambiCloudDucking_Changed"
                                      ToolTip="{loc:Str tooltip_when_enabled_audio_from_the_integrated_bambic}"
                                      Foreground="{DynamicResource PinkBrush}" FontSize="9"/>
                            <Button Grid.Column="1"
                                    x:Name="BtnTestAudio" Content="Test Audio"
                                    Click="BtnTestAudio_Click"
                                    ToolTip="Play a test sound and show audio diagnostics. Use this if audio isn't working."
                                    Background="#33FF69B4" Foreground="White" FontSize="9" Padding="8,3"
                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" Cursor="Hand"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
    
                <!-- Quick Actions (right half) -->
                <Border Grid.Column="2" CornerRadius="12" Padding="9" Margin="0,0,0,6"
                        Background="{DynamicResource ElevatedSurfaceBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <helpers:EmojiTextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_quick_links}" FontSize="12" Margin="0"/>
                            <Button x:Name="HelpBtnQuickLinks" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="QuickLinks"/>
                        </Grid>
    
                        <!-- Unified Login Button -->
                        <Button x:Name="BtnUnifiedLogin" x:FieldModifier="internal" Content="{loc:Str btn_login_2}"
                                Click="BtnUnifiedLogin_Click"
                                Padding="8,12" Margin="0,0,0,6"
                                ToolTip="{loc:Str tooltip_login_with_discord_or_patreon}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource PinkBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E055A0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#C04888"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
    
                        <!-- Logged In Status (shown when logged in) -->
                        <Border x:Name="LoggedInStatusPanel" x:FieldModifier="internal" Visibility="Collapsed"
                                Background="{DynamicResource PanelBgBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="TxtLoggedInAs" Text="{loc:Str label_logged_in_as}"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                    <TextBlock x:Name="TxtLoggedInName" x:FieldModifier="internal" Text="{loc:Str label_username}"
                                               Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </StackPanel>
                                <Button x:Name="BtnQuickLogout" Grid.Column="1" Content="{loc:Str btn_logout}"
                                        Click="BtnQuickLogout_Click"
                                        Padding="10,5" Background="{DynamicResource AccentTintedBgBrush}" Foreground="{DynamicResource PinkBrush}"
                                        BorderThickness="0" FontSize="10" Cursor="Hand"/>
                            </Grid>
                        </Border>
    
                        <!-- Discord Join Button + Rich Presence -->
                        <Grid Margin="0,4,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Click="BtnDiscord_Click"
                                    ToolTip="{loc:Str tooltip_join_the_discord_community}" Cursor="Hand"
                                    HorizontalAlignment="Stretch">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="#5865F2" CornerRadius="5"
                                                            Padding="0,4" HorizontalAlignment="Stretch">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Image Width="13" Height="13" VerticalAlignment="Center"
                                                                   Source="{Binding Source='💬', Converter={StaticResource EmojiToImageSource}}"/>
                                                            <TextBlock Text="{loc:Str label_join_discord}" Foreground="White" FontSize="10" FontWeight="Bold"
                                                                       VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#6C75F2"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                <StackPanel.ToolTip>
                                    <ToolTip Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" Padding="10">
                                        <StackPanel MaxWidth="280">
                                            <TextBlock Text="{loc:Str label_discord_rich_presence}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <TextBlock Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8">
                                                Shows "Playing Conditioning Control Panel" in your Discord status, along with your current level and session time.
                                            </TextBlock>
                                            <TextBlock Text="{loc:Str label_who_can_see_this}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                            <TextBlock Foreground="#AAAAAA" FontSize="10" TextWrapping="Wrap">
                                                Only people who can already see your Discord activity status (friends, server members if enabled in your Discord privacy settings). This does NOT send notifications - it simply updates your "Currently Playing" status like any other game.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </StackPanel.ToolTip>
                                <CheckBox x:Name="ChkQuickDiscordRichPresence" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          Checked="ChkDiscordRichPresence_Changed" Unchecked="ChkDiscordRichPresence_Changed">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                                <TextBlock Text="{loc:Str label_rp}" Foreground="{DynamicResource TextMutedBrush}" FontSize="9"
                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    
        <!-- ============================================================ -->
        <!-- VELVET MOSAIC HELPER BUTTON ROW - full width, under both     -->
        <!-- the feature grid AND the right half.                         -->
        <!-- ============================================================ -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" x:Name="VelvetHelperButtonRow"
              Height="30" Margin="5,4,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Webcam card — surfaced from the Lab for discoverability.
                 Distinct Secondary (cyan) accent + tinted fill so it stands
                 out from the two neutral cards beside it. -->
            <Button Grid.Column="0" x:Name="VelvetBtnWebcam"
                    Click="VelvetBtnWebcam_Click"
                    Cursor="Hand" FontSize="12" FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{DynamicResource AccentTintedBgBrush}"
                                BorderBrush="{DynamicResource SecondaryBrush}"
                                BorderThickness="1.5"
                                CornerRadius="14">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Source="{Binding Source='📷', Converter={StaticResource EmojiToImageSource}}"/>
                                <helpers:EmojiTextBlock Text="{loc:Str blink_trainer_section_webcam}" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource SecondaryBrush}"/>
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource TransparentPinkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
    
            <Button Grid.Column="2" x:Name="VelvetBtnAppInfo"
                    Click="VelvetBtnAppInfo_Click"
                    Cursor="Hand" FontSize="12" FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="ℹ" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"
                                           Foreground="{DynamicResource PinkBrush}"/>
                                <TextBlock Text="{loc:Str label_app_info}" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource TransparentPinkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
    
            <!-- Combined Scheduler + Intensity Ramp card. Opens one popup
                 holding both panels. Label is two live-localized strings
                 joined by " + " so both halves stay translated. -->
            <Button Grid.Column="4" x:Name="VelvetBtnSchedulerRamp"
                    Click="VelvetBtnSchedulerRamp_Click"
                    Cursor="Hand" FontSize="12" FontWeight="Bold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Source="{Binding Source='📅', Converter={StaticResource EmojiToImageSource}}"/>
                                <helpers:EmojiTextBlock Text="{loc:Str section_scheduler}" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text=" + " Foreground="White" VerticalAlignment="Center"/>
                                <helpers:EmojiTextBlock Text="{loc:Str section_intensity_ramp}" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource TransparentPinkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- CCP Catalogue card — opens the web catalogue to browse/share
                 community presets and sessions. Pink-tinted to flag it as the
                 community/social action of the row. -->
            <Button Grid.Column="6" x:Name="VelvetBtnCatalogue"
                    Click="VelvetBtnCatalogue_Click"
                    Cursor="Hand" FontSize="12" FontWeight="Bold"
                    ToolTip="Opens app.cclabs.app/catalogue in your browser">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{DynamicResource TransparentPinkBrush}"
                                BorderBrush="{DynamicResource PinkBrush}"
                                BorderThickness="1.5"
                                CornerRadius="14">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Source="{Binding Source='📚', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock Text="CCP Catalogue" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource SecondaryBrush}"/>
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentTintedBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Scrolling Marquee Banner - row 2, spans all columns -->
        <Border x:Name="MarqueeBanner" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                Background="#1A0A1A" BorderBrush="{DynamicResource DarkPinkBrush}" BorderThickness="2"
                CornerRadius="8" Height="48" Margin="5,5,5,0" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource DarkPink}" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <Canvas x:Name="MarqueeCanvas" x:FieldModifier="internal" ClipToBounds="True">
                <TextBlock x:Name="MarqueeText" x:FieldModifier="internal"
                           Text="{loc:Str label_v5_2_1_is_out_thanks_to_all_the_100_patreons}"
                           FontFamily="Impact" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource PinkBrush}" Canvas.Top="8">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{DynamicResource DarkPink}" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                    </TextBlock.Effect>
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="MarqueeTransform"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Canvas>
        </Border>
        </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Views.Tabs.SettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:features="clr-namespace:ConditioningControlPanel.Features"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84"/>
            <ColumnDefinition Width="640"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- PREMIUM QUICK-TOGGLE RAIL (col 0). Quick on/off for gated     -->
        <!-- features. Greyed with a lock (doubles as an ad) when the      -->
        <!-- user is not a logged-in patron.                               -->
        <!-- ============================================================ -->
        <Border x:Name="PremiumRail" x:FieldModifier="internal" Grid.Column="0" Grid.Row="0" Margin="5,5,0,5"
                Background="{DynamicResource ElevatedSurfaceBrush}" BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="12">
            <Border.Resources>
                <Style x:Key="PremiumChipStyle" TargetType="Button">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Margin" Value="0,0,0,5"/>
                    <Setter Property="Height" Value="46"/>
                    <Setter Property="Background" Value="{DynamicResource AccentTintedBgBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cb" Background="{TemplateBinding Background}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                        CornerRadius="9" Padding="2,3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cb" Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                        <Setter TargetName="cb" Property="Background" Value="{DynamicResource TransparentPinkBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style x:Key="RailMiniBtn" TargetType="Button">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="mb" Background="{DynamicResource AccentTintedBgBrush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="mb" Property="Background" Value="{DynamicResource TransparentPinkBrush}"/>
                                        <Setter TargetName="mb" Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>
            <Grid>
                <StackPanel Margin="4,6,4,6">
                    <TextBlock Text="PREMIUM" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}"
                               TextAlignment="Center" Margin="0,0,0,6"/>
                    <Button x:Name="ChipTakeover" x:FieldModifier="internal" Style="{StaticResource PremiumChipStyle}"
                            Click="ChipTakeover_Click" ToolTip="Takeover — the companion triggers effects on her own">
                        <StackPanel>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="pack://application:,,,/Resources/features/takeover.png"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <Ellipse x:Name="DotTakeover" x:FieldModifier="internal" Width="8" Height="8"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#555555"
                                         Stroke="#1A1A2E" StrokeThickness="1"/>
                            </Grid>
                            <TextBlock Text="Takeover" FontSize="9" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ChipAwareness" x:FieldModifier="internal" Style="{StaticResource PremiumChipStyle}"
                            Click="ChipAwareness_Click" ToolTip="Awareness — reacts to what's on your screen">
                        <StackPanel>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="pack://application:,,,/Resources/features/awareness.png"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <Ellipse x:Name="DotAwareness" x:FieldModifier="internal" Width="8" Height="8"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#555555"
                                         Stroke="#1A1A2E" StrokeThickness="1"/>
                            </Grid>
                            <TextBlock Text="Awareness" FontSize="9" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ChipHaptics" x:FieldModifier="internal" Style="{StaticResource PremiumChipStyle}"
                            Click="ChipHaptics_Click" ToolTip="Haptics — connect a toy">
                        <StackPanel>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="pack://application:,,,/Resources/features/vibe.png"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <Ellipse x:Name="DotHaptics" x:FieldModifier="internal" Width="8" Height="8"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#555555"
                                         Stroke="#1A1A2E" StrokeThickness="1"/>
                            </Grid>
                            <TextBlock Text="Haptics" FontSize="9" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <!-- Lockdown — launcher with +/- duration and a live countdown -->
                    <Border Margin="0,0,0,5" Background="{DynamicResource AccentTintedBgBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" CornerRadius="9" Padding="2,3"
                            ToolTip="Lockdown — locks you in for the set time (panic key disabled)">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border CornerRadius="4" ClipToBounds="True" Width="14" Height="14" Margin="0,0,4,0">
                                    <Image Source="pack://application:,,,/Resources/lockdown_icon.png"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="Lockdown" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid x:Name="LockdownSetRow" x:FieldModifier="internal" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="BtnLockdownMinus" x:FieldModifier="internal" Style="{StaticResource RailMiniBtn}"
                                        Content="−" FontSize="13" Width="18" Height="18" Click="BtnLockdownMinus_Click"/>
                                <TextBlock Grid.Column="1" x:Name="TxtLockdownMins" x:FieldModifier="internal" Text="15m" FontSize="10"
                                           Foreground="White" VerticalAlignment="Center" TextAlignment="Center"/>
                                <Button Grid.Column="2" x:Name="BtnLockdownPlus" x:FieldModifier="internal" Style="{StaticResource RailMiniBtn}"
                                        Content="＋" FontSize="11" Width="18" Height="18" Click="BtnLockdownPlus_Click"/>
                            </Grid>
                            <Button x:Name="BtnLockdownGo" x:FieldModifier="internal" Style="{StaticResource RailMiniBtn}"
                                    Content="Lock in" FontSize="9" Height="16" Margin="0,3,0,0" Click="BtnLockdownGo_Click"/>
                            <TextBlock x:Name="TxtLockdownCountdown" x:FieldModifier="internal" Visibility="Collapsed"
                                       FontSize="12" FontWeight="Bold" Foreground="#FF6B6B" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Blink Trainer — launcher with +/- duration and countdown -->
                    <Border Margin="0,0,0,5" Background="{DynamicResource AccentTintedBgBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" CornerRadius="9" Padding="2,3"
                            ToolTip="Blink Trainer — webcam blink-gated visuals">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border CornerRadius="4" ClipToBounds="True" Width="14" Height="14" Margin="0,0,4,0">
                                    <Image Source="pack://application:,,,/Resources/features/blink_trainer.png"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="Blink" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid x:Name="BlinkSetRow" x:FieldModifier="internal" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Name="BtnBlinkMinus" x:FieldModifier="internal" Style="{StaticResource RailMiniBtn}"
                                        Content="−" FontSize="13" Width="18" Height="18" Click="BtnBlinkMinus_Click"/>
                                <TextBlock Grid.Column="1" x:Name="TxtBlinkMins" x:FieldModifier="internal" Text="10m" FontSize="10"
                                           Foreground="White" VerticalAlignment="Center" TextAlignment="Center"/>
                                <Button Grid.Column="2" x:Name="BtnBlinkPlus" x:FieldModifier="internal" Style="{StaticResource RailMiniBtn}"
                                        Content="＋" FontSize="11" Width="18" Height="18" Click="BtnBlinkPlus_Click"/>
                            </Grid>
                            <Button x:Name="BtnBlinkGo" x:FieldModifier="internal" Style="{StaticResource RailMiniBtn}"
                                    Content="Start" FontSize="9" Height="16" Margin="0,3,0,0" Click="BtnBlinkGo_Click"/>
                            <TextBlock x:Name="TxtBlinkCountdown" x:FieldModifier="internal" Visibility="Collapsed"
                                       FontSize="12" FontWeight="Bold" Foreground="#7FD8FF" TextAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Remote — opens a flyout to compose + start a remote session -->
                    <Button x:Name="ChipRemote" x:FieldModifier="internal" Style="{StaticResource PremiumChipStyle}"
                            Click="ChipRemote_Click" ToolTip="Remote Control — let someone drive your session">
                        <StackPanel>
                            <Grid Width="24" Height="24" HorizontalAlignment="Center">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="pack://application:,,,/Resources/features/remote_control.png"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <Ellipse x:Name="DotRemote" x:FieldModifier="internal" Width="8" Height="8"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Fill="#555555"
                                         Stroke="#1A1A2E" StrokeThickness="1"/>
                            </Grid>
                            <TextBlock Text="Remote" FontSize="9" Foreground="White" TextAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="RemoteFlyout" x:FieldModifier="internal" PlacementTarget="{Binding ElementName=ChipRemote}"
                           Placement="Right" StaysOpen="False" AllowsTransparency="True" HorizontalOffset="4">
                        <Border Background="{DynamicResource ElevatedSurfaceBrush}" BorderBrush="{DynamicResource PinkBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="10" Width="226">
                            <StackPanel>
                                <TextBlock Text="Go available" FontWeight="Bold" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Text="Difficulty" Foreground="{DynamicResource SecondaryBrush}" FontSize="10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                                    <RadioButton x:Name="RemoteDiffEasy" x:FieldModifier="internal" GroupName="RemoteDiff" Content="Easy" Foreground="White" Margin="0,0,10,0"/>
                                    <RadioButton x:Name="RemoteDiffMed" x:FieldModifier="internal" GroupName="RemoteDiff" Content="Medium" IsChecked="True" Foreground="White" Margin="0,0,10,0"/>
                                    <RadioButton x:Name="RemoteDiffHard" x:FieldModifier="internal" GroupName="RemoteDiff" Content="Hard" Foreground="White"/>
                                </StackPanel>
                                <CheckBox x:Name="RemoteShareCheck" x:FieldModifier="internal" Content="Share in Available Subjects"
                                          Foreground="White" FontSize="11" Margin="0,0,0,6"/>
                                <TextBlock Text="Message" Foreground="{DynamicResource SecondaryBrush}" FontSize="10"/>
                                <TextBox x:Name="RemoteMessageBox" x:FieldModifier="internal" MaxLength="80" Height="40"
                                         TextWrapping="Wrap" AcceptsReturn="True" Margin="0,2,0,6"/>
                                <TextBlock Text="Tags (up to 5)" Foreground="{DynamicResource SecondaryBrush}" FontSize="10"/>
                                <WrapPanel x:Name="RemoteTagPanel" x:FieldModifier="internal" Margin="0,2,0,8">
                                    <ToggleButton Content="Bimbo" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Drone" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Trance" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Fem" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Submission" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Degrade" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Audio OK" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Soft" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Lockdown OK" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                    <ToggleButton Content="Chastity" FontSize="10" Padding="5,1" Margin="0,0,3,3"/>
                                </WrapPanel>
                                <Button x:Name="BtnRemoteStart" x:FieldModifier="internal" Content="Start Remote"
                                        Click="BtnRemoteStart_Click" Style="{StaticResource PinkButton}"
                                        Background="{DynamicResource AccentGradientBrush}" Height="30" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
                <!-- Patron lock overlay (also serves as the ad) -->
                <Border x:Name="PremiumRailLock" x:FieldModifier="internal" Visibility="Collapsed"
                        Background="#E01A1A2E" CornerRadius="12" Cursor="Hand"
                        ToolTip="Premium features — unlock with Patreon">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <helpers:EmojiTextBlock Text="🔒" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Patron" FontSize="10" Foreground="White" TextAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- VELVET MOSAIC DASHBOARD - 4x4 feature card grid (col 0)       -->
        <!-- ============================================================ -->
        <Grid Grid.Column="1" Grid.Row="0" x:Name="VelvetFeatureGrid" x:FieldModifier="internal" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
    
            <!-- Row 1: Dashboard features -->
            <features:FeatureCard Grid.Row="0" Grid.Column="0" x:Name="CardFlash" x:FieldModifier="internal"
                                  Title="Flash Images"
                                  Icon="pack://application:,,,/Resources/features/flash.png"
                                  HelpSectionId="FlashImages"
                                  Click="CardFlash_Click"/>
            <features:FeatureCard Grid.Row="0" Grid.Column="1" x:Name="CardVisuals"
                                  Title="Visuals"
                                  Glyph="👁"
                                  HelpSectionId="Visuals"
                                  Click="CardVisuals_Click"/>
            <features:FeatureCard Grid.Row="0" Grid.Column="2" x:Name="CardVideo" x:FieldModifier="internal"
                                  Title="Mandatory Video"
                                  Icon="pack://application:,,,/Resources/features/mandatory_videos.png"
                                  HelpSectionId="Video"
                                  Click="CardVideo_Click"/>
            <features:FeatureCard Grid.Row="0" Grid.Column="3" x:Name="CardSubliminal" x:FieldModifier="internal"
                                  Title="Subliminals"
                                  Icon="pack://application:,,,/Resources/features/subliminal.png"
                                  HelpSectionId="Subliminals"
                                  Click="CardSubliminal_Click"/>
    
            <!-- Row 2: Left edge + center logo start + right edge -->
            <features:FeatureCard Grid.Row="1" Grid.Column="0" x:Name="CardSpiral" x:FieldModifier="internal"
                                  Title="Spiral Overlay"
                                  Icon="pack://application:,,,/Resources/features/spiral_overlay.png"
                                  HelpSectionId="SpiralOverlay"
                                  Click="CardSpiral_Click"/>
    
            <!-- Center logo (2x2) spanning rows 1-2, cols 1-2 -->
            <Border x:Name="LogoBrandFrame" x:FieldModifier="internal"
                    Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Grid.ColumnSpan="2"
                    Background="#01000000" Margin="6"
                    Cursor="Hand" MouseLeftButtonDown="ImgLogo_MouseLeftButtonDown"
                    ToolTip="{loc:Str tooltip_click_me_rapidly}">
                <Border CornerRadius="12" ClipToBounds="True">
                    <Image x:Name="ImgLogo" x:FieldModifier="internal" Stretch="Uniform"
                           HorizontalAlignment="Stretch" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
            </Border>
    
            <features:FeatureCard Grid.Row="1" Grid.Column="3" x:Name="CardLockCard" x:FieldModifier="internal"
                                  Title="Lock Card"
                                  Icon="pack://application:,,,/Resources/features/Phrase_Lock.png"
                                  HelpSectionId="LockCard"
                                  Click="CardLockCard_Click"/>
    
            <!-- Row 3: Left edge + center logo continued + right edge -->
            <features:FeatureCard Grid.Row="2" Grid.Column="0" x:Name="CardPinkFilter" x:FieldModifier="internal"
                                  Title="Pink Filter"
                                  Icon="pack://application:,,,/Resources/features/Pink_filter.png"
                                  HelpSectionId="PinkFilter"
                                  Click="CardPinkFilter_Click"/>
            <features:FeatureCard Grid.Row="2" Grid.Column="3" x:Name="CardMindWipe" x:FieldModifier="internal"
                                  Title="Mind Wipe"
                                  Icon="pack://application:,,,/Resources/features/Mind_Wipers.png"
                                  HelpSectionId="MindWipe"
                                  Click="CardMindWipe_Click"/>
    
            <!-- Row 4: Bottom row -->
            <features:FeatureCard Grid.Row="3" Grid.Column="0" x:Name="CardBubblePop" x:FieldModifier="internal"
                                  Title="Bubble Pop"
                                  Icon="pack://application:,,,/Resources/features/Bubble_pop.png"
                                  HelpSectionId="BubblePop"
                                  Click="CardBubblePop_Click"/>
            <features:FeatureCard Grid.Row="3" Grid.Column="1" x:Name="CardBouncingText" x:FieldModifier="internal"
                                  Title="Bouncing Text"
                                  Icon="pack://application:,,,/Resources/features/bouncing_text.png"
                                  HelpSectionId="BouncingText"
                                  Click="CardBouncingText_Click"/>
            <features:FeatureCard Grid.Row="3" Grid.Column="2" x:Name="CardSystem"
                                  Title="System"
                                  Glyph="⚙"
                                  HelpSectionId="System"
                                  Click="CardSystem_Click"/>
            <features:FeatureCard Grid.Row="3" Grid.Column="3" x:Name="CardBubbleCount" x:FieldModifier="internal"
                                  Title="Bubble Count"
                                  Icon="pack://application:,,,/Resources/features/Bubble_count.png"
                                  HelpSectionId="BubbleCount"
                                  Click="CardBubbleCount_Click"/>
        </Grid>
    
        <!-- ============================================================ -->
        <!-- LEGACY DASHBOARD HOST - kept collapsed to preserve x:Names   -->
        <!-- referenced by MainWindow.xaml.cs until the full rewire is    -->
        <!-- complete. Phase 6+ will delete this block.                   -->
        <!-- ============================================================ -->
        <Grid x:Name="LegacyDashboardHost" x:FieldModifier="internal" Grid.Column="1" Grid.Row="0" Visibility="Collapsed">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>
    
        <!-- LEFT COLUMN -->
        <ScrollViewer Grid.Column="0" Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="5">
            <StackPanel>
    
                <!-- Flash Images Section -->
                <Border x:Name="FlashSection" CornerRadius="12" Padding="10,6" Margin="0,0,0,6"
                        Background="{DynamicResource ElevatedSurfaceBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,2">
                            <helpers:EmojiTextBlock x:Name="TxtFeatureFlash" x:FieldModifier="internal" Style="{StaticResource SectionHeader}" Text="{loc:Str section_flash_images}" Margin="0"/>
                            <Button x:Name="HelpBtnFlash" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="FlashImages"/>
                        </Grid>
                        
                        <!-- Enable / Clickable / Hydra / Linked in one row -->
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0"
                                        ToolTip="{loc:Str tooltip_flash_enable}">
                                <CheckBox x:Name="ChkFlashEnabled" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                          Checked="ChkFlashEnabled_Changed" Unchecked="ChkFlashEnabled_Changed"/>
                                <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str btn_enable}" Margin="5,0,0,0" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0"
                                        ToolTip="{loc:Str tooltip_when_enabled_clicking_an_image_dismisses_it_w}">
                                <CheckBox x:Name="ChkClickable" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                          Checked="ChkClickable_Changed" Unchecked="ChkClickable_Changed"/>
                                <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_click}" Margin="5,0,0,0" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,6,0"
                                        ToolTip="{loc:Str tooltip_hydra_mode_clicking_an_image_spawns_two_more}">
                                <CheckBox x:Name="ChkCorruption" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          Checked="ChkCorruption_Changed" Unchecked="ChkCorruption_Changed"/>
                                <helpers:EmojiTextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_hydra}" Margin="5,0,0,0" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        ToolTip="{loc:Str tooltip_linked_hydra_spawns_share_the_parent_flash_ti}">
                                <CheckBox x:Name="ChkHydraLinked" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                          Checked="ChkHydraLinked_Changed" Unchecked="ChkHydraLinked_Changed"/>
                                <helpers:EmojiTextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_linked}" Margin="5,0,0,0" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="6,0,0,0"
                                        ToolTip="{loc:Str tooltip_toggle_the_pink_sparkle_glow_effect_on_flash}">
                                <CheckBox x:Name="ChkFlashGlow" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                          Checked="ChkFlashGlow_Changed" Unchecked="ChkFlashGlow_Changed"/>
                                <helpers:EmojiTextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_glow}" Margin="5,0,0,0" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                        <!-- Per Hour / Images in two columns -->
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" ToolTip="{loc:Str tooltip_how_many_flash_events_occur_per_hour_higher_v}">
                                <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_per_hour}" FontSize="11"/><TextBlock x:Name="TxtPerMin" x:FieldModifier="internal" Style="{StaticResource ValueLabel}" Text="10" HorizontalAlignment="Right"/></Grid>

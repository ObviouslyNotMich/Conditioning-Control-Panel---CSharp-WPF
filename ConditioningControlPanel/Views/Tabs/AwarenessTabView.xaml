<UserControl x:Class="ConditioningControlPanel.Views.Tabs.AwarenessTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
      <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,20,28,20" MaxWidth="980" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="Auto"/> <!-- Pulse -->
                    <RowDefinition Height="Auto"/> <!-- Presets -->
                    <RowDefinition Height="Auto"/> <!-- Timing (two sliders) -->
                    <RowDefinition Height="Auto"/> <!-- Sources + Safety (two columns) -->
                    <RowDefinition Height="Auto"/> <!-- Advanced link -->
                </Grid.RowDefinitions>
    
                <!-- ==================== HERO BANNER + HEADER ==================== -->
                <StackPanel Grid.Row="0">
                <Border CornerRadius="14" Margin="0,0,0,18" ClipToBounds="True" MaxHeight="320"
                        HorizontalAlignment="Center" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                    <Image x:Name="ImgAwarenessFeature" x:FieldModifier="internal" Source="pack://application:,,,/Resources/features/awareness.png"
                           Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
                <Grid Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Width="38" Height="38" VerticalAlignment="Center" Margin="0,0,14,0"
                           Source="{Binding Source='👁', Converter={StaticResource EmojiToImageSource}}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Awareness Engine" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="She's watching your screen and your typing. React in real time."
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnAwarenessTutorial" Content="🎓 Tutorial"
                                Style="{StaticResource SmallPinkButton}"
                                VerticalAlignment="Center" Margin="0,0,16,0"
                                Click="BtnAwarenessTutorial_Click"
                                ToolTip="Walk through the Awareness Engine — sources, cooldowns, presets, and the editor."/>
                        <Ellipse x:Name="AwarenessStatusDot" x:FieldModifier="internal" Width="8" Height="8" Fill="#606060" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtAwarenessStatus" x:FieldModifier="internal" Text="Off" Foreground="#A0A0A0"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <CheckBox x:Name="ChkAwarenessMaster" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                  VerticalAlignment="Center"
                                  Checked="ChkAwarenessMaster_Changed" Unchecked="ChkAwarenessMaster_Changed">
                            <CheckBox.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="320">
                                        <TextBlock Text="Awareness Engine — Master Switch" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                            Turns the whole Awareness system on or off. When ON, enabled signal sources (OCR + keyboard) feed words into the trigger engine and matching keywords fire their actions in real time. When OFF, nothing detects anything — installed presets stay on disk but do nothing.
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </CheckBox.ToolTip>
                        </CheckBox>
                    </StackPanel>
                </Grid>
                </StackPanel>
    
                <!-- ==================== LIVE PULSE ==================== -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                        BorderThickness="1" CornerRadius="10" Padding="18,16" Margin="0,0,0,18">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="LAST DETECTED" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtAwarenessFireCount" x:FieldModifier="internal" Text="" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="10"/>
                        </Grid>
                        <StackPanel x:Name="AwarenessPulseFeed" x:FieldModifier="internal">
                            <!-- Empty state shown when no fires yet -->
                            <TextBlock x:Name="TxtAwarenessPulseEmpty" x:FieldModifier="internal"
                                       Text="Nothing yet. Enable the engine and she'll start noticing things."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontStyle="Italic"
                                       TextAlignment="Center" Margin="0,18,0,18"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
    
                <!-- ==================== PRESETS ==================== -->
                <StackPanel Grid.Row="2" Margin="0,0,0,18">
                    <Grid Margin="4,0,4,10">
                        <TextBlock Text="PRESETS" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="One-click packs — click any card to preview or install"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontStyle="Italic"/>
                    </Grid>
                    <!-- Cards are built imperatively in MainWindow.RefreshAwarenessPresetCards
                         so the trailing "+ New Preset" card can share the wrap flow with the
                         real preset cards. -->
                    <WrapPanel x:Name="AwarenessPresetItems" x:FieldModifier="internal" HorizontalAlignment="Stretch"/>
                </StackPanel>
    
                <!-- ==================== TIMING ==================== -->
                <StackPanel Grid.Row="3" Margin="0,0,0,14">
                    <TextBlock Text="TIMING" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                               Margin="4,0,4,10"/>
                    <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                            BorderThickness="1" CornerRadius="10" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
    
                            <!-- Col 0: global effect cooldown -->
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Cooldown between effects" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" Margin="6,0,0,0">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <StackPanel MaxWidth="340">
                                                    <TextBlock Text="Cooldown between effects" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                        Minimum delay between any two Awareness reactions, from ANY trigger. Keeps her from spamming effects when lots of trigger words end up on screen or in your typing at once.
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                        Lower = more reactive, higher = calmer pacing. 10s is the default. Max 180s.
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>
                                <Grid>
                                    <Slider x:Name="SliderAwarenessGlobalCooldown" x:FieldModifier="internal" Minimum="1" Maximum="180"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="SliderAwarenessGlobalCooldown_ValueChanged"/>
                                    <TextBlock x:Name="TxtAwarenessGlobalCooldown" x:FieldModifier="internal" Text="10s"
                                               Foreground="{DynamicResource PinkBrush}" FontSize="10"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
    
                            <!-- Col 2: same-word cooldown -->
                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Same-word cooldown" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" Margin="6,0,0,0">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <StackPanel MaxWidth="340">
                                                    <TextBlock Text="Same-word cooldown" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                        Minimum gap before the SAME word can fire again, regardless of which trigger caught it. Stops a single word on screen from re-triggering on every OCR scan.
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                        Independent of the "cooldown between effects" above — a different word can still fire within this window. 15s default. Max 180s.
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>
                                <Grid>
                                    <Slider x:Name="SliderAwarenessSameWordCooldown" x:FieldModifier="internal" Minimum="1" Maximum="180"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="SliderAwarenessSameWordCooldown_ValueChanged"/>
                                    <TextBlock x:Name="TxtAwarenessSameWordCooldown" x:FieldModifier="internal" Text="15s"
                                               Foreground="{DynamicResource PinkBrush}" FontSize="10"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
    
                <!-- ==================== SOURCES + SAFETY ==================== -->
                <Grid Grid.Row="4" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
    
                    <!-- Signal Sources -->
                    <Border Grid.Column="0" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                            BorderThickness="1" CornerRadius="10" Padding="18,14">
                        <StackPanel>
                            <TextBlock Text="SIGNAL SOURCES" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,10"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="Screen OCR" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                Scans your screen every few seconds with optical character recognition and feeds detected words into the trigger engine. This is how she notices text inside other apps — Discord, browsers, image viewers, game UIs, anything visible.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                Uses modest CPU/GPU during active sessions. Turn off if you don't want screen-based triggers or want to save power.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Grid.ToolTip>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"
                                           Source="{Binding Source='🖵', Converter={StaticResource EmojiToImageSource}}"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Screen OCR" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Reads words from what's on your screen"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox x:Name="ChkAwarenessOcr" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="ChkAwarenessOcr_Changed" Unchecked="ChkAwarenessOcr_Changed"/>
                            </Grid>
                            <Grid Margin="0,4,0,4">
                                <Grid.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="Keyboard Capture" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                Listens to your keystrokes and assembles a rolling buffer of recent typing. When you type a trigger keyword, it fires immediately — no OCR delay.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                Only trigger words are acted on; nothing else is stored or logged. Fastest signal source. Turn off if you don't want typing-based triggers.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </Grid.ToolTip>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⌨" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Keyboard" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Catches trigger words as you type them"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox x:Name="ChkAwarenessKeyboard" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="ChkAwarenessKeyboard_Changed" Unchecked="ChkAwarenessKeyboard_Changed"/>
                            </Grid>
                            <TextBlock Text="More sources coming: browser URL, active window title, process"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontStyle="Italic"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
    
                    <!-- Safety -->
                    <Border Grid.Column="2" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                            BorderThickness="1" CornerRadius="10" Padding="18,14">
                        <StackPanel>
                            <TextBlock Text="SAFETY" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,10"/>
                            <CheckBox x:Name="ChkAwarenessIgnoreOwnUi" x:FieldModifier="internal"
                                      Foreground="White" FontSize="12" Margin="0,4,0,2"
                                      Checked="ChkAwarenessIgnoreOwnUi_Changed" Unchecked="ChkAwarenessIgnoreOwnUi_Changed">
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="Ignore CCP's own windows" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                OCR will skip words drawn by Control Panel itself — avatar speech bubbles, subliminal flash overlays, bouncing text, and the main window. Prevents Awareness from reacting to her own voice and creating feedback loops.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                Strongly recommended ON. Only turn off if you're debugging why a specific overlay isn't being detected.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                                <TextBlock Text="Ignore CCP's own windows" FontWeight="SemiBold"/>
                            </CheckBox>
                            <TextBlock Text="OCR skips words inside Control Panel, avatar bubbles, and subliminal flashes — so she won't react to her own voice."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,0,0,10"/>
                            <CheckBox x:Name="ChkAwarenessLoopProtection" x:FieldModifier="internal"
                                      Foreground="White" FontSize="12" Margin="0,4,0,2"
                                      Checked="ChkAwarenessLoopProtection_Changed" Unchecked="ChkAwarenessLoopProtection_Changed">
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="Loop protection" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                When a trigger fires, its keyword is silenced for a few seconds. Stops a single mention on screen from firing multiple times in quick succession if OCR keeps catching it.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                Also works across sources — a keyword fired via Keyboard is muted for OCR detection too, and vice versa.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                                <TextBlock Text="Loop protection" FontWeight="SemiBold"/>
                            </CheckBox>
                            <TextBlock Text="After a trigger fires, its keyword is muted for a few seconds so the reaction can't re-arm it."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,0,0,10"/>
    
                            <!-- On-screen highlight: toggle + color picker. The highlight overlay
                                 draws a glowing box around OCR-matched words on your screen. -->
                            <CheckBox x:Name="ChkAwarenessHighlight" x:FieldModifier="internal"
                                      Foreground="White" FontSize="12" Margin="0,4,0,2"
                                      Checked="ChkAwarenessHighlight_Changed" Unchecked="ChkAwarenessHighlight_Changed">
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="Highlight matched words on screen" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                Draws a glowing rectangle around every OCR-detected trigger word on your screen, just long enough to see it catch your eye. Gives you a visual confirmation that Awareness is watching.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                Only shows for OCR detections, not keyboard triggers. Pick the glow color from the swatches below.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                                <TextBlock Text="Highlight matched words on screen" FontWeight="SemiBold"/>
                            </CheckBox>
                            <TextBlock Text="Draws a glowing box around OCR-detected trigger words. Pick the glow color below."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,0,0,6"/>
                            <StackPanel x:Name="AwarenessHighlightColorPanel" Orientation="Horizontal" Margin="22,0,0,0"
                                        ToolTip="Click a swatch to pick the highlight glow color, or type a custom hex in the box.">
                                <TextBlock Text="Color:" Foreground="#A0A0B8" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border x:Name="SwatchHighlightPink" x:FieldModifier="internal" Width="22" Height="22" CornerRadius="3"
                                        Background="#FF69B4" BorderBrush="#3A3A5A" BorderThickness="1"
                                        Margin="0,0,4,0" Cursor="Hand" Tag="#FF69B4"
                                        ToolTip="Hot pink — CCP default"
                                        MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                <Border x:Name="SwatchHighlightCyan" x:FieldModifier="internal" Width="22" Height="22" CornerRadius="3"
                                        Background="#00E5FF" BorderBrush="#3A3A5A" BorderThickness="1"
                                        Margin="0,0,4,0" Cursor="Hand" Tag="#00E5FF"
                                        ToolTip="Electric cyan — max contrast on dark UIs"
                                        MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                <Border x:Name="SwatchHighlightLime" x:FieldModifier="internal" Width="22" Height="22" CornerRadius="3"
                                        Background="#9DFF00" BorderBrush="#3A3A5A" BorderThickness="1"
                                        Margin="0,0,4,0" Cursor="Hand" Tag="#9DFF00"
                                        ToolTip="Lime — visible on pink/purple themes"
                                        MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                <Border x:Name="SwatchHighlightOrange" x:FieldModifier="internal" Width="22" Height="22" CornerRadius="3"
                                        Background="#FF8A00" BorderBrush="#3A3A5A" BorderThickness="1"
                                        Margin="0,0,4,0" Cursor="Hand" Tag="#FF8A00"
                                        ToolTip="Amber orange — warm alternative"
                                        MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                <Border x:Name="SwatchHighlightViolet" x:FieldModifier="internal" Width="22" Height="22" CornerRadius="3"
                                        Background="#B388FF" BorderBrush="#3A3A5A" BorderThickness="1"
                                        Margin="0,0,4,0" Cursor="Hand" Tag="#B388FF"
                                        ToolTip="Soft violet — matches SissyHypno theme"
                                        MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                <Border x:Name="SwatchHighlightWhite" x:FieldModifier="internal" Width="22" Height="22" CornerRadius="3"
                                        Background="#FFFFFF" BorderBrush="#3A3A5A" BorderThickness="1"
                                        Margin="0,0,8,0" Cursor="Hand" Tag="#FFFFFF"
                                        ToolTip="Pure white — most neutral option"
                                        MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                <TextBox x:Name="TxtAwarenessHighlightHex" x:FieldModifier="internal" Width="74" FontSize="10"
                                         Background="#1E1E32" Foreground="White" BorderBrush="#3A3A5A"
                                         Padding="4,3" VerticalAlignment="Center"
                                         ToolTip="Custom hex color (e.g. #FF00AA). Type and press Enter or Tab to apply."
                                         LostFocus="TxtAwarenessHighlightHex_LostFocus"
                                         KeyDown="TxtAwarenessHighlightHex_KeyDown"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkAwarenessHighlightVisibleInCapture" x:FieldModifier="internal"
                                      Content="Visible in screen capture / streams"
                                      Foreground="#A0A0A0" FontSize="10" Margin="22,6,0,0"
                                      Checked="ChkAwarenessHighlightVisibleInCapture_Changed"
                                      Unchecked="ChkAwarenessHighlightVisibleInCapture_Changed">
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="340">
                                            <TextBlock Text="Visible in screen capture" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                Off (default): highlights render on your desktop but are excluded from screen capture via WDA_EXCLUDEFROMCAPTURE, so OBS, Discord, and screen recordings don't see them.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White" Margin="0,6,0,0">
                                                On: lets the highlights show up in recordings — useful for streaming or demos. Also a fallback if your GPU driver is one of the few that hides excluded windows from the desktop itself.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                            </CheckBox>
                        </StackPanel>
                    </Border>
                </Grid>
    
                <!-- ==================== ADVANCED LINK ==================== -->
                <Grid Grid.Row="5" Margin="0,0,0,0"
                      ToolTip="Opens a detailed editor for the currently installed preset where you can add/remove keywords, tweak per-trigger actions, and edit phrase pools. If no preset is installed yet, this link opens the App Info &amp; Data popup instead.">
                    <TextBlock HorizontalAlignment="Center">
                        <Hyperlink x:Name="LnkAwarenessAdvanced"
                                   Foreground="{DynamicResource PinkBrush}"
                                   TextDecorations="Underline"
                                   Click="LnkAwarenessAdvanced_Click">
                            <Run x:Name="LnkAwarenessAdvancedText" x:FieldModifier="internal" Text="Customize individual triggers (advanced) →"/>
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Grid>
        </ScrollViewer>
    
        <!-- Translucent gating overlay (only for free users) -->
        <Border x:Name="AwarenessGate" x:FieldModifier="internal" Visibility="Collapsed"
                Background="#99000010" BorderBrush="#FF69B4" BorderThickness="2"
                CornerRadius="10" IsHitTestVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Width="52" Height="52" HorizontalAlignment="Center" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                <TextBlock Text="{loc:Str gate_premium_locked}" FontSize="22"
                           FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{loc:Str gate_premium_subtitle}" FontSize="14"
                           Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                <Button Click="BtnGateUnlock_Click" Padding="20,8" Background="#FF69B4"
                        Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                    <helpers:EmojiTextBlock Text="{loc:Str gate_unlock_with_patreon}"/>
                </Button>
            </StackPanel>
        </Border>
      </Grid>
</UserControl>

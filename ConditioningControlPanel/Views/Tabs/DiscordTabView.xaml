<UserControl x:Class="ConditioningControlPanel.Views.Tabs.DiscordTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SectionPanel}" BorderBrush="#5865F2" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="{loc:Str label_profile_viewer}" Foreground="#5865F2" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Button x:Name="HelpBtnDiscordProfile" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="DiscordProfile"/>
                    </Grid>
    
                    <!-- Search Input -->
                    <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtProfileSearch" x:FieldModifier="internal" Background="Transparent" BorderThickness="0" Foreground="White"
                                     FontSize="13" VerticalAlignment="Center" KeyDown="TxtProfileSearch_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="{loc:Str label_search_by_display_name}" Foreground="#606080" FontSize="13" Margin="2,0,0,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <Button Grid.Column="1" Content="🔍" Background="Transparent" BorderThickness="0"
                                    Foreground="#5865F2" FontSize="16" Cursor="Hand" Click="BtnProfileSearch_Click"
                                    ToolTip="{loc:Str tooltip_search_profile}"/>
                        </Grid>
                    </Border>
    
                    <!-- Quick buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Button Content="{loc:Str btn_my_profile}" Background="#5865F2" Foreground="White" BorderThickness="0"
                                Padding="12,6" Margin="0,0,8,0" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                Click="BtnViewMyProfile_Click"/>
                        <Button Content="{loc:Str btn_clear}" Background="{DynamicResource PanelAccentBrush}" Foreground="White" BorderThickness="0"
                                Padding="12,6" FontSize="11" Cursor="Hand" Click="BtnClearProfile_Click"/>
                    </StackPanel>
    
                    <!-- Profile Card with optional OG animated border (layered via Grid) -->
                    <Grid x:Name="ProfileCardWrapper" x:FieldModifier="internal" Visibility="Collapsed">
                        <!-- OG animated border (behind the card) -->
                        <Border x:Name="OgBorderContainer" x:FieldModifier="internal" Visibility="Collapsed" Padding="0" CornerRadius="18">
                            <Border.Resources>
                                <Storyboard x:Key="OgBorderAnimation" RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="OgBorderRotation"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:3"/>
                                </Storyboard>
                            </Border.Resources>
                            <Border.Background>
                                <LinearGradientBrush x:Name="OgBorderBrush" StartPoint="0,0" EndPoint="1,1">
                                    <LinearGradientBrush.RelativeTransform>
                                        <RotateTransform x:Name="OgBorderRotation" CenterX="0.5" CenterY="0.5" Angle="0"/>
                                    </LinearGradientBrush.RelativeTransform>
                                    <GradientStop Color="#FFD700" Offset="0"/>
                                    <GradientStop Color="#FFA500" Offset="0.25"/>
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="0.5"/>
                                    <GradientStop Color="#FFA500" Offset="0.75"/>
                                    <GradientStop Color="#FFD700" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Profile card content (always visible when wrapper is visible) -->
                        <Border x:Name="ProfileCardContainer" Margin="8" Background="{DynamicResource DarkerBgBrush}" CornerRadius="12">
                        <StackPanel>
                            <!-- Profile Header (Avatar + Name + Status) -->
                            <Border CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1E1E3F" Offset="0"/>
                                        <GradientStop Color="#2A2A4A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
    
                                    <!-- Avatar with online indicator -->
                                    <Grid Width="100" Height="100">
                                        <Border CornerRadius="50" BorderBrush="#5865F2" BorderThickness="3">
                                            <Border.Background>
                                                <ImageBrush x:Name="ProfileViewerAvatar" x:FieldModifier="internal" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <!-- Online status dot -->
                                        <Ellipse x:Name="ProfileOnlineIndicator" x:FieldModifier="internal" Width="20" Height="20"
                                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                 Margin="0,0,5,5" Stroke="#1E1E3F" StrokeThickness="3" Fill="#43B581"/>
                                    </Grid>
    
                                    <!-- Name and handle -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="TxtProfileViewerName" x:FieldModifier="internal" Text="{loc:Str login_display_name}"
                                                       Foreground="White" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <!-- Edit display name button (own profile only) -->
                                            <Button x:Name="BtnChangeDisplayName" x:FieldModifier="internal" Visibility="Collapsed"
                                                    Width="24" Height="24" Margin="6,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" VerticalAlignment="Center"
                                                    ToolTip="{loc:Str tooltip_change_display_name}"
                                                    Click="BtnChangeDisplayName_Click">
                                                <helpers:EmojiTextBlock Text="{loc:Str label_text}" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                                            </Button>
                                            <!-- Delete profile button (own profile only) -->
                                            <Button x:Name="BtnDeleteProfile" x:FieldModifier="internal" Visibility="Collapsed"
                                                    Width="24" Height="24" Margin="4,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" VerticalAlignment="Center"
                                                    ToolTip="{loc:Str tooltip_delete_your_profile}"
                                                    Click="BtnDeleteProfile_Click">
                                                <helpers:EmojiTextBlock Text="{loc:Str label_text_2}" Foreground="#FF4444" FontSize="13" VerticalAlignment="Center"/>
                                            </Button>
                                            <!-- OG GOOD GIRL Banner -->
                                            <Border x:Name="OgBannerBadge" x:FieldModifier="internal" Visibility="Collapsed" Margin="10,0,0,0" Padding="8,3" CornerRadius="4"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#FFD700" Offset="0"/>
                                                        <GradientStop Color="#FFA500" Offset="0.5"/>
                                                        <GradientStop Color="{DynamicResource PinkColor}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{loc:Str label_og_good_girl}" Foreground="{DynamicResource DarkerBgBrush}" FontSize="10" FontWeight="ExtraBold"
                                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock x:Name="TxtProfileViewerOnline" x:FieldModifier="internal" Text="{loc:Str label_online}"
                                                       Foreground="#43B581" FontSize="11"/>
                                        </StackPanel>
                                        <!-- Discord button + Patreon badge row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button x:Name="BtnProfileDiscord" x:FieldModifier="internal" Visibility="Collapsed"
                                                    Background="#5865F2" Foreground="White" BorderThickness="0"
                                                    Padding="10,5" Cursor="Hand"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Click="BtnProfileDiscord_Click"
                                                    ToolTip="{loc:Str tooltip_open_discord_profile}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"
                                                           Source="{Binding Source='💬', Converter={StaticResource EmojiToImageSource}}"/>
                                                    <TextBlock x:Name="TxtProfileDiscordId" x:FieldModifier="internal" Text="{loc:Str label_message_on_discord}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                            <!-- Patreon tier badge (same as leaderboard) -->
                                            <Image x:Name="ProfilePatreonTierBadge" x:FieldModifier="internal" Width="80" Height="80" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" Visibility="Collapsed" Stretch="Uniform"/>
                                        </StackPanel>
                                    </StackPanel>
    
                                    <!-- Patreon tier banner -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <!-- Patreon tier banner (Pink filter / Prime subject) -->
                                        <Border x:Name="ProfilePatreonTierBanner" x:FieldModifier="internal" Visibility="Collapsed"
                                                Width="140" Height="100" CornerRadius="8">
                                            <Image x:Name="ImgPatreonTierBanner" x:FieldModifier="internal" Stretch="Uniform"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- Level, Rank & Patreon Badge -->
                            <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Str label_level_2}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtProfileViewerLevel" x:FieldModifier="internal" Text="1" Foreground="#FFD700" FontSize="32" FontWeight="ExtraBold" Margin="0,-5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{loc:Str label_rank}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock x:Name="TxtProfileViewerRank" x:FieldModifier="internal" Text="#-" Foreground="#FFD700" FontSize="32" FontWeight="ExtraBold" Margin="0,-5,0,0"/>
                                    </StackPanel>
                                    <!-- Patreon Badge -->
                                    <Image x:Name="ProfilePatreonBadge" x:FieldModifier="internal" Grid.Column="2" Height="40" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                </Grid>
                            </Border>
    
                            <!-- Stats Grid (Trainer Card Style) -->
                            <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
    
                                    <!-- XP with image -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12" Orientation="Horizontal">
                                        <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                            <Image x:Name="ImgStatXp" Source="pack://application:,,,/Resources/achievements/lv_10.png" Stretch="Uniform" Margin="3"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_xp}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProfileViewerXp" x:FieldModifier="internal" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
    
                                    <!-- Bubbles with image -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" Orientation="Horizontal">
                                        <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                            <Image x:Name="ImgStatBubbles" Source="pack://application:,,,/Resources/achievements/pop_the_Thought.png" Stretch="Uniform" Margin="3"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_bubbles_2}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProfileViewerBubbles" x:FieldModifier="internal" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
    
                                    <!-- Video Time with image -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12" Orientation="Horizontal">
                                        <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                            <Image x:Name="ImgStatVideos" Source="pack://application:,,,/Resources/achievements/10_hours_pink.png" Stretch="Uniform" Margin="3"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_videos}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProfileViewerVideos" x:FieldModifier="internal" Text="{loc:Str label_0h}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
    
                                    <!-- GIFs with image -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Orientation="Horizontal">
                                        <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                            <Image x:Name="ImgStatGifs" Source="pack://application:,,,/Resources/achievements/retinal_burn.png" Stretch="Uniform" Margin="3"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_flashes}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProfileViewerGifs" x:FieldModifier="internal" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
    
                                    <!-- Lock Cards with image -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                        <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                            <Image x:Name="ImgStatLockCards" Source="pack://application:,,,/Resources/achievements/total_lockdown.png" Stretch="Uniform" Margin="3"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_lock_cards_2}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProfileViewerLockCards" x:FieldModifier="internal" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
    
                                    <!-- Achievements with image -->
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                        <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                            <Image x:Name="ImgStatAchievements" Source="pack://application:,,,/Resources/achievements/spiral_eyes.png" Stretch="Uniform" Margin="3"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_achievements}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtProfileViewerAchievements" x:FieldModifier="internal" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- Achievement Images Grid -->
                            <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,5">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str label_achievements}" Foreground="#5865F2" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="ProfileAchievementGrid" x:FieldModifier="internal">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="80" Height="80" Margin="4" CornerRadius="8"
                                                        Background="{DynamicResource PanelAccentBrush}" ToolTip="{Binding Name}">
                                                    <Image Source="{Binding Image}" Stretch="Uniform" Margin="4"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="TxtNoAchievements" x:FieldModifier="internal" Text="{loc:Str label_no_achievements_yet}"
                                               Foreground="#606080" FontSize="11" FontStyle="Italic"
                                               HorizontalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    </Grid>
    
                    <!-- No profile selected message -->
                    <Border x:Name="NoProfileSelected" x:FieldModifier="internal" Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="30">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,10"
                                   Source="{Binding Source='👤', Converter={StaticResource EmojiToImageSource}}"/>
                            <TextBlock Text="{loc:Str label_search_for_a_user}" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Str label_or_click_my_profile}" Foreground="#606080" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>            <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SectionPanel}" BorderBrush="#5865F2" BorderThickness="1"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="10"><TextBlock Text="{loc:Str label_community_settings}" Foreground="#5865F2" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/><Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,12" BorderBrush="#5865F2" BorderThickness="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock x:Name="TxtDiscordTabStatus" x:FieldModifier="internal" Text="{loc:Str label_not_connected}" Foreground="White" FontSize="14" FontWeight="Bold"/><TextBlock x:Name="TxtDiscordTabInfo" x:FieldModifier="internal" Text="{loc:Str label_link_discord_for_community_features}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/></StackPanel><Button x:Name="BtnDiscordTabLogin" x:FieldModifier="internal" Grid.Column="1" Content="{loc:Str btn_login}" Background="#5865F2" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" FontSize="11" Cursor="Hand" Click="BtnDiscordTabLogin_Click"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_discord_rich_presence}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_show_your_activity_status}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabRichPresence" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkDiscordRichPresence_Changed" Unchecked="ChkDiscordRichPresence_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_show_level_in_status}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_display_your_level}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShowLevel" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True" Checked="ChkShowLevelInPresence_Changed" Unchecked="ChkShowLevelInPresence_Changed"/></Grid></Border><TextBlock Text="{loc:Str label_community_sharing}" Foreground="#5865F2" FontSize="13" FontWeight="Bold" Margin="0,12,0,10"/><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_share_achievements}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_post_achievements_to_discord}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShareAchievements" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareAchievements_Changed" Unchecked="ChkShareAchievements_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_share_level_milestones}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_post_level_ups_to_discord}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShareLevelUps" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareLevelUps_Changed" Unchecked="ChkShareLevelUps_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_allow_dms_from_leaderboard}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_let_others_message_you}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabAllowDm" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkAllowDiscordDm_Changed" Unchecked="ChkAllowDiscordDm_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_share_profile_picture}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_show_your_avatar_to_others}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabSharePfp" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareProfilePicture_Changed" Unchecked="ChkShareProfilePicture_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_show_online_status}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_appear_offline_when_disabled}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShowOnline" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True" Checked="ChkShowOnlineStatus_Changed" Unchecked="ChkShowOnlineStatus_Changed"/></Grid></Border><TextBlock Text="{loc:Str label_all_sharing_is_opt_in}" Foreground="#5865F2" FontSize="10" FontStyle="Italic" Margin="0,10,0,0"/><Button Content="{loc:Str btn_join_discord_server}" Background="#5865F2" Foreground="White" BorderThickness="0" Padding="15,12" Margin="0,15,0,0" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnDiscord_Click"/></StackPanel></ScrollViewer></Border>
        </Grid>
</UserControl>

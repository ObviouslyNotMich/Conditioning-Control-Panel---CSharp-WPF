<UserControl x:Class="ConditioningControlPanel.Views.Tabs.HapticsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="36,28,36,28" MaxWidth="1280" HorizontalAlignment="Center">
    
                <!-- Header -->
                <Grid Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Width="44" Height="44" VerticalAlignment="Center" Margin="0,0,16,0"
                           Source="{Binding Source='💜', Converter={StaticResource EmojiToImageSource}}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str tab_haptics}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
    
                <!-- Description card (always visible) -->
                <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="24,20" Margin="0,0,0,22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="160" Height="160" CornerRadius="12" ClipToBounds="True"
                                BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2" VerticalAlignment="Top">
                            <Image x:Name="ImgHapticsVibeDesc" x:FieldModifier="internal"
                                   Source="pack://application:,,,/Resources/features/vibe.png"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str label_what_is_this}" Foreground="{DynamicResource PinkBrush}"
                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Str desc_haptics}" Foreground="White" FontSize="15"
                                       TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="22"/>
                            <TextBlock Text="{loc:Str desc_haptics_bullets}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>
    
                <!-- Interactive controls + translucent gating overlay -->
                <Grid>
                    <Grid>
                <!-- Haptics Content (enabled for Patreon supporters) -->
                <Grid x:Name="HapticsContentGrid" x:FieldModifier="internal">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
    
                <!-- ============ SECTION 1: CONNECTION ============ -->
                <Grid Grid.Row="0">
                    <Border x:Name="HapticsConnectionBox" x:FieldModifier="internal" CornerRadius="10" Padding="22,18"
                            Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48" BorderThickness="1">
                        <StackPanel>
                            <!-- Header: title + master toggle -->
                            <Grid Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Source="{Binding Source='🔌', Converter={StaticResource EmojiToImageSource}}"/>
                                    <TextBlock Text="{loc:Str label_haptic_connection}" Foreground="{DynamicResource PinkBrush}"
                                               FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button x:Name="HelpBtnHaptics" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="Haptics"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Str btn_enable}" Foreground="#AAA" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <CheckBox x:Name="ChkHapticsEnabled" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                              VerticalAlignment="Center"
                                              Checked="ChkHapticsEnabled_Changed" Unchecked="ChkHapticsEnabled_Changed"/>
                                </StackPanel>
                            </Grid>
    
                            <!-- Provider + URL + Connect (single horizontal row) -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str label_provider}" Foreground="White" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="CmbHapticProvider" x:FieldModifier="internal" Grid.Column="1" Padding="8,4" FontSize="13"
                                          Background="{DynamicResource SurfaceBgBrush}" Foreground="Black" BorderThickness="0"
                                          SelectionChanged="CmbHapticProvider_SelectionChanged">
                                    <ComboBoxItem Content="{loc:Str btn_lovense_connect}" Tag="Lovense" Foreground="Black"/>
                                    <ComboBoxItem Content="{loc:Str btn_buttplug_io_intiface}" Tag="Buttplug" Foreground="Black"/>
                                </ComboBox>
                                <TextBox x:Name="TxtHapticUrl" x:FieldModifier="internal" Grid.Column="3"
                                         Background="#FFFFFF" Foreground="Black" BorderThickness="1"
                                         BorderBrush="{DynamicResource PanelAccentBrush}" Padding="8,6" FontSize="13"
                                         VerticalContentAlignment="Center"
                                         TextChanged="TxtHapticUrl_TextChanged">
                                    <TextBox.ToolTip>
                                        <ToolTip Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" Padding="12">
                                            <StackPanel MaxWidth="280">
                                                <TextBlock Text="{loc:Str label_connection_guide}" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <TextBlock Text="{loc:Str label_lovense_connect}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Foreground="#CCCCCC" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,6">
                                                    <Run Text="1."/><Run Text="{loc:Str label_open_lovense_remote_app}" Foreground="White"/>
                                                    <LineBreak/><Run Text="2."/><Run Text="{loc:Str label_go_to_settings_game_mode}" Foreground="White"/>
                                                    <LineBreak/><Run Text="3."/><Run Text="{loc:Str label_enable_game_mode_note_the_ip}" Foreground="White"/>
                                                    <LineBreak/><Run Text="4."/><Run Text="{loc:Str label_enter_http_ip_30010}" Foreground="{DynamicResource PinkBrush}"/>
                                                </TextBlock>
                                                <TextBlock Text="{loc:Str label_buttplug_io_intiface}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Foreground="#CCCCCC" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0">
                                                    <Run Text="1."/><Run Text="{loc:Str label_open_intiface_central}" Foreground="White"/>
                                                    <LineBreak/><Run Text="2."/><Run Text="{loc:Str label_click_start_server}" Foreground="White"/>
                                                    <LineBreak/><Run Text="3."/><Run Text="{loc:Str label_click_start_scanning_for_devices}" Foreground="White"/>
                                                    <LineBreak/><Run Text="4."/><Run Text="{loc:Str label_use_ws_localhost_12345}" Foreground="{DynamicResource PinkBrush}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>
                                <Button x:Name="BtnHapticConnect" x:FieldModifier="internal" Grid.Column="5" Content="{loc:Str btn_connect}"
                                        Background="{DynamicResource PinkBrush}" Foreground="White"
                                        BorderThickness="0" Padding="18,8"
                                        FontSize="13" FontWeight="Bold" Cursor="Hand"
                                        Click="BtnHapticConnect_Click"/>
                            </Grid>
    
                            <!-- URL hint + auto-connect (single row) -->
                            <Grid Margin="0,0,0,14">
                                <TextBlock x:Name="TxtHapticUrlHint" x:FieldModifier="internal"
                                           Text="{loc:Str label_lovense_enter_ip_from_lovense_remote_settings}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <CheckBox x:Name="ChkHapticAutoConnect" x:FieldModifier="internal" Content="{loc:Str setting_auto_connect_on_startup}"
                                          Foreground="#CCCCCC" FontSize="12" HorizontalAlignment="Right"
                                          Checked="ChkHapticAutoConnect_Changed" Unchecked="ChkHapticAutoConnect_Changed"
                                          ToolTip="{loc:Str tooltip_automatically_connect_to_your_haptic_device_w}"/>
                            </Grid>
    
                            <!-- Status + Master Intensity + Test (in inset card) -->
                            <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="16,12">
                                <StackPanel>
                                    <!-- Status row -->
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center" Fill="#FF6B6B"/>
                                            <TextBlock Text="{loc:Str label_status}" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtHapticStatus" x:FieldModifier="internal" Text="{loc:Str label_disconnected}"
                                                       Foreground="#FF6B6B" FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtHapticDevices" x:FieldModifier="internal" Text="{loc:Str label_no_devices}"
                                                   Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Intensity slider + test -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{loc:Str label_intensity}" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Slider x:Name="SliderHapticIntensity" x:FieldModifier="internal" Grid.Column="1"
                                                Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="70" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticIntensity_ValueChanged"/>
                                        <TextBlock x:Name="TxtHapticIntensity" x:FieldModifier="internal" Grid.Column="2" Text="70%"
                                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Button x:Name="BtnHapticTest" Grid.Column="3" Content="{loc:Str btn_test_vibration}"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                                Padding="14,8" Margin="12,0,0,0"
                                                FontSize="13" FontWeight="Bold" Cursor="Hand"
                                                Click="BtnHapticTest_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
    
                            <!-- Help link -->
                            <Button x:Name="BtnHapticsHelp" Content="{loc:Str btn_need_help_setting_up}"
                                    HorizontalAlignment="Left" Margin="0,10,0,0" Background="Transparent"
                                    Foreground="{DynamicResource PinkBrush}" BorderThickness="0" FontSize="12"
                                    Cursor="Hand" Click="BtnHapticsHelp_Click" Padding="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               FontSize="{TemplateBinding FontSize}"
                                                               TextDecorations="Underline"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                    <!-- Lock Overlay (legacy, hidden — gating handled by HapticsGate) -->
                    <Border x:Name="HapticsConnectionLock" x:FieldModifier="internal" Background="#80000000" CornerRadius="10" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Width="36" Height="36" HorizontalAlignment="Center" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                            <TextBlock Text="{loc:Str label_patreon_only_2}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
    
                <!-- ============ SECTION 2: PER-FEATURE INTENSITY ============ -->
                <Grid Grid.Row="2">
                    <Border x:Name="HapticsFeatureBox" x:FieldModifier="internal" CornerRadius="10" Padding="22,18"
                            Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48" BorderThickness="1">
                        <StackPanel>
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Image Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Source="{Binding Source='✨', Converter={StaticResource EmojiToImageSource}}"/>
                                <TextBlock Text="{loc:Str section_feature_intensity}" Foreground="{DynamicResource PinkBrush}"
                                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{loc:Str label_adjust_vibration_strength_per_feature}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,14"/>
    
                            <!-- 2-column feature grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
    
                                <!-- LEFT COLUMN: 5 features -->
                                <StackPanel Grid.Column="0">
    
                                    <!-- Bubble Pop -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticBubble" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="Bubble"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str label_bubbles}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticBubble" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="Bubble"/>
                                        <TextBlock x:Name="TxtHapticBubble" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticBubbleMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="0" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="Bubble">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Flash Display -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticFlashDisplay" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="FlashDisplay"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str label_flash_show}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticFlashDisplay" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="FlashDisplay"/>
                                        <TextBlock x:Name="TxtHapticFlashDisplay" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticFlashDisplayMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="0" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="FlashDisplay">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Flash Click -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticFlashClick" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="FlashClick"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str label_flash_click}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticFlashClick" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="FlashClick"/>
                                        <TextBlock x:Name="TxtHapticFlashClick" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticFlashClickMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="0" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="FlashClick">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Video -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticVideo" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="Video"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str tab_videos}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticVideo" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="Video"/>
                                        <TextBlock x:Name="TxtHapticVideo" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticVideoMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="0" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="Video">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Target Hit (video attention targets) -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticTargetHit" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="TargetHit"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str label_target_hit}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticTargetHit" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="70" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="TargetHit"/>
                                        <TextBlock x:Name="TxtHapticTargetHit" x:FieldModifier="internal" Grid.Column="3" Text="70%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticTargetHitMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="1" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="TargetHit">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                </StackPanel>
    
                                <!-- RIGHT COLUMN: 4 features -->
                                <StackPanel Grid.Column="2">
    
                                    <!-- Subliminal -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticSubliminal" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="Subliminal"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str tab_subliminals}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticSubliminal" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="Subliminal"/>
                                        <TextBlock x:Name="TxtHapticSubliminal" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticSubliminalMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="1" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="Subliminal">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Level Up -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticLevelUp" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="LevelUp"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str label_level_up}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticLevelUp" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="LevelUp"/>
                                        <TextBlock x:Name="TxtHapticLevelUp" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticLevelUpMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="4" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="LevelUp">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Achievement -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticAchievement" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="Achievement"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str tab_achievements}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticAchievement" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="Achievement"/>
                                        <TextBlock x:Name="TxtHapticAchievement" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticAchievementMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="3" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="Achievement">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                    <!-- Bouncing Text -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="92"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="ChkHapticBouncingText" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                  VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="BouncingText"/>
                                        <TextBlock Grid.Column="1" Text="{loc:Str label_bounce_text}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <Slider x:Name="SliderHapticBouncingText" x:FieldModifier="internal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                ValueChanged="SliderHapticFeature_Changed" Tag="BouncingText"/>
                                        <TextBlock x:Name="TxtHapticBouncingText" x:FieldModifier="internal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <ComboBox x:Name="CmbHapticBouncingTextMode" x:FieldModifier="internal" Grid.Column="4" SelectedIndex="1" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                  SelectionChanged="CmbHapticMode_SelectionChanged" Tag="BouncingText">
                                            <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                            <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                        </ComboBox>
                                    </Grid>
    
                                </StackPanel>
                            </Grid>
    
                    <!-- Video Haptic Sync - Enhanced Featured Card -->
                    <Border x:Name="VideoHapticSyncCard" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1,2,1,1"
                            CornerRadius="8" Margin="0,12,0,0" Background="{DynamicResource SurfaceBgBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
    
                            <!-- Row 0: Header Section -->
                            <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="8,8,0,0" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
    
                                    <!-- Title and Description -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"
                                                   Source="{Binding Source='🎵', Converter={StaticResource EmojiToImageSource}}"/>
                                            <TextBlock Text="{loc:Str label_video_haptic_sync}" Foreground="{DynamicResource SecondaryBrush}"
                                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{loc:Str label_syncs_haptics_to_video_audio_in_real_time}"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
    
                                    <!-- Help Button -->
                                    <Button x:Name="HelpBtnVideoHapticSync" x:FieldModifier="internal" Grid.Column="1"
                                            Style="{StaticResource HelpButtonStyle}" Tag="VideoHapticSync"
                                            Margin="0,0,10,0"/>
    
                                    <!-- Master Enable Toggle -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <TextBlock Text="{loc:Str btn_enable}" Foreground="#AAAAAA" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <CheckBox x:Name="ChkHapticAudioSync" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                  IsChecked="False"
                                                  Checked="ChkHapticAudioSync_Changed"
                                                  Unchecked="ChkHapticAudioSync_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- Row 1: Algorithm Cards (left) + Image (right) -->
                            <Grid Grid.Row="1" Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
    
                                <!-- Left: Algorithm Selection Cards (stacked vertically) -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Str label_sync_algorithm}" Foreground="#AAAAAA" FontSize="10" Margin="0,0,0,5"/>
    
                                    <!-- Algorithm 1: Audio Reactive (Enabled) -->
                                    <Border x:Name="AlgorithmCardAudioReactive"
                                            Background="{DynamicResource PanelBgBrush}" CornerRadius="4" Padding="8,5" Cursor="Hand"
                                            BorderThickness="2" BorderBrush="{DynamicResource SecondaryBrush}" Margin="0,0,0,3"
                                            MouseLeftButtonDown="AlgorithmCard_Click" Tag="AudioReactive">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A2A4E"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{loc:Str label_audio_reactive}" Foreground="White"
                                                       FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Ellipse x:Name="AlgorithmIndicatorAudioReactive" Grid.Column="1"
                                                     Width="6" Height="6" Fill="{DynamicResource SecondaryBrush}"
                                                     VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
    
                                    <!-- Algorithm 2: Beat Detection (Coming Soon) -->
                                    <Grid Margin="0,0,0,3">
                                        <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="8,5">
                                            <Border.Effect>
                                                <BlurEffect Radius="2"/>
                                            </Border.Effect>
                                            <TextBlock Text="{loc:Str label_beat_detection}" Foreground="#666666"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#CC1A1A2E" CornerRadius="4">
                                            <TextBlock Text="{loc:Str label_coming_soon}" Foreground="{DynamicResource SecondaryBrush}" FontSize="8"
                                                       FontWeight="Bold" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
    
                                    <!-- Algorithm 3: AI Enhanced (Coming Soon) -->
                                    <Grid>
                                        <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="8,5">
                                            <Border.Effect>
                                                <BlurEffect Radius="2"/>
                                            </Border.Effect>
                                            <TextBlock Text="{loc:Str label_ai_enhanced}" Foreground="#666666"
                                                       FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#CC1A1A2E" CornerRadius="4">
                                            <TextBlock Text="{loc:Str label_coming_soon}" Foreground="{DynamicResource SecondaryBrush}" FontSize="8"
                                                       FontWeight="Bold" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
    
                                <!-- Right: Square Image -->
                                <Border Grid.Column="2" CornerRadius="6" ClipToBounds="True"
                                        BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1"
                                        Width="130" Height="130">
                                    <Image x:Name="ImgVideoHapticSync" x:FieldModifier="internal"
                                           Source="pack://application:,,,/Resources/features/vibe.png"
                                           Stretch="UniformToFill"/>
                                </Border>
                            </Grid>
    
                            <!-- Row 3: Delay and Power Sliders -->
                            <Border x:Name="VideoHapticSyncSliders" x:FieldModifier="internal" Grid.Row="3" Padding="12,8,12,12"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
    
                                    <!-- Delay Slider -->
                                    <StackPanel Grid.Column="0">
                                        <Grid>
                                            <TextBlock Text="{loc:Str label_delay_2}" Foreground="#AAAAAA" FontSize="10"/>
                                            <TextBlock x:Name="TxtVideoHapticDelay" x:FieldModifier="internal" Text="{loc:Str label_0ms}"
                                                       Foreground="{DynamicResource SecondaryBrush}" FontSize="10"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Slider x:Name="SliderVideoHapticDelay" x:FieldModifier="internal" Minimum="-600" Maximum="600"
                                                Value="0" Margin="0,4,0,0"
                                                ValueChanged="SliderVideoHapticDelay_Changed"
                                                ToolTip="{loc:Str tooltip_adjust_haptic_timing_positive_earlier_negativ}"/>
                                    </StackPanel>
    
                                    <!-- Power Slider -->
                                    <StackPanel Grid.Column="2">
                                        <Grid>
                                            <TextBlock Text="{loc:Str label_power_2}" Foreground="#AAAAAA" FontSize="10"/>
                                            <TextBlock x:Name="TxtVideoHapticPower" x:FieldModifier="internal" Text="100%"
                                                       Foreground="{DynamicResource SecondaryBrush}" FontSize="10"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Slider x:Name="SliderVideoHapticPower" x:FieldModifier="internal" Minimum="0" Maximum="100"
                                                Value="100" Margin="0,4,0,0"
                                                ValueChanged="SliderVideoHapticPower_Changed"
                                                ToolTip="{loc:Str tooltip_live_intensity_control_reduce_if_vibration_is}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
            <!-- Lock Overlay for Right Box -->
            <Border x:Name="HapticsFeatureLock" x:FieldModifier="internal" Background="#80000000" CornerRadius="8" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Width="36" Height="36" HorizontalAlignment="Center" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                    <TextBlock Text="{loc:Str label_patreon_only_2}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    
        <!-- Patreon Only Overlay (hidden for Patreon supporters) -->
        <Border x:Name="HapticsComingSoonOverlay" x:FieldModifier="internal" Background="#CC1A1A2E" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{loc:Str label_patreon_only_2}" Foreground="{DynamicResource PinkBrush}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="{loc:Str label_unlock_haptic_feedback_by_supporting_on_patre}"
                           Foreground="#AAAAAA" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="{loc:Str label_lovense_buttplug_io_support}"
                           Foreground="{DynamicResource SecondaryBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
            </Grid>
    
                    <!-- Translucent gating overlay (only for free users) -->
                    <Border x:Name="HapticsGate" x:FieldModifier="internal" Visibility="Collapsed"
                            Background="#99000010" BorderBrush="#FF69B4" BorderThickness="2"
                            CornerRadius="10" IsHitTestVisible="True">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Width="52" Height="52" HorizontalAlignment="Center" Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                            <TextBlock Text="{loc:Str gate_premium_locked}" FontSize="22"
                                       FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Str gate_premium_subtitle}" FontSize="14"
                                       Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                            <Button Click="BtnGateUnlock_Click" Padding="20,8" Background="#FF69B4"
                                    Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0">
                                <helpers:EmojiTextBlock Text="{loc:Str gate_unlock_with_patreon}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
    
            </StackPanel>
        </ScrollViewer>
</UserControl>

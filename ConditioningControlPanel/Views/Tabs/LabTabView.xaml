<UserControl x:Class="ConditioningControlPanel.Views.Tabs.LabTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             xmlns:local="clr-namespace:ConditioningControlPanel"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <Grid>
        <Grid.Resources>
            <!-- Lab redesign (mod-aware): all colour via DynamicResource theme keys so the
                 whole tab recolours per active mod (drone→green, Bambi→pink, …). -->
            <Style x:Key="LabCard" TargetType="Border">
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource PanelAccentBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="22"/>
                <Setter Property="Margin" Value="9"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource PanelAccentHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="LabZoneTag" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource PinkBrush}"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="LabCardTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Header -->
                <TextBlock Text="{loc:Str label_the_lab}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,4">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00FF88" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="{loc:Str label_experimental_features_and_special_modes}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,0,0,16"/>
    
                <!-- ===================== HERO: CHAOS MODE ===================== -->
                <Border CornerRadius="16" BorderThickness="1" BorderBrush="{DynamicResource PanelAccentBrush}"
                        Margin="9,0,9,18" ClipToBounds="True" MinHeight="150">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2A123A" Offset="0"/>
                            <GradientStop Color="#FF14122A" Offset="0.55"/>
                            <GradientStop Color="#FF3A1030" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="24,20,24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- left: title + blurb -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="🐇 DOWN THE RABBIT HOLE" Foreground="White" FontSize="24" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FFFF69B4" BlurRadius="22" ShadowDepth="0" Opacity="0.7"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <Border Background="{DynamicResource TransparentPink20Brush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="7,2" Margin="12,2,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="NEW" Foreground="{DynamicResource PinkBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="it's right there. it's always been right there. bubbles drift up carrying flashes, videos, overlays. snap them in time or let them trigger you. stack streaks, accept mantras, sink deeper."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" MaxWidth="520" HorizontalAlignment="Left"/>
                        </StackPanel>
    
                        <!-- right: launch -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                            <!-- Play-mode pick: retired from the Lab card now that the in-game main
                                 menu owns mode selection (FALL IN = Free Desktop; Story is greyed there
                                 until it ships). Kept collapsed — flip back to Visible to restore the
                                 radios here. Story is still disabled via ChaosModeService.StoryModeEnabled. -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8" Visibility="Collapsed">
                                <RadioButton x:Name="RbChaosFreeDesktop" GroupName="ChaosPlayMode" Content="🖥 Free Desktop"
                                             Checked="ChaosPlayMode_Changed" Cursor="Hand"
                                             Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,14,0"
                                             ToolTip="Play over your real desktop — your companion floats along."/>
                                <RadioButton x:Name="RbChaosStory" GroupName="ChaosPlayMode" Content="▶ Story"
                                             Checked="ChaosPlayMode_Changed" Cursor="Hand"
                                             Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                                             ToolTip="The Madam's narrated descent — coming soon."/>
                                <!-- Hidden in code-behind once ChaosModeService.StoryModeEnabled flips true. -->
                                <Border x:Name="ChaosStorySoonBadge" Background="{DynamicResource TransparentPink20Brush}"
                                        BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" CornerRadius="5"
                                        Padding="5,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="COMING SOON" Foreground="{DynamicResource PinkBrush}"
                                               FontFamily="Consolas" FontWeight="Bold" FontSize="9"/>
                                </Border>
                            </StackPanel>
                            <Button x:Name="BtnStartChaos" Content="▶ FALL IN" Cursor="Hand" ToolTip="you were always going to."
                                    Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="16"
                                    BorderThickness="0" Padding="30,14" HorizontalAlignment="Right"
                                    Click="BtnStartChaos_Click">
                                <Button.Effect>
                                    <DropShadowEffect Color="#FFFF69B4" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                </Button.Effect>
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="14"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnQuickStartChaos" Content="💧 Quick Drop" Cursor="Hand"
                                    Background="Transparent" Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold" FontSize="12"
                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" Padding="14,6" Margin="0,8,0,0"
                                    HorizontalAlignment="Right" ToolTip="skip the dollhouse. fall straight in with your saved settings"
                                    Click="BtnQuickStartChaos_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="9"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <CheckBox Content="Announcements"
                                      IsChecked="{Binding Source={x:Static local:App.Settings}, Path=Current.ChaosAnnouncerEnabled, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Cursor="Hand"
                                      HorizontalAlignment="Right" Margin="0,10,0,0"
                                      ToolTip="Flash on-screen subtitle announcements (mantra, resistance, depth, streak) during a descent"/>
                        </StackPanel>
                    </Grid>
                </Border>
    
                <!-- HOW TO PLAY moved to the Rabbit Hole main menu (📖 HOW TO PLAY button → card tutorial overlay). -->

                <!-- ===================== ZONE: MIND ===================== -->
                <Grid Margin="2,4,2,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="MIND" Style="{StaticResource LabZoneTag}" Margin="0,0,14,0"/>
                    <Border Grid.Column="1" Height="1" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource PanelAccentHover}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
    
                <UniformGrid Rows="1" Columns="2">
                    <!-- Quiz Training Card -->
                    <Border Style="{StaticResource LabCard}">
                        <StackPanel>
                            <!-- hero header -->
                            <Border CornerRadius="16,16,0,0" Height="138" Margin="-22,-22,-22,16" ClipToBounds="True">
                                <Grid>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <ImageBrush x:Name="LabQuizHeroBrush" x:FieldModifier="internal" ImageSource="pack://application:,,,/Resources/features/lab_quiz_hero.png" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                <GradientStop Color="{DynamicResource SurfaceBg}" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="0.9"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="10" Margin="0,0,11,0"
                                            Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                                        <Image Width="18" Height="18" Source="{Binding Source='❓', Converter={StaticResource EmojiToImageSource}}"/>
                                    </Border>
                                    <TextBlock Text="{loc:Str label_quiz_training}" Style="{StaticResource LabCardTitle}"/>
                                    <Border Background="{DynamicResource TransparentPink20Brush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="6,2" Margin="9,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str label_beta_2}" Foreground="{DynamicResource PinkBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="9.5"/>
                                    </Border>
                                </StackPanel>
                                <Button x:Name="HelpBtnQuiz" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Quiz"/>
                            </Grid>
                            <TextBlock Text="{loc:Str label_ai_generated_personality_quiz_10_questions_th}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
    
                            <CheckBox x:Name="ChkQuizFullscreen" x:FieldModifier="internal" Content="{loc:Str btn_fullscreen}" IsChecked="True"
                                      Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="ChkQuizDrone" x:FieldModifier="internal" Content="{loc:Str setting_play_drone_in_background}" IsChecked="False"
                                      Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,10"/>
    
                            <Button x:Name="BtnStartQuiz" Content="{loc:Str btn_start_quiz}" Cursor="Hand"
                                    Background="{DynamicResource SecondaryBrush}" Foreground="White" FontWeight="Bold" FontSize="12"
                                    BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                    Click="BtnStartQuiz_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
    
                            <!-- Pop Quiz sub-section (folded in from former standalone Lab card) -->
                            <Border Height="1" Background="#33FF69B4" Margin="0,12,0,8"/>
    
                            <TextBlock Text="{loc:Str label_pop_quiz}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,2"/>
                            <TextBlock Text="{loc:Str label_reinforcement_questions_pop_up_during_session}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
    
                            <CheckBox x:Name="ChkPopQuizEnabled" x:FieldModifier="internal" Content="{loc:Str setting_enable_pop_up_questions}"
                                      Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"
                                      Checked="ChkPopQuizEnabled_Changed" Unchecked="ChkPopQuizEnabled_Changed"/>
    
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{loc:Str label_frequency}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider x:Name="SliderPopQuizFrequency" x:FieldModifier="internal" Minimum="1" Maximum="100" Width="120"
                                        VerticalAlignment="Center"
                                        ValueChanged="SliderPopQuizFrequency_ValueChanged"/>
                                <TextBlock x:Name="TxtPopQuizFrequency" x:FieldModifier="internal" Foreground="#B0B0C8" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0" Text="{loc:Str label_2_session_hr}"/>
                            </StackPanel>
    
                            <Button x:Name="BtnTestPopQuiz" Content="{loc:Str btn_test}" Cursor="Hand"
                                    Background="{DynamicResource SecondaryBrush}" Foreground="White" FontWeight="Bold" FontSize="12"
                                    BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                    Click="BtnTestPopQuiz_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
    
                            <TextBlock Text="{loc:Str label_past_quizzes}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,10,0,4"
                                       x:Name="TxtPastQuizzesHeader" x:FieldModifier="internal" Visibility="Collapsed"/>
                            <Border MaxHeight="130" CornerRadius="6" x:Name="PastQuizzesPanel" x:FieldModifier="internal" Visibility="Collapsed"
                                    Background="#10FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PastQuizzesList" x:FieldModifier="internal"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
    
                    <!-- AI Companion Effects & Memory -->
                    <Border Style="{StaticResource LabCard}">
                        <StackPanel>
                            <!-- hero header -->
                            <Border CornerRadius="16,16,0,0" Height="138" Margin="-22,-22,-22,16" ClipToBounds="True">
                                <Grid>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <ImageBrush x:Name="LabAiMemoryHeroBrush" x:FieldModifier="internal" ImageSource="pack://application:,,,/Resources/features/lab_aimemory_hero.png" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                <GradientStop Color="{DynamicResource SurfaceBg}" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="0.9"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <Grid Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="10" Margin="0,0,11,0"
                                            Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                                        <Image Width="18" Height="18" Source="{Binding Source='🧠', Converter={StaticResource EmojiToImageSource}}"/>
                                    </Border>
                                    <TextBlock Text="{loc:Str lab_ai_effects_memory_title}" Style="{StaticResource LabCardTitle}"/>
                                    <Border Background="{DynamicResource TransparentPink20Brush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="6,2" Margin="9,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str label_beta_2}" Foreground="{DynamicResource PinkBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="9.5"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{loc:Str lab_ai_effects_memory_subtitle}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
    
                            <!-- Notice + setup button — only shown when the user is NOT on local AI.
                                 Cloud AI can't drive effects (proxy token cap), so the controls below
                                 do nothing without a local Ollama. The button switches to the
                                 Companion tab and launches the setup wizard. -->
                            <Border x:Name="LabEffectsNeedsLocalNotice" x:FieldModifier="internal" Visibility="Collapsed"
                                    Background="#221A38" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str lab_ai_effects_needs_local_title}"
                                                   Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{loc:Str lab_ai_effects_needs_local_body}"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" x:Name="BtnLabEffectsSetupLocal"
                                            Content="{loc:Str btn_lab_effects_setup_local}"
                                            Click="BtnLabEffectsSetupLocal_Click"
                                            Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="12"
                                            BorderThickness="0" Padding="12,6" Margin="12,0,0,0" Cursor="Hand"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
    
                            <!-- Master toggle -->
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Str label_capability_effects}" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource HelpButtonStyle}" ToolTip="{loc:Str tooltip_lab_ai_effects}"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkCapEffects" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          IsChecked="False"
                                          Checked="ChkCapEffects_Changed" Unchecked="ChkCapEffects_Changed"/>
                            </Grid>
    
                            <!-- Effect permissions panel -->
                            <Border x:Name="EffectPermsPanel" x:FieldModifier="internal" Visibility="Collapsed" CornerRadius="8" Padding="10" Margin="0,0,0,12"
                                    Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#FF6B6B" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str label_effect_permissions}" Foreground="#FF6B6B" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="{loc:Str label_max_haptic_intensity}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtMaxHapticIntensity" x:FieldModifier="internal" Text="60%" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="SliderMaxHapticIntensity" x:FieldModifier="internal" Style="{StaticResource PinkSlider}"
                                            Minimum="0" Maximum="1" Value="0.6" Margin="0,0,0,10"
                                            ValueChanged="SliderMaxHapticIntensity_ValueChanged"/>
                                    <UniformGrid Columns="2" Rows="5">
                                        <CheckBox x:Name="ChkAllowFlash" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_flash}" Foreground="White" FontSize="13" Margin="0,2,4,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Flash"/>
                                        <CheckBox x:Name="ChkAllowVideo" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_video}" Foreground="White" FontSize="13" Margin="4,2,0,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Video"/>
                                        <CheckBox x:Name="ChkAllowAudio" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_audio}" Foreground="White" FontSize="13" Margin="0,2,4,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Audio"/>
                                        <CheckBox x:Name="ChkAllowBubbles" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_bubbles}" Foreground="White" FontSize="13" Margin="4,2,0,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Bubbles"/>
                                        <CheckBox x:Name="ChkAllowSubliminal" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_subliminal}" Foreground="White" FontSize="13" Margin="0,2,4,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Subliminal"/>
                                        <CheckBox x:Name="ChkAllowOverlay" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_overlay}" Foreground="White" FontSize="13" Margin="4,2,0,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Overlay"/>
                                        <CheckBox x:Name="ChkAllowLockCard" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_lockcard}" Foreground="White" FontSize="13" Margin="0,2,4,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="LockCard"/>
                                        <CheckBox x:Name="ChkAllowBounce" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_bounce}" Foreground="White" FontSize="13" Margin="4,2,0,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Bounce"/>
                                        <CheckBox x:Name="ChkAllowHaptic" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_haptic}" Foreground="White" FontSize="13" Margin="0,2,4,2" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="Haptic"/>
                                        <StackPanel Orientation="Horizontal" Margin="4,2,0,2">
                                            <CheckBox x:Name="ChkAllowGetBackToMe" x:FieldModifier="internal" Style="{StaticResource DotCheckBoxStyle}" Content="{loc:Str label_allow_get_back_to_me}" Foreground="White" FontSize="13" Checked="ChkAllowEffect_Changed" Unchecked="ChkAllowEffect_Changed" Tag="GetBackToMe"/>
                                            <Button x:Name="HelpBtnGetBackToMe" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="GetBackToMe"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
    
                            <!-- Memory section -->
                            <Border CornerRadius="8" Padding="10"
                                    Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#9370DB" BorderThickness="1">
                                <StackPanel>
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="{loc:Str label_chat_memory_title}" Foreground="#9370DB" FontSize="13" FontWeight="SemiBold"/>
                                                <Button Style="{StaticResource HelpButtonStyle}" ToolTip="{loc:Str tooltip_lab_ai_memory}"/>
                                            </StackPanel>
                                            <TextBlock Text="{loc:Str label_chat_memory_hint}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkChatMemoryEnabled" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  IsChecked="True"
                                                  Checked="ChkChatMemoryEnabled_Changed" Unchecked="ChkChatMemoryEnabled_Changed"/>
                                    </Grid>
                                    <Button x:Name="BtnClearChatMemory" Content="{loc:Str btn_forget_everything}" HorizontalAlignment="Right" Margin="0,8,0,0"
                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="#FF6B6B" BorderBrush="#FF6B6B" BorderThickness="1"
                                            Padding="10,4" FontSize="13" Cursor="Hand" Click="BtnClearChatMemory_Click"
                                            ToolTip="{loc:Str tooltip_forget_everything}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
    
                </UniformGrid>
    
                <!-- ===================== ZONE: EYES ===================== -->
                <Grid Margin="2,18,2,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="EYES" Style="{StaticResource LabZoneTag}" Margin="0,0,14,0"/>
                    <Border Grid.Column="1" Height="1" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{DynamicResource PanelAccentHover}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Blink Trainer relocation chip (kept clickable → opens it in Exclusives) -->
                    <Button Grid.Column="2" x:Name="BtnLabBlinkTrainerOpenNew"
                            ToolTip="{loc:Str blink_trainer_lab_stub_body}"
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                            Click="BtnLabBlinkTrainerOpenNew_Click">
                        <Border Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="11,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Str blink_trainer_lab_stub_moved}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                <TextBlock Text=" ↗" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </Grid>
    
                <!-- Engine bar — slim webcam tracking controls (reproportioned from the old card).
                     Named so VelvetBtnWebcam can borrow it into a popup (reparent on open,
                     restore on close — same instance, all handlers stay valid). -->
                <Border x:Name="LabWebcamEngineBar" x:FieldModifier="internal" CornerRadius="16" Margin="9,4,9,12" Padding="16,14"
                        Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource PanelAccentHoverBrush}" BorderThickness="1">
                    <StackPanel>
                        <WrapPanel Orientation="Horizontal">
                            <!-- label -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,18,4">
                                <Border Width="38" Height="38" CornerRadius="11" Margin="0,0,11,0"
                                        Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                                    <Image Width="20" Height="20" Source="{Binding Source='👁', Converter={StaticResource EmojiToImageSource}}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Webcam tracking" Foreground="{DynamicResource TextLightBrush}" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="local · on-device" Foreground="{DynamicResource TextMutedBrush}" FontFamily="Consolas" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- 6-blink → stop & recalibrate shortcut toggle -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,18,4"
                                        ToolTip="Blink fast 6 times in a row to stop everything and jump to recalibration.">
                                <CheckBox x:Name="ChkBlinkRecalWebcamBar" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                                          Checked="ChkBlinkRecalShortcut_Changed" Unchecked="ChkBlinkRecalShortcut_Changed"/>
                                <TextBlock Text="Blink to recalibrate" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="7,0,0,0"/>
                            </StackPanel>
                            <!-- camera -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,12,4">
                                <TextBlock Text="CAM" Foreground="{DynamicResource TextDimBrush}" FontFamily="Consolas" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <ComboBox x:Name="CmbWebcamDevice" x:FieldModifier="internal" Width="150"
                                          Foreground="Black" Background="White"
                                          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" VerticalAlignment="Center"
                                          ToolTip="Pick the capture device to use for blink / gaze tracking. If your physical webcam doesn't show its in-use light, you may have a virtual camera selected (OBS, Snap, etc.) — switch here, then hit Start."
                                          SelectionChanged="CmbWebcamDevice_SelectionChanged"/>
                                <Button x:Name="BtnWebcamDeviceRefresh" Content="↻"
                                        ToolTip="Re-scan connected video-capture devices."
                                        Padding="9,3" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Background="Transparent" Foreground="{DynamicResource PinkBrush}"
                                        BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                        FontSize="12" FontWeight="Bold" Cursor="Hand"
                                        Click="BtnWebcamDeviceRefresh_Click">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                            <!-- monitor -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,12,4">
                                <TextBlock Text="MON" Foreground="{DynamicResource TextDimBrush}" FontFamily="Consolas" FontSize="10.5" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <ComboBox x:Name="CmbWebcamMonitor" x:FieldModifier="internal" Width="140"
                                          Foreground="Black" Background="White"
                                          BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" VerticalAlignment="Center"
                                          ToolTip="{loc:Str webcam_monitor_tooltip}"
                                          SelectionChanged="CmbWebcamMonitor_SelectionChanged"/>
                            </StackPanel>
                            <!-- status pill -->
                            <Border x:Name="LabTrackerPill" x:FieldModifier="internal" CornerRadius="9" Padding="11,7" Margin="0,4,16,4" VerticalAlignment="Center"
                                    Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="LabTrackerDot" x:FieldModifier="internal" Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtWebcamDebugStatus" x:FieldModifier="internal" Text="Stopped" Foreground="{DynamicResource TextLightBrush}"
                                               FontFamily="Consolas" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <!-- actions -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,4">
                                <Button x:Name="BtnWebcamReviewPrivacy" Content="Privacy info"
                                        ToolTip="{loc:Str tooltip_webcam_review_privacy}"
                                        Padding="10,6" Margin="0,0,6,0" VerticalAlignment="Center"
                                        Background="Transparent" Foreground="{DynamicResource TextMutedBrush}"
                                        BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                                        FontSize="11" Cursor="Hand" Click="BtnWebcamReviewPrivacy_Click">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="BtnWebcamDebugCalibrate" Content="Calibrate"
                                        ToolTip="{loc:Str tooltip_webcam_calibrate}"
                                        Padding="11,6" Margin="0,0,6,0" VerticalAlignment="Center"
                                        Background="Transparent" Foreground="{DynamicResource PinkBrush}"
                                        BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand" Click="BtnWebcamDebugCalibrate_Click">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="BtnWebcamDebugQuickRecal" Content="Quick Recal"
                                        ToolTip="One-dot drift correction. Stare at the pink center dot for ~2 s — a constant nudge is added to the cursor so it lands where you're looking, no full recalibration needed."
                                        Padding="11,6" Margin="0,0,6,0" VerticalAlignment="Center"
                                        Background="Transparent" Foreground="{DynamicResource PinkBrush}"
                                        BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                        FontSize="11" FontWeight="SemiBold" Cursor="Hand" Click="BtnWebcamDebugQuickRecal_Click">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="BtnWebcamDebugStart" x:FieldModifier="internal" Content="Start tracking"
                                        ToolTip="{loc:Str tooltip_webcam_start_tracking}"
                                        Padding="14,7" VerticalAlignment="Center"
                                        Background="{DynamicResource SuccessGreenBrush}" Foreground="Black" BorderThickness="0"
                                        FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnWebcamDebugStart_Click">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="9"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                        </WrapPanel>
    
                        <!-- Advanced / diagnostics (everything from the old card preserved) -->
                        <Expander Header="Advanced" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,12,0,0">
                            <StackPanel Margin="4,8,0,0">
                                <WrapPanel Orientation="Horizontal">
                                    <Button x:Name="BtnWebcamDebugTrackerTest" Content="Tracker Test"
                                            ToolTip="{loc:Str tooltip_webcam_tracker_test}"
                                            Padding="11,6" Margin="0,0,10,8" VerticalAlignment="Center"
                                            Background="Transparent" Foreground="{DynamicResource SecondaryBrush}"
                                            BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1"
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand" Click="BtnWebcamDebugTrackerTest_Click">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <Button x:Name="BtnWebcamRevokeConsent" Content="Revoke consent"
                                            ToolTip="Stops webcam tracking, deletes calibration data, and clears your consent. You'll be re-prompted next time you enable a webcam feature."
                                            Padding="11,6" Margin="0,0,10,8" VerticalAlignment="Center"
                                            Background="Transparent" Foreground="{DynamicResource DangerBrush}"
                                            BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1"
                                            FontSize="11" FontWeight="SemiBold" Cursor="Hand" Click="BtnWebcamRevokeConsent_Click">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                                    </Button>
                                    <CheckBox x:Name="ChkWebcamDebugCursor" x:FieldModifier="internal" Content="Show debug gaze cursor"
                                              ToolTip="{loc:Str tooltip_webcam_show_debug_cursor}"
                                              Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,0,8"
                                              Checked="ChkWebcamDebugCursor_Changed" Unchecked="ChkWebcamDebugCursor_Changed"/>
                                </WrapPanel>
                                <TextBlock x:Name="TxtWebcamDebugCounters" x:FieldModifier="internal"
                                           Text="Face: — | Blinks: 0 | Gaze: —"
                                           Foreground="{DynamicResource SuccessGreenBrush}" FontFamily="Consolas" FontSize="12"
                                           FontWeight="SemiBold" Margin="0,2,0,0"/>
                                <Border Background="{DynamicResource PreviewBgBrush}" CornerRadius="6" Padding="10" Margin="0,8,0,0">
                                    <TextBlock x:Name="TxtWebcamDebugLog" x:FieldModifier="internal" Text="(events will appear here)"
                                               Foreground="{DynamicResource SuccessGreenBrush}" FontFamily="Consolas" FontSize="11"
                                               TextWrapping="Wrap" MinHeight="60"/>
                                </Border>
                                <CheckBox x:Name="ChkRestrictGazeToCalScreen" x:FieldModifier="internal"
                                          Content="Restrict gaze-reactive effects to the calibrated screen"
                                          ToolTip="Advanced: leave on unless you know what you're doing. Affects how gaze-reactive effects map to your monitors."
                                          Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,10,0,0"
                                          Checked="ChkRestrictGazeToCalScreen_Changed"
                                          Unchecked="ChkRestrictGazeToCalScreen_Changed"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>
    
                <!-- Eyes cards (dim when tracker is off — gated in code-behind) -->
                <UniformGrid Rows="1" Columns="2">
                    <!-- Gaze Minigame Card -->
                    <Border x:Name="LabGazeCard" x:FieldModifier="internal" Style="{StaticResource LabCard}">
                        <StackPanel>
                            <!-- hero header -->
                            <Border CornerRadius="16,16,0,0" Height="138" Margin="-22,-22,-22,16" ClipToBounds="True">
                                <Grid>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <ImageBrush x:Name="LabGazeHeroBrush" x:FieldModifier="internal" ImageSource="pack://application:,,,/Resources/features/lab_gaze_hero.png" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                <GradientStop Color="{DynamicResource SurfaceBg}" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="0.9"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="10" Margin="0,0,11,0"
                                            Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                                        <Image Width="18" Height="18" Source="{Binding Source='🎯', Converter={StaticResource EmojiToImageSource}}"/>
                                    </Border>
                                    <TextBlock Text="{loc:Str label_gaze_minigame}" Style="{StaticResource LabCardTitle}"/>
                                    <Border Background="{DynamicResource TransparentPink20Brush}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="6,2" Margin="9,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str label_beta_2}" Foreground="{DynamicResource PinkBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="9.5"/>
                                    </Border>
                                    <Button x:Name="HelpBtnGazeMinigame" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="GazeMinigame" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            ToolTip="Blink fast 6 times in a row to stop everything and jump to recalibration.">
                                    <CheckBox x:Name="ChkBlinkRecalGaze" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                                              Checked="ChkBlinkRecalShortcut_Changed" Unchecked="ChkBlinkRecalShortcut_Changed"/>
                                    <TextBlock Text="Blink to recal" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{loc:Str label_gaze_minigame_description}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,14"/>
                            <Button x:Name="BtnGazeMinigame" Content="{loc:Str btn_open}"
                                    ToolTip="{loc:Str tooltip_gaze_minigame_open}"
                                    HorizontalAlignment="Left"
                                    Padding="16,8" Background="{DynamicResource AccentGradientBrush}" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold" FontSize="13" Cursor="Hand"
                                    Click="BtnGazeMinigame_Click">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                                </Button.Resources>
                            </Button>
                            <Border x:Name="LabGazeNeedsTracker" x:FieldModifier="internal" Visibility="Collapsed"
                                    Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="10,7" Margin="0,12,0,0" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Start tracking to play" Foreground="{DynamicResource TextMutedBrush}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
    
                    <!-- Focus Gaze Card -->
                    <Border x:Name="LabFocusCard" x:FieldModifier="internal" Style="{StaticResource LabCard}">
                        <StackPanel>
                            <!-- hero header -->
                            <Border CornerRadius="16,16,0,0" Height="138" Margin="-22,-22,-22,16" ClipToBounds="True">
                                <Grid>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <ImageBrush x:Name="LabFocusHeroBrush" x:FieldModifier="internal" ImageSource="pack://application:,,,/Resources/features/lab_focusgaze_hero.png" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border CornerRadius="16,16,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                                <GradientStop Color="{DynamicResource SurfaceBg}" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="0.9"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="10" Margin="0,0,11,0"
                                            Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                                        <Image Width="18" Height="18" Source="{Binding Source='✨', Converter={StaticResource EmojiToImageSource}}"/>
                                    </Border>
                                    <TextBlock Text="{loc:Str label_focus_gaze}" Style="{StaticResource LabCardTitle}"/>
                                    <Button x:Name="HelpBtnFocusGaze" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="FocusGaze" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                            ToolTip="Blink fast 6 times in a row to stop everything and jump to recalibration.">
                                    <CheckBox x:Name="ChkBlinkRecalFocus" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                                              Checked="ChkBlinkRecalShortcut_Changed" Unchecked="ChkBlinkRecalShortcut_Changed"/>
                                    <TextBlock Text="Blink to recal" Foreground="{DynamicResource TextMutedBrush}" FontSize="10.5" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{loc:Str label_focus_gaze_description}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Enable" Foreground="{DynamicResource TextLightBrush}" FontSize="14" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1" x:Name="ChkFocusGaze" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}"
                                          ToolTip="{loc:Str tooltip_focus_gaze_toggle}"
                                          VerticalAlignment="Center"
                                          Checked="ChkFocusGaze_Changed" Unchecked="ChkFocusGaze_Changed"/>
                            </Grid>
                            <TextBlock x:Name="TxtFocusGazeStatus" x:FieldModifier="internal" Text=""
                                       Foreground="{DynamicResource SuccessGreenBrush}" FontSize="11" Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                            <Border x:Name="LabFocusNeedsTracker" x:FieldModifier="internal" Visibility="Collapsed"
                                    Background="{DynamicResource AccentTintedBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="10,7" Margin="0,12,0,0" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="{DynamicResource TextMutedBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Start tracking to enable" Foreground="{DynamicResource TextMutedBrush}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </UniformGrid>
    
                <!-- Wallpaper Override Card (hidden until feature is ready — kept Collapsed so handlers can reference its controls) -->
                <Border CornerRadius="12" Margin="6" Padding="15" Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A1A32" Offset="0"/>
                            <GradientStop Color="#201A38" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                            <GradientStop Color="{DynamicResource PatreonPurple}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>
                        <Thickness>2</Thickness>
                    </Border.BorderThickness>
                    <StackPanel>
                        <TextBlock Text="{loc:Str label_wallpaper_override}" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                        <TextBlock Text="{loc:Str label_wallpaper_description}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
    
                        <CheckBox x:Name="ChkWallpaperEnabled" x:FieldModifier="internal" Content="{loc:Str setting_enable_wallpaper_override}"
                                  Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"
                                  Checked="ChkWallpaperEnabled_Changed" Unchecked="ChkWallpaperEnabled_Changed"/>
    
                        <TextBlock x:Name="TxtCurrentWallpaper" x:FieldModifier="internal" Foreground="#B0B0C8" FontSize="11"
                                   Margin="0,0,0,8" Visibility="Collapsed"/>
    
                        <Button x:Name="BtnShuffleWallpaper" x:FieldModifier="internal" Content="{loc:Str btn_shuffle_wallpaper}" Cursor="Hand"
                                Background="{DynamicResource SecondaryBrush}" Foreground="White" FontWeight="Bold" FontSize="12"
                                BorderThickness="0" Padding="12,8" HorizontalAlignment="Left" Visibility="Collapsed"
                                Click="BtnShuffleWallpaper_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Border>
    
                <!-- (Webcam Tracking controls relocated into the Eyes engine bar above.) -->
    
            </StackPanel>
        </ScrollViewer>
    
        <!-- Lab Smokescreen Overlay (Patreon T2 / Whitelist gate) -->
        <Border x:Name="LabSmokescreen" x:FieldModifier="internal" Background="#CC1A1A2E" IsHitTestVisible="True" Visibility="Visible">
            <Border Background="#20FFFFFF" CornerRadius="16" Padding="32,28" HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="360" BorderBrush="{DynamicResource TransparentPink50Brush}" BorderThickness="1.5">
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <helpers:EmojiTextBlock Text="{loc:Str label_text_3}" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource TransparentPinkBrush}" CornerRadius="8" Padding="12,4" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="{loc:Str label_beta_testing}" Foreground="{DynamicResource PinkBrush}" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <TextBlock Text="{loc:Str label_these_experimental_features_are_currently_bei}"
                               Foreground="#B0B0C8" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" Margin="0,0,0,4"/>
                </StackPanel>
            </Border>
        </Border>
        </Grid>
</UserControl>

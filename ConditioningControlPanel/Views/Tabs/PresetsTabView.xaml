<UserControl x:Class="ConditioningControlPanel.Views.Tabs.PresetsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
        <!-- Main Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="430" MinWidth="300" MaxWidth="700"/>
            </Grid.ColumnDefinitions>
    
            <!-- Left Side: Presets and Sessions -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
    
                <!-- Top Section: Preset Cards Row -->
                <Border Grid.Row="0" Style="{StaticResource SectionPanel}" Margin="5,5,5,0" Padding="10">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <helpers:EmojiTextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_presets}" Margin="0"/>
                            <Button x:Name="HelpBtnPresets" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Presets"/>
                        </Grid>
                        
                        <!-- Horizontal Scrolling Preset Cards -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="PacksScrollViewer_PreviewMouseWheel">
                            <StackPanel Orientation="Horizontal">
                                <!-- Preset Cards Container -->
                                <StackPanel x:Name="PresetCardsPanel" x:FieldModifier="internal" Orientation="Horizontal">
                                    <!-- Preset cards will be generated here dynamically -->
                            </StackPanel>
                            
                            <!-- Fixed "New Preset" Card -->
                            <Border Background="#2A2A4A" CornerRadius="6" Padding="8" Margin="4,0,0,0" 
                                    Width="100" Height="70" Cursor="Hand"
                                    MouseLeftButtonUp="BtnNewPreset_Click"
                                    ToolTip="{loc:Str tooltip_create_a_new_preset_from_current_settings}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelAccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                                <Setter Property="Background" Value="#353550"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="➕" FontSize="20" HorizontalAlignment="Center" Foreground="{DynamicResource PinkBrush}"/>
                                    <TextBlock Text="{loc:Str label_new}" FontSize="10" FontWeight="Bold" 
                                               Foreground="{DynamicResource PinkBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
    
            <!-- Bottom Section: Sessions -->
            <Border Grid.Row="1" Style="{StaticResource SectionPanel}" Margin="5,8,5,5" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="*" MinHeight="120"/>
                    </Grid.RowDefinitions>
    
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <helpers:EmojiTextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_sessions}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnSessionHistory" Click="BtnSessionHistory_Click"
                                    ToolTip="{loc:Str tooltip_recent_sessions}"
                                    Background="Transparent" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                    Foreground="{DynamicResource PinkBrush}"
                                    Padding="8,3" Margin="0,0,6,0" FontSize="12" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <helpers:EmojiTextBlock Text="{loc:Str btn_recent_sessions}" FontWeight="SemiBold"/>
                            </Button>
                            <Button x:Name="HelpBtnSessions" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" Tag="Sessions"/>
                        </StackPanel>
                    </Grid>
    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SessionsPanel">
                            <!-- Morning Drift - Available -->
                            <Border Background="#2A2A4A" CornerRadius="8" Padding="16,14" Margin="0,0,0,8"
                                    Cursor="Hand" x:Name="SessionMorningDrift" MouseLeftButtonUp="SessionCard_Click" Tag="morning_drift">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelAccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <helpers:EmojiTextBlock Text="{loc:Str label_morning_drift}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                            <Border Background="{DynamicResource PinkBrush}" CornerRadius="3" Padding="8,3" Margin="10,0,0,0">
                                                <TextBlock Text="{loc:Str label_30_min}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#2A3A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_easy}" Foreground="#90EE90" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#2A4A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_400_xp}" Foreground="#90EE90" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{loc:Str label_gentle_subliminals_bouncing_text_with_gradual}"
                                                   Foreground="#A0A0A0" FontSize="13" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource SessionActionButton}" Content="✏" ToolTip="{loc:Str tooltip_edit_session}"
                                                Tag="morning_drift" Click="SessionBtn_Edit"/>
                                        <Button Style="{StaticResource SessionActionButton}" Content="📤" ToolTip="{loc:Str tooltip_export_session}"
                                                Tag="morning_drift" Click="SessionBtn_Export"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- Gamer Girl - Available -->
                            <Border Background="#2A2A4A" CornerRadius="8" Padding="16,14" Margin="0,0,0,8"
                                    Cursor="Hand" x:Name="SessionGamerGirl" MouseLeftButtonUp="SessionCard_Click" Tag="gamer_girl">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelAccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <helpers:EmojiTextBlock Text="{loc:Str label_gamer_girl}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                            <Border Background="{DynamicResource PinkBrush}" CornerRadius="3" Padding="8,3" Margin="10,0,0,0">
                                                <TextBlock Text="{loc:Str label_45_min}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#3A3A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_medium}" Foreground="#FFD700" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#3A4A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_800_xp}" Foreground="#FFD700" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{loc:Str label_non_intrusive_conditioning_with_pink_filter_s}"
                                                   Foreground="#A0A0A0" FontSize="13" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource SessionActionButton}" Content="✏" ToolTip="{loc:Str tooltip_edit_session}"
                                                Tag="gamer_girl" Click="SessionBtn_Edit"/>
                                        <Button Style="{StaticResource SessionActionButton}" Content="📤" ToolTip="{loc:Str tooltip_export_session}"
                                                Tag="gamer_girl" Click="SessionBtn_Export"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- The Distant Doll - Available -->
                            <Border Background="#2A2A4A" CornerRadius="8" Padding="16,14" Margin="0,0,0,8"
                                    Cursor="Hand" x:Name="SessionDistantDoll" MouseLeftButtonUp="SessionCard_Click" Tag="distant_doll">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelAccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <helpers:EmojiTextBlock Text="{loc:Str label_the_distant_doll}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                            <Border Background="{DynamicResource PinkBrush}" CornerRadius="3" Padding="8,3" Margin="10,0,0,0">
                                                <TextBlock Text="{loc:Str label_45_min}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#2A3A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_easy}" Foreground="#90EE90" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#2A4A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_400_xp}" Foreground="#90EE90" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{loc:Str label_large_visuals_for_couch_viewing_no_audio_duck}"
                                                   Foreground="#A0A0A0" FontSize="13" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource SessionActionButton}" Content="✏" ToolTip="{loc:Str tooltip_edit_session}"
                                                Tag="distant_doll" Click="SessionBtn_Edit"/>
                                        <Button Style="{StaticResource SessionActionButton}" Content="📤" ToolTip="{loc:Str tooltip_export_session}"
                                                Tag="distant_doll" Click="SessionBtn_Export"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- Good Girls Don't Cum - Available -->
                            <Border Background="#2A2A4A" CornerRadius="8" Padding="16,14" Margin="0,0,0,8"
                                    Cursor="Hand" x:Name="SessionGoodGirls" MouseLeftButtonUp="SessionCard_Click" Tag="good_girls_dont_cum">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource PanelAccentBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <helpers:EmojiTextBlock Text="{loc:Str label_good_girls_don_t_cum}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                            <Border Background="{DynamicResource PinkBrush}" CornerRadius="3" Padding="8,3" Margin="10,0,0,0">
                                                <TextBlock Text="{loc:Str label_60_min}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#4A3A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_hard}" Foreground="#FFA500" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <Border Background="#4A4A2A" CornerRadius="3" Padding="8,3" Margin="6,0,0,0">
                                                <TextBlock Text="{loc:Str label_1200_xp}" Foreground="#FFA500" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{loc:Str label_denial_session_with_heavy_conditioning_and_es}"
                                                   Foreground="#A0A0A0" FontSize="13" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Style="{StaticResource SessionActionButton}" Content="✏" ToolTip="{loc:Str tooltip_edit_session}"
                                                Tag="good_girls_dont_cum" Click="SessionBtn_Edit"/>
                                        <Button Style="{StaticResource SessionActionButton}" Content="📤" ToolTip="{loc:Str tooltip_export_session}"
                                                Tag="good_girls_dont_cum" Click="SessionBtn_Export"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
    
                            <!-- Custom/Imported Sessions Section -->
                            <TextBlock x:Name="TxtCustomSessionsHeader" x:FieldModifier="internal" Text="{loc:Str label_your_sessions}" Foreground="{DynamicResource PinkBrush}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,16,0,10" Visibility="Collapsed"/>
                            <StackPanel x:Name="CustomSessionsPanel" x:FieldModifier="internal"/>
                        </StackPanel>
                    </ScrollViewer>
    
                    <!-- Drop Zone and Editor Panel -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Left: Drop Zone -->
                        <Border Grid.Column="0"
                                x:Name="SessionDropZone" x:FieldModifier="internal"
                                Background="{DynamicResource SurfaceBgBrush}"
                                BorderBrush="{DynamicResource PanelAccentBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="0,0,4,0"
                                AllowDrop="True"
                                Drop="SessionDropZone_Drop"
                                DragEnter="SessionDropZone_DragEnter"
                                DragLeave="SessionDropZone_DragLeave"
                                DragOver="SessionDropZone_DragOver">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#606080"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="DropZoneIcon" x:FieldModifier="internal" Text="📂" FontSize="28" HorizontalAlignment="Center" Foreground="#707090"/>
                                <TextBlock Text="{loc:Str label_drag_drop}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#909090" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                <TextBlock Text="{loc:Str label_session_json}" FontSize="11"
                                           Foreground="#606070" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock x:Name="DropZoneStatus" x:FieldModifier="internal" Text="" FontSize="10"
                                           Foreground="{DynamicResource PinkBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
    
                        <!-- Right: Session Editor Panel -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceBgBrush}"
                                BorderBrush="{DynamicResource PanelAccentBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="4,0,0,0">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{loc:Str label_session_editor}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PinkBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{loc:Str label_create_custom_sessions}" FontSize="11"
                                               Foreground="#707090" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                        <Button x:Name="BtnCreateSession" Content="{loc:Str btn_create_new}"
                                                Click="BtnCreateSession_Click"
                                                Background="{DynamicResource PinkBrush}" Foreground="White"
                                                BorderThickness="0"
                                                Padding="12,6" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                Margin="0,0,8,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PinkBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button x:Name="BtnExportSession" x:FieldModifier="internal" Content="{loc:Str btn_export}"
                                                Click="BtnExportSession_Click"
                                                IsEnabled="False"
                                                Background="#2A2A4A" Foreground="#909090"
                                                BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1"
                                                Padding="12,6" FontSize="11" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="Background" Value="#3A3A5A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PinkBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource PanelAccentBrush}" Cursor="SizeWE"/>
    
        <!-- Right Side: Details Panel -->
        <Border Grid.Column="2" Style="{StaticResource SectionPanel}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <Grid>
                        <TextBlock x:Name="TxtDetailTitle" x:FieldModifier="internal" Text="{loc:Str label_select_a_preset}"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="18" FontWeight="Bold"/>
                        <Button x:Name="HelpBtnSessionDetails" x:FieldModifier="internal" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="SessionDetails"/>
                    </Grid>
                    <TextBlock x:Name="TxtDetailSubtitle" x:FieldModifier="internal" Text="{loc:Str label_click_on_a_preset_or_session_to_see_details}"
                               Foreground="#909090" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- Details Content - Preset View -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="PresetDetailScroller" x:FieldModifier="internal">
                    <StackPanel x:Name="DetailContentPanel">
                        <!-- Preset details will show here -->
                        <helpers:EmojiTextBlock x:Name="TxtDetailFlashLabel" x:FieldModifier="internal" Text="{loc:Str section_flash_images}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetailFlash" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,12"/>
    
                        <helpers:EmojiTextBlock x:Name="TxtDetailVideoLabel" x:FieldModifier="internal" Text="{loc:Str label_mandatory_videos}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetailVideo" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,12"/>
    
                        <helpers:EmojiTextBlock x:Name="TxtDetailSubLabel" x:FieldModifier="internal" Text="{loc:Str section_subliminals_2}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetailSubliminal" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,12"/>
    
                        <helpers:EmojiTextBlock Text="{loc:Str section_audio}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetailAudio" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,12"/>
    
                        <helpers:EmojiTextBlock Text="{loc:Str label_overlays}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetailOverlays" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,12"/>
    
                        <helpers:EmojiTextBlock Text="{loc:Str label_advanced}" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtDetailAdvanced" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,12"/>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Details Content - Session View (Spoiler-Free) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="SessionDetailScroller" x:FieldModifier="internal" Visibility="Collapsed">
                    <StackPanel x:Name="SessionDetailPanel">
                        <!-- Session Duration & Difficulty -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{loc:Str label_duration}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSessionDuration" x:FieldModifier="internal" Text="{loc:Str label_30_minutes}" Foreground="White" 
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <helpers:EmojiTextBlock Text="{loc:Str label_reward}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSessionXP" x:FieldModifier="internal" Text="{loc:Str label_50_xp}" Foreground="#90EE90" 
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Difficulty Badge -->
                        <Border x:Name="DifficultyBadge" Background="#2A2A4A" CornerRadius="6" Padding="8,4" 
                                Margin="0,0,0,12" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtSessionDifficulty" x:FieldModifier="internal" Text="{loc:Str label_easy_2}" Foreground="#FFD700" 
                                       FontSize="12" FontWeight="Bold"/>
                        </Border>
                        
                        <!-- Spoiler-Free Description -->
                        <TextBlock x:Name="TxtSessionDescription" x:FieldModifier="internal" TextWrapping="Wrap" Foreground="#C0C0C0" FontSize="12" 
                                   LineHeight="20" Margin="0,0,0,16"
                                   Text="{loc:Str label_let_the_morning_carry_you_away}"/>
                        
                        <!-- Corner GIF Option (shown for Gamer Girl session) -->
                        <Border x:Name="CornerGifOptionPanel" x:FieldModifier="internal" Background="#252540" CornerRadius="6" Padding="10" 
                                Margin="0,0,0,12" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <TextBlock x:Name="TxtFeatureCornerGif" x:FieldModifier="internal" Text="{loc:Str label_corner_gif}" Foreground="{DynamicResource PinkBrush}"
                                               FontWeight="Bold" FontSize="11"/>
                                    <CheckBox x:Name="ChkCornerGifEnabled" x:FieldModifier="internal" Style="{StaticResource ToggleStyle}" 
                                              HorizontalAlignment="Right" Checked="ChkCornerGifEnabled_Changed" 
                                              Unchecked="ChkCornerGifEnabled_Changed"/>
                                </Grid>
                                <TextBlock x:Name="TxtCornerGifDesc" x:FieldModifier="internal" Text="{loc:Str label_place_a_subtle_gif_in_a_screen_corner}" 
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                
                                <StackPanel x:Name="CornerGifSettings" x:FieldModifier="internal" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Button x:Name="BtnSelectCornerGif" x:FieldModifier="internal" Content="{loc:Str btn_select_gif}" 
                                            Style="{StaticResource OutlineButton}" Padding="8,6" FontSize="10"
                                            Margin="0,0,0,8" Click="BtnSelectCornerGif_Click"/>
                                    <TextBlock Text="{loc:Str label_position}" Foreground="#909090" FontSize="10" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <RadioButton x:Name="RbCornerTL" x:FieldModifier="internal" Content="{loc:Str btn_top_left}" Foreground="White"
                                                     GroupName="CornerPos" Margin="0,2" FontSize="10"/>
                                        <RadioButton x:Name="RbCornerTR" x:FieldModifier="internal" Grid.Column="1" Content="{loc:Str btn_top_right}"
                                                     Foreground="White" GroupName="CornerPos" Margin="0,2" FontSize="10"/>
                                        <RadioButton x:Name="RbCornerBL" Grid.Row="1" Content="{loc:Str btn_bottom_left}"
                                                     Foreground="White" GroupName="CornerPos" Margin="0,2" FontSize="10" IsChecked="True"/>
                                        <RadioButton x:Name="RbCornerBR" x:FieldModifier="internal" Grid.Row="1" Grid.Column="1" Content="{loc:Str btn_bottom_right}"
                                                     Foreground="White" GroupName="CornerPos" Margin="0,2" FontSize="10"/>
                                    </Grid>
    
                                    <!-- Size Slider -->
                                    <TextBlock Text="{loc:Str label_size}" Foreground="#909090" FontSize="10" Margin="0,10,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="SliderCornerGifSize" x:FieldModifier="internal" Minimum="100" Maximum="600" Value="300"
                                                VerticalAlignment="Center" ValueChanged="SliderCornerGifSize_ValueChanged"/>
                                        <TextBlock x:Name="TxtCornerGifSize" x:FieldModifier="internal" Grid.Column="1" Text="{loc:Str label_300px}"
                                                   Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
    
                                    <!-- Opacity Slider -->
                                    <TextBlock Text="{loc:Str label_opacity}" Foreground="#909090" FontSize="10" Margin="0,10,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="SliderCornerGifOpacity" x:FieldModifier="internal" Minimum="5" Maximum="100" Value="20"
                                                VerticalAlignment="Center" ValueChanged="SliderCornerGifOpacity_ValueChanged"/>
                                        <TextBlock x:Name="TxtCornerGifOpacity" x:FieldModifier="internal" Grid.Column="1" Text="20%"
                                                   Foreground="#C0C0C0" FontSize="10" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Spoiler Warning -->
                        <Border Background="#2A2040" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_mystery_experience}" Foreground="{DynamicResource PinkBrush}" 
                                           FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Str label_the_magic_works_best_when_you_don_t_know_what}" 
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextAlignment="Center" 
                                           Margin="0,6,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Reveal Spoilers Button -->
                        <Button x:Name="BtnRevealSpoilers" x:FieldModifier="internal" Content="{loc:Str btn_reveal_details}" 
                                Style="{StaticResource OutlineButton}" Padding="12,8" FontSize="12"
                                Click="BtnRevealSpoilers_Click" Margin="0,0,0,12"
                                ToolTip="{loc:Str tooltip_this_will_show_all_session_settings_spoils_th}"/>
                        
                        <!-- Spoiler Content (Hidden by default) -->
                        <StackPanel x:Name="SessionSpoilerPanel" x:FieldModifier="internal" Visibility="Collapsed">
                            <Border Background="#301520" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                <TextBlock Text="{loc:Str label_spoilers_below}" Foreground="#FF6B6B" FontSize="12" 
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                            </Border>
                            
                            <helpers:EmojiTextBlock x:Name="TxtSessionFlashLabel" x:FieldModifier="internal" Text="{loc:Str section_flash_images}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock x:Name="TxtSessionFlash" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>
    
                            <helpers:EmojiTextBlock x:Name="TxtSessionSubLabel" x:FieldModifier="internal" Text="{loc:Str section_subliminals_2}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock x:Name="TxtSessionSubliminal" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,10"/>
                            
                            <helpers:EmojiTextBlock Text="{loc:Str section_audio}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock x:Name="TxtSessionAudio" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,10"/>
                            
                            <helpers:EmojiTextBlock Text="{loc:Str label_overlays}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock x:Name="TxtSessionOverlays" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            
                            <helpers:EmojiTextBlock Text="{loc:Str label_extras}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock x:Name="TxtSessionExtras" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>
                            
                            <TextBlock Text="{loc:Str label_timeline}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,3"/>
                            <TextBlock x:Name="TxtSessionTimeline" x:FieldModifier="internal" Text="—" Foreground="#909090" FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Preset Action Buttons -->
                <StackPanel Grid.Row="2" x:Name="PresetButtonsPanel" x:FieldModifier="internal" Margin="0,10,0,0">
                    <Button x:Name="BtnLoadPreset" x:FieldModifier="internal" Content="{loc:Str btn_load_preset}" Style="{StaticResource PinkButton}"
                            Margin="0,0,0,6" Padding="12,10" FontSize="13" Click="BtnLoadPreset_Click" IsEnabled="False"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnSaveOverPreset" x:FieldModifier="internal" Grid.Column="0" Content="{loc:Str btn_save_2}" 
                                Style="{StaticResource OutlineButton}" Margin="0,0,3,0" Padding="10,8"
                                Click="BtnSaveOverPreset_Click" IsEnabled="False" FontSize="12"/>
                        <Button x:Name="BtnDeletePreset" x:FieldModifier="internal" Grid.Column="1" Content="{loc:Str btn_delete_2}" 
                                Style="{StaticResource OutlineButton}" Margin="3,0,0,0" Padding="10,8"
                                Click="BtnDeletePreset_Click" IsEnabled="False" FontSize="12"/>
                    </Grid>
                </StackPanel>
                
                <!-- Session Action Buttons -->
                <StackPanel Grid.Row="2" x:Name="SessionButtonsPanel" x:FieldModifier="internal" Margin="0,10,0,0" Visibility="Collapsed">
                    <Button x:Name="BtnStartSession" x:FieldModifier="internal" Content="{loc:Str btn_start_session}" Style="{StaticResource PinkButton}"
                            Padding="12,12" FontSize="14" Click="BtnStartSession_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
</UserControl>

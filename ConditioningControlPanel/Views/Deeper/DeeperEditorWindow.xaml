<Window x:Class="ConditioningControlPanel.Views.Deeper.DeeperEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Deeper"
        Height="720" Width="1180"
        MinHeight="560" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkerBgBrush}"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="EditorMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DeeperAccentTransparent40Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <!-- ComboBox needs Black foreground for both the closed header and the
             expanded popup items - WPF's default popup uses a near-white system
             background, so light text becomes unreadable. Apply this style to
             every ComboBox in the editor. -->
        <Style x:Key="EditorComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DeeperAccentTransparent40Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="EditorComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- title bar / menu -->
            <RowDefinition Height="*"/>    <!-- main content -->
            <RowDefinition Height="Auto"/> <!-- validation strip -->
        </Grid.RowDefinitions>

        <!-- Title / menu bar -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="0,0,0,1"
                Padding="10,4">
            <DockPanel LastChildFill="True">
                <Menu DockPanel.Dock="Left" Background="Transparent" Foreground="{DynamicResource TextLightBrush}">
                    <MenuItem Header="{loc:Str menu_file}" Style="{StaticResource EditorMenuItem}">
                        <MenuItem Header="{loc:Str menu_file_save}" Click="MenuSave_Click" InputGestureText="Ctrl+S"/>
                        <MenuItem Header="{loc:Str menu_file_save_as}" Click="MenuSaveAs_Click" InputGestureText="Ctrl+Shift+S"/>
                        <Separator/>
                        <MenuItem Header="{loc:Str menu_file_close}" Click="MenuClose_Click"/>
                    </MenuItem>
                </Menu>
                <TextBlock x:Name="TxtTitle" DockPanel.Dock="Left" Margin="22,0,0,0"
                           Foreground="{DynamicResource DeeperAccentSoftBrush}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtDirty" DockPanel.Dock="Left" Margin="6,0,0,0" Text="●"
                           Foreground="{DynamicResource DeeperAccentBrush}" Visibility="Collapsed"
                           FontSize="14" VerticalAlignment="Center"
                           ToolTip="{loc:Str deeper_editor_unsaved_marker}"/>
                <Button x:Name="BtnEditorHelp" DockPanel.Dock="Right" Margin="0,0,0,0"
                        Content="{loc:Str deeper_editor_help_btn}"
                        ToolTip="{loc:Str deeper_editor_help_tooltip}"
                        Click="BtnEditorHelp_Click"
                        Width="26" Height="22" Padding="0" Cursor="Hand" FontSize="13" FontWeight="Bold"
                        Background="{DynamicResource DeeperAccentTransparent20Brush}"
                        Foreground="{DynamicResource DeeperAccentBrush}"
                        BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"/>
                <TextBlock x:Name="TxtFilePath" Margin="0,0,12,0" HorizontalAlignment="Right"
                           Foreground="{DynamicResource TextDimBrush}" FontSize="11"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main 2-column body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: preview + timeline -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>      <!-- preview -->
                    <RowDefinition Height="160"/>    <!-- timeline -->
                </Grid.RowDefinitions>

                <!-- Preview pane -->
                <Border Grid.Row="0" Background="#0A0A14" Margin="10,10,10,5">
                    <Grid x:Name="PreviewHost">
                        <vlc:VideoView x:Name="VideoPreview" Visibility="Collapsed"/>

                        <Canvas x:Name="WaveformCanvas" Visibility="Collapsed" Background="#10000020">
                            <Path x:Name="WaveformPath" Stroke="{DynamicResource DeeperAccentBrush}"
                                  StrokeThickness="1.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>

                        <StackPanel x:Name="PreviewPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="TxtPlaceholderIcon" Text="🌐" FontSize="42" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource DeeperAccentSoftBrush}" Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtPlaceholderTitle"
                                       Text="{loc:Str deeper_editor_remote_preview_unavailable}"
                                       Foreground="{DynamicResource TextLightBrush}" FontSize="14"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="380"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="TxtPlaceholderSource" Foreground="{DynamicResource TextDimBrush}"
                                       FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" MaxWidth="420" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- Gaze rect picker now lives in a separate transparent
                             Window (GazePickerWindow). Inline overlay won't work
                             because LibVLC's VideoView wins WPF airspace. -->

                        <!-- Preview-mode debug overlay (live state + last fired actions).
                             Placed inline; visible only while previewing. For audio
                             enhancements LibVLC isn't drawing so airspace isn't a
                             concern; for video enhancements VLC's HWND will hide
                             this overlay too, but the same panel re-mounts to a
                             popup window in code when the preview pane has a
                             VideoView - see DeeperEditorWindow.xaml.cs. -->
                        <Border x:Name="PreviewDebugOverlay" Visibility="Collapsed"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,12,12,0" MaxWidth="320"
                                Background="#E61C1C35" Padding="10,8" CornerRadius="6"
                                BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TxtPreviewState" Foreground="White"
                                           FontFamily="Consolas" FontSize="11"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{loc:Str deeper_editor_preview_recent_actions}"
                                           Foreground="#FFB8A8FF" FontSize="10"
                                           FontWeight="SemiBold" Margin="0,8,0,4"/>
                                <ItemsControl x:Name="LstPreviewActions">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="White"
                                                       FontFamily="Consolas" FontSize="10"
                                                       TextWrapping="Wrap" Margin="0,1,0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{loc:Str deeper_editor_preview_keys_hint}"
                                           Foreground="#FFB8A8FF" FontSize="10"
                                           Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Timeline -->
                <Border Grid.Row="1" Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1"
                        CornerRadius="6" Margin="10,5,10,10" Padding="10,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Transport row -->
                        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,6">
                            <Button x:Name="BtnPlayPause" DockPanel.Dock="Left"
                                    Content="▶" Click="BtnPlayPause_Click"
                                    ToolTip="{loc:Str deeper_editor_tt_play}"
                                    Width="34" Height="28" Padding="0" Cursor="Hand"
                                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                                    Foreground="{DynamicResource DeeperAccentBrush}"
                                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                                    FontSize="13"/>
                            <TextBlock x:Name="TxtCurrentTime" DockPanel.Dock="Left"
                                       Text="0:00" Foreground="{DynamicResource TextLightBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="10,0,4,0"/>
                            <TextBlock DockPanel.Dock="Left" Text="/" Foreground="{DynamicResource TextDimBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalTime" DockPanel.Dock="Left"
                                       Text="0:00" Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            <ToggleButton x:Name="BtnPreview" DockPanel.Dock="Right"
                                          Content="{loc:Str deeper_editor_preview_off}"
                                          ToolTip="{loc:Str deeper_editor_tt_preview}"
                                          Click="BtnPreview_Click" Cursor="Hand"
                                          Padding="12,4" Margin="8,0,0,0" FontSize="11" FontWeight="SemiBold"
                                          Background="{DynamicResource DeeperAccentTransparent20Brush}"
                                          Foreground="{DynamicResource DeeperAccentBrush}"
                                          BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"/>
                            <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource TextDimBrush}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Text="{loc:Str deeper_editor_scrub_hint}"/>
                        </DockPanel>

                        <!-- Timeline canvas (scrub area + lanes: regions on top half, haptics on bottom half) -->
                        <Canvas x:Name="TimelineCanvas" Grid.Row="1" Background="#15151F"
                                Cursor="Hand" ClipToBounds="True"
                                ToolTip="{loc:Str deeper_editor_tt_timeline}"
                                MouseLeftButtonDown="TimelineCanvas_MouseLeftButtonDown"
                                MouseMove="TimelineCanvas_MouseMove"
                                MouseLeftButtonUp="TimelineCanvas_MouseLeftButtonUp"
                                SizeChanged="TimelineCanvas_SizeChanged">
                            <Line x:Name="LaneDivider" X1="0" X2="0" Y1="0" Y2="0"
                                  Stroke="{DynamicResource DeeperAccentTransparent40Brush}"
                                  StrokeThickness="1" StrokeDashArray="2,3"
                                  IsHitTestVisible="False"/>
                            <TextBlock x:Name="LaneLabelRegions" Text="R" Canvas.Left="4" Canvas.Top="2"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="10"
                                       FontFamily="Consolas" IsHitTestVisible="False"/>
                            <TextBlock x:Name="LaneLabelHaptics" Text="H" Canvas.Left="4"
                                       Foreground="{DynamicResource DeeperAccentSoftBrush}" FontSize="10"
                                       FontFamily="Consolas" IsHitTestVisible="False"/>
                            <!-- Playhead -->
                            <Line x:Name="PlayheadLine" X1="0" X2="0" Y1="0" Y2="0"
                                  Stroke="{DynamicResource DeeperAccentBrush}" StrokeThickness="2"/>
                        </Canvas>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: side panel -->
            <Border Grid.Column="1" Background="{DynamicResource PanelBgBrush}"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,12">
                    <StackPanel>
                        <!-- Metadata -->
                        <TextBlock Text="{loc:Str deeper_editor_section_metadata}"
                                   Foreground="{DynamicResource DeeperAccentBrush}"
                                   FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_name}" Style="{StaticResource EditorLabel}"/>
                        <TextBox x:Name="TxtMetaName" Style="{StaticResource EditorTextBox}"
                                 ToolTip="{loc:Str deeper_editor_tt_meta_name}"
                                 TextChanged="MetadataField_TextChanged"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_creator}" Style="{StaticResource EditorLabel}"/>
                        <TextBox x:Name="TxtMetaCreator" Style="{StaticResource EditorTextBox}"
                                 ToolTip="{loc:Str deeper_editor_tt_meta_creator}"
                                 TextChanged="MetadataField_TextChanged"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_description}" Style="{StaticResource EditorLabel}"/>
                        <TextBox x:Name="TxtMetaDescription" Style="{StaticResource EditorTextBox}"
                                 ToolTip="{loc:Str deeper_editor_tt_meta_description}"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="68"
                                 TextChanged="MetadataField_TextChanged"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_tags}" Style="{StaticResource EditorLabel}"/>
                        <TextBox x:Name="TxtMetaTags" Style="{StaticResource EditorTextBox}"
                                 ToolTip="{loc:Str deeper_editor_tt_meta_tags}"
                                 TextChanged="MetadataField_TextChanged"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_license}" Style="{StaticResource EditorLabel}"/>
                        <TextBox x:Name="TxtMetaLicense" Style="{StaticResource EditorTextBox}"
                                 ToolTip="{loc:Str deeper_editor_tt_meta_license}"
                                 TextChanged="MetadataField_TextChanged"/>

                        <Separator Margin="0,10,0,14"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_media_source}" Style="{StaticResource EditorLabel}"/>
                        <TextBox x:Name="TxtMediaSource" Style="{StaticResource EditorTextBox}"
                                 ToolTip="{loc:Str deeper_editor_tt_media_source}"
                                 IsReadOnly="True" Foreground="{DynamicResource TextDimBrush}"/>

                        <TextBlock Text="{loc:Str deeper_editor_label_media_type}" Style="{StaticResource EditorLabel}"/>
                        <TextBlock x:Name="TxtMediaType" Foreground="{DynamicResource TextLightBrush}"
                                   ToolTip="{loc:Str deeper_editor_tt_media_type}"
                                   FontSize="12" Margin="0,0,0,8"/>

                        <Separator Margin="0,10,0,14"/>

                        <DockPanel Margin="0,0,0,8" LastChildFill="True"
                                   ToolTip="{loc:Str deeper_editor_tt_rules_section}">
                            <TextBlock DockPanel.Dock="Left" Text="{loc:Str deeper_editor_section_rules}"
                                       Foreground="{DynamicResource DeeperAccentBrush}"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="+" Click="BtnAddRule_Click"
                                    Width="22" Height="22" Padding="0,0,0,2" Cursor="Hand"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                                    Foreground="{DynamicResource DeeperAccentBrush}"
                                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                                    FontWeight="Bold" FontSize="13"
                                    ToolTip="{loc:Str deeper_editor_rules_add_tooltip}"/>
                            <TextBlock/>
                        </DockPanel>
                        <TextBlock x:Name="RulesEmptyHint"
                                   Text="{loc:Str deeper_editor_rules_empty}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <StackPanel x:Name="RulesList" Margin="0,0,0,0"/>

                        <Separator Margin="0,10,0,14"/>

                        <TextBlock Text="{loc:Str deeper_editor_section_selected}"
                                   Foreground="{DynamicResource DeeperAccentBrush}"
                                   FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock x:Name="SelectedPlaceholder"
                                   Text="{loc:Str deeper_editor_section_selected_empty}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap"/>

                        <StackPanel x:Name="RegionEditor" Visibility="Collapsed">
                            <TextBlock Text="{loc:Str deeper_editor_region_id}" Style="{StaticResource EditorLabel}"/>
                            <TextBlock x:Name="TxtRegionId" Foreground="{DynamicResource TextDimBrush}"
                                       FontSize="11" FontFamily="Consolas" Margin="0,0,0,8"/>

                            <TextBlock Text="{loc:Str deeper_editor_region_label}" Style="{StaticResource EditorLabel}"/>
                            <TextBox x:Name="TxtRegionLabel" Style="{StaticResource EditorTextBox}"
                                     ToolTip="{loc:Str deeper_editor_tt_region_label}"
                                     TextChanged="RegionField_TextChanged"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Str deeper_editor_region_start}" Style="{StaticResource EditorLabel}"/>
                                    <TextBox x:Name="TxtRegionStart" Style="{StaticResource EditorTextBox}"
                                             ToolTip="{loc:Str deeper_editor_tt_region_start}"
                                             TextChanged="RegionField_TextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Str deeper_editor_region_end}" Style="{StaticResource EditorLabel}"/>
                                    <TextBox x:Name="TxtRegionEnd" Style="{StaticResource EditorTextBox}"
                                             ToolTip="{loc:Str deeper_editor_tt_region_end}"
                                             TextChanged="RegionField_TextChanged"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{loc:Str deeper_editor_region_color}" Style="{StaticResource EditorLabel}"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="RegionColorSwatch" Grid.Column="0"
                                        Width="24" Height="24" Margin="0,0,8,0" CornerRadius="4"
                                        Background="{DynamicResource DeeperAccentBrush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"/>
                                <TextBox x:Name="TxtRegionColor" Grid.Column="1" Style="{StaticResource EditorTextBox}"
                                         ToolTip="{loc:Str deeper_editor_tt_region_color}"
                                         TextChanged="RegionField_TextChanged" Margin="0"/>
                            </Grid>
                            <WrapPanel x:Name="RegionColorSwatches" Margin="0,4,0,12"/>

                            <Button Content="{loc:Str deeper_editor_region_delete}"
                                    Click="BtnDeleteRegion_Click"
                                    Background="{DynamicResource DangerBrush}" Foreground="White"
                                    BorderThickness="0" Padding="10,6" Cursor="Hand"
                                    HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel x:Name="HapticEventEditor" Visibility="Collapsed">
                            <TextBlock Text="{loc:Str deeper_editor_haptic_event}" Style="{StaticResource EditorLabel}"/>
                            <TextBlock x:Name="TxtHapticTrackId" Foreground="{DynamicResource TextDimBrush}"
                                       FontSize="11" FontFamily="Consolas" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Str deeper_editor_haptic_start}" Style="{StaticResource EditorLabel}"/>
                                    <TextBox x:Name="TxtHapticStart" Style="{StaticResource EditorTextBox}"
                                             ToolTip="{loc:Str deeper_editor_tt_haptic_start}"
                                             TextChanged="HapticField_TextChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{loc:Str deeper_editor_haptic_duration}" Style="{StaticResource EditorLabel}"/>
                                    <TextBox x:Name="TxtHapticDuration" Style="{StaticResource EditorTextBox}"
                                             ToolTip="{loc:Str deeper_editor_tt_haptic_duration}"
                                             TextChanged="HapticField_TextChanged"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{loc:Str deeper_editor_haptic_intensity}" Style="{StaticResource EditorLabel}"/>
                            <Grid Margin="0,0,0,8" ToolTip="{loc:Str deeper_editor_tt_haptic_intensity}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="SliderHapticIntensity" Grid.Column="0"
                                        Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                        TickFrequency="0.1" IsSnapToTickEnabled="False"
                                        Foreground="{DynamicResource DeeperAccentBrush}"
                                        ValueChanged="SliderHapticIntensity_ValueChanged"
                                        VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtHapticIntensityValue" Grid.Column="1"
                                           Text="100%" Foreground="{DynamicResource TextLightBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           FontFamily="Consolas" FontSize="11"/>
                            </Grid>

                            <TextBlock Text="{loc:Str deeper_editor_haptic_pattern}" Style="{StaticResource EditorLabel}"/>
                            <ComboBox x:Name="CmbHapticPattern" Style="{StaticResource EditorComboBox}"
                                      ItemContainerStyle="{StaticResource EditorComboBoxItem}"
                                      ToolTip="{loc:Str deeper_editor_tt_haptic_pattern}"
                                      SelectionChanged="CmbHapticPattern_SelectionChanged"/>

                            <StackPanel x:Name="CurveEditorPanel" Visibility="Collapsed" Margin="0,4,0,8">
                                <TextBlock Text="{loc:Str deeper_editor_haptic_curve}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <Border Background="#10000020"
                                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"
                                        BorderThickness="1" CornerRadius="3">
                                    <Canvas x:Name="CurveCanvas" Height="120" Background="Transparent"
                                            ClipToBounds="True"
                                            SizeChanged="CurveCanvas_SizeChanged"/>
                                </Border>
                                <Button Content="{loc:Str deeper_editor_haptic_curve_reset}"
                                        Click="BtnResetCurve_Click"
                                        HorizontalAlignment="Left" Margin="0,4,0,0"
                                        Padding="8,4" Cursor="Hand" FontSize="11"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextLightBrush}"
                                        BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}"/>
                            </StackPanel>

                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="{loc:Str deeper_editor_haptic_test}"
                                        Click="BtnTestHaptic_Click"
                                        ToolTip="{loc:Str deeper_editor_tt_haptic_test}"
                                        Background="{DynamicResource DeeperAccentBrush}" Foreground="White"
                                        BorderThickness="0" Padding="10,6" Cursor="Hand"
                                        FontWeight="SemiBold"/>
                                <Button Grid.Column="2" Content="{loc:Str deeper_editor_haptic_delete}"
                                        Click="BtnDeleteHaptic_Click"
                                        Background="{DynamicResource DangerBrush}" Foreground="White"
                                        BorderThickness="0" Padding="10,6" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="RuleEditor" Visibility="Collapsed">
                            <DockPanel Margin="0,0,0,10" LastChildFill="True">
                                <TextBlock x:Name="TxtRuleHeader" DockPanel.Dock="Left"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="{loc:Str deeper_editor_rule_delete}"
                                        Click="BtnDeleteRule_Click"
                                        Background="{DynamicResource DangerBrush}" Foreground="White"
                                        BorderThickness="0" Padding="8,4" Cursor="Hand" FontSize="11"
                                        HorizontalAlignment="Right"/>
                                <TextBlock/>
                            </DockPanel>

                            <CheckBox x:Name="ChkRuleEnabled"
                                      Content="{loc:Str deeper_editor_rule_enabled}"
                                      ToolTip="{loc:Str deeper_editor_tt_rule_enabled}"
                                      Click="ChkRuleEnabled_Changed"
                                      Foreground="{DynamicResource TextLightBrush}"
                                      Margin="0,0,0,10"/>

                            <TextBlock Text="{loc:Str deeper_editor_rule_trigger}" Style="{StaticResource EditorLabel}"/>
                            <ComboBox x:Name="CmbTriggerType" Style="{StaticResource EditorComboBox}"
                                      ItemContainerStyle="{StaticResource EditorComboBoxItem}"
                                      ToolTip="{loc:Str deeper_editor_tt_rule_trigger}"
                                      SelectionChanged="CmbTriggerType_SelectionChanged"/>
                            <StackPanel x:Name="TriggerFields"/>

                            <TextBlock Text="{loc:Str deeper_editor_rule_action}" Style="{StaticResource EditorLabel}" Margin="0,4,0,4"/>
                            <ComboBox x:Name="CmbActionType" Style="{StaticResource EditorComboBox}"
                                      ItemContainerStyle="{StaticResource EditorComboBoxItem}"
                                      ToolTip="{loc:Str deeper_editor_tt_rule_action}"
                                      SelectionChanged="CmbActionType_SelectionChanged"/>
                            <StackPanel x:Name="ActionFields"/>

                            <TextBlock Text="{loc:Str deeper_editor_rule_region_constraint}" Style="{StaticResource EditorLabel}" Margin="0,4,0,4"/>
                            <ComboBox x:Name="CmbRuleRegion" Style="{StaticResource EditorComboBox}"
                                      ItemContainerStyle="{StaticResource EditorComboBoxItem}"
                                      ToolTip="{loc:Str deeper_editor_tt_rule_region}"
                                      SelectionChanged="CmbRuleRegion_SelectionChanged"/>

                            <TextBlock Text="{loc:Str deeper_editor_rule_cooldown}" Style="{StaticResource EditorLabel}"/>
                            <TextBox x:Name="TxtRuleCooldown" Style="{StaticResource EditorTextBox}"
                                     ToolTip="{loc:Str deeper_editor_tt_rule_cooldown}"
                                     TextChanged="TxtRuleCooldown_TextChanged"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Validation strip -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="0,1,0,0"
                Padding="14,8">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="{loc:Str btn_save}" Click="MenuSave_Click"
                        ToolTip="{loc:Str deeper_editor_tt_save}"
                        Padding="14,6" Cursor="Hand" FontWeight="SemiBold"
                        Background="{DynamicResource DeeperAccentBrush}" Foreground="White"
                        BorderThickness="0"/>
                <TextBlock x:Name="TxtValidationSummary" Text="{loc:Str deeper_editor_validation_clean}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"
                           ToolTip="{loc:Str deeper_editor_tt_validation}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>

<Window x:Class="ConditioningControlPanel.Views.Deeper.EnhancementPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Deeper Player"
        Height="768" Width="900" MinHeight="504" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DarkerBgBrush}"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DeeperAccentBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DimText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- header -->
            <RowDefinition Height="Auto"/> <!-- audio file (audio mode only) -->
            <RowDefinition Height="Auto"/> <!-- enhancement file -->
            <RowDefinition Height="*"/>    <!-- media pane (audio waveform OR video webview) -->
            <RowDefinition Height="Auto"/> <!-- transport -->
            <RowDefinition Height="Auto"/> <!-- status -->
            <RowDefinition Height="Auto"/> <!-- event log -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="🌊" FontSize="22"
                       Foreground="{DynamicResource DeeperAccentBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{loc:Str deeper_player_title}" Style="{StaticResource HeaderText}"
                       VerticalAlignment="Center" FontSize="18"/>
        </StackPanel>

        <!-- Audio file row (audio mode only) -->
        <Grid Grid.Row="1" Margin="0,0,0,8" x:Name="AudioFileRow">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{loc:Str deeper_player_media_label}"
                       Foreground="{DynamicResource TextLightBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="TxtAudioPath"
                       Text="{loc:Str deeper_player_no_media}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="2" Content="{loc:Str deeper_player_pick_media}"
                    Click="BtnPickAudio_Click"
                    Padding="10,4" Cursor="Hand" FontSize="11"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"/>
        </Grid>

        <!-- Enhancement file row -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Str deeper_player_enh_label}"
                       Foreground="{DynamicResource TextLightBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtEnhPath"
                       Text="{loc:Str deeper_player_no_enh}"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Button Grid.Row="0" Grid.Column="2" Content="{loc:Str deeper_player_pick_enh}"
                    Click="BtnPickEnhancement_Click"
                    Padding="10,4" Cursor="Hand" FontSize="11"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"/>
            <Button Grid.Row="0" Grid.Column="3" Content="{loc:Str deeper_player_load_url}"
                    Click="BtnLoadUrl_Click"
                    Padding="10,4" Cursor="Hand" FontSize="11" Margin="6,0,0,0"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"/>
            <Button Grid.Row="0" Grid.Column="4" x:Name="BtnCreateNewEnhancement"
                    Content="{loc:Str deeper_player_create_new_btn}"
                    Click="BtnCreateNewEnhancement_Click"
                    Padding="10,4" Cursor="Hand" FontSize="11" Margin="6,0,0,0"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                    Visibility="Collapsed"/>
            <Button Grid.Row="0" Grid.Column="5" x:Name="BtnUnloadEnhancement"
                    Content="{loc:Str deeper_player_unload}"
                    Click="BtnUnloadEnhancement_Click"
                    Padding="8,4" Cursor="Hand" FontSize="11" Margin="6,0,0,0"
                    Background="Transparent"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1"
                    Visibility="Collapsed"/>

            <!-- Discovery-source badge: tells the user how the loaded enhancement
                 was found (library / sidecar / embedded / manual / URL). Hidden
                 when no enhancement is loaded. -->
            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5" x:Name="TxtEnhSource"
                       Foreground="{DynamicResource DeeperAccentSoftBrush}"
                       FontSize="10" Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Media pane: audio waveform OR video WebView2, swapped by MediaType -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <!-- Audio mode: waveform + scrub -->
            <Border x:Name="AudioPane" Background="#15151F"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1"
                    CornerRadius="4" Height="80" VerticalAlignment="Top">
                <Canvas x:Name="WaveformCanvas" ClipToBounds="True"
                        MouseLeftButtonDown="WaveformCanvas_MouseLeftButtonDown">
                    <Path x:Name="WaveformPath" Stroke="{DynamicResource DeeperAccentBrush}"
                          StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Line x:Name="PlayheadLine" X1="0" X2="0" Y1="0" Y2="0"
                          Stroke="White" StrokeThickness="1.5" IsHitTestVisible="False"/>
                </Canvas>
            </Border>

            <!-- Video mode: WebView2 hosting the embedded video page -->
            <Border x:Name="VideoPane" Background="Black"
                    BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1"
                    CornerRadius="4" Visibility="Collapsed">
                <Grid>
                    <wv2:WebView2 x:Name="VideoBrowser"/>
                    <TextBlock x:Name="TxtVideoStatus"
                               Text="{loc:Str deeper_player_video_loading}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <!-- Zoom controls overlay: top-right corner, semi-transparent
                         pill, 10% per click. Sits above the WebView via Z-order. -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,6,8,0" Panel.ZIndex="10">
                        <Button x:Name="BtnZoomOut" Content="−"
                                Click="BtnZoomOut_Click"
                                Width="26" Height="26" Padding="0" FontSize="16" FontWeight="Bold"
                                Background="#A0000000" Foreground="White" BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{loc:Str deeper_zoom_out_tt}"/>
                        <Button x:Name="BtnZoomIn" Content="+"
                                Click="BtnZoomIn_Click"
                                Width="26" Height="26" Padding="0" FontSize="16" FontWeight="Bold" Margin="4,0,0,0"
                                Background="#A0000000" Foreground="White" BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{loc:Str deeper_zoom_in_tt}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Transport row -->
        <DockPanel Grid.Row="4" LastChildFill="True" Margin="0,0,0,10">
            <Button x:Name="BtnPlayPause" DockPanel.Dock="Left"
                    Content="▶" Click="BtnPlayPause_Click"
                    Width="38" Height="32" Padding="0" Cursor="Hand"
                    Background="{DynamicResource DeeperAccentBrush}"
                    Foreground="White" BorderThickness="0" FontSize="15"/>
            <Button DockPanel.Dock="Left" Content="⏹"
                    Click="BtnStop_Click"
                    Width="32" Height="32" Padding="0" Cursor="Hand" Margin="6,0,0,0"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                    FontSize="13"/>
            <TextBlock x:Name="TxtCurrent" DockPanel.Dock="Left"
                       Text="0:00" Foreground="{DynamicResource TextLightBrush}"
                       FontSize="12" VerticalAlignment="Center" Margin="12,0,4,0"/>
            <TextBlock DockPanel.Dock="Left" Text="/" Foreground="{DynamicResource TextDimBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtTotal" DockPanel.Dock="Left"
                       Text="0:00" Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <StackPanel x:Name="VolumePanel" DockPanel.Dock="Right"
                        Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔊" Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="8,0,4,0"/>
                <Slider x:Name="SliderVolume"
                        Width="120" Minimum="0" Maximum="100" Value="80"
                        VerticalAlignment="Center"
                        ValueChanged="SliderVolume_ValueChanged"/>
            </StackPanel>
            <Button x:Name="BtnEyeTracking" DockPanel.Dock="Right"
                    Content="{loc:Str deeper_player_btn_eye_tracking_start}"
                    Click="BtnEyeTracking_Click"
                    ToolTip="{loc:Str deeper_player_tt_eye_tracking}"
                    Padding="10,4" Margin="0,0,8,0" Cursor="Hand" FontSize="12"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"/>
            <Button x:Name="BtnPictureInPicture" DockPanel.Dock="Right"
                    Content="{loc:Str deeper_player_btn_pip}"
                    Click="BtnPictureInPicture_Click"
                    ToolTip="{loc:Str deeper_player_tt_pip}"
                    Padding="10,4" Margin="0,0,8,0" Cursor="Hand" FontSize="12"
                    Background="{DynamicResource DeeperAccentTransparent20Brush}"
                    Foreground="{DynamicResource DeeperAccentBrush}"
                    BorderBrush="{DynamicResource DeeperAccentBrush}" BorderThickness="1"
                    Visibility="Collapsed"/>
        </DockPanel>

        <!-- Status -->
        <Border Grid.Row="5" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1"
                CornerRadius="4" Padding="12,10">
            <StackPanel>
                <TextBlock x:Name="TxtStatus"
                           Text="{loc:Str deeper_player_status_idle}"
                           Foreground="{DynamicResource TextLightBrush}"
                           FontSize="11" TextWrapping="Wrap"/>
                <TextBlock x:Name="TxtEnhMetadata"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Event log: live feed of triggered effects/rules -->
        <Border Grid.Row="6" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource DeeperAccentTransparent40Brush}" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="{loc:Str deeper_player_event_log}"
                           Foreground="{DynamicResource DeeperAccentBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ScrollViewer x:Name="EventScroll" MaxHeight="120"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LstEvents">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{DynamicResource TextLightBrush}"
                                           FontFamily="Consolas" FontSize="10"
                                           TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>

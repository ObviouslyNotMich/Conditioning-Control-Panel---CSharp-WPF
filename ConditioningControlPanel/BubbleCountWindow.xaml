<Window x:Class="ConditioningControlPanel.BubbleCountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        Title="{loc:Str dialog_bubble_count_challenge}"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        ResizeMode="NoResize"
        FontFamily="Comic Sans MS, Segoe UI">

    <Grid x:Name="MainGrid">
        <!-- Video Player Container - VideoView added programmatically -->
        <!-- Bubbles are now separate windows to avoid blocking LibVLC rendering -->
        <Grid x:Name="VideoContainer" Background="Black"/>

        <!-- Top Info Bar -->
        <Border Background="#80000000"
                VerticalAlignment="Top"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{loc:Str label_count_the_bubbles}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PinkBrush}">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="TxtDifficulty"
                           Text="{loc:Str label_medium_2}"
                           FontSize="22"
                           Foreground="{DynamicResource PinkBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Strict Mode Indicator -->
        <TextBlock x:Name="TxtStrict"
                   Text="{loc:Str label_strict}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#FF6B6B"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="0,15,20,0"
                   Visibility="Collapsed"/>

        <!-- ESC Hint -->
        <TextBlock x:Name="TxtEscHint"
                   Text="{loc:Str label_press_esc_to_skip_won_t_earn_xp}"
                   FontSize="16"
                   Foreground="#888888"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
    </Grid>
</Window>

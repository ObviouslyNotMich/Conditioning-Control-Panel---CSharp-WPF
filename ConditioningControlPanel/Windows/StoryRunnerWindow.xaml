<Window x:Class="ConditioningControlPanel.StoryRunnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Rabbit Hole — Opening"
        WindowStyle="None" ResizeMode="NoResize" WindowState="Maximized"
        ShowInTaskbar="False" Background="Black"
        KeyDown="OnKeyDown" MouseLeftButtonDown="OnClick" Cursor="Hand">
    <Grid x:Name="Root" Background="Black">
        <!-- Two stage layers so transitions (fade/crossfade/slide) can show old + new at once. -->
        <Grid x:Name="LayerA">
            <Grid.RenderTransform><TranslateTransform/></Grid.RenderTransform>
            <Image x:Name="BgA" Stretch="UniformToFill"/>
            <Canvas x:Name="StageA" ClipToBounds="True"/>
        </Grid>
        <Grid x:Name="LayerB">
            <Grid.RenderTransform><TranslateTransform/></Grid.RenderTransform>
            <Image x:Name="BgB" Stretch="UniformToFill"/>
            <Canvas x:Name="StageB" ClipToBounds="True"/>
        </Grid>
        <TextBlock Text="click / space ▸    esc to quit"
                   Foreground="#66FFFFFF" FontSize="12" FontFamily="Consolas"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,10"/>
    </Grid>
</Window>

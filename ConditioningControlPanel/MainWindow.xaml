                                            ValueChanged="SliderPopQuizFrequency_ValueChanged"/>
                                    <TextBlock x:Name="TxtPopQuizFrequency" Foreground="#B0B0C8" FontSize="12"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Text="{loc:Str label_2_session_hr}"/>
                                </StackPanel>

                                <Button x:Name="BtnTestPopQuiz" Content="{loc:Str btn_test}" Cursor="Hand"
                                        Background="{DynamicResource SecondaryBrush}" Foreground="White" FontWeight="Bold" FontSize="12"
                                        BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                        Click="BtnTestPopQuiz_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Placeholder Card 4 -->
                        <Border Background="#12FFFFFF" CornerRadius="12" Margin="6" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="{loc:Str label_coming_soon}" Foreground="#505070" FontSize="14" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>

            <!-- Lab Smokescreen Overlay (Patreon T2 / Whitelist gate) -->
            <Border x:Name="LabSmokescreen" Background="#CC1A1A2E" IsHitTestVisible="True" Visibility="Visible">
                <Border Background="#20FFFFFF" CornerRadius="16" Padding="32,28" HorizontalAlignment="Center" VerticalAlignment="Center"
                        MaxWidth="360" BorderBrush="{DynamicResource TransparentPink50Brush}" BorderThickness="1.5">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{loc:Str label_text_3}" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Border Background="{DynamicResource TransparentPinkBrush}" CornerRadius="8" Padding="12,4" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="{loc:Str label_beta_testing}" Foreground="{DynamicResource PinkBrush}" FontWeight="Bold" FontSize="14"/>
                        </Border>
                        <TextBlock Text="{loc:Str label_these_experimental_features_are_currently_bei}"
                                   Foreground="#B0B0C8" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20" Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>
            </Border>
            </Grid>
        </ContentControl>

        <!-- Leaderboard Tab -->
        <ContentControl x:Name="LeaderboardTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with sort dropdown and refresh -->
                    <Border Grid.Row="0" Background="{DynamicResource TransparentPink20Brush}" CornerRadius="12,12,0,0" Padding="20,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Help button + left flavour text -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="HelpBtnLeaderboard" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Tag="Leaderboard"/>
                                <Border Background="#1888AACC" CornerRadius="8" Padding="12,8" Margin="10,0,0,0" BorderBrush="#3388AACC" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str label_who_s_the_prettiest_bimbo}" FontStyle="Italic" FontSize="15" FontWeight="Bold"
                                                   Foreground="#9988AACC"/>
                                        <TextBlock Text="{loc:Str label_every_level_counts_every_quest_matters}" FontStyle="Italic" FontSize="13" FontWeight="Bold"
                                                   Foreground="#6688AACC" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Big LEADERBOARD title with stroke effect + mode toggle -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid HorizontalAlignment="Center">
                                    <!-- Shadow/outline layer -->
                                    <TextBlock Text="LEADERBOARD" FontSize="38" FontWeight="ExtraBold" FontFamily="Segoe UI"
                                               Foreground="#80000000" Margin="2,2,0,0"/>
                                    <!-- Main text -->
                                    <TextBlock Text="LEADERBOARD" FontSize="38" FontWeight="ExtraBold" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource PinkBrush}"/>
                                </Grid>
                                <!-- Monthly / All-Time toggle buttons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <Button x:Name="BtnLeaderboardMonthly" Content="{loc:Str btn_monthly}" Padding="16,5" FontSize="12" FontWeight="SemiBold"
                                            Background="{DynamicResource PinkBrush}" Foreground="White" Cursor="Hand" Click="BtnLeaderboardMode_Click" Tag="monthly">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="MonthlyBorder" Background="{TemplateBinding Background}" CornerRadius="10,0,0,10" Padding="{TemplateBinding Padding}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="BtnLeaderboardAllTime" Content="{loc:Str btn_all_time}" Padding="16,5" FontSize="12" FontWeight="SemiBold"
                                            Background="{DynamicResource AccentTintedBgBrush}" Foreground="{DynamicResource PinkBrush}" Cursor="Hand" Click="BtnLeaderboardMode_Click" Tag="all-time">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="AllTimeBorder" Background="{TemplateBinding Background}" CornerRadius="0,10,10,0" Padding="{TemplateBinding Padding}" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Border Background="#1888AACC" CornerRadius="8" Padding="12,8" Margin="0,0,12,0" BorderBrush="#3388AACC" BorderThickness="1" VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtLeaderboardSeason" Text="{loc:Str label_season_1_prove_your_devotion}"
                                                       FontStyle="Italic" FontSize="15" FontWeight="Bold" Foreground="#9988AACC"/>
                                            <TextBlock x:Name="TxtLeaderboardSubtitle" Text="{loc:Str label_resets_monthly_your_rank_is_everything}" FontStyle="Italic" FontSize="13" FontWeight="Bold"
                                                       Foreground="#6688AACC" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtLeaderboardStatus" Foreground="{DynamicResource PinkBrush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4" FontSize="13"/>
                                        <Button x:Name="BtnRefreshLeaderboard" Content="{loc:Str btn_refresh}" Padding="15,8"
                                                Background="{DynamicResource PinkBrush}" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                                Click="BtnRefreshLeaderboard_Click" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PinkButtonHoveredBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Leaderboard list - double-click to view profile -->
                    <ListView x:Name="LstLeaderboard" Grid.Row="1" Background="Transparent"
                              BorderThickness="0" Margin="10,5,10,10" Foreground="{DynamicResource PinkBrush}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.IsDeferredScrollingEnabled="True"
                              FontSize="18" FontFamily="Segoe UI" FontWeight="ExtraBold"
                              GridViewColumnHeader.Click="LeaderboardColumnHeader_Click"
                              MouseDoubleClick="LstLeaderboard_MouseDoubleClick">
                        <ListView.Resources>
                            <!-- Header style for dark theme - clickable for sorting -->
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource AccentTintedBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PinkBrush}"/>
                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontFamily" Value="Segoe Print"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,1,2"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource PinkBrush}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentTintedBgHoverBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{loc:Str section_rank}" Width="80" DisplayMemberBinding="{Binding Rank}"/>
                                <!-- OG Column - Glowing pink neon for Season 0 OGs -->
                                <GridViewColumn Header="" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{loc:Str label_og}" FontWeight="ExtraBold" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI Black">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSeason0Og}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource PinkBrush}"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="15" ShadowDepth="0" Opacity="1"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{loc:Str section_name}" Width="280" DisplayMemberBinding="{Binding DisplayNameWithFlair}"/>
                                <GridViewColumn Header="{loc:Str section_patreon}" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Tier 1 Badge (also fallback for IsPatreon with tier 0) -->
                                                <Image Source="/Resources/Patreon tier1.png" Height="42" RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PatreonTier}" Value="1">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <!-- Fallback: show tier1 for patrons with tier 0 -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsPatreon}" Value="True"/>
                                                                        <Condition Binding="{Binding PatreonTier}" Value="0"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <!-- Tier 2 Badge -->
                                                <Image Source="/Resources/Patreon tier2.png" Height="42" RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PatreonTier}" Value="2">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <!-- Tier 3 Badge -->
                                                <Image Source="/Resources/Patreon tier3.png" Height="42" RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PatreonTier}" Value="3">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{loc:Str section_disc}" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Click="BtnLeaderboardDiscord_Click" Cursor="Hand"
                                                    Tag="{Binding DiscordId}" Background="Transparent" BorderThickness="0"
                                                    ToolTip="{loc:Str tooltip_send_discord_dm}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDiscord}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Image Source="/Resources/discord.png" Height="36" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{loc:Str label_level}" Width="100" DisplayMemberBinding="{Binding Level}"/>
                                <GridViewColumn Header="{loc:Str label_xp}" Width="100" DisplayMemberBinding="{Binding XpDisplay}"/>
                                <GridViewColumn Header="{loc:Str tab_achievements}" Width="130" DisplayMemberBinding="{Binding AchievementsDisplay}"/>
                                <!-- Seasons column (shown only in All-Time mode) -->
                                <GridViewColumn Header="{loc:Str section_seasons}" Width="0" DisplayMemberBinding="{Binding SeasonsCompleted}"/>
                                <!-- Trophy Case Columns (shown only when skill unlocked) -->
                                <GridViewColumn x:Name="ColLongestSession" Header="{loc:Str section_best_session}" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Visibility="{Binding HasTrophyCase, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding LongestSessionDisplay}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{loc:Str label_min}" FontSize="11" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="ColHighestStreak" Header="{loc:Str section_best_streak}" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Visibility="{Binding HasTrophyCase, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding HighestStreakDisplay}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{loc:Str label_days}" FontSize="11" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{loc:Str label_online}" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="18" Height="18" HorizontalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#353545"/>
                                                        <Setter Property="Stroke" Value="#454560"/>
                                                        <Setter Property="StrokeThickness" Value="2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource PinkBrush}"/>
                                                                <Setter Property="Stroke" Value="{DynamicResource PinkButtonHoveredBrush}"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="12" ShadowDepth="0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="{DynamicResource PinkBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="8"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                <Setter Property="FontFamily" Value="Segoe Print"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <!-- OG users get gold-tinted row -->
                                    <DataTrigger Binding="{Binding IsSeason0Og}" Value="True">
                                        <Setter Property="Background" Value="#25FFD700"/>
                                        <Setter Property="BorderBrush" Value="#50FFD700"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TransparentPink40Brush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TransparentPink50Brush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
        </ContentControl>

        <!-- Assets & Packs Tab -->
        <ContentControl x:Name="AssetsTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" MaxHeight="340"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header with title and actions -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str section_assets_content_packs}" Style="{StaticResource SectionHeader}"
                               FontSize="18" VerticalAlignment="Center"/>
                    <Button x:Name="HelpBtnAssets" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="Assets"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnRefreshPacks" Content="{loc:Str btn_refresh_2}"
                            Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Padding="12,6"
                            Click="BtnRefreshPacks_Click" ToolTip="{loc:Str tooltip_refresh_available_packs}"/>
                    <Button x:Name="BtnDeleteDownloadedPacks" Content="{loc:Str btn_delete_downloaded_packs}"
                            Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Padding="12,6"
                            Click="BtnDeleteDownloadedPacks_Click"
                            ToolTip="{loc:Str tooltip_delete_all_downloaded_content_packs_your_loca}"/>
                    <Button x:Name="BtnOpenAssetsFolder" Content="{loc:Str btn_open_folder}"
                            Style="{StaticResource OutlineButton}" Padding="12,6"
                            Click="BtnOpenAssetsFolder_Click" ToolTip="{loc:Str tooltip_open_assets_folder_in_explorer}"/>
                </StackPanel>
            </Grid>

            <!-- TOP: Content Packs Section -->
            <Border Grid.Row="1" Style="{StaticResource SectionPanel}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str label_community_content_packs}"
                                       Style="{StaticResource SectionHeader}"/>
                            <Button x:Name="HelpBtnPacks" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="ContentPacks"/>
                        </StackPanel>
                        <TextBlock Text="{loc:Str label_after_downloading_a_pack_just_drag_and_drop_t}"
                                   Foreground="#888" FontSize="11" FontStyle="Italic"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Horizontal scrolling pack cards -->
                    <ScrollViewer x:Name="PacksScrollViewer" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Visible"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="PacksScrollViewer_PreviewMouseWheel"
                                  Padding="0,0,0,8">
                        <ScrollViewer.Resources>
                            <!-- Force bigger scrollbar -->
                            <Style TargetType="ScrollBar">
                                <Setter Property="Height" Value="14"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="Transparent">
                                                <Border Background="#403949" CornerRadius="7" Opacity="0.5" Margin="2"/>
                                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                                    <Track.Thumb>
                                                        <Thumb Background="{DynamicResource PinkBrush}" Cursor="Hand">
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            CornerRadius="6" Margin="2"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ScrollViewer.Resources>
                        <StackPanel Orientation="Horizontal">
                            <!-- Dynamic Pack Cards -->
                            <ItemsControl x:Name="PackCardsItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="192" Height="240" Margin="0,0,10,0" CornerRadius="8"
                                                Background="{DynamicResource SurfaceBgBrush}" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PanelAccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExternal}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#FFA500"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="72"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Preview Image (rotating for installed packs, static otherwise) -->
                                                <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True" Background="{DynamicResource DarkerBgBrush}">
                                                    <Grid>
                                                        <!-- Rotating preview image from pack content (for installed packs with loaded previews) -->
                                                        <Image Source="{Binding CurrentPreviewImage}"
                                                               Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                                                               Visibility="{Binding HasPreviewImages, Converter={StaticResource BoolToVisibility}}"/>
                                                        <!-- Static preview image from URL (fallback when no dynamic previews) -->
                                                        <Image Source="{Binding PreviewImageUrl, TargetNullValue={x:Null}}"
                                                               Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                                                               Visibility="{Binding HasPreviewImages, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                        <!-- "No Preview" text shows only when no dynamic or static preview exists -->
                                                        <TextBlock Text="{loc:Str label_no_preview}" FontSize="14" Foreground="#666"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{Binding HasAnyPreview, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                        <!-- Size badge -->
                                                        <Border Background="{DynamicResource PinkBrush}" CornerRadius="4" Padding="8,3"
                                                                HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="6">
                                                            <TextBlock Text="{Binding SizeDisplay}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                        <!-- Installed badge -->
                                                        <Border Background="#4CAF50" CornerRadius="4" Padding="6,2"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6"
                                                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="{loc:Str label_installed}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                        <!-- Manual download badge for external packs -->
                                                        <Border Background="#FFA500" CornerRadius="4" Padding="6,2"
                                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6"
                                                                Visibility="{Binding ShowExternalButtons, Converter={StaticResource BoolToVisibility}}">
                                                            <TextBlock Text="{loc:Str label_manual_download}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- Info section -->
                                                <Grid Grid.Row="1" Margin="6,3,6,3">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Text="{Binding Name}" FontWeight="Bold"
                                                               Foreground="{StaticResource TextLightBrush}" FontSize="11"
                                                               Margin="0,0,0,1"/>
                                                    <TextBlock Grid.Row="1" Text="{Binding Description}"
                                                               Foreground="{StaticResource TextMutedBrush}" FontSize="9"
                                                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                               MaxHeight="60"
                                                               VerticalAlignment="Top"
                                                               ToolTip="{Binding Description}"/>
                                                    <TextBlock Grid.Row="2" Foreground="{DynamicResource PinkBrush}" FontSize="8" Margin="0,1,0,3" FontWeight="SemiBold">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} images, {1} videos">
                                                                <Binding Path="ImageCount"/>
                                                                <Binding Path="VideoCount"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>

                                                    <!-- Action Buttons -->
                                                    <Grid Grid.Row="3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="4"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Install/Uninstall Button -->
                                                        <Button Grid.Column="0" Content="{Binding DownloadButtonText}"
                                                                Tag="{Binding}"
                                                                Style="{StaticResource SmallPinkButton}"
                                                                Padding="4,4" Click="BtnPackDownload_Click"
                                                                IsEnabled="{Binding IsNotDownloading}"/>
                                                        <!-- Activate/Deactivate Button (only visible when downloaded) -->
                                                        <Button Grid.Column="2" Content="{Binding ActivateButtonText}"
                                                                Tag="{Binding}"
                                                                Style="{StaticResource SmallPinkButton}"
                                                                Padding="4,4" Click="BtnPackActivate_Click"
                                                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVisibility}}"/>
                                                    </Grid>

                                                    <!-- Progress bar -->
                                                    <ProgressBar Grid.Row="4" Height="4" Margin="0,6,0,0"
                                                                 Minimum="0" Maximum="100" Value="{Binding DownloadProgress}"
                                                                 Foreground="{DynamicResource PinkBrush}" Background="{DynamicResource DarkerBgBrush}"
                                                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Creator Card: Join Discord -->
                            <Border Width="176" Height="240" Margin="0,0,10,0" CornerRadius="8"
                                    Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#5865F2" BorderThickness="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="72"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Discord Preview -->
                                    <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True" Background="#5865F2">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Image Source="pack://application:,,,/Resources/discord.png"
                                                   Width="48" Height="48" Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Info section -->
                                    <Grid Grid.Row="1" Margin="8,4,8,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Text="{loc:Str label_create_your_own_pack}" FontWeight="Bold"
                                                   Foreground="{StaticResource TextLightBrush}" FontSize="12"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Grid.Row="1" Text="{loc:Str label_are_you_a_content_creator_join_our_discord_to}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                                                   TextWrapping="Wrap" MaxHeight="52" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="2" Foreground="#5865F2" FontSize="9" Margin="0,2,0,4" FontWeight="SemiBold">
                                            Get featured in the app
                                        </TextBlock>

                                        <!-- Button -->
                                        <Button Grid.Row="3" Content="{loc:Str label_join_discord}"
                                                Background="#5865F2" Foreground="White" BorderThickness="0"
                                                Padding="8,4" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                                Click="BtnCreatorDiscord_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeNS"/>

            <!-- BOTTOM: Interactive File Browser -->
            <Border Grid.Row="3" Style="{StaticResource SectionPanel}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str section_asset_browser}" Style="{StaticResource SectionHeader}"/>
                            <Button x:Name="HelpBtnAssetBrowser" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="AssetBrowser"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtAssetCounts" Text="{loc:Str label_0_images_0_videos}"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Action bar with preset selector -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Select/Deselect buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="{loc:Str btn_select_all}" Style="{StaticResource OutlineButton}"
                                    Padding="10,4" FontSize="11" Margin="0,0,6,0" Click="BtnSelectAllAssets_Click"/>
                            <Button Content="{loc:Str btn_deselect_all}" Style="{StaticResource OutlineButton}"
                                    Padding="10,4" FontSize="11" Click="BtnDeselectAllAssets_Click"/>
                        </StackPanel>

                        <!-- Right: Preset selector -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="{loc:Str label_preset_2}" Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbAssetPresets" Width="180" FontSize="11"
                                      DisplayMemberPath="DisplayText"
                                      SelectedValuePath="Id"
                                      SelectionChanged="CmbAssetPresets_SelectionChanged"/>
                            <Button x:Name="BtnSaveAssetPreset" Content="{loc:Str btn_save_as}"
                                    Style="{StaticResource SmallPinkButton}"
                                    Padding="8,4" FontSize="11" Margin="6,0,0,0"
                                    ToolTip="{loc:Str tooltip_save_current_selection_as_a_new_preset}"
                                    Click="BtnSaveAssetPreset_Click"/>
                            <Button x:Name="BtnUpdateAssetPreset" Content="{loc:Str btn_update}"
                                    Style="{StaticResource OutlineButton}"
                                    Padding="8,4" FontSize="11" Margin="4,0,0,0"
                                    ToolTip="{loc:Str tooltip_update_selected_preset_with_current_selection}"
                                    Click="BtnUpdateAssetPreset_Click"/>
                            <Button x:Name="BtnDeleteAssetPreset" Content="{loc:Str btn_delete}"
                                    Style="{StaticResource OutlineButton}"
                                    Padding="8,4" FontSize="11" Margin="4,0,0,0"
                                    ToolTip="{loc:Str tooltip_delete_selected_preset}"
                                    Click="BtnDeleteAssetPreset_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Split view: TreeView on left, Thumbnails on right -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Folder TreeView -->
                        <Border Grid.Column="0" Background="{DynamicResource DarkerBgBrush}" CornerRadius="6" Padding="4">
                            <TreeView x:Name="AssetTreeView" Background="Transparent" BorderThickness="0"
                                      SelectedItemChanged="AssetTreeView_SelectedItemChanged"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Visible">
                                <TreeView.Resources>
                                    <!-- Force bigger scrollbars in TreeView -->
                                    <Style TargetType="ScrollBar">
                                        <Setter Property="Width" Value="14"/>
                                        <Setter Property="Height" Value="14"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ScrollBar">
                                                    <Grid Background="Transparent">
                                                        <Border Background="#403949" CornerRadius="7" Opacity="0.5" Margin="2"/>
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb Background="{DynamicResource PinkBrush}" Cursor="Hand">
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    CornerRadius="6" Margin="2"/>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="Orientation" Value="Horizontal">
                                                <Setter Property="Height" Value="14"/>
                                                <Setter Property="Width" Value="Auto"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="2"/>
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource TransparentPink40Brush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource TransparentPink20Brush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.Resources>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      IsThreeState="False"
                                                      Checked="FolderCheckBox_Changed"
                                                      Unchecked="FolderCheckBox_Changed"
                                                      VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="📁" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding FileCountDisplay}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>

                        <!-- Splitter -->
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                      Background="Transparent" Cursor="SizeWE"/>

                        <!-- RIGHT: Thumbnail Preview Grid -->
                        <Border Grid.Column="2" Background="{DynamicResource DarkerBgBrush}" CornerRadius="6" Padding="4">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="ThumbnailsItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="100" Height="120" Margin="4" CornerRadius="6"
                                                        Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PanelAccentBrush}" BorderThickness="2" Cursor="Hand"
                                                        MouseLeftButtonDown="ThumbnailItem_Click">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{loc:Str section_preview}" Click="ThumbnailItem_Preview_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="{loc:Str section_open_in_explorer}" Click="ThumbnailItem_OpenInExplorer_Click"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Thumbnail image -->
                                                        <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True" Background="{DynamicResource DarkerBgBrush}">
                                                            <Grid>
                                                                <!-- Video placeholder icon (shows when IsVideo and no thumbnail) -->
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock Text="🎬" FontSize="32" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{loc:Str label_video}" FontSize="9" Foreground="#888" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                                </StackPanel>
                                                                <!-- Image thumbnail (for images, or video if we had one) -->
                                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                                                <!-- Loading indicator -->
                                                                <TextBlock Text="⏳" FontSize="14"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="{Binding IsLoadingThumbnail, Converter={StaticResource BoolToVisibility}}"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Checkbox overlay -->
                                                        <CheckBox Grid.Row="0" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                                  HorizontalAlignment="Left" VerticalAlignment="Top"
                                                                  Margin="4" Checked="ThumbnailCheckBox_Changed"
                                                                  Unchecked="ThumbnailCheckBox_Changed"/>

                                                        <!-- Filename -->
                                                        <Border Grid.Row="1" Background="#303050" Padding="4,2">
                                                            <TextBlock Text="{Binding Name}" FontSize="9"
                                                                       Foreground="{StaticResource TextLightBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Name}"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Empty state -->
                                <TextBlock x:Name="TxtThumbnailsEmpty"
                                           Text="{loc:Str label_select_a_folder_to_view_its_contents}"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </ContentControl>

        <!-- Enhancements Tab (Skill Tree) -->
        <ContentControl x:Name="EnhancementsTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Grid>
                <!-- Hidden container for named elements (used programmatically) -->
                <StackPanel Visibility="Collapsed">
                    <TextBlock x:Name="TxtSkillPoints" Text="0"/>
                    <TextBlock x:Name="TxtXpMultiplier" Text="1.00x"/>
                    <TextBlock x:Name="TxtPinkRushIndicator" Text="{loc:Str label_rush}"/>
                    <TextBlock x:Name="TxtConditioningTime" Text="{loc:Str label_0h_0m}"/>
                    <WrapPanel x:Name="ActiveBonusesList"/>
                    <Border x:Name="ActiveBonusesPanel"/>
                </StackPanel>

                <Border x:Name="SkillTreeOuterBorder" Background="#151528" CornerRadius="12" Padding="5" Margin="20,5,20,20">
                    <ScrollViewer x:Name="SkillTreeScroller"
                             Style="{StaticResource SkillTreeScrollViewerStyle}"
                             HorizontalScrollBarVisibility="Visible"
                             VerticalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="SkillTreeScroller_PreviewMouseWheel">
                        <Canvas x:Name="SkillTreeCanvas" Width="2400" Height="460" HorizontalAlignment="Left">
                            <!-- Header and skill nodes will be drawn programmatically -->
                        </Canvas>
                    </ScrollViewer>
                </Border>

                <!-- Login Required Overlay -->
                <Border x:Name="EnhancementsLoginOverlay" Background="#E6151528" CornerRadius="12" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                        <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <TextBlock Text="{loc:Str label_login_required}" Foreground="{DynamicResource PinkBrush}" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{loc:Str label_log_in_with_discord_or_patreon_to_access_enha}"
                                   Foreground="#AA99AA" FontSize="14" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" MaxWidth="350"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ContentControl>

        <!-- Awareness Engine Tab -->
        <ContentControl x:Name="AwarenessTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
          <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="28,20,28,20" MaxWidth="980" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="Auto"/> <!-- Pulse -->
                        <RowDefinition Height="Auto"/> <!-- Presets -->
                        <RowDefinition Height="Auto"/> <!-- Sources + Safety (two columns) -->
                        <RowDefinition Height="Auto"/> <!-- Advanced link -->
                    </Grid.RowDefinitions>

                    <!-- ==================== HEADER ==================== -->
                    <Grid Grid.Row="0" Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="👁" FontSize="34" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Awareness Engine" Foreground="White" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="She's watching your screen and your typing. React in real time."
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="AwarenessStatusDot" Width="8" Height="8" Fill="#606060" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtAwarenessStatus" Text="Off" Foreground="#A0A0A0"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <CheckBox x:Name="ChkAwarenessMaster" Style="{StaticResource ToggleStyle}"
                                      VerticalAlignment="Center"
                                      Checked="ChkAwarenessMaster_Changed" Unchecked="ChkAwarenessMaster_Changed">
                                <CheckBox.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="320">
                                            <TextBlock Text="Awareness Engine — Master Switch" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                Turns the whole Awareness system on or off. When ON, enabled signal sources (OCR + keyboard) feed words into the trigger engine and matching keywords fire their actions in real time. When OFF, nothing detects anything — installed presets stay on disk but do nothing.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </CheckBox.ToolTip>
                            </CheckBox>
                        </StackPanel>
                    </Grid>

                    <!-- ==================== LIVE PULSE ==================== -->
                    <Border Grid.Row="1" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                            BorderThickness="1" CornerRadius="10" Padding="18,16" Margin="0,0,0,18">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="LAST DETECTED" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtAwarenessFireCount" Text="" HorizontalAlignment="Right"
                                           Foreground="{DynamicResource TextDimBrush}" FontSize="10"/>
                            </Grid>
                            <StackPanel x:Name="AwarenessPulseFeed">
                                <!-- Empty state shown when no fires yet -->
                                <TextBlock x:Name="TxtAwarenessPulseEmpty"
                                           Text="Nothing yet. Enable the engine and she'll start noticing things."
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontStyle="Italic"
                                           TextAlignment="Center" Margin="0,18,0,18"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ==================== PRESETS ==================== -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,18">
                        <Grid Margin="4,0,4,10">
                            <TextBlock Text="PRESETS" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="One-click packs — click any card to preview or install"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontStyle="Italic"/>
                        </Grid>
                        <ItemsControl x:Name="AwarenessPresetItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48" BorderThickness="1"
                                            CornerRadius="10" Padding="16,14" Margin="0,0,12,12" Width="218" Height="150"
                                            Cursor="Hand" Tag="{Binding Id}" MouseLeftButtonUp="AwarenessPresetCard_Click"
                                            ToolTip="{Binding LongDescription}"
                                            ToolTipService.ShowDuration="20000"
                                            ToolTipService.InitialShowDelay="400">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" FontSize="26"/>
                                                <Border Background="#2A1A3E" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                                        CornerRadius="4" Padding="5,1" Margin="8,4,0,0" VerticalAlignment="Center"
                                                        Visibility="{Binding RequiresAi, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="AI" Foreground="{DynamicResource PinkBrush}" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,6,0,2"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock Text="✓ Installed" Foreground="{DynamicResource PinkBrush}" FontSize="10"
                                                       FontWeight="Bold" Margin="0,8,0,0"
                                                       Visibility="{Binding MasterEnabled, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ==================== SOURCES + SAFETY ==================== -->
                    <Grid Grid.Row="3" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Signal Sources -->
                        <Border Grid.Column="0" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                                BorderThickness="1" CornerRadius="10" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="SIGNAL SOURCES" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <Grid Margin="0,4,0,8">
                                    <Grid.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock Text="Screen OCR" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                    Scans your screen every few seconds with optical character recognition and feeds detected words into the trigger engine. This is how she notices text inside other apps — Discord, browsers, image viewers, game UIs, anything visible.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                    Uses modest CPU/GPU during active sessions. Turn off if you don't want screen-based triggers or want to save power.
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </Grid.ToolTip>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🖵" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Screen OCR" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Reads words from what's on your screen"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkAwarenessOcr" Style="{StaticResource ToggleStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ChkAwarenessOcr_Changed" Unchecked="ChkAwarenessOcr_Changed"/>
                                </Grid>
                                <Grid Margin="0,4,0,4">
                                    <Grid.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock Text="Keyboard Capture" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                    Listens to your keystrokes and assembles a rolling buffer of recent typing. When you type a trigger keyword, it fires immediately — no OCR delay.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                    Only trigger words are acted on; nothing else is stored or logged. Fastest signal source. Turn off if you don't want typing-based triggers.
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </Grid.ToolTip>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⌨" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Keyboard" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Catches trigger words as you type them"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <CheckBox x:Name="ChkAwarenessKeyboard" Style="{StaticResource ToggleStyle}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Checked="ChkAwarenessKeyboard_Changed" Unchecked="ChkAwarenessKeyboard_Changed"/>
                                </Grid>
                                <TextBlock Text="More sources coming: browser URL, active window title, process"
                                           Foreground="{DynamicResource TextDimBrush}" FontSize="10" FontStyle="Italic"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Safety -->
                        <Border Grid.Column="2" Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                                BorderThickness="1" CornerRadius="10" Padding="18,14">
                            <StackPanel>
                                <TextBlock Text="SAFETY" Foreground="#8A8AA0" FontSize="10" FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <CheckBox x:Name="ChkAwarenessIgnoreOwnUi"
                                          Foreground="White" FontSize="12" Margin="0,4,0,2"
                                          Checked="ChkAwarenessIgnoreOwnUi_Changed" Unchecked="ChkAwarenessIgnoreOwnUi_Changed">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock Text="Ignore CCP's own windows" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                    OCR will skip words drawn by Control Panel itself — avatar speech bubbles, subliminal flash overlays, bouncing text, and the main window. Prevents Awareness from reacting to her own voice and creating feedback loops.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                    Strongly recommended ON. Only turn off if you're debugging why a specific overlay isn't being detected.
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                    <TextBlock Text="Ignore CCP's own windows" FontWeight="SemiBold"/>
                                </CheckBox>
                                <TextBlock Text="OCR skips words inside Control Panel, avatar bubbles, and subliminal flashes — so she won't react to her own voice."
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,0,0,10"/>
                                <CheckBox x:Name="ChkAwarenessLoopProtection"
                                          Foreground="White" FontSize="12" Margin="0,4,0,2"
                                          Checked="ChkAwarenessLoopProtection_Changed" Unchecked="ChkAwarenessLoopProtection_Changed">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock Text="Loop protection" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                    When a trigger fires, its keyword is silenced for a few seconds. Stops a single mention on screen from firing multiple times in quick succession if OCR keeps catching it.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                    Also works across sources — a keyword fired via Keyboard is muted for OCR detection too, and vice versa.
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                    <TextBlock Text="Loop protection" FontWeight="SemiBold"/>
                                </CheckBox>
                                <TextBlock Text="After a trigger fires, its keyword is muted for a few seconds so the reaction can't re-arm it."
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,0,0,10"/>

                                <!-- On-screen highlight: toggle + color picker. The highlight overlay
                                     draws a glowing box around OCR-matched words on your screen. -->
                                <CheckBox x:Name="ChkAwarenessHighlight"
                                          Foreground="White" FontSize="12" Margin="0,4,0,2"
                                          Checked="ChkAwarenessHighlight_Changed" Unchecked="ChkAwarenessHighlight_Changed">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock Text="Highlight matched words on screen" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                    Draws a glowing rectangle around every OCR-detected trigger word on your screen, just long enough to see it catch your eye. Gives you a visual confirmation that Awareness is watching.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#A0A0A0" Margin="0,6,0,0">
                                                    Only shows for OCR detections, not keyboard triggers. Pick the glow color from the swatches below.
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                    <TextBlock Text="Highlight matched words on screen" FontWeight="SemiBold"/>
                                </CheckBox>
                                <TextBlock Text="Draws a glowing box around OCR-detected trigger words. Pick the glow color below."
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="22,0,0,6"/>
                                <StackPanel x:Name="AwarenessHighlightColorPanel" Orientation="Horizontal" Margin="22,0,0,0"
                                            ToolTip="Click a swatch to pick the highlight glow color, or type a custom hex in the box.">
                                    <TextBlock Text="Color:" Foreground="#A0A0B8" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Border x:Name="SwatchHighlightPink" Width="22" Height="22" CornerRadius="3"
                                            Background="#FF69B4" BorderBrush="#3A3A5A" BorderThickness="1"
                                            Margin="0,0,4,0" Cursor="Hand" Tag="#FF69B4"
                                            ToolTip="Hot pink — CCP default"
                                            MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                    <Border x:Name="SwatchHighlightCyan" Width="22" Height="22" CornerRadius="3"
                                            Background="#00E5FF" BorderBrush="#3A3A5A" BorderThickness="1"
                                            Margin="0,0,4,0" Cursor="Hand" Tag="#00E5FF"
                                            ToolTip="Electric cyan — max contrast on dark UIs"
                                            MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                    <Border x:Name="SwatchHighlightLime" Width="22" Height="22" CornerRadius="3"
                                            Background="#9DFF00" BorderBrush="#3A3A5A" BorderThickness="1"
                                            Margin="0,0,4,0" Cursor="Hand" Tag="#9DFF00"
                                            ToolTip="Lime — visible on pink/purple themes"
                                            MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                    <Border x:Name="SwatchHighlightOrange" Width="22" Height="22" CornerRadius="3"
                                            Background="#FF8A00" BorderBrush="#3A3A5A" BorderThickness="1"
                                            Margin="0,0,4,0" Cursor="Hand" Tag="#FF8A00"
                                            ToolTip="Amber orange — warm alternative"
                                            MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                    <Border x:Name="SwatchHighlightViolet" Width="22" Height="22" CornerRadius="3"
                                            Background="#B388FF" BorderBrush="#3A3A5A" BorderThickness="1"
                                            Margin="0,0,4,0" Cursor="Hand" Tag="#B388FF"
                                            ToolTip="Soft violet — matches SissyHypno theme"
                                            MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                    <Border x:Name="SwatchHighlightWhite" Width="22" Height="22" CornerRadius="3"
                                            Background="#FFFFFF" BorderBrush="#3A3A5A" BorderThickness="1"
                                            Margin="0,0,8,0" Cursor="Hand" Tag="#FFFFFF"
                                            ToolTip="Pure white — most neutral option"
                                            MouseLeftButtonDown="AwarenessHighlightSwatch_Click"/>
                                    <TextBox x:Name="TxtAwarenessHighlightHex" Width="74" FontSize="10"
                                             Background="#1E1E32" Foreground="White" BorderBrush="#3A3A5A"
                                             Padding="4,3" VerticalAlignment="Center"
                                             ToolTip="Custom hex color (e.g. #FF00AA). Type and press Enter or Tab to apply."
                                             LostFocus="TxtAwarenessHighlightHex_LostFocus"
                                             KeyDown="TxtAwarenessHighlightHex_KeyDown"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkAwarenessHighlightVisibleInCapture"
                                          Content="Visible in screen capture / streams"
                                          Foreground="#A0A0A0" FontSize="10" Margin="22,6,0,0"
                                          Checked="ChkAwarenessHighlightVisibleInCapture_Changed"
                                          Unchecked="ChkAwarenessHighlightVisibleInCapture_Changed">
                                    <CheckBox.ToolTip>
                                        <ToolTip>
                                            <StackPanel MaxWidth="340">
                                                <TextBlock Text="Visible in screen capture" Foreground="#FF69B4" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White">
                                                    Off (default): highlights render on your desktop but are excluded from screen capture via WDA_EXCLUDEFROMCAPTURE, so OBS, Discord, and screen recordings don't see them.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="White" Margin="0,6,0,0">
                                                    On: lets the highlights show up in recordings — useful for streaming or demos. Also a fallback if your GPU driver is one of the few that hides excluded windows from the desktop itself.
                                                </TextBlock>
                                            </StackPanel>
                                        </ToolTip>
                                    </CheckBox.ToolTip>
                                </CheckBox>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ==================== ADVANCED LINK ==================== -->
                    <Grid Grid.Row="4" Margin="0,0,0,0"
                          ToolTip="Opens a detailed editor for the currently installed preset where you can add/remove keywords, tweak per-trigger actions, and edit phrase pools. If no preset is installed yet, this link opens the App Info &amp; Data popup instead.">
                        <TextBlock HorizontalAlignment="Center">
                            <Hyperlink x:Name="LnkAwarenessAdvanced"
                                       Foreground="{DynamicResource PinkBrush}"
                                       TextDecorations="Underline"
                                       Click="LnkAwarenessAdvanced_Click">
                                <Run x:Name="LnkAwarenessAdvancedText" Text="Customize individual triggers (advanced) →"/>
                            </Hyperlink>
                        </TextBlock>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <!-- Translucent gating overlay (only for free users) -->
            <Border x:Name="AwarenessGate" Visibility="Collapsed"
                    Background="#99000010" BorderBrush="#FF69B4" BorderThickness="2"
                    CornerRadius="10" IsHitTestVisible="True">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Str gate_premium_locked}" FontSize="22"
                               FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Str gate_premium_subtitle}" FontSize="14"
                               Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                    <Button Content="{loc:Str gate_unlock_with_patreon}"
                            Click="BtnGateUnlock_Click" Padding="20,8" Background="#FF69B4"
                            Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
                </StackPanel>
            </Border>
          </Grid>
        </ContentControl>

        <!-- Remote Control Tab — Patreon premium feature, full redesign with QR pairing -->
        <ContentControl x:Name="RemoteControlTab" Grid.Row="4" Margin="10,5,10,10"
                        Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="36,28,36,28" MaxWidth="1280" HorizontalAlignment="Center">

                    <!-- Header -->
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🎮" FontSize="40" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str tab_remote_control}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="HelpBtnRemoteControl" Style="{StaticResource HelpButtonStyle}"
                                    VerticalAlignment="Center" Margin="0,0,8,0" Tag="RemoteControl"/>
                            <CheckBox x:Name="ChkRemoteControlEnabled" Style="{StaticResource ToggleStyle}"
                                      VerticalAlignment="Center"
                                      Checked="ChkRemoteControlEnabled_Changed" Unchecked="ChkRemoteControlEnabled_Changed"/>
                        </StackPanel>
                    </Grid>

                    <!-- Description card (always visible) -->
                    <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="24,20" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="28"
                                    Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                                    BorderThickness="2" VerticalAlignment="Top">
                                <TextBlock Text="🎮" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Str label_what_is_this}" Foreground="{DynamicResource PinkBrush}"
                                           FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="{loc:Str desc_remote_control}" Foreground="White" FontSize="15"
                                           TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="22"/>
                                <TextBlock Text="{loc:Str desc_remote_control_bullets}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Interactive controls + translucent gating overlay -->
                    <Grid>
                        <StackPanel x:Name="RemoteControlControls">

                            <!-- Tier comparison cards (3 across) -->
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="TierCardLight" Grid.Column="0" Background="{DynamicResource SurfaceBgBrush}"
                                        BorderBrush="#FF69B4" BorderThickness="2" CornerRadius="10" Padding="20,16"
                                        MinHeight="140" Cursor="Hand" Tag="0" MouseLeftButtonUp="TierCard_Click">
                                    <StackPanel>
                                        <TextBlock Text="✨" FontSize="26"/>
                                        <TextBlock Text="{loc:Str label_remote_tier_light}" Foreground="White"
                                                   FontSize="17" FontWeight="Bold" Margin="0,6,0,6"/>
                                        <TextBlock Text="Visual triggers only"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="• Flashes • Subliminals • Overlays" Foreground="#A0A0A0"
                                                   FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="TierCardStandard" Grid.Column="2" Background="{DynamicResource SurfaceBgBrush}"
                                        BorderBrush="#2E2E48" BorderThickness="1" CornerRadius="10" Padding="20,16"
                                        MinHeight="140" Cursor="Hand" Tag="1" MouseLeftButtonUp="TierCard_Click">
                                    <StackPanel>
                                        <TextBlock Text="🎯" FontSize="26"/>
                                        <TextBlock Text="{loc:Str label_remote_tier_standard}" Foreground="White"
                                                   FontSize="17" FontWeight="Bold" Margin="0,6,0,6"/>
                                        <TextBlock Text="Light + audio + overlays"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="• Videos • Haptics • Audio ducking" Foreground="#A0A0A0"
                                                   FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="TierCardFull" Grid.Column="4" Background="{DynamicResource SurfaceBgBrush}"
                                        BorderBrush="#2E2E48" BorderThickness="1" CornerRadius="10" Padding="20,16"
                                        MinHeight="140" Cursor="Hand" Tag="2" MouseLeftButtonUp="TierCard_Click">
                                    <StackPanel>
                                        <TextBlock Text="🔥" FontSize="26"/>
                                        <TextBlock Text="{loc:Str label_remote_tier_full}" Foreground="White"
                                                   FontSize="17" FontWeight="Bold" Margin="0,6,0,6"/>
                                        <TextBlock Text="Everything including session control"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="• Bambi Takeover • Sessions • Lockdown" Foreground="#A0A0A0"
                                                   FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Hidden ComboBox keeps existing handler wiring intact -->
                            <ComboBox x:Name="CmbRemoteTier" Visibility="Collapsed"
                                      SelectionChanged="CmbRemoteTier_SelectionChanged">
                                <ComboBoxItem Content="Light" IsSelected="True"/>
                                <ComboBoxItem Content="Standard"/>
                                <ComboBoxItem Content="Full"/>
                            </ComboBox>

                            <!-- Pairing hero panel: 2 columns (code 60% / QR 40%) -->
                            <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="28,24" Margin="0,0,0,22">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: code + PIN + buttons -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="SESSION CODE" Foreground="#8A8AA0" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="TxtRemoteCode" Text="- - - - - - - -"
                                                   Foreground="{DynamicResource PinkBrush}" FontSize="52"
                                                   FontWeight="Bold" FontFamily="Consolas"/>
                                        <TextBlock x:Name="TxtRemotePin" Text="" Foreground="{DynamicResource SecondaryBrush}"
                                                   FontSize="24" FontWeight="Bold" FontFamily="Consolas" Margin="0,6,0,0"
                                                   Visibility="Collapsed"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button x:Name="BtnCopyRemoteCode" Content="{loc:Str btn_copy}"
                                                    Background="#353550" Foreground="White" FontSize="13"
                                                    Padding="14,8" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnCopyRemoteCode_Click"/>
                                            <Button x:Name="BtnCopyRemoteLink" Content="{loc:Str btn_copy_link}"
                                                    Background="#353550" Foreground="White" FontSize="13"
                                                    Padding="14,8" Margin="10,0,0,0" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnCopyRemoteLink_Click"/>
                                        </StackPanel>
                                        <Border x:Name="RemoteLinkPanel" Visibility="Collapsed"/>
                                        <Border x:Name="RemoteCodePanel" Visibility="Collapsed"/>
                                    </StackPanel>

                                    <!-- Right: QR code with themed frame -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border CornerRadius="8" Background="White" Padding="12"
                                                BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2">
                                            <Image x:Name="ImgRemoteQrCode" Width="220" Height="220" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="{loc:Str label_remote_pairing}"
                                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Status row: Controller info (left) + Command log (right) -->
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Connected controller card -->
                                <Border Grid.Column="0" Background="{DynamicResource SurfaceBgBrush}"
                                        BorderBrush="#2E2E48" BorderThickness="1"
                                        CornerRadius="10" Padding="20,16">
                                    <StackPanel x:Name="ControllerInfoPanel">
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="{loc:Str label_remote_controller_info}"
                                                       Foreground="#8A8AA0" FontSize="12" FontWeight="Bold"/>
                                            <StackPanel x:Name="RemoteStatusPanel" Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Ellipse x:Name="RemoteStatusDot" Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="TxtRemoteStatus" Text="{loc:Str label_remote_idle}" Foreground="#A0A0A0" FontSize="13"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Command log -->
                                <Border Grid.Column="2" Background="{DynamicResource SurfaceBgBrush}"
                                        BorderBrush="#2E2E48" BorderThickness="1"
                                        CornerRadius="10" Padding="20,16">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str label_remote_command_log}"
                                                   Foreground="#8A8AA0" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <ListBox x:Name="LstRemoteCommandLog" Background="Transparent" BorderThickness="0"
                                                 Foreground="White" FontSize="13" MaxHeight="260"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Stop session button -->
                            <Button x:Name="BtnStopRemote" Content="{loc:Str btn_stop_session}" Background="#FF4444"
                                    Foreground="White" FontWeight="Bold" FontSize="14" Padding="18,10"
                                    BorderThickness="0" Cursor="Hand" HorizontalAlignment="Stretch"
                                    Visibility="Collapsed"
                                    Click="BtnStopRemote_Click"/>

                            <!-- Hidden legacy container — kept so existing handlers don't NRE -->
                            <StackPanel x:Name="RemoteControlPanel" Visibility="Collapsed"/>

                        </StackPanel>

                        <!-- Translucent gating overlay (only for free users) -->
                        <Border x:Name="RemoteControlGate" Visibility="Collapsed"
                                Background="#99000010" BorderBrush="#FF69B4" BorderThickness="2"
                                CornerRadius="10" IsHitTestVisible="True">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Str gate_premium_locked}" FontSize="22"
                                           FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Str gate_premium_subtitle}" FontSize="14"
                                           Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                                <Button Content="{loc:Str gate_unlock_with_patreon}"
                                        Click="BtnGateUnlock_Click" Padding="20,8" Background="#FF69B4"
                                        Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </ContentControl>

        <!-- Bambi Takeover Tab — Patreon premium feature, visible-but-locked for free users -->
        <ContentControl x:Name="BambiTakeoverTab" Grid.Row="4" Margin="10,5,10,10"
                        Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="36,28,36,28" MaxWidth="1180" HorizontalAlignment="Center">
                <!-- Header -->
                <Grid Margin="0,0,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🤖" FontSize="40" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtBambiTakeoverHeader" Text="{loc:Str tab_bambi_takeover}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>

                <!-- Description card (always visible — even to free users) -->
                <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="24,20" Margin="0,0,0,22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="160" Height="160" CornerRadius="12" ClipToBounds="True"
                                BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2" VerticalAlignment="Top">
                            <Image x:Name="ImgBambiTakeoverDesc"
                                   Source="pack://application:,,,/Resources/features/bambi takeover.png"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str label_what_is_this}" Foreground="{DynamicResource PinkBrush}"
                                       FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Str desc_bambi_takeover}" Foreground="White" FontSize="15"
                                       TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="22"/>
                            <TextBlock Text="{loc:Str desc_bambi_takeover_bullets}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                       TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Interactive controls + translucent gating overlay -->
                <Grid>
                    <StackPanel x:Name="BambiTakeoverControls">
                <!-- Lifted from old Bambi Expander — every x:Name preserved -->
                <!-- Locked State (legacy — kept hidden, replaced by gating overlay below) -->
                <StackPanel x:Name="AutonomyLocked" Visibility="Collapsed">
                    <Grid>
                        <TextBlock x:Name="TxtTakeoverLocked" Text="{loc:Str label_bambi_takeover}" Foreground="#666666" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="TxtAutonomyLockStatus" Text="{loc:Str label_patreon_only}" Foreground="{DynamicResource SecondaryBrush}" HorizontalAlignment="Right" FontSize="11"/>
                    </Grid>
                    <TextBlock x:Name="TxtAutonomyLockMessage" Text="{loc:Str label_support_on_patreon_to_unlock}" Foreground="{DynamicResource PinkBrush}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Unlocked State — always visible now; gating handled by overlay -->
                <StackPanel x:Name="AutonomyUnlocked" Visibility="Visible">
                    <StackPanel x:Name="AutonomySettings">

                        <!-- ============ SUBSECTION 1: CADENCE ============ -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                                BorderThickness="1" CornerRadius="10" Padding="20,16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{loc:Str setting_interval}" Foreground="{DynamicResource PinkBrush}"
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" ToolTip="{loc:Str tooltip_autonomy_interval}">
                                        <Grid><TextBlock Text="{loc:Str setting_interval}" Foreground="#AAA" FontSize="12"/><TextBlock x:Name="TxtAutonomyInterval" Text="{loc:Str label_60s}" Foreground="{DynamicResource PinkBrush}" FontSize="12" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="SliderAutonomyInterval" Minimum="30" Maximum="300" Value="60" Height="22" ValueChanged="SliderAutonomyInterval_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" ToolTip="{loc:Str tooltip_autonomy_cooldown}">
                                        <Grid><TextBlock Text="{loc:Str label_cooldown}" Foreground="#AAA" FontSize="12"/><TextBlock x:Name="TxtAutonomyCooldown" Text="{loc:Str label_30s}" Foreground="{DynamicResource PinkBrush}" FontSize="12" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="SliderAutonomyCooldown" Minimum="10" Maximum="300" Value="30" Height="22" ValueChanged="SliderAutonomyCooldown_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0" ToolTip="{loc:Str tooltip_autonomy_intensity}">
                                        <Grid><TextBlock Text="{loc:Str setting_intensity}" Foreground="#AAA" FontSize="12"/><TextBlock x:Name="TxtAutonomyIntensity" Text="5" Foreground="{DynamicResource PinkBrush}" FontSize="12" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="SliderAutonomyIntensity" Minimum="1" Maximum="10" Value="5" Height="22" ValueChanged="SliderAutonomyIntensity_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" ToolTip="{loc:Str tooltip_autonomy_announce}">
                                        <Grid><TextBlock Text="{loc:Str label_announce}" Foreground="#AAA" FontSize="12"/><TextBlock x:Name="TxtAutonomyAnnounce" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="SliderAutonomyAnnounce" Minimum="0" Maximum="100" Value="50" Height="22" ValueChanged="SliderAutonomyAnnounce_Changed"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ============ SUBSECTION 2: TRIGGERS ============ -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                                BorderThickness="1" CornerRadius="10" Padding="20,16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_triggers}" Foreground="{DynamicResource PinkBrush}"
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_idle}"><TextBlock Text="{loc:Str label_idle}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyIdle" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyIdle_Changed" Unchecked="ChkAutonomyIdle_Changed"/></Grid>
                                    <Grid Grid.Column="2" Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_random}"><TextBlock Text="{loc:Str label_random_2}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyRandom" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyRandom_Changed" Unchecked="ChkAutonomyRandom_Changed"/></Grid>
                                    <Grid Grid.Column="4" Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_time_aware}"><TextBlock Text="{loc:Str label_time_aware}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyTimeAware" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyTimeAware_Changed" Unchecked="ChkAutonomyTimeAware_Changed"/></Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ============ SUBSECTION 3: BEHAVIORS ============ -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                                BorderThickness="1" CornerRadius="10" Padding="20,16" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{loc:Str label_basic}" Foreground="{DynamicResource PinkBrush}" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Grid.Column="2" Text="{loc:Str label_advanced_2}" Foreground="{DynamicResource PinkBrush}" FontWeight="Bold" FontSize="13"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Basic column -->
                                    <StackPanel Grid.Column="0">
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_flash}"><TextBlock x:Name="TxtAutoFlash" Text="{loc:Str tab_flashes}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyFlash" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_video}"><TextBlock x:Name="TxtAutoVideo" Text="{loc:Str tab_videos}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyVideo" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_auto_plays_hypnotube_videos_fullscreen}"><TextBlock Text="{loc:Str label_web_videos}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyWebVideo" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_subliminal}"><TextBlock x:Name="TxtAutoSubliminal" Text="{loc:Str tab_subliminals}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomySubliminal" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_comment}"><TextBlock Text="{loc:Str label_comments}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyComment" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                    </StackPanel>
                                    <!-- Advanced column -->
                                    <StackPanel Grid.Column="2">
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_bubbles}"><TextBlock x:Name="TxtAutoBubbles" Text="{loc:Str label_bubbles}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyBubbles" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_pink_filter}"><TextBlock x:Name="TxtAutoPinkFilter" Text="{loc:Str label_pink_filter_2}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyPinkFilter" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_lock_cards}"><TextBlock x:Name="TxtAutoLockCards" Text="{loc:Str label_lock_cards}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyLockCard" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_bouncing_text}"><TextBlock x:Name="TxtAutoBouncing" Text="{loc:Str label_bouncing}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyBouncingText" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                        <Grid Margin="0,2" ToolTip="{loc:Str tooltip_autonomy_mind_wipe}"><TextBlock x:Name="TxtAutoMindwipe" Text="{loc:Str label_mindwipe}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/><CheckBox x:Name="ChkAutonomyMindWipe" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/></Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ============ SUBSECTION 4: CONTROLS ============ -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48"
                                BorderThickness="1" CornerRadius="10" Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnAutonomyStartStop" Grid.Column="0" Content="{loc:Str btn_start_2}" Background="#2A1A3A" Foreground="#90EE90"
                                        FontWeight="Bold" FontSize="14" Padding="14,8"
                                        Click="BtnAutonomyStartStop_Click" ToolTip="{loc:Str tooltip_start_stop_bambi_takeover}"/>
                                <Button Grid.Column="2" Content="{loc:Str btn_test}" Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="14"
                                        Padding="14,8" Click="BtnTestAutonomy_Click" ToolTip="{loc:Str tooltip_test_action}"/>
                            </Grid>
                        </Border>

                        <!-- Hidden elements -->
                        <TextBlock x:Name="TxtTakeoverUnlocked" Visibility="Collapsed"/>
                        <CheckBox x:Name="ChkAutonomySpiral" Visibility="Collapsed" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/>
                        <CheckBox x:Name="ChkAutonomyBubbleCount" Visibility="Collapsed" Checked="ChkAutonomyBehavior_Changed" Unchecked="ChkAutonomyBehavior_Changed"/>
                        <Button x:Name="BtnForceStartAutonomy" Visibility="Collapsed" Click="BtnForceStartAutonomy_Click"/>
                        <CheckBox x:Name="ChkAutonomyEnabled" Visibility="Collapsed" Checked="ChkAutonomyEnabled_Changed" Unchecked="ChkAutonomyEnabled_Changed"/>
                    </StackPanel>
                </StackPanel>
                    </StackPanel>

                    <!-- Translucent gating overlay (only for free users) -->
                    <Border x:Name="BambiTakeoverGate" Visibility="Collapsed"
                            Background="#99000010" BorderBrush="#FF69B4" BorderThickness="2"
                            CornerRadius="10" IsHitTestVisible="True">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Str gate_premium_locked}" FontSize="22"
                                       FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Str gate_premium_subtitle}" FontSize="14"
                                       Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,4,0,12"/>
                            <Button Content="{loc:Str gate_unlock_with_patreon}"
                                    Click="BtnGateUnlock_Click" Padding="20,8" Background="#FF69B4"
                                    Foreground="White" FontWeight="Bold" Cursor="Hand" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                </StackPanel>
            </ScrollViewer>
        </ContentControl>

        <!-- Haptics Tab — Patreon premium feature, visible-but-locked for free users -->
        <ContentControl x:Name="HapticsTab" Grid.Row="4" Margin="10,5,10,10"
                        Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="36,28,36,28" MaxWidth="1280" HorizontalAlignment="Center">

                    <!-- Header -->
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💜" FontSize="40" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Str tab_haptics}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Description card (always visible) -->
                    <Border Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource PinkBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="24,20" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="160" Height="160" CornerRadius="12" ClipToBounds="True"
                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="2" VerticalAlignment="Top">
                                <Image x:Name="ImgHapticsVibeDesc"
                                       Source="pack://application:,,,/Resources/features/vibe.png"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Str label_what_is_this}" Foreground="{DynamicResource PinkBrush}"
                                           FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="{loc:Str desc_haptics}" Foreground="White" FontSize="15"
                                           TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="22"/>
                                <TextBlock Text="{loc:Str desc_haptics_bullets}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Interactive controls + translucent gating overlay -->
                    <Grid>
                        <Grid>
                    <!-- Haptics Content (enabled for Patreon supporters) -->
                    <Grid x:Name="HapticsContentGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ============ SECTION 1: CONNECTION ============ -->
                    <Grid Grid.Row="0">
                        <Border x:Name="HapticsConnectionBox" CornerRadius="10" Padding="22,18"
                                Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48" BorderThickness="1">
                            <StackPanel>
                                <!-- Header: title + master toggle -->
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔌" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{loc:Str label_haptic_connection}" Foreground="{DynamicResource PinkBrush}"
                                                   FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button x:Name="HelpBtnHaptics" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="Haptics"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str btn_enable}" Foreground="#AAA" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <CheckBox x:Name="ChkHapticsEnabled" Style="{StaticResource ToggleStyle}"
                                                  VerticalAlignment="Center"
                                                  Checked="ChkHapticsEnabled_Changed" Unchecked="ChkHapticsEnabled_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Provider + URL + Connect (single horizontal row) -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str label_provider}" Foreground="White" FontSize="13"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="CmbHapticProvider" Grid.Column="1" Padding="8,4" FontSize="13"
                                              Background="{DynamicResource SurfaceBgBrush}" Foreground="Black" BorderThickness="0"
                                              SelectionChanged="CmbHapticProvider_SelectionChanged">
                                        <ComboBoxItem Content="{loc:Str btn_lovense_connect}" Tag="Lovense" Foreground="Black"/>
                                        <ComboBoxItem Content="{loc:Str btn_buttplug_io_intiface}" Tag="Buttplug" Foreground="Black"/>
                                    </ComboBox>
                                    <TextBox x:Name="TxtHapticUrl" Grid.Column="3"
                                             Background="#FFFFFF" Foreground="Black" BorderThickness="1"
                                             BorderBrush="{DynamicResource PanelAccentBrush}" Padding="8,6" FontSize="13"
                                             VerticalContentAlignment="Center"
                                             TextChanged="TxtHapticUrl_TextChanged">
                                        <TextBox.ToolTip>
                                            <ToolTip Background="{DynamicResource SurfaceBgBrush}" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" Padding="12">
                                                <StackPanel MaxWidth="280">
                                                    <TextBlock Text="{loc:Str label_connection_guide}" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                                                    <TextBlock Text="{loc:Str label_lovense_connect}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Foreground="#CCCCCC" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,6">
                                                        <Run Text="1."/><Run Text="{loc:Str label_open_lovense_remote_app}" Foreground="White"/>
                                                        <LineBreak/><Run Text="2."/><Run Text="{loc:Str label_go_to_settings_game_mode}" Foreground="White"/>
                                                        <LineBreak/><Run Text="3."/><Run Text="{loc:Str label_enable_game_mode_note_the_ip}" Foreground="White"/>
                                                        <LineBreak/><Run Text="4."/><Run Text="{loc:Str label_enter_http_ip_30010}" Foreground="{DynamicResource PinkBrush}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{loc:Str label_buttplug_io_intiface}" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Foreground="#CCCCCC" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0">
                                                        <Run Text="1."/><Run Text="{loc:Str label_open_intiface_central}" Foreground="White"/>
                                                        <LineBreak/><Run Text="2."/><Run Text="{loc:Str label_click_start_server}" Foreground="White"/>
                                                        <LineBreak/><Run Text="3."/><Run Text="{loc:Str label_click_start_scanning_for_devices}" Foreground="White"/>
                                                        <LineBreak/><Run Text="4."/><Run Text="{loc:Str label_use_ws_localhost_12345}" Foreground="{DynamicResource PinkBrush}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </TextBox.ToolTip>
                                    </TextBox>
                                    <Button x:Name="BtnHapticConnect" Grid.Column="5" Content="{loc:Str btn_connect}"
                                            Background="{DynamicResource PinkBrush}" Foreground="White"
                                            BorderThickness="0" Padding="18,8"
                                            FontSize="13" FontWeight="Bold" Cursor="Hand"
                                            Click="BtnHapticConnect_Click"/>
                                </Grid>

                                <!-- URL hint + auto-connect (single row) -->
                                <Grid Margin="0,0,0,14">
                                    <TextBlock x:Name="TxtHapticUrlHint"
                                               Text="{loc:Str label_lovense_enter_ip_from_lovense_remote_settings}"
                                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ChkHapticAutoConnect" Content="{loc:Str setting_auto_connect_on_startup}"
                                              Foreground="#CCCCCC" FontSize="12" HorizontalAlignment="Right"
                                              Checked="ChkHapticAutoConnect_Changed" Unchecked="ChkHapticAutoConnect_Changed"
                                              ToolTip="{loc:Str tooltip_automatically_connect_to_your_haptic_device_w}"/>
                                </Grid>

                                <!-- Status + Master Intensity + Test (in inset card) -->
                                <Border Background="{DynamicResource PanelBgBrush}" CornerRadius="8" Padding="16,12">
                                    <StackPanel>
                                        <!-- Status row -->
                                        <Grid Margin="0,0,0,10">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center" Fill="#FF6B6B"/>
                                                <TextBlock Text="{loc:Str label_status}" Foreground="{DynamicResource TextMutedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="TxtHapticStatus" Text="{loc:Str label_disconnected}"
                                                           Foreground="#FF6B6B" FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TxtHapticDevices" Text="{loc:Str label_no_devices}"
                                                       Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        <!-- Intensity slider + test -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{loc:Str label_intensity}" Foreground="White" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <Slider x:Name="SliderHapticIntensity" Grid.Column="1"
                                                    Style="{StaticResource PinkSlider}"
                                                    Minimum="0" Maximum="100" Value="70" VerticalAlignment="Center"
                                                    ValueChanged="SliderHapticIntensity_ValueChanged"/>
                                            <TextBlock x:Name="TxtHapticIntensity" Grid.Column="2" Text="70%"
                                                       Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Button x:Name="BtnHapticTest" Grid.Column="3" Content="{loc:Str btn_test_vibration}"
                                                    Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                                                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                                    Padding="14,8" Margin="12,0,0,0"
                                                    FontSize="13" FontWeight="Bold" Cursor="Hand"
                                                    Click="BtnHapticTest_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Help link -->
                                <Button x:Name="BtnHapticsHelp" Content="{loc:Str btn_need_help_setting_up}"
                                        HorizontalAlignment="Left" Margin="0,10,0,0" Background="Transparent"
                                        Foreground="{DynamicResource PinkBrush}" BorderThickness="0" FontSize="12"
                                        Cursor="Hand" Click="BtnHapticsHelp_Click" Padding="0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                   Foreground="{TemplateBinding Foreground}"
                                                                   FontSize="{TemplateBinding FontSize}"
                                                                   TextDecorations="Underline"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                        <!-- Lock Overlay (legacy, hidden — gating handled by HapticsGate) -->
                        <Border x:Name="HapticsConnectionLock" Background="#80000000" CornerRadius="10" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Str label_patreon_only_2}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ============ SECTION 2: PER-FEATURE INTENSITY ============ -->
                    <Grid Grid.Row="2">
                        <Border x:Name="HapticsFeatureBox" CornerRadius="10" Padding="22,18"
                                Background="{DynamicResource SurfaceBgBrush}" BorderBrush="#2E2E48" BorderThickness="1">
                            <StackPanel>
                                <!-- Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="✨" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                    <TextBox x:Name="TxtLockdownExit" Visibility="Collapsed"
                                             Background="#1A0A0A" Foreground="#DC143C" BorderBrush="#DC143C" BorderThickness="1"
                                             FontSize="12" Padding="6,4" Margin="0,6,0,0"
                                             KeyDown="TxtLockdownExit_KeyDown"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Quiz Training Card -->
                        <Border CornerRadius="12" Margin="6" Padding="15">

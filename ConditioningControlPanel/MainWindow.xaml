                                              Checked="ChkDualMon_Changed" Unchecked="ChkDualMon_Changed"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_multi_mon}" Margin="6,0,0,0"/>
                                </StackPanel>

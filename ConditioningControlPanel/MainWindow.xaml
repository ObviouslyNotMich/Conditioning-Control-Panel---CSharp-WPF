                                              Checked="ChkClickable_Changed" Unchecked="ChkClickable_Changed"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_click}" Margin="5,0,0,0" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,6,0"
                                            ToolTip="{loc:Str tooltip_hydra_mode_clicking_an_image_spawns_two_more}">
                                    <CheckBox x:Name="ChkCorruption" Style="{StaticResource ToggleStyle}"
                                              Checked="ChkCorruption_Changed" Unchecked="ChkCorruption_Changed"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_hydra}" Margin="5,0,0,0" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            ToolTip="{loc:Str tooltip_linked_hydra_spawns_share_the_parent_flash_ti}">
                                    <CheckBox x:Name="ChkHydraLinked" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                              Checked="ChkHydraLinked_Changed" Unchecked="ChkHydraLinked_Changed"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_linked}" Margin="5,0,0,0" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="6,0,0,0"
                                            ToolTip="{loc:Str tooltip_toggle_the_pink_sparkle_glow_effect_on_flash}">
                                    <CheckBox x:Name="ChkFlashGlow" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                              Checked="ChkFlashGlow_Changed" Unchecked="ChkFlashGlow_Changed"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_glow}" Margin="5,0,0,0" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                            <!-- Per Hour / Images in two columns -->
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" ToolTip="{loc:Str tooltip_how_many_flash_events_occur_per_hour_higher_v}">
                                    <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_per_hour}" FontSize="11"/><TextBlock x:Name="TxtPerMin" Style="{StaticResource ValueLabel}" Text="10" HorizontalAlignment="Right"/></Grid>
                                    <Slider x:Name="SliderPerMin" Minimum="1" Maximum="180" Value="10" Margin="0,1" ValueChanged="SliderPerMin_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" ToolTip="{loc:Str tooltip_number_of_images_shown_per_flash_event_multip}">
                                    <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_images}" FontSize="11"/><TextBlock x:Name="TxtImages" Style="{StaticResource ValueLabel}" Text="5" HorizontalAlignment="Right"/></Grid>
                                    <Slider x:Name="SliderImages" Minimum="1" Maximum="15" Value="5" Margin="0,1" ValueChanged="SliderImages_Changed"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Max On Screen -->
                            <Grid Margin="0,2,0,0" ToolTip="{loc:Str tooltip_maximum_images_displayed_at_once_limits_scree}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_max_on_screen}" FontSize="11"/>
                                <TextBlock x:Name="TxtMaxOnScreen" Grid.Column="1" Style="{StaticResource ValueLabel}" Text="20"/>
                            </Grid>
                            <Slider x:Name="SliderMaxOnScreen" Minimum="2" Maximum="20" Value="20" Margin="0,1" ValueChanged="SliderMaxOnScreen_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Visuals Section -->
                    <Border x:Name="VisualsSection" CornerRadius="12" Padding="10,6" Margin="0,0,0,6"
                            Background="{DynamicResource ElevatedSurfaceBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,2">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="{loc:Str section_visuals}" Margin="0"/>
                                <Button x:Name="HelpBtnVisuals" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Visuals"/>
                            </Grid>
                            
                            <!-- Size / Opacity in two columns -->
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" ToolTip="{loc:Str tooltip_scale_of_flash_images_100_original_size_200_d}">
                                    <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_size}" FontSize="11"/><TextBlock x:Name="TxtSize" Style="{StaticResource ValueLabel}" Text="100%" HorizontalAlignment="Right"/></Grid>
                                    <Slider x:Name="SliderSize" Minimum="50" Maximum="250" Value="100" Margin="0,1" ValueChanged="SliderSize_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" ToolTip="{loc:Str tooltip_transparency_of_flash_images_lower_more_see_t}">
                                    <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_opacity}" FontSize="11"/><TextBlock x:Name="TxtOpacity" Style="{StaticResource ValueLabel}" Text="100%" HorizontalAlignment="Right"/></Grid>
                                    <Slider x:Name="SliderOpacity" Minimum="10" Maximum="100" Value="100" Margin="0,1" ValueChanged="SliderOpacity_Changed"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Fade / Duration in two columns -->
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" ToolTip="{loc:Str tooltip_fade_in_out_animation_speed_0_instant_appear}">
                                    <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_fade}" FontSize="11"/><TextBlock x:Name="TxtFade" Style="{StaticResource ValueLabel}" Text="50%" HorizontalAlignment="Right"/></Grid>
                                    <Slider x:Name="SliderFade" Minimum="0" Maximum="100" Value="50" Margin="0,1" ValueChanged="SliderFade_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" ToolTip="{loc:Str tooltip_how_long_images_stay_on_screen_only_used_when}">
                                    <Grid><TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_duration}" FontSize="11"/><TextBlock x:Name="TxtFlashDuration" Style="{StaticResource ValueLabel}" Text="{loc:Str setting_5s}" HorizontalAlignment="Right"/></Grid>
                                    <Slider x:Name="SliderFlashDuration" Minimum="1" Maximum="30" Value="5" Margin="0,1" ValueChanged="SliderFlashDuration_Changed"/>
                                </StackPanel>
                            </Grid>
                            

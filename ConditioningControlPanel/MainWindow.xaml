                                <GradientStop x:Name="Stop2" Color="{DynamicResource AccentMidGradient}" Offset="0.5"/>
                                <GradientStop x:Name="Stop3" Color="{DynamicResource DarkerBg}" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Multiple Radial Glow Effects spread across tab -->
                    <Ellipse x:Name="GlowPink1" Width="400" Height="300" Opacity="0.1"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-80,0,0">

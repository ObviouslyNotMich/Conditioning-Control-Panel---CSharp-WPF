                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A32" Offset="0"/>
                                    <GradientStop Color="#201A38" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource PatreonPurple}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>2</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{loc:Str label_quiz_training}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{loc:Str label_beta_2}" Foreground="{DynamicResource SecondaryBrush}" FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="HelpBtnQuiz" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="Quiz"/>
                                </Grid>
                                <TextBlock Text="{loc:Str label_ai_generated_personality_quiz_10_questions_th}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <CheckBox x:Name="ChkQuizFullscreen" Content="{loc:Str btn_fullscreen}" IsChecked="True"
                                          Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,4"/>
                                <CheckBox x:Name="ChkQuizDrone" Content="{loc:Str setting_play_drone_in_background}" IsChecked="False"
                                          Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,10"/>

                                <Button x:Name="BtnStartQuiz" Content="{loc:Str btn_start_quiz}" Cursor="Hand"

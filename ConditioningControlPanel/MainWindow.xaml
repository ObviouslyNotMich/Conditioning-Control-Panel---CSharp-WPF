                                        BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                        Click="BtnStartQuiz_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <TextBlock Text="{loc:Str label_past_quizzes}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,10,0,4"
                                           x:Name="TxtPastQuizzesHeader" Visibility="Collapsed"/>
                                <Border MaxHeight="130" CornerRadius="6" x:Name="PastQuizzesPanel" Visibility="Collapsed"
                                        Background="#10FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="PastQuizzesList"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Pop Quiz Card -->
                        <Border CornerRadius="12" Margin="6" Padding="15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource TransparentPink20}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource TransparentPink20}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{DynamicResource TransparentPink40}"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>1</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_pop_quiz}" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                                <TextBlock Text="{loc:Str label_reinforcement_questions_pop_up_during_session}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <CheckBox x:Name="ChkPopQuizEnabled" Content="{loc:Str setting_enable_pop_up_questions}"
                                          Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,0,8"
                                          Checked="ChkPopQuizEnabled_Changed" Unchecked="ChkPopQuizEnabled_Changed"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{loc:Str label_frequency}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderPopQuizFrequency" Minimum="1" Maximum="100" Width="120"

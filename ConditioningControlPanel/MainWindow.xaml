                                                <Image x:Name="ImgStatVideos" Source="pack://application:,,,/Resources/achievements/10_hours_pink.png" Stretch="Uniform" Margin="3"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Str label_videos}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtProfileViewerVideos" Text="{loc:Str label_0h}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- GIFs with image -->
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" Orientation="Horizontal">
                                            <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                                <Image x:Name="ImgStatGifs" Source="pack://application:,,,/Resources/achievements/retinal_burn.png" Stretch="Uniform" Margin="3"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Str label_flashes}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtProfileViewerGifs" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Lock Cards with image -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                                <Image x:Name="ImgStatLockCards" Source="pack://application:,,,/Resources/achievements/total_lockdown.png" Stretch="Uniform" Margin="3"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Str label_lock_cards_2}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtProfileViewerLockCards" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Achievements with image -->
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                            <Border Width="64" Height="64" CornerRadius="8" Background="{DynamicResource PanelAccentBrush}" Margin="0,0,12,0">
                                                <Image x:Name="ImgStatAchievements" Source="pack://application:,,,/Resources/achievements/spiral_eyes.png" Stretch="Uniform" Margin="3"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Str label_achievements}" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold"/>
                                                <TextBlock x:Name="TxtProfileViewerAchievements" Text="0" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Achievement Images Grid -->
                                <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="{loc:Str label_achievements}" Foreground="#5865F2" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="ProfileAchievementGrid">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="80" Height="80" Margin="4" CornerRadius="8"
                                                            Background="{DynamicResource PanelAccentBrush}" ToolTip="{Binding Name}">
                                                        <Image Source="{Binding Image}" Stretch="Uniform" Margin="4"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock x:Name="TxtNoAchievements" Text="{loc:Str label_no_achievements_yet}"
                                                   Foreground="#606080" FontSize="11" FontStyle="Italic"
                                                   HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        </Grid>

                        <!-- No profile selected message -->
                        <Border x:Name="NoProfileSelected" Background="{DynamicResource SurfaceBgBrush}" CornerRadius="10" Padding="30">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="{loc:Str label_search_for_a_user}" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" HorizontalAlignment="Center"/>
                                <TextBlock Text="{loc:Str label_or_click_my_profile}" Foreground="#606080" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>            <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SectionPanel}" BorderBrush="#5865F2" BorderThickness="1"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="10"><TextBlock Text="{loc:Str label_community_settings}" Foreground="#5865F2" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/><Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,12" BorderBrush="#5865F2" BorderThickness="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center"><TextBlock x:Name="TxtDiscordTabStatus" Text="{loc:Str label_not_connected}" Foreground="White" FontSize="14" FontWeight="Bold"/><TextBlock x:Name="TxtDiscordTabInfo" Text="{loc:Str label_link_discord_for_community_features}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/></StackPanel><Button x:Name="BtnDiscordTabLogin" Grid.Column="1" Content="{loc:Str btn_login}" Background="#5865F2" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" FontSize="11" Cursor="Hand" Click="BtnDiscordTabLogin_Click"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_discord_rich_presence}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_show_your_activity_status}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabRichPresence" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkDiscordRichPresence_Changed" Unchecked="ChkDiscordRichPresence_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_show_level_in_status}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_display_your_level}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShowLevel" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True" Checked="ChkShowLevelInPresence_Changed" Unchecked="ChkShowLevelInPresence_Changed"/></Grid></Border><TextBlock Text="{loc:Str label_community_sharing}" Foreground="#5865F2" FontSize="13" FontWeight="Bold" Margin="0,12,0,10"/><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_share_achievements}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_post_achievements_to_discord}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShareAchievements" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareAchievements_Changed" Unchecked="ChkShareAchievements_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_share_level_milestones}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_post_level_ups_to_discord}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShareLevelUps" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareLevelUps_Changed" Unchecked="ChkShareLevelUps_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_allow_dms_from_leaderboard}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_let_others_message_you}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabAllowDm" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkAllowDiscordDm_Changed" Unchecked="ChkAllowDiscordDm_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_share_profile_picture}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_show_your_avatar_to_others}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabSharePfp" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkShareProfilePicture_Changed" Unchecked="ChkShareProfilePicture_Changed"/></Grid></Border><Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"><Grid><StackPanel><TextBlock Text="{loc:Str label_show_online_status}" Foreground="White" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="{loc:Str label_appear_offline_when_disabled}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10"/></StackPanel><CheckBox x:Name="ChkDiscordTabShowOnline" Style="{StaticResource ToggleStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True" Checked="ChkShowOnlineStatus_Changed" Unchecked="ChkShowOnlineStatus_Changed"/></Grid></Border><TextBlock Text="{loc:Str label_all_sharing_is_opt_in}" Foreground="#5865F2" FontSize="10" FontStyle="Italic" Margin="0,10,0,0"/><Button Content="{loc:Str btn_join_discord_server}" Background="#5865F2" Foreground="White" BorderThickness="0" Padding="15,12" Margin="0,15,0,0" FontWeight="Bold" FontSize="12" Cursor="Hand" Click="BtnDiscord_Click"/></StackPanel></ScrollViewer></Border>
            </Grid>
        </ContentControl>
        <!-- Lab Tab -->
        <ContentControl x:Name="LabTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Header -->
                    <TextBlock Text="{loc:Str label_the_lab}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,4">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FF88" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="{loc:Str label_experimental_features_and_special_modes}" Foreground="{DynamicResource TextDimBrush}" FontSize="12" Margin="0,0,0,16"/>

                    <!-- 2x2 Modes Grid -->
                    <UniformGrid Rows="2" Columns="2">
                        <!-- Lockdown Mode Card -->
                        <Border x:Name="LockdownCardBorder" CornerRadius="12" Margin="6" Padding="15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A1A32" Offset="0"/>
                                    <GradientStop Color="#201A38" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PatreonPurple}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>
                                <Thickness>2</Thickness>
                            </Border.BorderThickness>
                            <StackPanel>
                                <Border x:Name="LockdownImageBorder" CornerRadius="10" Margin="0,0,0,12"
                                        BorderThickness="2" ClipToBounds="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="#12FFFFFF"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="LockdownImageBorderBrush" Color="#FF1493"/>
                                    </Border.BorderBrush>
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="LockdownImageGlow" Color="#FF1493" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                    </Border.Effect>
                                    <!-- Lockdown pulse managed in code-behind (StartLockdownPulse/StopLockdownPulse) -->
                                    <Image Source="Resources/lockdown_icon.png" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                                <TextBlock Text="{loc:Str label_lockdown_mode}" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                                <TextBlock Text="{loc:Str label_lock_yourself_into_a_timed_conditioning_sessi}"
                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <!-- Setup Panel (visible when lockdown is NOT active) -->
                                <StackPanel x:Name="LockdownSetupPanel">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="{loc:Str label_duration_2}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CmbLockdownDuration" Width="120" SelectedIndex="1"
                                                  Background="{DynamicResource DarkerBgBrush}" Foreground="Black" FontSize="12" BorderBrush="{DynamicResource PanelAccentBrush}">
                                            <ComboBoxItem Content="{loc:Str btn_5_minutes}" Tag="5" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_10_minutes}" Tag="10" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_15_minutes}" Tag="15" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str label_30_minutes}" Tag="30" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_60_minutes}" Tag="60" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_2_hours}" Tag="120" Foreground="Black"/>
                                            <ComboBoxItem Content="{loc:Str btn_4_hours}" Tag="240" Foreground="Black"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button x:Name="BtnActivateLockdown" Content="{loc:Str btn_activate}" Cursor="Hand"
                                            Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="12"
                                            BorderThickness="0" Padding="12,8" HorizontalAlignment="Left"
                                            Click="BtnActivateLockdown_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- Active Panel (visible when lockdown IS active) -->
                                <StackPanel x:Name="LockdownActivePanel" Visibility="Collapsed">
                                    <TextBlock Text="{loc:Str label_lockdown_active}" Foreground="#DC143C" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtLockdownTimer" Text="00:00" Foreground="#DC143C" FontWeight="Bold" FontSize="28"

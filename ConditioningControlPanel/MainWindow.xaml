                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock x:Name="TxtCompanion4Name" Text="{loc:Str label_bambi_cow}" Foreground="#F5DEB3" FontSize="12" FontWeight="SemiBold"/>
                                                        <TextBlock x:Name="TxtCompanion4Lock" Text=" [75]" Foreground="#FFD700" FontSize="9"
                                                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="TxtCompanion4Level" Text="{loc:Str label_lv_1}" Foreground="#AAAAAA" FontSize="12"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="{loc:Str label_session_completion_bonus}" Foreground="{DynamicResource TextDimBrush}" FontSize="10" Margin="0,4,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Button x:Name="BtnCompanion4Personality" Content="🎭" FontSize="10" Padding="4,1"
                                                            Background="{DynamicResource DarkerBgBrush}" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                                            PreviewMouseLeftButtonDown="BtnCompanionPersonality_Click" Tag="4" ToolTip="{loc:Str tooltip_assign_ai_personality}"/>
                                                    <TextBlock x:Name="TxtCompanion4Prompt" Text="" Foreground="#555" FontSize="9"
                                                               VerticalAlignment="Center" Margin="4,0,0,0" TextTrimming="CharacterEllipsis"
                                                               MaxWidth="80"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <!-- Active Companion Info -->
                                    <Border CornerRadius="8" Padding="12" BorderBrush="{DynamicResource TransparentPink20Brush}" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#16162B" Offset="0"/>
                                                <GradientStop Color="#1C1635" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel>
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="TxtActiveCompanionName" Text="{loc:Str label_bambi_sprite}" Foreground="White"
                                                               FontSize="14" FontWeight="Bold"/>
                                                    <TextBlock x:Name="TxtActiveCompanionLevel" Text="{loc:Str label_level_1}" Foreground="#888"
                                                               FontSize="14"/>
                                                </StackPanel>
                                                <TextBlock x:Name="TxtActiveCompanionXP" Text="{loc:Str label_0_550_xp}" Foreground="{DynamicResource PinkBrush}"
                                                           FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <ProgressBar x:Name="PrgCompanion0" Height="6" Margin="0,8,0,0" Value="0"
                                                         Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}"/>
                                            <TextBlock x:Name="TxtActiveCompanionDesc" Text="{loc:Str label_gains_bonus_xp_based_on_pink_filter_intensity}"
                                                       Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="TxtCompanionStatus" Text="" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- COMMUNITY PROMPTS BOX -->
                            <Border Grid.Column="2" CornerRadius="12" Padding="15"
                                    Background="{DynamicResource ElevatedSurfaceBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{loc:Str label_community_prompts}" Foreground="#9370DB" FontSize="14" FontWeight="Bold"/>
                                            <Border Background="#FF6B6B" CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Str label_beta}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                            <Button x:Name="HelpBtnPrompts" Style="{StaticResource HelpButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" Tag="CommunityPrompts"/>
                                        </StackPanel>
                                        <Button x:Name="BtnRefreshPrompts" Content="{loc:Str btn_refresh}" HorizontalAlignment="Right"
                                                Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                                FontSize="11" Padding="8,2" Cursor="Hand" Click="BtnRefreshPrompts_Click"/>
                                    </Grid>

                                    <!-- Active Prompt -->
                                    <Border CornerRadius="8" Padding="12" Margin="0,0,0,10" BorderBrush="#339370DB" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#16162B" Offset="0"/>
                                                <GradientStop Color="#1C1635" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{loc:Str label_active_personality}" Foreground="{DynamicResource TextDimBrush}" FontSize="11"/>
                                                <TextBlock x:Name="TxtActivePromptName" Text="{loc:Str label_default_built_in}" Foreground="White"
                                                           FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Button x:Name="BtnDeactivatePrompt" Content="{loc:Str btn_reset}" HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource TextMutedBrush}" BorderThickness="0"
                                                    FontSize="11" Padding="10,4" Cursor="Hand" Visibility="Collapsed"
                                                    Click="BtnDeactivatePrompt_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- Installed List -->
                                    <TextBlock Text="{loc:Str label_installed_prompts}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,0,0,6"/>
                                    <Border CornerRadius="8" Padding="10" MinHeight="80" MaxHeight="120"
                                            Margin="0,0,0,12" BorderBrush="#22808080" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#16162B" Offset="0"/>
                                                <GradientStop Color="#1A1832" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="InstalledPromptsPanel">
                                                <TextBlock x:Name="TxtNoInstalledPrompts" Text="{loc:Str label_no_prompts_installed_yet}"
                                                           Foreground="#505050" FontSize="12" FontStyle="Italic"
                                                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="BtnBrowsePrompts" Grid.Column="0" Content="{loc:Str btn_browse}"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                                FontSize="12" Padding="0,8" Margin="0,0,4,0" Cursor="Hand" Click="BtnBrowsePrompts_Click"/>
                                        <Button x:Name="BtnImportPrompt" Grid.Column="1" Content="{loc:Str btn_import}"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                FontSize="12" Padding="0,8" Margin="4,0,4,0" Cursor="Hand" Click="BtnImportPrompt_Click"/>
                                        <Button x:Name="BtnExportPrompt" Grid.Column="2" Content="{loc:Str btn_export}"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                FontSize="12" Padding="0,8" Margin="4,0,0,0" Cursor="Hand" Click="BtnExportPrompt_Click"/>
                                    </Grid>

                                    <!-- Hypnotube Links Section -->
                                    <TextBlock Text="{loc:Str label_hypnotube_links}" FontWeight="Bold" FontSize="14"
                                               Foreground="{DynamicResource PinkBrush}" Margin="0,20,0,5"/>
                                    <TextBlock Text="{loc:Str label_video_links_for_ai_to_suggest_comma_separated}"
                                               FontSize="11" Foreground="#888" Margin="0,0,0,5" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{loc:Str label_current_mode}" FontSize="11" Foreground="#AAA"/>
                                        <TextBlock x:Name="TxtHypnotubeModeLabel" Text="{loc:Str label_bambi_sleep}"
                                                   FontSize="11" Foreground="{DynamicResource PinkBrush}"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtHypnotubeLinks"
                                             MaxLength="2000"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="False"
                                             Height="60"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="{DynamicResource SurfaceBgBrush}"
                                             Foreground="White"
                                             BorderBrush="#505050"
                                             BorderThickness="1"
                                             Padding="8,6"
                                             Margin="0,0,0,10"
                                             Style="{StaticResource FocusGlowTextBox}"
                                             TextChanged="TxtHypnotubeLinks_TextChanged"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Margin="20,5,20,10" CornerRadius="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#9370DB" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- ROW 2: Settings + Quick Controls -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SETTINGS BOX -->
                            <Border Grid.Column="0" CornerRadius="12" Padding="15"
                                    Background="{DynamicResource ElevatedSurfaceBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="{loc:Str label_companion_settings}" Foreground="{DynamicResource PinkBrush}" FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="HelpBtnCompanionSettings" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="CompanionSettings"/>
                                    </Grid>

                                    <!-- Show Companion -->
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="{loc:Str label_show_companion}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                        <CheckBox x:Name="ChkAvatarEnabledCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right"
                                                  Checked="ChkAvatarEnabled_Changed" Unchecked="ChkAvatarEnabled_Changed"/>
                                    </Grid>

                                    <!-- Detach -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_window_mode}" Foreground="White" FontSize="13"/>
                                            <TextBlock x:Name="TxtDetachStatusCompanion" Text="{loc:Str label_anchored_to_main_window}"
                                                       Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="BtnDetachCompanionTab" Content="{loc:Str btn_detach}" HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                Padding="15,6" FontSize="12" Cursor="Hand" Click="BtnDetachCompanion_Click"/>
                                    </Grid>

                                    <!-- Idle Interval -->
                                    <Grid Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_idle_giggle_interval}" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="{loc:Str label_how_often_companion_speaks_when_idle}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtIdleIntervalCompanion" Text="{loc:Str label_120s}" Foreground="{DynamicResource PinkBrush}"
                                                   FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="SliderIdleIntervalCompanion" Style="{StaticResource PinkSlider}"
                                            Minimum="5" Maximum="300" Value="120" Margin="0,0,0,15"
                                            ValueChanged="SliderIdleInterval_ValueChanged"/>

                                    <!-- Customize Button -->
                                    <Button x:Name="BtnCustomizeCompanion"
                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#9370DB" BorderThickness="1"
                                            Padding="10,10" FontSize="13" Cursor="Hand" Click="BtnCustomizeCompanion_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_customize_ai}" Foreground="White"/>
                                            <TextBlock x:Name="TxtCustomizePromptName" Text="{loc:Str label_default}" Foreground="#9370DB" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Manage Phrases Button -->
                                    <Button x:Name="BtnManagePhrases"
                                            Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1"
                                            Padding="10,10" FontSize="13" Cursor="Hand" Margin="0,8,0,0"
                                            Click="BtnManagePhrases_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="{loc:Str label_manage_phrases}" Foreground="White"/>
                                            <TextBlock x:Name="TxtPhraseCount" Text="{loc:Str label_0_active}" Foreground="{DynamicResource PinkBrush}" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Phrase Presets -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CmbPhrasePresets" Grid.Column="0" FontSize="11"
                                                  Style="{StaticResource DarkComboBoxStyle}"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectedValuePath="Id"
                                                  SelectionChanged="CmbPhrasePresets_SelectionChanged"/>
                                        <Button Content="{loc:Str btn_save}" Grid.Column="1"
                                                Style="{StaticResource SmallPinkButton}"
                                                Padding="10,4" FontSize="11" Margin="6,0,0,0"
                                                ToolTip="{loc:Str tooltip_save_current_phrase_config_as_a_preset}"
                                                Click="BtnSavePhrasePreset_Click"/>
                                        <Button Content="{loc:Str btn_delete}" Grid.Column="2"
                                                Style="{StaticResource OutlineButton}"
                                                Padding="10,4" FontSize="11" Margin="4,0,0,0"
                                                ToolTip="{loc:Str tooltip_delete_selected_phrase_preset}"
                                                Click="BtnDeletePhrasePreset_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- QUICK CONTROLS BOX -->
                            <Border Grid.Column="2" CornerRadius="12" Padding="15"
                                    Background="{DynamicResource ElevatedSurfaceBrush}"
                                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="{loc:Str label_quick_controls}" Foreground="{DynamicResource PinkBrush}" FontSize="14" FontWeight="Bold"/>
                                        <Button x:Name="HelpBtnQuickControls" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="QuickControls"/>
                                    </Grid>

                                    <!-- Mute Avatar -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_mute_avatar}" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="{loc:Str label_hide_speech_bubbles_and_sounds}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkMuteAvatarCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkMuteAvatar_Changed" Unchecked="ChkMuteAvatar_Changed"/>
                                    </Grid>

                                    <!-- Mute Whispers -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_mute_whispers}" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="{loc:Str label_mute_subliminal_audio}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkMuteWhispersCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkMuteWhispers_Changed" Unchecked="ChkMuteWhispers_Changed"/>
                                    </Grid>

                                    <!-- Pause Browser -->
                                    <Grid Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{loc:Str label_pause_browser}" Foreground="White" FontSize="13"/>
                                            <TextBlock Text="{loc:Str label_pause_embedded_browser_audio}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="ChkPauseBrowserCompanion" Style="{StaticResource ToggleStyle}"
                                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Checked="ChkPauseBrowser_Changed" Unchecked="ChkPauseBrowser_Changed"/>
                                    </Grid>

                                    <!-- Tips -->
                                    <Border CornerRadius="6" Padding="10" Margin="0,8,0,0" BorderBrush="#22808080" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#16162B" Offset="0"/>
                                                <GradientStop Color="#1A1832" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Foreground="{DynamicResource TextDimBrush}" FontSize="11" TextWrapping="Wrap" TextAlignment="Center">
                                            <Run Text="{loc:Str label_click_avatar_for_progress_right_click_for_men}"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ROW 3: Triggers -->
                        <Border CornerRadius="10" Padding="15" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource SurfaceBg}" Offset="0"/>
                                    <GradientStop Color="#252548" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#9370DB" Offset="0"/>
                                    <GradientStop Color="{DynamicResource PinkColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#9370DB" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{loc:Str label_trigger_mode}" Foreground="#9370DB" FontSize="14" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{loc:Str label_random_conditioning_phrases_with_audio}" Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <!-- Trigger Settings (shown when enabled) -->
                                    <StackPanel x:Name="TriggerSettingsPanelCompanion" Orientation="Horizontal" Visibility="Collapsed"
                                                Margin="0,12,0,0">
                                        <TextBlock Text="{loc:Str label_interval}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                        <Slider x:Name="SliderTriggerIntervalCompanion" Style="{StaticResource PinkSlider}"
                                                Width="150" Minimum="10" Maximum="600" Value="60"
                                                VerticalAlignment="Center" Margin="10,0,0,0"
                                                ValueChanged="SliderTriggerInterval_ValueChanged"/>
                                        <TextBlock x:Name="TxtTriggerIntervalCompanion" Text="{loc:Str label_60s}" Foreground="#9370DB"
                                                   FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <Button x:Name="BtnEditTriggersCompanion" Content="{loc:Str btn_edit_phrases_2}"
                                                Background="{DynamicResource SurfaceBgBrush}" Foreground="White" BorderBrush="#505050" BorderThickness="1"
                                                Padding="12,4" FontSize="11" Margin="20,0,0,0" Cursor="Hand"
                                                Click="BtnEditTriggers_Click"/>
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox x:Name="ChkTriggerModeCompanion" Grid.Column="1" Style="{StaticResource ToggleStyle}"
                                          VerticalAlignment="Top" Margin="0,2,0,0"
                                          Checked="ChkTriggerMode_Changed" Unchecked="ChkTriggerMode_Changed"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </ContentControl>

        <!-- Patreon Exclusives Tab -->
        <ContentControl x:Name="PatreonTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Border Style="{StaticResource SectionPanel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PatreonTabContent" Margin="15">
                        <Grid Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_patreon_exclusives}" Foreground="White" FontSize="22" FontWeight="Bold">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{loc:Str label_premium_features_for_supporters}" Foreground="{DynamicResource TextDimBrush}" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button x:Name="HelpBtnPatreon" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="PatreonExclusives"/>
                        </Grid>

                        <!-- Patreon Login Status -->
                        <Border x:Name="PatreonLoginCard" CornerRadius="12" Padding="15" Margin="0,0,0,15"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderBrush="#FF424D" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="TxtPatreonStatus" Text="{loc:Str label_not_connected}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtPatreonTier" Text="{loc:Str label_login_to_unlock_exclusive_features}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                </StackPanel>

                                <Button x:Name="BtnPatreonLogin" Grid.Column="1"
                                        Content="{loc:Str btn_login}"
                                        Background="#FF424D" Foreground="White"
                                        BorderThickness="0" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnPatreonLogin_Click"/>
                            </Grid>
                        </Border>

                        <!-- Discord Login Status -->
                        <Border x:Name="DiscordLoginCard" CornerRadius="12" Padding="15" Margin="0,0,0,15"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderBrush="#5865F2" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="TxtDiscordStatus" Text="{loc:Str label_not_connected}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="TxtDiscordInfo" Text="{loc:Str label_link_discord_for_community_features}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                                </StackPanel>

                                <Button x:Name="BtnDiscordLogin" Grid.Column="1"
                                        Content="{loc:Str btn_login}"
                                        Background="#5865F2" Foreground="White"
                                        BorderThickness="0" Padding="15,8"
                                        FontWeight="Bold" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnDiscordLogin_Click"/>
                            </Grid>
                        </Border>

                        <!-- Account Linking Section (visible when logged in but other provider not linked) -->
                        <Border x:Name="AccountLinkingSection" Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#FFD700" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_link_accounts}" Foreground="#FFD700" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="{loc:Str label_link_both_providers_to_access_your_account_fr}"
                                           Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnLinkPatreon"
                                            Content="{loc:Str btn_link_patreon}"
                                            Background="#FF424D" Foreground="White"
                                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand" Visibility="Collapsed"
                                            Click="BtnLinkPatreon_Click"/>
                                    <Button x:Name="BtnLinkDiscord"
                                            Content="{loc:Str btn_link_discord}"
                                            Background="#5865F2" Foreground="White"
                                            BorderThickness="0" Padding="15,8"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand" Visibility="Collapsed"
                                            Click="BtnLinkDiscord_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Cloud Settings Backup Section (visible when user has cloud identity) -->
                        <Border x:Name="CloudSettingsBackupSection" Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_cloud_settings_backup}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtCloudBackupStatus"
                                           Text="{loc:Str label_checking_backup_status}"
                                           Foreground="#B0B0B0" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnBackupSettingsNow"
                                            Content="{loc:Str btn_backup_now}"
                                            Background="{DynamicResource SecondaryBrush}" Foreground="White"
                                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnBackupSettingsNow_Click"/>
                                    <Button x:Name="BtnRestoreSettings"
                                            Content="{loc:Str btn_restore_from_cloud}"
                                            Background="Transparent" Foreground="{DynamicResource SecondaryBrush}"
                                            BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1" Padding="15,8"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnRestoreSettings_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Data & Privacy Section (visible when user has cloud identity) -->
                        <Border x:Name="DataPrivacySection" Background="{DynamicResource DarkerBgBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                                BorderBrush="#555" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="{loc:Str label_data_privacy}" Foreground="#B0B0B0" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Text="{loc:Str label_export_your_cloud_data_or_view_our_privacy_po}"
                                           Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="BtnExportData"
                                            Content="{loc:Str btn_export_my_data}"
                                            Background="#555" Foreground="White"
                                            BorderThickness="0" Padding="15,8" Margin="0,0,10,0"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnExportData_Click"/>
                                    <Button x:Name="BtnPrivacyPolicy"
                                            Content="{loc:Str btn_privacy_policy}"
                                            Background="Transparent" Foreground="#888"
                                            BorderBrush="#555" BorderThickness="1" Padding="15,8"
                                            FontWeight="Bold" FontSize="12"
                                            Cursor="Hand"
                                            Click="BtnPrivacyPolicy_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 2-Column Grid of Feature Expanders (wrapped with Patreon lock overlay) -->
                        <Grid Margin="0,10,0,0">
                        <!-- Patreon-Only Overlay for entire features grid -->
                        <Border x:Name="PatreonFeaturesOverlay" Background="#CC1A1A2E" CornerRadius="12" Panel.ZIndex="100">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="{loc:Str section_patreon_exclusive_features}" Foreground="{DynamicResource PinkBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{DynamicResource PinkColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{loc:Str label_support_on_patreon_to_unlock_autonomy_remote}"
                                           Foreground="#AAAAAA" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                                <Button Content="{loc:Str btn_visit_patreon}" Background="#FF424D" Foreground="White"
                                        BorderThickness="0" Padding="20,10" Margin="0,18,0,0"
                                        FontWeight="Bold" FontSize="13" Cursor="Hand"
                                        Click="BtnVisitPatreon_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E8363F"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                        <!-- Actual features grid -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0, Col 0: Bambi Takeover — moved to BambiTakeoverTab -->

                            <!-- Row 0, Col 2: Remote Control — moved to RemoteControlTab -->

                            <!-- Row 1, Col 0: Keyword Triggers -->
                            <Expander Grid.Row="1" Grid.Column="0" Style="{StaticResource ExclusivesSectionExpander}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{loc:Str label_keyword_triggers}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{loc:Str label_keyword_triggers_2}" Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="Bold"/>
                                            <TextBlock x:Name="TxtKeywordTriggersLocked" Text="{loc:Str label_in_beta_testing_for_patreon_supporters}"
                                                       Foreground="#DAA520" FontSize="10" FontStyle="Italic" VerticalAlignment="Center" Margin="8,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button x:Name="HelpBtnKeywordTriggers" Style="{StaticResource HelpButtonStyle}"
                                                    VerticalAlignment="Center" Margin="0,0,8,0" Tag="KeywordTriggers" Panel.ZIndex="1"/>
                                            <Button x:Name="BtnKeywordTriggersStartStop" Content="{loc:Str btn_start}"
                                                    Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold" FontSize="11"
                                                    Padding="14,4" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnKeywordTriggersStartStop_Click"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap">
                                            <Run Text="{loc:Str label_your_everyday_typing_becomes_part_of_your_con}"/>
                                        </TextBlock>

                                    <!-- Settings panel -->
                                    <StackPanel x:Name="KeywordTriggersSettingsPanel" Margin="0,10,0,0">

                                        <!-- Global settings row -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Buffer timeout -->
                                            <StackPanel Grid.Column="0" Margin="0,0,6,0"
                                                        ToolTip="{loc:Str tooltip_how_long_to_wait_after_a_keystroke_before_che}">
                                                <TextBlock Text="{loc:Str label_buffer_timeout}" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid>
                                                    <Slider x:Name="SliderKeywordBufferTimeout" Minimum="1000" Maximum="10000"
                                                            TickFrequency="500" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordBufferTimeout_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordBufferTimeout" Text="{loc:Str label_3_0s}"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Global cooldown -->
                                            <StackPanel Grid.Column="1" Margin="6,0,6,0"
                                                        ToolTip="{loc:Str tooltip_minimum_time_between_any_two_trigger_activati}">
                                                <TextBlock Text="{loc:Str label_global_cooldown}" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid>
                                                    <Slider x:Name="SliderKeywordGlobalCooldown" Minimum="1" Maximum="120"
                                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordGlobalCooldown_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordGlobalCooldown" Text="{loc:Str setting_5s}"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>

                                            <!-- Session XP boost -->
                                            <StackPanel Grid.Column="2" Margin="6,0,0,0"
                                                        ToolTip="{loc:Str tooltip_xp_multiplier_bonus_when_triggers_fire_during}">
                                                <TextBlock Text="{loc:Str label_session_xp_boost}" Foreground="#A0A0A0" FontSize="10"/>
                                                <Grid>
                                                    <Slider x:Name="SliderKeywordSessionMultiplier" Minimum="1.0" Maximum="3.0"
                                                            TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                            ValueChanged="SliderKeywordSessionMultiplier_ValueChanged"/>
                                                    <TextBlock x:Name="TxtKeywordSessionMultiplier" Text="1.5x"
                                                               Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Screen OCR -->
                                        <Border CornerRadius="6" Padding="8" Margin="0,0,0,8"
                                                Background="{DynamicResource DarkerBgBrush}" BorderBrush="#353550" BorderThickness="1">
                                            <StackPanel>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{loc:Str label_screen_text_detection_ocr}" Foreground="#C0C0C0" FontSize="12" FontWeight="SemiBold"/>
                                                        <Button x:Name="HelpBtnScreenOcr" Style="{StaticResource HelpButtonStyle}"
                                                                VerticalAlignment="Center" Margin="6,0,0,0" Tag="ScreenOcr" Panel.ZIndex="1"/>
                                                    </StackPanel>
                                                    <CheckBox x:Name="ChkScreenOcrEnabled" Style="{StaticResource ToggleStyle}"
                                                              HorizontalAlignment="Right" VerticalAlignment="Center"
                                                              Checked="ChkScreenOcrEnabled_Changed" Unchecked="ChkScreenOcrEnabled_Changed"/>
                                                </Grid>
                                                <TextBlock Text="{loc:Str label_scans_your_screen_for_trigger_keywords_using}"
                                                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                <CheckBox x:Name="ChkKeywordHighlightEnabled" Content="{loc:Str setting_highlight_matched_keywords_on_screen}"
                                                          Foreground="#A0A0A0" FontSize="10" Margin="0,4,0,0"
                                                          IsChecked="True"
                                                          Checked="ChkKeywordHighlightEnabled_Changed"
                                                          Unchecked="ChkKeywordHighlightEnabled_Changed"
                                                          ToolTip="{loc:Str tooltip_show_a_glowing_overlay_over_the_word_when_ocr}"/>
                                                <StackPanel x:Name="HighlightDurationPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="{loc:Str label_highlight_mode}" Foreground="#A0A0A0" FontSize="10" VerticalAlignment="Center"/>
                                                        <ComboBox x:Name="CmbOcrHighlightMode" Margin="6,0,0,0" MinWidth="110"
                                                                  Style="{StaticResource DarkComboBoxStyle}" FontSize="10"
                                                                  SelectionChanged="CmbOcrHighlightMode_SelectionChanged"
                                                                  ToolTip="{loc:Str tooltip_all_matches_highlights_every_keyword_immediat}">
                                                            <ComboBoxItem Content="{loc:Str btn_all_matches}"/>
                                                            <ComboBoxItem Content="{loc:Str btn_random_subset}"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <CheckBox x:Name="ChkHighlightVisibleInCapture" Content="{loc:Str setting_show_highlights_in_screen_capture_streams}"
                                                              Foreground="#A0A0A0" FontSize="10" Margin="0,2,0,4"
                                                              Checked="ChkHighlightVisibleInCapture_Changed"
                                                              Unchecked="ChkHighlightVisibleInCapture_Changed"
                                                              ToolTip="{loc:Str tooltip_when_enabled_keyword_highlights_will_be_visib}"/>
                                                    <TextBlock Text="{loc:Str label_highlight_duration}" Foreground="#A0A0A0" FontSize="10"/>
                                                    <Grid ToolTip="{loc:Str tooltip_how_long_the_pink_highlight_stays_on_screen_0}">
                                                        <Slider x:Name="SliderKeywordHighlightDuration" Minimum="0.3" Maximum="5.0"
                                                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                                                ValueChanged="SliderKeywordHighlightDuration_ValueChanged"/>
                                                        <TextBlock x:Name="TxtKeywordHighlightDuration" Text="{loc:Str label_0_6s}"
                                                                   Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel x:Name="ScreenOcrIntervalPanel" Visibility="Collapsed" Margin="0,6,0,0">
                                                    <TextBlock Text="{loc:Str label_scan_interval}" Foreground="#A0A0A0" FontSize="10"/>
                                                    <Grid ToolTip="{loc:Str tooltip_how_often_to_scan_your_screen_for_trigger_key}">
                                                        <Slider x:Name="SliderScreenOcrInterval" Minimum="2" Maximum="10"
                                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                                ValueChanged="SliderScreenOcrInterval_ValueChanged"/>
                                                        <TextBlock x:Name="TxtScreenOcrInterval" Text="{loc:Str label_3s}"
                                                                   Foreground="{DynamicResource PinkBrush}" FontSize="10" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Trigger list -->
                                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0"
                                                      PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                                            <StackPanel x:Name="KeywordTriggerListPanel"/>
                                        </ScrollViewer>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="{loc:Str btn_add_trigger}" Background="{DynamicResource PinkBrush}" Foreground="White" FontWeight="Bold"
                                                    FontSize="11" Padding="12,6" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnAddKeywordTrigger_Click"/>
                                            <Button Content="{loc:Str btn_import_from_trigger_mode}" Background="#353550" Foreground="#A0A0A0"
                                                    FontSize="11" Padding="12,6" Margin="8,0,0,0" BorderThickness="0" Cursor="Hand"
                                                    Click="BtnImportFromCustomTriggers_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Row 2, Full Width: Haptic Feedback — moved to HapticsTab -->

                        </Grid>
                        </Grid>

                        <!-- Patreon Info Box -->
                        <Border x:Name="SupportDevelopmentCard" CornerRadius="12" Padding="15" Margin="0,10,0,0"
                                Background="{DynamicResource ElevatedSurfaceBrush}"
                                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{loc:Str section_support_development}" Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="Bold"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,8,0,0">
                                    <Run Text="{loc:Str section_patreon_unlocks}"/> <Run x:Name="RunPatreonFeatures" Text="{loc:Str section_ai_chat_window_awareness_slut_mode_bambi_take}" Foreground="White"/>
                                </TextBlock>
                                <Button x:Name="BtnVisitPatreon" Content="{loc:Str btn_visit_patreon}"
                                        Background="{DynamicResource SecondaryBrush}" Foreground="White"
                                        BorderThickness="0" Padding="15,8" Margin="0,12,0,0"
                                        HorizontalAlignment="Left" FontSize="12"
                                        Cursor="Hand"
                                        Click="BtnVisitPatreon_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </ContentControl>

        <!-- Profile Tab -->
        <ContentControl x:Name="DiscordTab" Grid.Row="4" Margin="10,5,10,10" Visibility="Collapsed" Template="{StaticResource AnimatedTabBackground}">
            <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource SectionPanel}" BorderBrush="#5865F2" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="{loc:Str label_profile_viewer}" Foreground="#5865F2" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <Button x:Name="HelpBtnDiscordProfile" Style="{StaticResource HelpButtonStyle}" HorizontalAlignment="Right" Tag="DiscordProfile"/>
                        </Grid>

                        <!-- Search Input -->
                        <Border Background="{DynamicResource SurfaceBgBrush}" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtProfileSearch" Background="Transparent" BorderThickness="0" Foreground="White"
                                         FontSize="13" VerticalAlignment="Center" KeyDown="TxtProfileSearch_KeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="{loc:Str label_search_by_display_name}" Foreground="#606080" FontSize="13" Margin="2,0,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Grid.Column="1" Content="🔍" Background="Transparent" BorderThickness="0"
                                        Foreground="#5865F2" FontSize="16" Cursor="Hand" Click="BtnProfileSearch_Click"
                                        ToolTip="{loc:Str tooltip_search_profile}"/>
                            </Grid>
                        </Border>

                        <!-- Quick buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <Button Content="{loc:Str btn_my_profile}" Background="#5865F2" Foreground="White" BorderThickness="0"
                                    Padding="12,6" Margin="0,0,8,0" FontSize="11" FontWeight="SemiBold" Cursor="Hand"
                                    Click="BtnViewMyProfile_Click"/>
                            <Button Content="{loc:Str btn_clear}" Background="{DynamicResource PanelAccentBrush}" Foreground="White" BorderThickness="0"
                                    Padding="12,6" FontSize="11" Cursor="Hand" Click="BtnClearProfile_Click"/>
                        </StackPanel>

                        <!-- Profile Card with optional OG animated border (layered via Grid) -->
                        <Grid x:Name="ProfileCardWrapper" Visibility="Collapsed">
                            <!-- OG animated border (behind the card) -->
                            <Border x:Name="OgBorderContainer" Visibility="Collapsed" Padding="0" CornerRadius="18">
                                <Border.Resources>
                                    <Storyboard x:Key="OgBorderAnimation" RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="OgBorderRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:3"/>
                                    </Storyboard>
                                </Border.Resources>
                                <Border.Background>
                                    <LinearGradientBrush x:Name="OgBorderBrush" StartPoint="0,0" EndPoint="1,1">
                                        <LinearGradientBrush.RelativeTransform>
                                            <RotateTransform x:Name="OgBorderRotation" CenterX="0.5" CenterY="0.5" Angle="0"/>
                                        </LinearGradientBrush.RelativeTransform>
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#FFA500" Offset="0.25"/>
                                        <GradientStop Color="{DynamicResource PinkColor}" Offset="0.5"/>
                                        <GradientStop Color="#FFA500" Offset="0.75"/>
                                        <GradientStop Color="#FFD700" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Profile card content (always visible when wrapper is visible) -->
                            <Border x:Name="ProfileCardContainer" Margin="8" Background="{DynamicResource DarkerBgBrush}" CornerRadius="12">
                            <StackPanel>
                                <!-- Profile Header (Avatar + Name + Status) -->
                                <Border CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E1E3F" Offset="0"/>
                                            <GradientStop Color="#2A2A4A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar with online indicator -->
                                        <Grid Width="100" Height="100">
                                            <Border CornerRadius="50" BorderBrush="#5865F2" BorderThickness="3">
                                                <Border.Background>
                                                    <ImageBrush x:Name="ProfileViewerAvatar" Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                            <!-- Online status dot -->
                                            <Ellipse x:Name="ProfileOnlineIndicator" Width="20" Height="20"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Margin="0,0,5,5" Stroke="#1E1E3F" StrokeThickness="3" Fill="#43B581"/>
                                        </Grid>

                                        <!-- Name and handle -->
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TxtProfileViewerName" Text="{loc:Str login_display_name}"
                                                           Foreground="White" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                <!-- Edit display name button (own profile only) -->
                                                <Button x:Name="BtnChangeDisplayName" Visibility="Collapsed"
                                                        Width="24" Height="24" Margin="6,0,0,0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" VerticalAlignment="Center"
                                                        ToolTip="{loc:Str tooltip_change_display_name}"
                                                        Click="BtnChangeDisplayName_Click">
                                                    <TextBlock Text="{loc:Str label_text}" Foreground="#888" FontSize="14" VerticalAlignment="Center"/>
                                                </Button>
                                                <!-- Delete profile button (own profile only) -->
                                                <Button x:Name="BtnDeleteProfile" Visibility="Collapsed"
                                                        Width="24" Height="24" Margin="4,0,0,0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" VerticalAlignment="Center"
                                                        ToolTip="{loc:Str tooltip_delete_your_profile}"
                                                        Click="BtnDeleteProfile_Click">
                                                    <TextBlock Text="{loc:Str label_text_2}" Foreground="#FF4444" FontSize="13" VerticalAlignment="Center"/>
                                                </Button>
                                                <!-- OG GOOD GIRL Banner -->
                                                <Border x:Name="OgBannerBadge" Visibility="Collapsed" Margin="10,0,0,0" Padding="8,3" CornerRadius="4"
                                                        VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#FFD700" Offset="0"/>
                                                            <GradientStop Color="#FFA500" Offset="0.5"/>
                                                            <GradientStop Color="{DynamicResource PinkColor}" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="{loc:Str label_og_good_girl}" Foreground="{DynamicResource DarkerBgBrush}" FontSize="10" FontWeight="ExtraBold"
                                                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock x:Name="TxtProfileViewerOnline" Text="{loc:Str label_online}"
                                                           Foreground="#43B581" FontSize="11"/>
                                            </StackPanel>
                                            <!-- Discord button + Patreon badge row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Button x:Name="BtnProfileDiscord" Visibility="Collapsed"
                                                        Background="#5865F2" Foreground="White" BorderThickness="0"
                                                        Padding="10,5" Cursor="Hand"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Click="BtnProfileDiscord_Click"
                                                        ToolTip="{loc:Str tooltip_open_discord_profile}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="💬" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="TxtProfileDiscordId" Text="{loc:Str label_message_on_discord}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <!-- Patreon tier badge (same as leaderboard) -->
                                                <Image x:Name="ProfilePatreonTierBadge" Width="80" Height="80" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" Visibility="Collapsed" Stretch="Uniform"/>
                                            </StackPanel>
                                        </StackPanel>


                                            ToolTip="{loc:Str tooltip_start_minimized_to_system_tray}">
                                    <CheckBox x:Name="ChkStartHidden" Style="{StaticResource ToggleStyle}" Click="ChkStartHidden_Click"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_start_hidden}" Margin="6,0,0,0"/>

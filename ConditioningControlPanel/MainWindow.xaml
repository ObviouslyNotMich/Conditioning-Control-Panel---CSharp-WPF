                                                <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Target Hit (video attention targets) -->
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkHapticTargetHit" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                      VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="TargetHit"/>
                                            <TextBlock Grid.Column="1" Text="{loc:Str label_target_hit}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Slider x:Name="SliderHapticTargetHit" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                    Minimum="0" Maximum="100" Value="70" Margin="5,0" VerticalAlignment="Center"
                                                    ValueChanged="SliderHapticFeature_Changed" Tag="TargetHit"/>
                                            <TextBlock x:Name="TxtHapticTargetHit" Grid.Column="3" Text="70%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <ComboBox x:Name="CmbHapticTargetHitMode" Grid.Column="4" SelectedIndex="1" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                      Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                      SelectionChanged="CmbHapticMode_SelectionChanged" Tag="TargetHit">
                                                <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                            </ComboBox>
                                        </Grid>

                                    </StackPanel>

                                    <!-- RIGHT COLUMN: 4 features -->
                                    <StackPanel Grid.Column="2">

                                        <!-- Subliminal -->
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkHapticSubliminal" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                      VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="Subliminal"/>
                                            <TextBlock Grid.Column="1" Text="{loc:Str tab_subliminals}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Slider x:Name="SliderHapticSubliminal" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                    Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                    ValueChanged="SliderHapticFeature_Changed" Tag="Subliminal"/>
                                            <TextBlock x:Name="TxtHapticSubliminal" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <ComboBox x:Name="CmbHapticSubliminalMode" Grid.Column="4" SelectedIndex="1" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                      Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                      SelectionChanged="CmbHapticMode_SelectionChanged" Tag="Subliminal">
                                                <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Level Up -->
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkHapticLevelUp" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                      VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="LevelUp"/>
                                            <TextBlock Grid.Column="1" Text="{loc:Str label_level_up}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Slider x:Name="SliderHapticLevelUp" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                    Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                    ValueChanged="SliderHapticFeature_Changed" Tag="LevelUp"/>
                                            <TextBlock x:Name="TxtHapticLevelUp" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <ComboBox x:Name="CmbHapticLevelUpMode" Grid.Column="4" SelectedIndex="4" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                      Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                      SelectionChanged="CmbHapticMode_SelectionChanged" Tag="LevelUp">
                                                <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Achievement -->
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkHapticAchievement" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                      VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="Achievement"/>
                                            <TextBlock Grid.Column="1" Text="{loc:Str tab_achievements}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Slider x:Name="SliderHapticAchievement" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                    Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                    ValueChanged="SliderHapticFeature_Changed" Tag="Achievement"/>
                                            <TextBlock x:Name="TxtHapticAchievement" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <ComboBox x:Name="CmbHapticAchievementMode" Grid.Column="4" SelectedIndex="3" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                      Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                      SelectionChanged="CmbHapticMode_SelectionChanged" Tag="Achievement">
                                                <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Bouncing Text -->
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="92"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox x:Name="ChkHapticBouncingText" Style="{StaticResource ToggleStyle}" IsChecked="True"
                                                      VerticalAlignment="Center" Checked="ChkHapticFeature_Changed" Unchecked="ChkHapticFeature_Changed" Tag="BouncingText"/>
                                            <TextBlock Grid.Column="1" Text="{loc:Str label_bounce_text}" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <Slider x:Name="SliderHapticBouncingText" Grid.Column="2" Style="{StaticResource PinkSlider}"
                                                    Minimum="0" Maximum="100" Value="50" Margin="5,0" VerticalAlignment="Center"
                                                    ValueChanged="SliderHapticFeature_Changed" Tag="BouncingText"/>
                                            <TextBlock x:Name="TxtHapticBouncingText" Grid.Column="3" Text="50%" Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <ComboBox x:Name="CmbHapticBouncingTextMode" Grid.Column="4" SelectedIndex="1" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center"
                                                      Background="{DynamicResource SurfaceBgBrush}" Foreground="{DynamicResource PinkBrush}" BorderBrush="{DynamicResource SecondaryBrush}"
                                                      SelectionChanged="CmbHapticMode_SelectionChanged" Tag="BouncingText">
                                                <ComboBoxItem Content="{loc:Str btn_constant}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_pulse}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_wave}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_heartbeat}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_escalate}" Foreground="{DynamicResource PinkBrush}"/>
                                                <ComboBoxItem Content="{loc:Str btn_earthquake}" Foreground="{DynamicResource PinkBrush}"/>
                                            </ComboBox>
                                        </Grid>

                                    </StackPanel>
                                </Grid>

                        <!-- Video Haptic Sync - Enhanced Featured Card -->
                        <Border x:Name="VideoHapticSyncCard" BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1,2,1,1"
                                CornerRadius="8" Margin="0,12,0,0" Background="{DynamicResource SurfaceBgBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Header Section -->
                                <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" CornerRadius="8,8,0,0" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Title and Description -->
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🎵" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{loc:Str label_video_haptic_sync}" Foreground="{DynamicResource SecondaryBrush}"
                                                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{loc:Str label_syncs_haptics_to_video_audio_in_real_time}"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Help Button -->
                                        <Button x:Name="HelpBtnVideoHapticSync" Grid.Column="1"
                                                Style="{StaticResource HelpButtonStyle}" Tag="VideoHapticSync"
                                                Margin="0,0,10,0"/>

                                        <!-- Master Enable Toggle -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="{loc:Str btn_enable}" Foreground="#AAAAAA" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <CheckBox x:Name="ChkHapticAudioSync" Style="{StaticResource ToggleStyle}"
                                                      IsChecked="False"
                                                      Checked="ChkHapticAudioSync_Changed"
                                                      Unchecked="ChkHapticAudioSync_Changed"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Row 1: Algorithm Cards (left) + Image (right) -->
                                <Grid Grid.Row="1" Margin="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: Algorithm Selection Cards (stacked vertically) -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{loc:Str label_sync_algorithm}" Foreground="#AAAAAA" FontSize="10" Margin="0,0,0,5"/>

                                        <!-- Algorithm 1: Audio Reactive (Enabled) -->
                                        <Border x:Name="AlgorithmCardAudioReactive"
                                                Background="{DynamicResource PanelBgBrush}" CornerRadius="4" Padding="8,5" Cursor="Hand"
                                                BorderThickness="2" BorderBrush="{DynamicResource SecondaryBrush}" Margin="0,0,0,3"
                                                MouseLeftButtonDown="AlgorithmCard_Click" Tag="AudioReactive">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2A2A4E"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{loc:Str label_audio_reactive}" Foreground="White"
                                                           FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <Ellipse x:Name="AlgorithmIndicatorAudioReactive" Grid.Column="1"
                                                         Width="6" Height="6" Fill="{DynamicResource SecondaryBrush}"
                                                         VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <!-- Algorithm 2: Beat Detection (Coming Soon) -->
                                        <Grid Margin="0,0,0,3">
                                            <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="8,5">
                                                <Border.Effect>
                                                    <BlurEffect Radius="2"/>
                                                </Border.Effect>
                                                <TextBlock Text="{loc:Str label_beat_detection}" Foreground="#666666"
                                                           FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="#CC1A1A2E" CornerRadius="4">
                                                <TextBlock Text="{loc:Str label_coming_soon}" Foreground="{DynamicResource SecondaryBrush}" FontSize="8"
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <!-- Algorithm 3: AI Enhanced (Coming Soon) -->
                                        <Grid>
                                            <Border Background="{DynamicResource DarkerBgBrush}" CornerRadius="4" Padding="8,5">
                                                <Border.Effect>
                                                    <BlurEffect Radius="2"/>
                                                </Border.Effect>
                                                <TextBlock Text="{loc:Str label_ai_enhanced}" Foreground="#666666"
                                                           FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="#CC1A1A2E" CornerRadius="4">
                                                <TextBlock Text="{loc:Str label_coming_soon}" Foreground="{DynamicResource SecondaryBrush}" FontSize="8"
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Right: Square Image -->
                                    <Border Grid.Column="2" CornerRadius="6" ClipToBounds="True"
                                            BorderBrush="{DynamicResource SecondaryBrush}" BorderThickness="1"
                                            Width="130" Height="130">
                                        <Image x:Name="ImgVideoHapticSync"
                                               Source="pack://application:,,,/Resources/features/vibe.png"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                </Grid>

                                <!-- Row 3: Delay and Power Sliders -->
                                <Border x:Name="VideoHapticSyncSliders" Grid.Row="3" Padding="12,8,12,12"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Delay Slider -->
                                        <StackPanel Grid.Column="0">
                                            <Grid>
                                                <TextBlock Text="{loc:Str label_delay_2}" Foreground="#AAAAAA" FontSize="10"/>
                                                <TextBlock x:Name="TxtVideoHapticDelay" Text="{loc:Str label_0ms}"
                                                           Foreground="{DynamicResource SecondaryBrush}" FontSize="10"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="SliderVideoHapticDelay" Minimum="-600" Maximum="600"

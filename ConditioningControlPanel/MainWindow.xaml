                                    <CheckBox x:Name="ChkVidLaunch" Style="{StaticResource ToggleStyle}"/>
                                    <TextBlock Style="{StaticResource SettingLabel}" Text="{loc:Str setting_vid_launch}" Margin="6,0,0,0"/>

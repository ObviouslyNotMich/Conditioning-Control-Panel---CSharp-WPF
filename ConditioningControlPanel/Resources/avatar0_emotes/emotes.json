{
  "_comment": "Avatar-0 (blonde) animated emote mapping, shared by BambiSleep + Sissy. Clip = Resources/avatar0_emotes/<clip>.gif. Per spoken line the controller plays [talk clip(s) by length] then [one reaction emote by situation], each clip ONCE, crossfading to the next (never loops a clip). Resolution for the reaction: stemPrefix(emotionLineId) -> mood(first token) -> none. Idle = weighted rotation of the idleRotation pool. Edit + rebuild to embed.",
  "fps": 15,
  "fadeMs": 1000,
  "idleRotation": [
    { "clip": "idle",  "weight": 6 },
    { "clip": "idle2", "weight": 6 },
    { "clip": "idle3", "weight": 6 },
    { "clip": "idle4", "weight": 6 },
    { "clip": "idle5", "weight": 6 },
    { "clip": "tender",     "weight": 1 },
    { "clip": "shy",        "weight": 1 },
    { "clip": "adoring",    "weight": 1 },
    { "clip": "blowkiss",   "weight": 1 },
    { "clip": "celebrate",  "weight": 1 },
    { "clip": "entrancing", "weight": 1 }
  ],
  "talking": {
    "_comment": "Talking is drawn at RANDOM from this pool. How many clips a line uses is decided by each clip's speaking-window (clip_timing.json) vs the voiceline length: enough distinct clips to cover the line, capped at maxTalkClips. The runtime cuts the last clip at the line's end and fires the reaction then. longMinSec is legacy/unused.",
    "pool": ["talkA", "talkB", "talkC", "talkD", "talkE", "talkF"],
    "longMinSec": 9.0,
    "maxTalkClips": 3
  },
  "expressive": {
    "_comment": "Giggles / 'mmm' / short non-verbal sounds play ONE of these (no mouth-flapping), held full length; lines with no situational reaction (e.g. repetitive flash audio) also draw one for variety. nonverbalMaxSec = an untexted sound shorter than this is treated as a quick vocalization.",
    "pool": ["giggle", "sultry", "wink", "tease", "blowkiss", "adoring", "flirt", "shy"],
    "nonverbalMaxSec": 1.4
  },
  "talkStartDelayMs": 1000,
  "talkLeadOutMs": 500,
  "minClipMs": 2500,
  "clickEmotes": ["shy", "sultry", "adoring", "tender", "blowkiss"],
  "clipScale": {
    "_comment": "Per-clip extra scale multiplier on top of layout.scale. talkB renders 10% smaller than the rest.",
    "talkB": 0.9
  },
  "layout": {
    "_comment": "Delta on top of the mod's avatar layout. scale = multiplier (0.855 = ~14.5% smaller total); offsetX += right (negative = left); offsetY += DOWN. Applies to BambiSleep + Sissy (the avatar0 set).",
    "scale": 0.855,
    "offsetX": 10,
    "offsetY": -30,
    "detachedX": 10,
    "detachedY": -30
  },
  "stemPrefix": {
    "session_start": "greeting",
    "session_complete": "tender",

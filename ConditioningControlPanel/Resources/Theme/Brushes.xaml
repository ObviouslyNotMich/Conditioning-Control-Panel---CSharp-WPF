<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brushes (derived from Colors — use DynamicResource so runtime color changes propagate) -->
    <SolidColorBrush x:Key="PinkBrush"   Color="{DynamicResource PinkColor}"/>
    <SolidColorBrush x:Key="DarkPinkBrush" Color="{DynamicResource DarkPink}"/>
    <SolidColorBrush x:Key="PanelBgBrush" Color="{DynamicResource PanelBg}"/>
    <SolidColorBrush x:Key="PanelBgTransparentBrush" Color="{DynamicResource PanelBgTransparent}"/>
    <SolidColorBrush x:Key="DarkerBgBrush" Color="{DynamicResource DarkerBg}"/>
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="{DynamicResource SurfaceBg}"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{DynamicResource TextLight}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{DynamicResource TextMuted}"/>
    <SolidColorBrush x:Key="PanelAccentBrush" Color="{DynamicResource PanelAccent}"/>
    <SolidColorBrush x:Key="PanelAccentHoverBrush" Color="{DynamicResource PanelAccentHover}"/>
    <SolidColorBrush x:Key="PreviewBgBrush" Color="{DynamicResource PreviewBg}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource Danger}"/>
    <SolidColorBrush x:Key="TransparentPinkBrush" Color="{DynamicResource TransparentPink}"/>
    <SolidColorBrush x:Key="PinkButtonHoveredBrush" Color="{DynamicResource PinkButtonHovered}"/>

    <!-- Accent pressed (darkened accent for press states) -->
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{DynamicResource AccentPressed}"/>

    <!-- 20% alpha transparent accent -->
    <SolidColorBrush x:Key="TransparentPink20Brush" Color="{DynamicResource TransparentPink20}"/>

    <!-- Patreon brushes (secondary color — auto-computed for custom mods) -->
    <SolidColorBrush x:Key="PatreonPurpleBrush" Color="{DynamicResource PatreonPurple}"/>
    <SolidColorBrush x:Key="PatreonLightPurpleBrush" Color="{DynamicResource PatreonLightPurple}"/>
    <SolidColorBrush x:Key="PatreonDarkPurpleBrush" Color="{DynamicResource PatreonDarkPurple}"/>

    <!-- Secondary brush (alias for PatreonPurpleBrush, used in UI elements) -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource PatreonPurple}"/>

    <!-- Semi-transparent white -->
    <SolidColorBrush x:Key="TransparentWhiteBrush" Color="{DynamicResource TransparentWhite}"/>

    <!-- Added: brush for Controls.xaml hover color -->
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{DynamicResource DangerHover}"/>

    <!-- Accent-tinted dark backgrounds (for headers, panels that need subtle accent tint) -->
    <SolidColorBrush x:Key="AccentTintedBgBrush" Color="{DynamicResource AccentTintedBg}"/>
    <SolidColorBrush x:Key="AccentTintedBgHoverBrush" Color="{DynamicResource AccentTintedBgHover}"/>
    <SolidColorBrush x:Key="AccentMidGradientBrush" Color="{DynamicResource AccentMidGradient}"/>

    <!-- 40% and 50% alpha accent brushes (for hover/selected overlays) -->
    <SolidColorBrush x:Key="TransparentPink40Brush" Color="{DynamicResource TransparentPink40}"/>
    <SolidColorBrush x:Key="TransparentPink50Brush" Color="{DynamicResource TransparentPink50}"/>

    <!-- New: de-saturated accent for headers/labels -->
    <SolidColorBrush x:Key="PinkSoftBrush" Color="{DynamicResource PinkSoft}"/>
    <!-- New: vibrant accent for CTAs and interactive elements -->
    <SolidColorBrush x:Key="PinkVibrantBrush" Color="{DynamicResource PinkVibrant}"/>
    <!-- New: glass-style card borders -->
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{DynamicResource GlassBorder}"/>
    <SolidColorBrush x:Key="GlassBorderHoverBrush" Color="{DynamicResource GlassBorderHover}"/>
    <!-- New: elevated card surface -->
    <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{DynamicResource ElevatedSurface}"/>
    <!-- New: quaternary text -->
    <SolidColorBrush x:Key="TextDimBrush" Color="{DynamicResource TextDim}"/>

    <!-- Deeper tab accent brushes -->
    <SolidColorBrush x:Key="DeeperAccentBrush" Color="{DynamicResource DeeperAccent}"/>
    <SolidColorBrush x:Key="DeeperAccentSoftBrush" Color="{DynamicResource DeeperAccentSoft}"/>
    <SolidColorBrush x:Key="DeeperAccentTransparent20Brush" Color="{DynamicResource DeeperAccentTransparent20}"/>
    <SolidColorBrush x:Key="DeeperAccentTransparent40Brush" Color="{DynamicResource DeeperAccentTransparent40}"/>

    <!-- Mission 2 (Hub redesign) — semantic aliases for the row badges /
         tag chips. Aliasing existing brushes (rather than minting new hex)
         lets future theming reskin each surface independently of its
         underlying palette entry. -->
    <SolidColorBrush x:Key="DeeperHubVideoBadgeBgBrush"   Color="{DynamicResource DeeperAccentTransparent40}"/>
    <SolidColorBrush x:Key="DeeperHubAudioBadgeBgBrush"   Color="{DynamicResource TransparentPink40}"/>
    <SolidColorBrush x:Key="DeeperHubHapticsChipBgBrush"  Color="{DynamicResource DeeperAccentTransparent20}"/>
    <SolidColorBrush x:Key="DeeperHubWebcamChipBgBrush"   Color="{DynamicResource DeeperHubWebcamChipBg}"/>

    <!-- Deeper editor chrome brushes — see Colors.xaml for the role of each. -->
    <SolidColorBrush x:Key="DeeperLaneCanvasBrush" Color="{DynamicResource DeeperLaneCanvas}"/>
    <SolidColorBrush x:Key="DeeperLaneBgBrush" Color="{DynamicResource DeeperLaneBg}"/>
    <SolidColorBrush x:Key="DeeperLaneHeaderBrush" Color="{DynamicResource DeeperLaneHeader}"/>
    <SolidColorBrush x:Key="DeeperLaneHeaderHoverBrush" Color="{DynamicResource DeeperLaneHeaderHover}"/>
    <SolidColorBrush x:Key="DeeperLaneSeparatorBrush" Color="{DynamicResource DeeperLaneSeparator}"/>
    <SolidColorBrush x:Key="DeeperDrawerStripBrush" Color="{DynamicResource DeeperDrawerStrip}"/>
    <SolidColorBrush x:Key="DeeperDrawerStripHoverBrush" Color="{DynamicResource DeeperDrawerStripHover}"/>
    <SolidColorBrush x:Key="DeeperSelectionStripBrush" Color="{DynamicResource DeeperSelectionStrip}"/>

    <!-- Mission 3 (Player redesign + theming cleanup) — see Colors.xaml. -->
    <SolidColorBrush x:Key="DeeperPreviewSurfaceBgBrush" Color="{DynamicResource DeeperPreviewSurfaceBg}"/>
    <SolidColorBrush x:Key="DeeperWaveformBgBrush" Color="{DynamicResource DeeperWaveformBg}"/>
    <SolidColorBrush x:Key="DeeperMenuItemHoverBgBrush" Color="{DynamicResource DeeperMenuItemHoverBg}"/>
    <SolidColorBrush x:Key="DeeperPlayerOverlayBgBrush" Color="{DynamicResource DeeperPlayerOverlayBg}"/>
    <SolidColorBrush x:Key="DeeperGazePickerBackdropBrush" Color="{DynamicResource DeeperGazePickerBackdrop}"/>
    <SolidColorBrush x:Key="DeeperGazePickerToolbarBgBrush" Color="{DynamicResource DeeperGazePickerToolbarBg}"/>
    <SolidColorBrush x:Key="DeeperGazePickerHandleFillBrush" Color="{DynamicResource DeeperGazePickerHandleFill}"/>
    <SolidColorBrush x:Key="DeeperGazePickerCancelBorderBrush" Color="{DynamicResource DeeperGazePickerCancelBorder}"/>

    <!-- SP5 layer 3: NeonPurple brushes for the Available Subjects tab. -->
    <SolidColorBrush x:Key="NeonPurpleBrush" Color="{DynamicResource NeonPurple}"/>
    <SolidColorBrush x:Key="NeonPurpleSoftBrush" Color="{DynamicResource NeonPurpleSoft}"/>
    <SolidColorBrush x:Key="NeonPurpleTransparent20Brush" Color="{DynamicResource NeonPurpleTransparent20}"/>

    <!-- v6 CCP brand gradient (135°, pink → violet). Static, NOT mod-overridable.
         Applied at the four brand anchors (logo, START button, XP bar, primary nav active)
         on CCP Default only; ApplyModTheme swaps AccentGradientBrush to point at this for
         CCP Default and to a solid SolidColorBrush(accent) for every other mod. -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E84393" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>

    <!-- Anchor swap point. ApplyModTheme rewrites this at runtime:
           CCP Default → BrandGradient (above)
           any other mod → SolidColorBrush of the active mod's accent color
         XAML anchors read {DynamicResource AccentGradientBrush}; everything else stays on PinkBrush. -->
    <SolidColorBrush x:Key="AccentGradientBrush" Color="{DynamicResource PinkColor}"/>

</ResourceDictionary>

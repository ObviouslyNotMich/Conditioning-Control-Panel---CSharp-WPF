                                <Canvas IsHitTestVisible="False">
                                    <Ellipse Width="4" Height="4" Fill="{DynamicResource PinkBrush}" Opacity="0.4" Canvas.Left="30" Canvas.Top="60">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform x:Name="Particle1Transform"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <Ellipse Width="3" Height="3" Fill="{DynamicResource SecondaryBrush}" Opacity="0.35" Canvas.Left="120" Canvas.Top="100">

        { "type": "VisualEffect", "effect": "SubliminalFlash" },
        { "type": "AvatarComment", "promptTemplate": "She just read the word 'smart'. Dismiss it with a giggly bimbo line in character — pretty over clever, one short sentence.", "fallbackPhraseCategory": "BimboGiggle", "requireAiAvailable": false },

      "keyword": "smart",
      "matchType": "PlainText",
      "enabled": true,
      "cooldownSeconds": 30,
      "visualEffect": "SubliminalFlash",
      "actions": [
        { "type": "PlayAudio", "filePath": "AwarenessPresets/audio/chime.wav", "volume": 70, "playCount": 1, "duckSystemAudio": true },
        { "type": "VisualEffect", "effect": "SubliminalFlash" },
        { "type": "AvatarComment", "promptTemplate": null, "fallbackPhraseCategory": "BimboGiggle", "requireAiAvailable": false },
        { "type": "Highlight" }

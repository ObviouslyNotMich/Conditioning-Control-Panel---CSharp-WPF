    "TestLab": [
      "Test word detected.",
      "Flashing now.",
      "Nailed it.",
      "Subject reaction logged.",
      "One more for the record.",
      "Mind blanking...",
      "*notes clipboard*",
      "Stimulus delivered.",
      "Response within parameters.",
      "Exposure count +1."
    ]
  },

{
  "id": "builtin.testlab",
  "name": "Test Lab",
  "icon": "🧪",
  "description": "Action showcase — every effect type on a different keyword",
  "longDescription": "A playground preset that wires a different action type to each keyword so you can see and hear every Awareness Engine effect working. Install it, then type the keywords to feel each mode. Great for verifying your setup end-to-end, and for deciding which effect combos you like before building your own triggers.",
  "author": "Built-in",
  "version": 1,
  "isBuiltIn": true,
  "requiresAi": false,
  "avatarPromptTemplate": "She just said '{keyword}'. React in character with one short test-lab themed line.",

        { "type": "PlayAudio", "filePath": "AwarenessPresets/audio/clicker.wav", "volume": 70, "playCount": 1, "duckSystemAudio": true },
{ "type": "AvatarComment", "promptTemplate": null, "fallbackPhraseCategory": "PuppyPraise", "requireAiAvailable": false },
        { "type": "Highlight" },
        { "type": "Haptic", "intensity": 0.3 }
      ]
    },

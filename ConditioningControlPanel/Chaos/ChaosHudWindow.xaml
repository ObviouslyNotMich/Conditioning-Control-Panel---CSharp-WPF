<Window x:Class="ConditioningControlPanel.ChaosHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rabbit Hole HUD"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize" WindowStartupLocation="Manual" FontFamily="Segoe UI" Width="300">
    <Window.Resources>
        <SolidColorBrush x:Key="Pink" Color="#FF69B4"/>
        <SolidColorBrush x:Key="StripBg" Color="#E6121026"/>
        <SolidColorBrush x:Key="PanelBg" Color="#F2151226"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#55FF69B4"/>
        <SolidColorBrush x:Key="TextDim" Color="#AAB8B8D0"/>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Pink}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- Hover card shared by every boon tile (pockets + run picks). Non-layered
             (HasDropShadow=False app-wide) so it can't collide with layered windows. -->
        <Style x:Key="BoonTipChrome" TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HasDropShadow" Value="False"/>
        </Style>
        <DataTemplate x:Key="BoonTipContent">
            <StackPanel MaxWidth="240">
                <TextBlock Text="{Binding TipTitle}" FontWeight="Bold" FontSize="13" Foreground="{Binding AccentBrush}"/>
                <TextBlock Text="{Binding Desc}" Foreground="#DDE0E0F0" FontSize="12" TextWrapping="Wrap"
                           Margin="0,3,0,0" Visibility="{Binding DescVisibility}"/>
                <TextBlock Text="{Binding Flavor}" Visibility="{Binding FlavorVisibility}" FontStyle="Italic" FontSize="11"
                           Foreground="#CCB0B0C8" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding Extra}" Foreground="#FFD700" FontSize="12" TextWrapping="Wrap"
                           Margin="0,3,0,0" Visibility="{Binding ExtraVisibility}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Equipped-boon tile for the collapsed strip (toys group above, accessories group below) -->
        <DataTemplate x:Key="StripBoonTile">
            <Grid Width="64" Height="64" Margin="0,0,0,8" HorizontalAlignment="Center" Opacity="{Binding TileOpacity}">
                <Grid.ToolTip>
                    <ToolTip Style="{StaticResource BoonTipChrome}" Content="{Binding}"
                             ContentTemplate="{StaticResource BoonTipContent}"/>
                </Grid.ToolTip>
                <Border CornerRadius="13" Background="{Binding TileBackBrush}" BorderThickness="0">
                    <Grid>
                        <!-- rounded clip so square art can't poke past the ring corners -->
                        <Grid.Clip><RectangleGeometry Rect="0,0,64,64" RadiusX="13" RadiusY="13"/></Grid.Clip>
                        <TextBlock Text="{Binding Glyph}" FontSize="30" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                        <!-- ring ABOVE the art: full-bleed sprites bury a behind-border -->
                        <Border CornerRadius="13" BorderBrush="{Binding AccentBrush}" BorderThickness="3.5" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <Border Background="#DD121026" CornerRadius="6" Padding="4,0"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"
                        Visibility="{Binding LevelBadgeVisibility}">
                    <TextBlock Text="{Binding LevelText}" Foreground="{StaticResource Pink}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Pocket tile for the expanded panel: pre-run, click a filled tile to take it off -->
        <DataTemplate x:Key="PocketTile">
            <Grid Width="57" Height="57" Margin="0,0,8,6" Opacity="{Binding TileOpacity}"
                  Background="Transparent" Cursor="Hand"
                  Tag="{Binding Id}" MouseLeftButtonDown="PocketTile_Click">
                <Grid.ToolTip>
                    <ToolTip Style="{StaticResource BoonTipChrome}" Content="{Binding}"
                             ContentTemplate="{StaticResource BoonTipContent}"/>
                </Grid.ToolTip>
                <Border CornerRadius="12" Background="{Binding TileBackBrush}" BorderThickness="0">
                    <Grid>
                        <Grid.Clip><RectangleGeometry Rect="0,0,57,57" RadiusX="12" RadiusY="12"/></Grid.Clip>
                        <TextBlock Text="{Binding Glyph}" FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                        <Border CornerRadius="12" BorderBrush="{Binding AccentBrush}" BorderThickness="3.5" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <Border Background="#DD121026" CornerRadius="6" Padding="4,0"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"
                        Visibility="{Binding LevelBadgeVisibility}">
                    <TextBlock Text="{Binding LevelText}" Foreground="{StaticResource Pink}" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Slim pink scrollbar for the expanded panel (pockets/modifiers/conditioning can outgrow it) -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="#80FF69B4" BorderThickness="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SlimScroll" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Margin="0,0,4,0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root has NO background → unpainted area is alpha-0 and click-through (desktop usable). -->
    <Grid>
        <!-- COLLAPSED STRIP (always visible, left edge) -->
        <Border x:Name="Strip" HorizontalAlignment="Left" Width="116"
                Background="{StaticResource StripBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,8,8"
                CornerRadius="0,0,18,0" MouseEnter="Hud_MouseEnter" MouseLeave="Strip_MouseLeave"
                MouseLeftButtonDown="Strip_Click">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0" HorizontalAlignment="Center">
                <TextBlock Text="🐇" Foreground="{StaticResource Pink}" FontSize="30" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtStripClock" Text="{Binding ClockText}" Foreground="White" FontFamily="Consolas" FontSize="17"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <!-- left/right side switch — parks the whole sidebar on the other screen edge so it's
                     out of the way of bubbles. Sits right under the clock; click a side to re-anchor. -->
                <Border Margin="0,8,0,0" HorizontalAlignment="Center" Background="#33000000" CornerRadius="9" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="SideLeftBtn" Width="28" Height="19" CornerRadius="8" Cursor="Hand"
                                Background="Transparent" MouseLeftButtonDown="SideLeft_Click">
                            <TextBlock x:Name="SideLeftGlyph" Text="◀" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SideRightBtn" Width="28" Height="19" CornerRadius="8" Cursor="Hand" Margin="2,0,0,0"
                                Background="Transparent" MouseLeftButtonDown="SideRight_Click">
                            <TextBlock x:Name="SideRightGlyph" Text="▶" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="TxtStripScore" Text="{Binding ScoreText}" Foreground="White" FontWeight="Bold" FontSize="16"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,14,0,0"/>
                <TextBlock x:Name="TxtStripMult" Text="{Binding TotalMultText}" Foreground="#FFD24DFF" FontWeight="Bold" FontSize="19"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>

                <!-- STREAK: Balatro-style combo readout — heats through color tiers as it climbs,
                     jitters when hot, punches on every gain, shakes hard on a drop (code-behind). -->
                <StackPanel x:Name="StreakBlock" Margin="0,12,0,0" HorizontalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="StreakScale"/>
                            <RotateTransform x:Name="StreakRot"/>
                            <TranslateTransform x:Name="StreakJitter"/>
                        </TransformGroup>
                    </StackPanel.RenderTransform>
                    <TextBlock x:Name="TxtStreakLbl" Text="STREAK" Foreground="{StaticResource TextDim}"
                               FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtStreakNum" Text="x0" Foreground="White" FontWeight="Bold"
                               FontFamily="Consolas" FontSize="24" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- FOCUS: the defuse fuel — a core resource like streak, so it lives on the
                     always-visible strip too. Dims + pulses when below a defuse's cost. -->
                <StackPanel x:Name="FocusStripBlock" Margin="0,14,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="FOCUS" Foreground="#FF9CE8FF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Grid Width="86" Height="8" Margin="0,3,0,0">
                        <ProgressBar x:Name="FocusStripBar" Minimum="0" Maximum="{Binding FocusMax, Mode=OneWay}"
                                     Value="{Binding Focus, Mode=OneWay}"
                                     Foreground="#FF5AC8FA" Background="#33000000" BorderThickness="0"/>
                        <!-- the 30-mark: a defuse's price, etched on the bar -->
                        <Grid IsHitTestVisible="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="7*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="1.5" HorizontalAlignment="Right" Background="#88FFFFFF"/>
                        </Grid>
                    </Grid>
                    <TextBlock Text="{Binding FocusText}" Foreground="White" FontWeight="Bold" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- RIPPLE: the right-click wave — one charge on a slow gather. Dims while charging;
                     READY breathes a soft cyan glow (code-behind, same pulse as the toy hero button). -->
                <StackPanel x:Name="RippleStripBlock" Margin="0,12,0,0" HorizontalAlignment="Center">
                    <TextBlock Text="RIPPLE" Foreground="#FF7AE0FF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="RippleStripText" Text="{Binding RippleText}" FontWeight="Bold" FontFamily="Consolas" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RippleReady}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- equipped toys (max 2), then accessories (max 2) — separate groups, thin seam between -->
                <ItemsControl ItemsSource="{Binding ActiveSidebarToys}" Margin="0,18,0,0" HorizontalAlignment="Center"
                              ItemTemplate="{StaticResource StripBoonTile}"/>
                <Border Height="1" Width="48" Background="{StaticResource PanelBorder}" Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSidebarToys.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSidebarAccessories.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <ItemsControl ItemsSource="{Binding ActiveSidebarAccessories}" HorizontalAlignment="Center"
                              ItemTemplate="{StaticResource StripBoonTile}"/>

                <!-- mantras/sins drafted this run now ride the horizontal ribbon across the TOP of
                     the screen (ChaosBoonBarOverlay), next to the clock — they outgrew this narrow
                     strip. Still listed in full under CONDITIONING in the expanded panel below. -->
            </StackPanel>
        </Border>

        <!-- EXPANDED PANEL (shown on hover) -->
        <Border x:Name="Panel" HorizontalAlignment="Left" Width="300" Visibility="Collapsed"
                Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="0,0,8,8"
                CornerRadius="0,0,18,0" MouseLeave="Hud_MouseLeave">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelSlide" X="-300"/>
            </Border.RenderTransform>
            <Grid Margin="20,18,20,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- header -->
                <StackPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="PortraitHost" Width="44" Height="44" Margin="0,0,10,0" CornerRadius="10" VerticalAlignment="Center"
                                Background="#33FF69B4" BorderThickness="0">
                            <Grid>
                                <Grid.Clip><RectangleGeometry Rect="0,0,44,44" RadiusX="10" RadiusY="10"/></Grid.Clip>
                                <Image x:Name="Portrait" Stretch="UniformToFill"/>
                                <Border CornerRadius="10" BorderBrush="{StaticResource PanelBorder}" BorderThickness="3" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🐇 THE HOLE" Foreground="{StaticResource Pink}" FontWeight="Bold" FontSize="22"/>
                                <TextBlock x:Name="TxtActWave" Text="{Binding ActWaveText}" Foreground="White" FontSize="13" VerticalAlignment="Bottom" Margin="8,0,0,3"/>
                            </StackPanel>
                            <!-- Run clock + fill bar: Pocket Watch perks only (SetClockVisible) — time stays a mystery otherwise. -->
                            <TextBlock x:Name="TxtRunTime" Text="{Binding RunTimeText}" Foreground="{StaticResource TextDim}" FontSize="13" Margin="0,2,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- same left/right side switch, mirrored UNDER the title so it's reachable while the
                         panel is open (e.g. the pre-run loadout glance, before you fall in) without
                         overlapping "THE HOLE · DEPTH". -->
                    <Border HorizontalAlignment="Left" Margin="0,6,0,0" Background="#33000000" CornerRadius="9" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="SideLeftBtn2" Width="28" Height="19" CornerRadius="8" Cursor="Hand"
                                    Background="Transparent" MouseLeftButtonDown="SideLeft_Click">
                                <TextBlock x:Name="SideLeftGlyph2" Text="◀" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="SideRightBtn2" Width="28" Height="19" CornerRadius="8" Cursor="Hand" Margin="2,0,0,0"
                                    Background="Transparent" MouseLeftButtonDown="SideRight_Click">
                                <TextBlock x:Name="SideRightGlyph2" Text="▶" FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    <ProgressBar x:Name="BarRunProgress" Minimum="0" Maximum="1" Value="{Binding RunProgress, Mode=OneWay}" Height="5" Margin="0,4,0,0"
                                 Foreground="#FF8A7DBD" Background="#33000000" BorderThickness="0" Visibility="Collapsed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock x:Name="TxtPanelScore" Text="{Binding ScoreText}" Foreground="White" FontWeight="Bold" FontSize="22" Margin="0,0,16,0"/>
                        <TextBlock x:Name="TxtPanelMult" Text="{Binding TotalMultText}" Foreground="#FFD24DFF" FontWeight="Bold" FontSize="22" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- middle: stack + boons (scrolls when the lists outgrow the panel) -->
                <ScrollViewer Grid.Row="1" Margin="0,6,0,0" VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource SlimScroll}" Focusable="False" PanningMode="VerticalOnly">
                <StackPanel>
                    <TextBlock x:Name="HdrStack" Text="MULTIPLIER STACK" Style="{StaticResource Hdr}"/>
                    <Grid x:Name="RowStreak" Margin="0,1" Background="Transparent"><TextBlock Text="{Binding Combo, StringFormat=streak x{0}}" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding ComboMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                    <Grid x:Name="RowDifficulty" Margin="0,1" Background="Transparent"><TextBlock Text="difficulty" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding DifficultyMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                    <Grid x:Name="RowLust" Margin="0,1" Background="Transparent"><TextBlock Text="lust" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding HeatMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                    <Grid x:Name="RowMantras" Margin="0,1" Background="Transparent"><TextBlock Text="mantras" Foreground="{StaticResource TextDim}" FontSize="13"/><TextBlock Text="{Binding BoonMult, StringFormat=x{0:0.0}}" Foreground="White" FontSize="13" HorizontalAlignment="Right"/></Grid>
                    <ProgressBar x:Name="BarLust" Minimum="0" Maximum="1" Value="{Binding Heat, Mode=OneWay}" Height="5" Margin="0,6,0,0"
                                 Foreground="#FFFF7A3D" Background="#33000000" BorderThickness="0"/>

                    <TextBlock x:Name="HdrResistance" Text="RESISTANCE" Style="{StaticResource Hdr}"/>
                    <TextBlock x:Name="TxtShields" Text="{Binding ShieldText}" Foreground="#FFFF6EC7" FontSize="22"
                               RenderTransformOrigin="0,0.5">
                        <TextBlock.RenderTransform><ScaleTransform/></TextBlock.RenderTransform>
                    </TextBlock>

                    <!-- focus: pops fill it, hold-channels spend it. Low = dim + pulse warning. -->
                    <TextBlock x:Name="HdrFocus" Text="FOCUS" Style="{StaticResource Hdr}"/>
                    <StackPanel x:Name="FocusPanelBlock">
                        <Grid>
                            <TextBlock Text="pops fill it · a hold spends it" Foreground="{StaticResource TextDim}" FontSize="12"/>
                            <TextBlock Text="{Binding FocusText}" Foreground="#FF9CE8FF" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Height="8" Margin="0,4,0,0">
                            <ProgressBar x:Name="FocusPanelBar" Minimum="0" Maximum="{Binding FocusMax, Mode=OneWay}"
                                         Value="{Binding Focus, Mode=OneWay}"
                                         Foreground="#FF5AC8FA" Background="#33000000" BorderThickness="0"/>
                            <Grid IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="7*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="1.5" HorizontalAlignment="Right" Background="#88FFFFFF"/>
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- loadout: what you took down with you, split by group (max 2 each). hover a tile
                         for its card; pre-run, click a filled tile to take it off (no-op once SINK fires) -->
                    <TextBlock x:Name="HdrPockets" Text="TOYS">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Hdr}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSidebarToys.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding ActiveSidebarToys}" ItemTemplate="{StaticResource PocketTile}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <TextBlock x:Name="HdrAccessories" Text="ACCESSORIES">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Hdr}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSidebarAccessories.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ItemsControl ItemsSource="{Binding ActiveSidebarAccessories}" ItemTemplate="{StaticResource PocketTile}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <!-- mantras/sins taken this run: tile + name rows, hover for the description -->
                    <TextBlock x:Name="HdrConditioning" Text="CONDITIONING" Style="{StaticResource Hdr}"/>
                    <ItemsControl ItemsSource="{Binding RunPickTiles}">
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <StackPanel.ToolTip>
                                    <ToolTip Style="{StaticResource BoonTipChrome}" Content="{Binding}"
                                             ContentTemplate="{StaticResource BoonTipContent}"/>
                                </StackPanel.ToolTip>
                                <Border Width="33" Height="33" CornerRadius="8"
                                        Background="{Binding TileBackBrush}" BorderThickness="0">
                                    <Grid>
                                        <Grid.Clip><RectangleGeometry Rect="0,0,33,33" RadiusX="8" RadiusY="8"/></Grid.Clip>
                                        <TextBlock Text="{Binding Glyph}" FontSize="16" Foreground="{Binding AccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                        <Border CornerRadius="8" BorderBrush="{Binding AccentBrush}" BorderThickness="3" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Name}" Foreground="{Binding AccentBrush}" FontSize="13"
                                           Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- passive modifiers: always-on owned upgrades shaping this run (purple tiles, hover for desc) -->
                    <TextBlock x:Name="HdrModifiers" Text="MODIFIERS" Style="{StaticResource Hdr}"/>
                    <ItemsControl ItemsSource="{Binding RunModifiers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="45" Height="45" Margin="0,0,7,7" CornerRadius="10"
                                        Background="{Binding TileBackBrush}" BorderThickness="0">
                                    <Border.ToolTip>
                                        <ToolTip Style="{StaticResource BoonTipChrome}" Content="{Binding}"
                                                 ContentTemplate="{StaticResource BoonTipContent}"/>
                                    </Border.ToolTip>
                                    <Grid>
                                        <Grid.Clip><RectangleGeometry Rect="0,0,45,45" RadiusX="10" RadiusY="10"/></Grid.Clip>
                                        <TextBlock Text="{Binding Glyph}" FontSize="20" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                        <Border CornerRadius="10" BorderBrush="{Binding AccentBrush}" BorderThickness="3" IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="HdrFeed" Text="FEED" Style="{StaticResource Hdr}"/>
                    <ItemsControl ItemsSource="{Binding RecentEvents}">
                        <ItemsControl.ItemTemplate><DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextDim}" FontSize="13" Margin="0,1" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </ScrollViewer>

                <!-- bottom: one hero button — FALL IN on the Warren-phase sidebar, PAUSE mid-run.
                     Pausing swaps in the continue-or-wake-up choice (the run stays held meanwhile).
                     Pre-run only, a ✖ beside the hero closes the whole mode (Warren + sidebar). -->
                <StackPanel x:Name="ControlsRow" Grid.Row="2" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="BtnHero" Content="⏸ PAUSE" Click="BtnHero_Click" FontSize="16" FontWeight="Bold"
                                Foreground="White" BorderThickness="0" Padding="0,13" Cursor="Hand"
                                HorizontalAlignment="Stretch">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFE84393" Offset="0"/>
                                    <GradientStop Color="#FF8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" x:Name="BtnCloseMode" Content="✖" Click="BtnCloseMode_Click" FontSize="15" FontWeight="Bold"
                                Width="46" Margin="8,0,0,0" Background="#66FF5050" Foreground="White" BorderThickness="0" Cursor="Hand"
                                ToolTip="leave the rabbit hole" Visibility="Collapsed">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    <Grid x:Name="PauseChoiceRow" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="▶ continue" Click="BtnResume_Click" FontSize="14" FontWeight="Bold"
                                Padding="0,12" Margin="0,0,5,0" Background="#449CE8A0" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" Content="✖ wake up" Click="BtnExit_Click" FontSize="14" FontWeight="Bold"
                                Padding="0,12" Margin="5,0,0,0" Background="#66FF5050" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="12"/></Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="TxtPauseHint" Text="⏸ HELD · your panic key again wakes you up"
                               Foreground="{StaticResource TextDim}" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,6,0,0" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="ConditioningControlPanel.OpenAiCompatibleSamplerSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
        Title="{loc:Str dialog_openai_sampler_title}"
        Width="420" Height="520"
        Background="{DynamicResource DarkerBgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SamplerLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SamplerInput" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SamplerButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{loc:Str dialog_openai_sampler_title}"
                   Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="{loc:Str hint_sampler_settings}"
                   Foreground="{DynamicResource TextDimBrush}" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <CheckBox x:Name="ChkUseCustomSamplers" Margin="0,0,0,12"
                          Foreground="White" FontSize="13"
                          Content="{loc:Str label_sampler_use_custom_settings}"
                          Checked="ChkUseCustomSamplers_Changed"
                          Unchecked="ChkUseCustomSamplers_Changed"/>

                <Grid x:Name="InputsPanel" IsEnabled="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_temperature}"/>
                        <TextBox x:Name="TxtTemperature" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_top_p}"/>
                        <TextBox x:Name="TxtTopP" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_top_k}"/>
                        <TextBox x:Name="TxtTopK" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_min_p}"/>
                        <TextBox x:Name="TxtMinP" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_frequency_penalty}"/>
                        <TextBox x:Name="TxtFrequencyPenalty" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_presence_penalty}"/>
                        <TextBox x:Name="TxtPresencePenalty" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource SamplerLabel}" Text="{loc:Str label_sampler_repetition_penalty}"/>
                        <TextBox x:Name="TxtRepetitionPenalty" Style="{StaticResource SamplerInput}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <TextBlock x:Name="TxtError" Grid.Row="3" Foreground="#FFFF6B6B" FontSize="11"
                   TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource SamplerButton}"
                    Content="{loc:Str label_sampler_reset_defaults}"
                    Background="Transparent" Foreground="{DynamicResource TextDimBrush}"
                    BorderBrush="#505050" BorderThickness="1"
                    Click="BtnReset_Click"/>

            <Button Grid.Column="2" Style="{StaticResource SamplerButton}"
                    Content="{loc:Str btn_cancel}" IsCancel="True"
                    Background="Transparent" Foreground="{DynamicResource TextLightBrush}"
                    BorderBrush="#505050" BorderThickness="1" Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>

            <Button Grid.Column="3" Style="{StaticResource SamplerButton}"
                    Content="{loc:Str btn_ok}" IsDefault="True"
                    Background="{StaticResource PinkBrush}" Foreground="White"
                    BorderThickness="0"
                    Click="BtnOk_Click"/>
        </Grid>
    </Grid>
</Window>

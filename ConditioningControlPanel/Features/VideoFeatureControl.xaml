<UserControl x:Class="ConditioningControlPanel.Features.VideoFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <StackPanel>
        <!-- Master enable -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Str tooltip_turn_mandatory_videos_on_or_off}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1" x:Name="ChkEnable"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
            </Grid>
        </Border>

        <!-- Per hour -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_per_hour}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtPerHour" Text="2" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderPerHour" Minimum="1" Maximum="20" Value="2"
                        ValueChanged="SliderPerHour_Changed"/>
                <TextBlock Text="{loc:Str tooltip_videos_per_hour}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Strict lock -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str setting_strict}" Foreground="#FFB347" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Str tooltip_strict_mode_videos_cannot_be_skipped_must_wat}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1" x:Name="ChkStrict"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkStrict_Changed" Unchecked="ChkStrict_Changed"/>
            </Grid>
        </Border>

        <!-- Mini game subsection -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str label_mini_game}" Foreground="{DynamicResource PinkBrush}" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkMiniGame" Style="{StaticResource ToggleStyle}"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Checked="ChkMiniGame_Changed" Unchecked="ChkMiniGame_Changed"/>
                </Grid>

                <!-- Targets -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{loc:Str label_targets}" Foreground="White" FontSize="12"/>
                        <CheckBox x:Name="ChkRandomize" Margin="8,0,0,0" VerticalAlignment="Center"
                                  Checked="ChkRandomize_Changed" Unchecked="ChkRandomize_Changed"
                                  ToolTip="{loc:Str tooltip_randomize_target_count_1_to_max}">
                            <TextBlock Text="🎲" FontSize="10"/>
                        </CheckBox>
                    </StackPanel>
                    <TextBlock x:Name="TxtTargets" Grid.Column="1" Text="3"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderTargets" Minimum="1" Maximum="10" Value="3"
                        ValueChanged="SliderTargets_Changed" Margin="0,0,0,10"/>

                <!-- Duration -->
                <Grid Margin="0,0,0,2">
                    <TextBlock Text="{loc:Str setting_duration}" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="TxtDuration" Text="5" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderDuration" Minimum="1" Maximum="15" Value="5"
                        ValueChanged="SliderDuration_Changed" Margin="0,0,0,10"/>

                <!-- Target size -->
                <Grid Margin="0,0,0,2">
                    <TextBlock Text="{loc:Str setting_size}" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="TxtTargetSize" Text="70" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderTargetSize" Minimum="30" Maximum="150" Value="70"
                        ValueChanged="SliderTargetSize_Changed" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{loc:Str btn_phrases}"
                            Style="{StaticResource OutlineButton}" Click="BtnManageAttention_Click"/>
                    <Button Grid.Column="2" Content="{loc:Str btn_style}"
                            Style="{StaticResource OutlineButton}" Click="BtnAttentionStyle_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <Button Content="{loc:Str btn_test_2}" Style="{StaticResource OutlineButton}"
                Click="BtnTestVideo_Click"/>
    </StackPanel>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Features.MindWipeFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <!-- Locked -->
        <StackPanel x:Name="LockedPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="20,24">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Foreground="{DynamicResource PinkBrush}"/>
                    <TextBlock Text="{loc:Str label_mind_wipe}" Foreground="White" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="{loc:Str label_reach_level_75_to_unlock}"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13"
                               TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Unlocked -->
        <StackPanel x:Name="UnlockedPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Str btn_enable}"
                               Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_frequency}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtFreq" Text="6/h" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderFreq" Minimum="1" Maximum="180" Value="6"
                            ValueChanged="SliderFreq_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_mind_wipe_frequency_1_180_per_hour}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_volume}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtVolume" Text="50%" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderVolume" Minimum="0" Maximum="100" Value="50"
                            ValueChanged="SliderVolume_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_volume_level_0_100}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str setting_loop_in_background}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_continuously_loop_a_single_track_instead_of_r}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkLoop"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkLoop_Changed" Unchecked="ChkLoop_Changed"/>
                </Grid>
            </Border>

            <Button Content="{loc:Str btn_test_now_2}" Style="{StaticResource OutlineButton}"
                    Click="BtnTest_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Features.WebcamFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <!-- Empty host. MainWindow reparents the Lab webcam engine bar
         (LabWebcamEngineBar) into SettingsHost when this popup opens, and
         puts it back when the popup closes. Borrowing the same control
         instance means all its handlers and live tracker state stay valid. -->
    <StackPanel>
        <TextBlock Text="{loc:Str blink_trainer_section_webcam}"
                   Foreground="{DynamicResource PinkBrush}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        <StackPanel x:Name="SettingsHost"/>

        <Border Height="1" Background="{DynamicResource GlassBorderBrush}" Margin="0,16"/>

        <!-- Microphone section: input device + voice precision + barge-in. Self-contained — writes the
             same AppSettings the She's Listening tab binds, and re-arms the mic live when the device changes. -->
        <TextBlock Text="🎤 Microphone" Foreground="{DynamicResource PinkBrush}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Text="Input device" Foreground="#CCC" FontSize="12" Margin="0,0,0,3"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CmbMicDevice" Foreground="Black" Background="White" FontSize="12"
                      BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" VerticalAlignment="Center"
                      SelectionChanged="CmbMicDevice_SelectionChanged"
                      ToolTip="Pick the microphone used for voice (Hey Bambi, mantras, lock cards)."/>
            <Button x:Name="BtnMicRefresh" Grid.Column="1" Content="↻" Margin="6,0,0,0" Padding="9,3"
                    Background="Transparent" Foreground="{DynamicResource PinkBrush}"
                    BorderBrush="{DynamicResource PinkBrush}" BorderThickness="1" FontWeight="Bold" Cursor="Hand"
                    Click="BtnMicRefresh_Click" ToolTip="Re-scan microphones."/>
        </Grid>

        <TextBlock Text="Wake sensitivity" Foreground="#CCC" FontSize="12"/>
        <TextBlock Text="Left = wakes more easily · Right = fewer false wakes" Foreground="#888" FontSize="10" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderWakePrecision" Minimum="0.3" Maximum="0.95" SmallChange="0.01" LargeChange="0.05"
                    VerticalAlignment="Center" ValueChanged="SliderWakePrecision_ValueChanged"/>
            <TextBlock x:Name="TxtWakeVal" Grid.Column="1" Text="0.60" Foreground="#9090A8" FontSize="11"
                       Width="34" TextAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <TextBlock Text="Command match precision" Foreground="#CCC" FontSize="12"/>
        <TextBlock Text="How close a spoken command must be to count." Foreground="#888" FontSize="10" Margin="0,0,0,2"/>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderCmdPrecision" Minimum="0.3" Maximum="0.95" SmallChange="0.01" LargeChange="0.05"
                    VerticalAlignment="Center" ValueChanged="SliderCmdPrecision_ValueChanged"/>
            <TextBlock x:Name="TxtCmdVal" Grid.Column="1" Text="0.50" Foreground="#9090A8" FontSize="11"
                       Width="34" TextAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Grid Margin="0,4,0,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🎧 Headphones — let me interrupt" Foreground="#CCC" FontSize="12"/>
                <TextBlock Text="Talk over her any time. Off (speakers): she finishes, then listens." Foreground="#888" FontSize="10"/>
            </StackPanel>
            <CheckBox x:Name="ChkHeadphones" HorizontalAlignment="Right" VerticalAlignment="Center"
                      Checked="ChkHeadphones_Changed" Unchecked="ChkHeadphones_Changed"/>
        </Grid>
    </StackPanel>
</UserControl>

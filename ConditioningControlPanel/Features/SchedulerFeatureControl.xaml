<UserControl x:Class="ConditioningControlPanel.Features.SchedulerFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <StackPanel>
        <!-- Enable -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Str btn_enable}"
                           Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" x:Name="ChkEnabled"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEnabled_Changed" Unchecked="ChkEnabled_Changed"/>
            </Grid>
        </Border>

        <!-- Time range -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Time Range" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtStart" Grid.Column="0" Text="16:00"
                             Background="{DynamicResource SurfaceBgBrush}"
                             Foreground="White" BorderBrush="{DynamicResource PinkBrush}"
                             Padding="8,6" FontSize="14" TextAlignment="Center"
                             LostFocus="TxtTime_LostFocus"/>
                    <TextBlock Grid.Column="1" Text="→" Foreground="{DynamicResource PinkBrush}"
                               FontSize="16" Margin="10,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtEnd" Grid.Column="2" Text="22:00"
                             Background="{DynamicResource SurfaceBgBrush}"
                             Foreground="White" BorderBrush="{DynamicResource PinkBrush}"
                             Padding="8,6" FontSize="14" TextAlignment="Center"
                             LostFocus="TxtTime_LostFocus"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Days -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14">
            <StackPanel>
                <TextBlock Text="Active Days" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <WrapPanel HorizontalAlignment="Center">
                    <CheckBox x:Name="DayMon" Content="M" Foreground="White" Margin="0,0,10,0" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                    <CheckBox x:Name="DayTue" Content="T" Foreground="White" Margin="0,0,10,0" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                    <CheckBox x:Name="DayWed" Content="W" Foreground="White" Margin="0,0,10,0" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                    <CheckBox x:Name="DayThu" Content="T" Foreground="White" Margin="0,0,10,0" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                    <CheckBox x:Name="DayFri" Content="F" Foreground="White" Margin="0,0,10,0" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                    <CheckBox x:Name="DaySat" Content="S" Foreground="White" Margin="0,0,10,0" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                    <CheckBox x:Name="DaySun" Content="S" Foreground="White" IsChecked="True"
                              FontSize="13" Checked="Day_Changed" Unchecked="Day_Changed"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

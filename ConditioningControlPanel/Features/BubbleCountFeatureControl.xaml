<UserControl x:Class="ConditioningControlPanel.Features.BubbleCountFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <!-- Locked -->
        <StackPanel x:Name="LockedPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="20,24">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Foreground="{DynamicResource PinkBrush}"/>
                    <TextBlock Text="{loc:Str label_bubble_count}" Foreground="White" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="{loc:Str label_reach_level_50_to_unlock}"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13"
                               TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Unlocked -->
        <StackPanel x:Name="UnlockedPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_count_the_bubbles_challenge_memory_and_attent}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_per_hour}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtFreq" Text="2" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderFreq" Minimum="1" Maximum="10" Value="2"
                            ValueChanged="SliderFreq_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_challenges_per_hour_1_10}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Str setting_difficulty}"
                               Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="CmbDifficulty" Width="130"
                              Background="{DynamicResource SurfaceBgBrush}" Foreground="White"
                              SelectionChanged="CmbDifficulty_Changed">
                        <ComboBoxItem Content="{loc:Str btn_easy}" Tag="0"/>
                        <ComboBoxItem Content="{loc:Str btn_medium}" Tag="1" IsSelected="True"/>
                        <ComboBoxItem Content="{loc:Str btn_hard}" Tag="2"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str setting_strict_lock}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_prevent_closing_until_correctly_answered}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkStrict"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkStrict_Changed" Unchecked="ChkStrict_Changed"/>
                </Grid>
            </Border>

            <Button Content="{loc:Str btn_test_now}" Style="{StaticResource OutlineButton}"
                    Click="BtnTest_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

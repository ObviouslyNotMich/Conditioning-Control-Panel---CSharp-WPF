<UserControl x:Class="ConditioningControlPanel.Features.LockCardFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <!-- Locked -->
        <StackPanel x:Name="LockedPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="20,24">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center" Foreground="{DynamicResource PinkBrush}"/>
                    <TextBlock Text="{loc:Str label_lock_card}" Foreground="White" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="{loc:Str label_reach_level_35_to_unlock}"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13"
                               TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Unlocked -->
        <StackPanel x:Name="UnlockedPanel" Visibility="Collapsed">
            <!-- Enable -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_show_lock_cards_that_require_typing_to_dismis}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <!-- Per hour -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_per_hour}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtFreq" Text="2" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderFreq" Minimum="1" Maximum="10" Value="2"
                            ValueChanged="SliderFreq_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_lock_card_frequency_1_10_per_hour}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Repeats -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_repeats}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtRepeats" Text="3x" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderRepeats" Minimum="1" Maximum="10" Value="3"
                            ValueChanged="SliderRepeats_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_number_of_times_to_type_the_phrase_1_10}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Strict lock -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str setting_strict_lock}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_cannot_escape_must_complete_typing}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkStrict"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkStrict_Changed" Unchecked="ChkStrict_Changed"/>
                </Grid>
            </Border>

            <!-- Actions -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{loc:Str btn_manage_phrases}"
                        Style="{StaticResource OutlineButton}" Click="BtnManagePhrases_Click"/>
                <Button Grid.Column="2" Content="{loc:Str btn_test_2}"
                        Style="{StaticResource OutlineButton}" Click="BtnTest_Click"/>
                <Button Grid.Column="4" Content="⚙" Width="44"
                        Style="{StaticResource OutlineButton}" Click="BtnColorSettings_Click"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>

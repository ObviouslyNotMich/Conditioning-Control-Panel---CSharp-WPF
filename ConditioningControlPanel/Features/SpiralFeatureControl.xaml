<UserControl x:Class="ConditioningControlPanel.Features.SpiralFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <!-- Locked state -->
        <StackPanel x:Name="LockedPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20,24">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="48" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PinkBrush}"/>
                    <TextBlock Text="{loc:Str label_spiral_overlay}"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,4"/>
                    <TextBlock Text="{loc:Str label_reach_level_10_to_unlock}"
                               Foreground="{DynamicResource PinkBrush}"
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Unlocked state -->
        <StackPanel x:Name="UnlockedPanel" Visibility="Collapsed">

            <!-- Enable toggle -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,12"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str btn_enable}"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_show_hypnotic_spiral_overlay}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}"
                              VerticalAlignment="Center"
                              Checked="ChkEnable_Changed"
                              Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <!-- Opacity slider -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,14"
                    Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_opacity}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtOpacity"
                                   Text="15%"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderOpacity"
                            Minimum="5" Maximum="50" Value="15"
                            ValueChanged="SliderOpacity_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_spiral_opacity_5_50}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Select GIF -->
            <Button x:Name="BtnSelectGif"
                    Content="{loc:Str btn_select_gif}"
                    Style="{StaticResource OutlineButton}"
                    Padding="12,10"
                    Click="BtnSelectGif_Click"/>

            <TextBlock Text="{loc:Str label_if_you_have_display_problems_try_setting_your}"
                       Foreground="#FFA500"
                       FontSize="10"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Opacity="0.8"
                       Margin="0,12,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Features.BouncingTextFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <StackPanel>
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Str btn_enable}"
                               Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_speed}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtSpeed" Text="5" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderSpeed" Minimum="1" Maximum="10" Value="5"
                            ValueChanged="SliderSpeed_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_bounce_speed_1_slow_10_fast}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_size}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtSize" Text="100%" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderSize" Minimum="50" Maximum="300" Value="100"
                            ValueChanged="SliderSize_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_text_size_50_small_100_normal_300_huge}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str setting_show_over_videos}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_keep_bouncing_text_visible_on_top_of_fullscre}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkAlwaysOnTop"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkAlwaysOnTop_Changed" Unchecked="ChkAlwaysOnTop_Changed"/>
                </Grid>
            </Border>

            <TextBlock Text="{loc:Str label_10_xp_per_bounce}"
                       Foreground="#50C878" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,2,0,10"/>

            <Button Content="{loc:Str btn_edit_phrases}" Style="{DynamicResource OutlineButton}"
                    Click="BtnEditPhrases_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Features.IntensityRampFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <StackPanel>
        <!-- Enable -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Str btn_enable}"
                           Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" x:Name="ChkEnabled"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEnabled_Changed" Unchecked="ChkEnabled_Changed"/>
            </Grid>
        </Border>

        <!-- Duration -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_duration}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtDuration" Text="60 min" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderDuration" Minimum="10" Maximum="180" Value="60"
                        ValueChanged="SliderDuration_Changed"/>
            </StackPanel>
        </Border>

        <!-- Multiplier -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_multiplier}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtMultiplier" Text="1.5x" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderMultiplier" Minimum="1" Maximum="3" Value="1.5"
                        SmallChange="0.1" LargeChange="0.5"
                        ValueChanged="SliderMultiplier_Changed"/>
            </StackPanel>
        </Border>

        <!-- End at ramp -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{loc:Str setting_end_at_complete}"
                           Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" x:Name="ChkEndAt"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEndAt_Changed" Unchecked="ChkEndAt_Changed"/>
            </Grid>
        </Border>

        <!-- Ramp links -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14">
            <StackPanel>
                <TextBlock Text="{loc:Str label_link_to_ramp}"
                           Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
                        <CheckBox x:Name="ChkLinkFlash" Style="{StaticResource ToggleStyle}"
                                  Checked="Link_Changed" Unchecked="Link_Changed"/>
                        <TextBlock Text="{loc:Str label_flash}" Foreground="White" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
                        <CheckBox x:Name="ChkLinkSpiral" Style="{StaticResource ToggleStyle}"
                                  Checked="Link_Changed" Unchecked="Link_Changed"/>
                        <TextBlock Text="{loc:Str label_spiral}" Foreground="White" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
                        <CheckBox x:Name="ChkLinkPink" Style="{StaticResource ToggleStyle}"
                                  Checked="Link_Changed" Unchecked="Link_Changed"/>
                        <TextBlock Text="{loc:Str label_pink}" Foreground="White" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,8">
                        <CheckBox x:Name="ChkLinkMaster" Style="{StaticResource ToggleStyle}"
                                  Checked="Link_Changed" Unchecked="Link_Changed"/>
                        <TextBlock Text="{loc:Str setting_master}" Foreground="White" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="ChkLinkSub" Style="{StaticResource ToggleStyle}"
                                  Checked="Link_Changed" Unchecked="Link_Changed"/>
                        <TextBlock Text="{loc:Str label_sub}" Foreground="White" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

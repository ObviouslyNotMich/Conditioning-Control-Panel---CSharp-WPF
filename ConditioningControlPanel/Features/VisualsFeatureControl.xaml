<UserControl x:Class="ConditioningControlPanel.Features.VisualsFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <StackPanel>
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_size}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtSize" Text="100%" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderSize" Minimum="50" Maximum="250" Value="100"
                        ValueChanged="SliderSize_Changed"/>
                <TextBlock Text="{loc:Str tooltip_scale_of_flash_images_100_original_size_200_d}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_opacity}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtOpacity" Text="100%" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderOpacity" Minimum="10" Maximum="100" Value="100"
                        ValueChanged="SliderOpacity_Changed"/>
                <TextBlock Text="{loc:Str tooltip_transparency_of_flash_images_lower_more_see_t}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_fade}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtFade" Text="50%" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderFade" Minimum="0" Maximum="100" Value="50"
                        ValueChanged="SliderFade_Changed"/>
                <TextBlock Text="{loc:Str tooltip_fade_in_out_animation_speed_0_instant_appear}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_duration}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtDuration" Text="5s" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderDuration" Minimum="1" Maximum="30" Value="5"
                        ValueChanged="SliderDuration_Changed"/>
                <TextBlock Text="{loc:Str tooltip_how_long_images_stay_on_screen_only_used_when}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Link to Audio -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str label_link_to_audio_trigger}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Str tooltip_when_enabled_flash_duration_matches_audio_len}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1" x:Name="ChkAudio"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkAudio_Changed" Unchecked="ChkAudio_Changed"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>

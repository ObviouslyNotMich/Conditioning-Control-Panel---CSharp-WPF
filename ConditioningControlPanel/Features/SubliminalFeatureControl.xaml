<UserControl x:Class="ConditioningControlPanel.Features.SubliminalFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers">

    <StackPanel>
        <!-- Enable -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Str tooltip_enable_disable_subliminal_messages}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1" x:Name="ChkEnable"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
            </Grid>
        </Border>

        <!-- Per minute -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str label_per_min}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtPerMin" Text="5" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderPerMin" Minimum="1" Maximum="30" Value="5"
                        ValueChanged="SliderPerMin_Changed"/>
                <TextBlock Text="{loc:Str tooltip_messages_shown_per_minute}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Frames -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str label_frames}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtFrames" Text="2" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderFrames" Minimum="1" Maximum="10" Value="2"
                        ValueChanged="SliderFrames_Changed"/>
                <TextBlock Text="{loc:Str tooltip_display_duration_in_frames_lower_faster_flash}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Opacity -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_opacity}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtOpacity" Text="80%" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderOpacity" Minimum="10" Maximum="100" Value="80"
                        ValueChanged="SliderOpacity_Changed"/>
                <TextBlock Text="{loc:Str tooltip_text_visibility_lower_more_subtle}"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Audio whispers -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <helpers:EmojiTextBlock Text="{loc:Str setting_audio_whispers}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_play_whispered_audio_when_subliminal_messages}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkWhispers"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkWhispers_Changed" Unchecked="ChkWhispers_Changed"/>
                </Grid>
                <Grid>
                    <TextBlock Text="{loc:Str setting_volume}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtWhisperVol" Text="50%" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderWhisperVol" Minimum="0" Maximum="100" Value="50"
                        ValueChanged="SliderWhisperVol_Changed" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="📝 Messages"
                    Style="{DynamicResource OutlineButton}" Click="BtnManageMessages_Click"
                    ToolTip="{loc:Str tooltip_edit_subliminal_messages}"/>
            <Button Grid.Column="2" Content="⚙ Advanced"
                    Style="{DynamicResource OutlineButton}" Click="BtnAdvanced_Click"
                    ToolTip="{loc:Str tooltip_advanced_subliminal_visual_settings}"/>
        </Grid>
    </StackPanel>
</UserControl>

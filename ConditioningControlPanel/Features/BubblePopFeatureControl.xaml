<UserControl x:Class="ConditioningControlPanel.Features.BubblePopFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <StackPanel>
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_pop_bubbles_to_earn_xp}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str label_per_min}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtFreq" Text="5" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderFreq" Minimum="1" Maximum="15" Value="5"
                            ValueChanged="SliderFreq_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_bubble_spawn_rate}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_volume}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtVolume" Text="50%" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderVolume" Minimum="0" Maximum="100" Value="50"
                            ValueChanged="SliderVolume_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_bubble_pop_sound_volume}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,10,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Speed" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtSpeed" Text="+0%" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderSpeed" Minimum="0" Maximum="500" Value="0"
                            ValueChanged="SliderSpeed_Changed"/>
                    <TextBlock Text="How fast bubbles travel across the screen"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Trigger Bubbles: a share of bubbles fire a Chaos effect when popped -->
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,10,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Trigger Bubbles" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Some bubbles fire an effect when popped (flash, video, overlays…)"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <TextBlock x:Name="TxtTriggerEggHint"
                                   Text="careful — Bambi loves these… leave one drifting too long and she might pop it for you~"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="11" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkTriggers"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkTriggers_Changed" Unchecked="ChkTriggers_Changed"/>
                </Grid>
            </Border>

            <StackPanel x:Name="TriggerOptionsPanel" Visibility="Collapsed">
                <Border Background="{DynamicResource SurfaceBgBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Trigger chance" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtTriggerChance" Text="10%" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="SliderTriggerChance" Minimum="0" Maximum="50" Value="10"
                                ValueChanged="SliderTriggerChance_Changed"/>
                        <TextBlock Text="How often a spawned bubble carries an effect"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SurfaceBgBrush}"
                        BorderBrush="{DynamicResource GlassBorderBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Effect types" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox x:Name="ChkTypeFlash"      Tag="flash"      Content="Flash"       Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                            <CheckBox x:Name="ChkTypeSubliminal" Tag="subliminal" Content="Subliminal"  Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                            <CheckBox x:Name="ChkTypePink"       Tag="pink"       Content="Pink Filter" Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                            <CheckBox x:Name="ChkTypeSpiral"     Tag="spiral"     Content="Spiral"      Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                            <CheckBox x:Name="ChkTypeGlitch"     Tag="glitch"     Content="Glitch"      Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                            <CheckBox x:Name="ChkTypeCascade"    Tag="htlink"     Content="Cascade"     Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                            <CheckBox x:Name="ChkTypeVideo"      Tag="video"      Content="Video"       Foreground="White" Margin="0,0,16,8" Checked="TriggerType_Changed" Unchecked="TriggerType_Changed"/>
                        </WrapPanel>
                        <TextBlock Text="Each ticked effect has an equal chance"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

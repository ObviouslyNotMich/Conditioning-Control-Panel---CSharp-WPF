<UserControl x:Class="ConditioningControlPanel.Features.BubblePopFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization">

    <Grid>
        <StackPanel>
            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_pop_bubbles_to_earn_xp}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkEnable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
                </Grid>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str label_per_min}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtFreq" Text="5" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderFreq" Minimum="1" Maximum="15" Value="5"
                            ValueChanged="SliderFreq_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_bubble_spawn_rate}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBgBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="16,14">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="{loc:Str setting_volume}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtVolume" Text="50%" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                    <Slider x:Name="SliderVolume" Minimum="0" Maximum="100" Value="50"
                            ValueChanged="SliderVolume_Changed"/>
                    <TextBlock Text="{loc:Str tooltip_bubble_pop_sound_volume}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Features.AttentionCheckFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <!-- Master enable. Placeholder copy — voice-pass at ship. -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Attention checks" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="A pink ring pops in at random — look at it within a few seconds to score points."
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1" x:Name="ChkEnable"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
            </Grid>
        </Border>

        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <!-- Min / max per hour -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Min per hour" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="TxtMin" Text="1" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderMin" Minimum="0" Maximum="20" Value="1"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="SliderMin_Changed" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Max per hour" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="TxtMax" Text="5" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderMax" Minimum="1" Maximum="30" Value="5"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="SliderMax_Changed" Margin="0,0,0,10"/>

                <!-- Grace -->
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Grace window" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="TxtGrace" Text="4000 ms" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderGrace" Minimum="1000" Maximum="15000" Value="4000"
                        TickFrequency="500" IsSnapToTickEnabled="True"
                        ValueChanged="SliderGrace_Changed" Margin="0,0,0,10"/>
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <!-- Fail mode -->
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="On miss" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <ComboBox x:Name="CmbFailMode" SelectionChanged="CmbFailMode_Changed"
                          Margin="0,0,0,10" Foreground="Black">
                    <ComboBoxItem Content="XP penalty" Tag="XpPenalty" Foreground="Black"/>
                    <ComboBoxItem Content="Lock card" Tag="LockCard" Foreground="Black"/>
                    <ComboBoxItem Content="Nothing" Tag="None" Foreground="Black"/>
                </ComboBox>

                <!-- Scope -->
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="When" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <ComboBox x:Name="CmbScope" SelectionChanged="CmbScope_Changed"
                          Margin="0,0,0,4" Foreground="Black">
                    <ComboBoxItem Content="Always" Tag="Always" Foreground="Black"/>
                    <ComboBoxItem Content="During sessions only" Tag="DuringSessionsOnly" Foreground="Black"/>
                </ComboBox>

                <TextBlock Text="Pass +20 XP. Miss penalty depends on the mode above."
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="10"
                           Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

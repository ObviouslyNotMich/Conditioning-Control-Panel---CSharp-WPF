<UserControl x:Class="ConditioningControlPanel.Features.FeatureCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="Hand"
             MouseLeftButtonUp="OnClick">

    <Border x:Name="RootBorder"
            Background="{DynamicResource ElevatedSurfaceBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True"
            Margin="6"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="ActiveGlow"
                              Color="{DynamicResource PinkColor}"
                              BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0"/>
        </Border.Effect>
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.03" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.03" Duration="0:0:0.15"/>
                        <!-- hover glow handled by ActiveGlow if the card is active -->
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1" Duration="0:0:0.15"/>
                        <!-- leave ActiveGlow alone on mouseleave -->
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid x:Name="ContentRoot">
            <!-- Full-bleed background image via ImageBrush (respects parent CornerRadius) -->
            <Border x:Name="ImgIconHost" CornerRadius="11"
                    RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Glyph fallback (for cards without an image) -->
            <Border x:Name="GlyphHost"
                    Width="68" Height="68"
                    CornerRadius="34"
                    Background="{DynamicResource TransparentPinkBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                <TextBlock x:Name="TxtGlyph"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PinkBrush}"/>
            </Border>

            <!-- Bottom gradient + title overlay -->
            <Border CornerRadius="0,0,11,11"
                    VerticalAlignment="Bottom"
                    IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#60000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock x:Name="TxtTitle"
                           Text="Feature"
                           Margin="8,14,8,8"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Active overlay: pink ring when the underlying feature is enabled -->
            <Border x:Name="ActiveBorder"
                    BorderBrush="{DynamicResource PinkBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- Locked overlay -->
            <Border x:Name="LockedOverlay"
                    Background="#C0000000"
                    CornerRadius="12"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Width="30" Height="30"
                           HorizontalAlignment="Center"
                           Source="{Binding Source='🔒', Converter={StaticResource EmojiToImageSource}}"/>
                    <TextBlock x:Name="TxtLockLabel"
                               Text="Lvl 10"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Help icon overlay (top-right corner) -->
            <Button x:Name="BtnHelp"
                    Style="{DynamicResource HelpButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,8,0"
                    Panel.ZIndex="10"
                    Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>

<UserControl x:Class="ConditioningControlPanel.Features.FeatureCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="Hand"
             MouseLeftButtonUp="OnClick">

    <Border x:Name="RootBorder"
            Background="{DynamicResource ElevatedSurfaceBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="6"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="RootGlow"
                              Color="{DynamicResource PinkColor}"
                              BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0"/>
        </Border.Effect>
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.03" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.03" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="RootGlow"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.55" Duration="0:0:0.15"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1" Duration="0:0:0.15"/>
                        <DoubleAnimation Storyboard.TargetName="RootGlow"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0" Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <!-- Content -->
            <Grid x:Name="ContentRoot" Margin="10,14,10,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Icon / glyph area -->
                <Grid Grid.Row="0">
                    <Image x:Name="ImgIcon"
                           Stretch="Uniform"
                           MaxHeight="72"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Border x:Name="GlyphHost"
                            Width="68" Height="68"
                            CornerRadius="34"
                            Background="{DynamicResource TransparentPinkBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtGlyph"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource PinkBrush}"/>
                    </Border>
                </Grid>

                <!-- Title -->
                <TextBlock Grid.Row="1"
                           x:Name="TxtTitle"
                           Text="Feature"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"/>
            </Grid>

            <!-- Locked overlay -->
            <Border x:Name="LockedOverlay"
                    Background="#C0000000"
                    CornerRadius="12"
                    Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="🔒"
                               FontSize="28"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource PinkBrush}"/>
                    <TextBlock x:Name="TxtLockLabel"
                               Text="Lvl 10"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

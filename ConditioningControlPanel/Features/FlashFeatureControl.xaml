<UserControl x:Class="ConditioningControlPanel.Features.FlashFeatureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ConditioningControlPanel.Localization"
             xmlns:helpers="clr-namespace:ConditioningControlPanel.Helpers">

    <StackPanel>
        <!-- Master enable -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Str btn_enable}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{loc:Str tooltip_flash_enable}"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1" x:Name="ChkEnable"
                          Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                          Checked="ChkEnable_Changed" Unchecked="ChkEnable_Changed"/>
            </Grid>
        </Border>

        <!-- Frequency / per hour -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_per_hour}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtFrequency" Text="10" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderFrequency" Minimum="1" Maximum="180" Value="10"
                        ValueChanged="SliderFrequency_Changed"/>
            </StackPanel>
        </Border>

        <!-- Images per flash -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_images}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtImages" Text="5" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderImages" Minimum="1" Maximum="20" Value="5"
                        ValueChanged="SliderImages_Changed"/>
            </StackPanel>
        </Border>

        <!-- Max on screen -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="{loc:Str setting_max_on_screen}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtMaxOnScreen" Text="20" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="13" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderMaxOnScreen" Minimum="2" Maximum="20" Value="20"
                        ValueChanged="SliderMaxOnScreen_Changed"/>
            </StackPanel>
        </Border>

        <!-- Toggle grid -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12">
            <StackPanel>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Str setting_click}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_when_enabled_clicking_an_image_dismisses_it_w}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkClickable"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkClickable_Changed" Unchecked="ChkClickable_Changed"/>
                </Grid>
                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <helpers:EmojiTextBlock Text="{loc:Str setting_hydra}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_hydra_mode_clicking_an_image_spawns_two_more}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkCorruption"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkCorruption_Changed" Unchecked="ChkCorruption_Changed"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <helpers:EmojiTextBlock Text="{loc:Str setting_linked}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_linked_hydra_spawns_share_the_parent_flash_ti}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkHydraLinked"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkHydraLinked_Changed" Unchecked="ChkHydraLinked_Changed"/>
                </Grid>
                <Grid Margin="0,8,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <helpers:EmojiTextBlock Text="{loc:Str setting_glow}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Str tooltip_toggle_the_pink_sparkle_glow_effect_on_flash}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkGlow"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkGlow_Changed" Unchecked="ChkGlow_Changed"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Gaze interaction toggles (Phase 3). Placeholder copy; voice-pass at ship. -->
        <Border Background="{DynamicResource SurfaceBgBrush}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Gaze interaction" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Stare to pop" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Look at a flash for ~1s to dismiss it (same effect as clicking, including hydra)."
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkFlashGazePop"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkFlashGazePop_Changed" Unchecked="ChkFlashGazePop_Changed"/>
                </Grid>

                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Stare to keep" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Keep a flash alive by looking at it. Stops boosting when you look away."
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="ChkFlashGazeLinger"
                              Style="{StaticResource ToggleStyle}" VerticalAlignment="Center"
                              Checked="ChkFlashGazeLinger_Changed" Unchecked="ChkFlashGazeLinger_Changed"/>
                </Grid>

                <Grid Margin="0,4,0,2">
                    <TextBlock Text="Linger boost" Foreground="White" FontSize="12"/>
                    <TextBlock x:Name="TxtFlashLingerMs" Text="1500 ms" HorizontalAlignment="Right"
                               Foreground="{DynamicResource PinkBrush}" FontSize="12" FontWeight="SemiBold"/>
                </Grid>
                <Slider x:Name="SliderFlashLingerMs" Minimum="500" Maximum="5000" Value="1500"
                        TickFrequency="250" IsSnapToTickEnabled="True"
                        ValueChanged="SliderFlashLingerMs_Changed"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
